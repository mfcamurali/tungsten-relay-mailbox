};

struct CompleteGhostSystem {
    int currentRegime;
    bool regimeComplete[9];
    
    // UPGRADED: Store 15 elite configs per regime (not just 1 best)
    EliteConfig eliteConfigs[9][15];  // 8 regimes ? 15 configs each = 120 total
    int eliteConfigCount[9];          // How many valid configs per regime
    double regimeBestWR[9];           // Best WR per regime (for backward compatibility)
    double regimeBestThreshold[9];    // Best threshold per regime (for backward compat)
    
    int startBar;
