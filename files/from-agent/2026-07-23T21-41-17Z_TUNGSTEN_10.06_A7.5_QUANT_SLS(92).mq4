//| INTELLIGENT RISK MANAGEMENT - Performance Based 0.5-7.5%         |

// g_Risk already declared at line 8697 - removed duplicate

//| Calculate intelligent risk based on performance                  |
void CalculateIntelligentRisk() {
    // STATE-DESTRUCTION FIX: this function runs every 5 trades. It previously
    // began by resetting g_Calibration (executionSuspended, calibratedWR, ghost
    // gate scores, warmup flags) and the WR Guardian tiers — init code merged
    // into the wrong function. Every 5 trades it un-suspended failed systems,
    // zeroed the calibrated WR reference, and wiped guardian protection.
    // Calibration and Guardian state are owned by their own systems; this
    // function computes RISK ONLY from trade history.
    g_Risk.minRisk = 1.0;  // Safety mode - conservative trading
    g_Risk.maxRisk = 15.0; // Elite mode — competence is the only ceiling
    
    // Need minimum 20 trades to be intelligent
    if(g_State.totalTrades < 20) {
        // Calibration quality earns better starting risk (CEO score set by Upgrade 4)
        if(g_CEO_CompetenceScore >= 68.0)      g_Risk.currentRisk = 3.0;
        else if(g_CEO_CompetenceScore >= 63.0) g_Risk.currentRisk = 2.5;
        else if(g_CEO_CompetenceScore >= 58.0) g_Risk.currentRisk = 2.0;
        else                                   g_Risk.currentRisk = 1.5;
        g_Risk.isCalibrated = false;
        g_Risk.riskReason = StringFormat("Calib-seeded %.1f%% (CEO %.0f)", g_Risk.currentRisk, g_CEO_CompetenceScore);
        return;
    }
    
    // Calculate recent performance (last 20 trades)
    int wins = 0;
    double totalProfit = 0.0;
    double totalLoss = 0.0;
    
        int _total_rb20282 = MathMin(g_State.totalTrades, 20);
        for(int _ri_rb20282 = 0; _ri_rb20282 < _total_rb20282; _ri_rb20282++) {  // FIX8
            int _idx_rb20282 = ((g_State.resultIndex - 1 - _ri_rb20282) + 100) % 100;
        double result = g_State.lastTradeResults[_idx_rb20282];
        if(result > 0) {
            wins++;
            totalProfit += result;
        } else {
            totalLoss += MathAbs(result);
        }
    }
    
    g_Risk.recentWinRate = (double)wins / 20.0 * 100.0;
    g_Risk.recentProfitFactor = (totalLoss > 0) ? totalProfit / totalLoss : 3.0;
    g_Risk.isCalibrated = true;
    
    // Not based on balance size, based on PERFORMANCE
    // OPTIMIZED: More aggressive thresholds for faster compounding
    // SVJ-C: Smooth interpolated risk ladder — conviction earns proportional access
    // Anchors: 58%=3.0% · 64%=6.5% · 69%=9.0% · 74%=12.0% — smooth between
    double _wr = g_Risk.recentWinRate;
    double _pf = g_Risk.recentProfitFactor;
    double _baseRisk;
    string _rReason;
    if(_wr >= 74.0 && _pf >= 1.9) {
        _baseRisk = MathMin(13.0, 12.0 + (_wr-74.0)/4.0);
        _rReason = StringFormat("elite   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    } else if(_wr >= 69.0 && _pf >= 1.75) {
        _baseRisk = 9.0 + (_wr-69.0)/5.0*3.0;
        _rReason = StringFormat("high   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    } else if(_wr >= 64.0 && _pf >= 1.6) {
        _baseRisk = 6.5 + (_wr-64.0)/5.0*2.5;
        _rReason = StringFormat("solid   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    } else if(_wr >= 62.0 && _pf >= 1.5) {
        _baseRisk = 5.0 + (_wr-62.0)/2.0*1.5;
        _rReason = StringFormat("balanced   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    } else if(_wr >= 60.0 && _pf >= 2.5) {
        _baseRisk = 4.0;
        _rReason = StringFormat("quality-edge   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    } else if(_wr >= 58.0 && _pf >= 1.3) {
        _baseRisk = 3.0 + (_wr-58.0)/4.0*2.0;
        _rReason = StringFormat("moderate   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    } else {
        _baseRisk = 1.5;
        _rReason = StringFormat("safety   |   WR %.1f%%   |   PF %.2f",_wr,_pf);
    }
    g_Risk.currentRisk = _baseRisk;
    g_Risk.riskReason = _rReason;
    
    // OPTIMIZATION: Win streak exploitation for maximum compounding
    // Check last 10 trades for consecutive wins
    int consecutiveWins = 0;
        int _total_rb20340 = MathMin(g_State.totalTrades, 10);
        for(int _ri_rb20340 = 0; _ri_rb20340 < _total_rb20340; _ri_rb20340++) {  // FIX8
            int _idx_rb20340 = ((g_State.resultIndex - 1 - _ri_rb20340) + 100) % 100;
            if(g_State.lastTradeResults[_idx_rb20340] > 0) { consecutiveWins++; } else { break; }
        }
    
    // Hot streak bonus: 8+ wins in a row = MAXIMUM AGGRESSION
    if(consecutiveWins >= 7 && g_Risk.recentWinRate >= 70.0) {
        g_Risk.currentRisk = 15.0; // Hot streak maximum — earned through performance
        g_Risk.riskReason = "HOT STREAK: " + IntegerToString(consecutiveWins) + " wins in a row — maximum aggression";
    }
    // Strong streak: 6-7 wins = high aggression
    else if(consecutiveWins >= 6 && g_Risk.recentWinRate >= 68.0) {
        if(g_Risk.currentRisk < 10.0) {
            g_Risk.currentRisk = 10.0;
            g_Risk.riskReason = "Strong streak: " + IntegerToString(consecutiveWins) + " wins - Elevated aggression";
        }
    }
    
    // OPTIMIZATION: Smarter drawdown response - check consecutive losses
    int consecutiveLosses = 0;
    // SLS23 FIX: was reading fixed slots [0..9] instead of the ring-buffer's actual last N trades
    for(int j = 0; j < 10 && j < g_State.totalTrades; j++) {
        int _idx_cl23230 = ((g_State.resultIndex - 1 - j) + 100) % 100;
        if(g_State.lastTradeResults[_idx_cl23230] < 0) {
            consecutiveLosses++;
        } else {
            break;  // Streak broken
        }
    }
    
    // Drawdown protection: reduce risk but not too aggressively
    if(consecutiveLosses >= 5) {
        // [FIX-D] 5+ losses: apply 40% reduction but NEVER raise risk from a lower level.
        // The old branch "if currentRisk < 2.5 -> set to 2.5" was RAISING risk during a
        // drawdown streak (e.g. 1.5% safety level -> bumped to 2.5%). Correct: floor only
        // prevents reduction going BELOW 2.5; it must not increase risk from below.
        // Drawdown protection: scale down but maintain meaningful size
        double _ddFloor = (g_CEO_CompetenceScore >= 75) ? 4.0 : 2.5;
        g_Risk.currentRisk = MathMax(_ddFloor, g_Risk.currentRisk * 0.6);
        g_Risk.riskReason = "DRAWDOWN: " + IntegerToString(consecutiveLosses) + " losses - protected floor";
    }
    else if(consecutiveLosses >= 3) {
        // 3-4 losses: moderate reduction
        g_Risk.currentRisk = MathMax(3.5, g_Risk.currentRisk * 0.75);  // 25% reduction but floor at 3.5%
        g_Risk.riskReason = "Caution: " + IntegerToString(consecutiveLosses) + " losses - Moderate reduction";
    }
    
    // WR Floor Guardian: proactive risk reduction when live WR drops below calibration
    if(g_WRGuardian.guardianRiskMult < 1.0 && !g_Calibration.isCalibrating)
        g_Risk.currentRisk = MathMax(g_Risk.minRisk, g_Risk.currentRisk * g_WRGuardian.guardianRiskMult);
    // Frequency excess guard: above quality-optimal — gentle risk reduction
    // More trades x lower per-trade risk = same expected value, less quality dilution
    if(g_FreqAdvisor.frequencyExcess && !g_Calibration.isCalibrating) {
        g_Risk.currentRisk = MathMax(g_Risk.minRisk, g_Risk.currentRisk * 0.92);
    }

    // SVJ-B: PS5 Pro log format — one line, full context
    static double lastLoggedRisk = 0;
    if(MathAbs(g_Risk.currentRisk - lastLoggedRisk) >= 0.5 && EnableFriendlyLogs) {
        PrintFormat("  RISK  |   %.1f%%   |   WR %.0f%%   |   PF %.2f   |   CEO %.0f   |   %s",
            g_Risk.currentRisk, g_Risk.recentWinRate,
            g_Risk.recentProfitFactor, g_CEO_CompetenceScore, g_Risk.riskReason);
        lastLoggedRisk = g_Risk.currentRisk;
    }
}

//| Get current risk - PERFORMANCE BASED                             |


//| DEEP RECALIBRATION - When fundamentally wrong                    |

// DeepRecalibration + g_DeepRecal declared earlier (forward)


// ## Structs needed by CheckDeepRecalibration ###############################
// CircuitBreaker + g_CircuitBreaker declared earlier (forward)

struct MarketAlignmentComponent {
    string name;
    double score;       // 0.0 - 1.0
    double weight;
    string status;      // "strong" / "ok" / "weak" / "critical"
    string detail;      // one-line explanation
};

struct MarketAlignmentState {
    double overallScore;            // 0.0 - 1.0  -- the CEO number
    double overallScorePrev;        // Previous tick value (for delta)
    double overallScoreSmoothed;    // EMA smoothed (reduces tick noise)

    MarketAlignmentComponent components[8];
    int componentCount;

    // Trend: is alignment improving or degrading?
    double trend;           // positive = improving, negative = degrading
    double trendStrength;   // 0-1

    // Action signals derived from alignment
    bool shouldReduceRisk;       // score < 0.40
    bool shouldSuspendTrading;   // score < 0.20
    bool shouldTriggerReview;    // score dropped > 0.20 in last 24h
    bool shouldIncreaseTier;     // score > 0.80 AND trend positive

    // History (last 48 readings, one per 30 minutes)
    double scoreHistory[48];
    int    scoreHistoryIdx;
    int    scoreHistoryLen;

    datetime lastFullUpdate;
    datetime lastQuickUpdate;
    int      updateCount;
};
MarketAlignmentState g_Alignment;

//| Check if deep recalibration is needed                            |
void CheckDeepRecalibration() {
    // Triggers for deep recalibration:
    // 1. 10+ consecutive losses (fundamental problem)
    // 2. 3+ consecutive days with <50% WR
    // 3. Drawdown >12% (emergency)
    
    bool trigger1 = g_State.consecutiveLosses >= 10;
    bool trigger2 = g_DeepRecal.consecutiveBadDays >= 3;
    bool trigger3 = g_State.currentDrawdown >= 12.0;
    // Alignment trigger: persistent CEO score below 0.25 for 2+ hours means
    // the model is structurally misaligned -- not just a bad patch, a changed market.
    bool trigger4 = (GetMarketAlignment() < 0.25 && g_Alignment.trendStrength > 0.3
                     && g_Alignment.scoreHistoryLen >= 4
                     && g_LiveAdaptive.totalLiveTrades >= 20);
    
    if(!g_DeepRecal.recalibrationNeeded && (trigger1 || trigger2 || trigger3 || trigger4)) {
        g_DeepRecal.recalibrationNeeded = true;
        
        if(trigger1) g_DeepRecal.primaryIssue = "10+ consecutive losses";
        else if(trigger3) g_DeepRecal.primaryIssue = "Severe drawdown (12%+)";
        else g_DeepRecal.primaryIssue = "3+ bad days consecutively";
        
        ExecuteDeepRecalibration();
    }
}

//| Execute deep recalibration - FIX EVERYTHING                      |
void ExecuteDeepRecalibration() {
    
    // Acquire lock for atomic operation
    if(!AcquireLock(LOCK_DEEP_RECAL)) {
        // Lock held by another operation - will retry next tick
        return;
    }

    // Log this recalibration for circuit breaker
    for(int i = 9; i > 0; i--) {
        g_CircuitBreaker.recalibrationDates[i] = g_CircuitBreaker.recalibrationDates[i-1];
    }
    g_CircuitBreaker.recalibrationDates[0] = TimeCurrent();

    if(EnableFriendlyLogs) {
        if(EnableFriendlyLogs) PrintFormat("  deep recal   |   %s   |   correcting", g_DeepRecal.primaryIssue);
    }
    
    // STEP 1: Analyze what's failing
    // SLS21 FIX: AnalyzeComponentPerformance returns a 0-100 win-rate %, not a bool -- any
    // nonzero WR (i.e. almost always) was implicitly converting to true, so every component
    // was treated as "failing" on virtually every deep recal. Compare against a real threshold.
    bool momentumFailing = AnalyzeComponentPerformance("Momentum", 50) < 50.0;
    bool reversalFailing = AnalyzeComponentPerformance("Reversal", 50) < 50.0;
    bool volatilityFailing = AnalyzeComponentPerformance("Volatility", 50) < 50.0;
    bool directionalFailing = AnalyzeComponentPerformance("Directional", 50) < 50.0;
    
    // STEP 2: Radical threshold increase
    double emergencyAdjustment = 15.0; // Massive increase
    g_BaseThreshold += emergencyAdjustment;
    if(g_BaseThreshold > 85.0) g_BaseThreshold = 85.0; // Cap at 85
    
    // STEP 3: Disable failing components temporarily
    if(momentumFailing) {
        g_ComponentWeights.momentum *= 0.5; // Halve weight
    }
    if(reversalFailing) {
        g_ComponentWeights.reversal *= 0.5;
    }
    
    // STEP 4: Force risk to minimum
    g_Risk.currentRisk = g_Risk.minRisk;
    
    // STEP 5: SMART: Downweight marginal hours instead of disabling them completely
    // Complete disabling loses compounding opportunities - downweight is smarter
    for(int h = 0; h < 24; h++) {
        if(g_TimePerf.winRateByHour[h] < 60.0 && g_TimePerf.tradesByHour[h] >= 10) {
            // SMART: Don't disable - instead, require higher score during this hour
            // This is handled in threshold logic, so we DON'T set g_HoursDisabled[h]
            // Instead, we'll add +5 to threshold during struggling hours
            // This allows premium setups to still trade, prevents marginal ones
            
            if(EnableFriendlyLogs) {
                if(EnableFriendlyLogs && ShowOptimizationLogs) Print("   Hour ", IntegerToString(h), ": WR ", DoubleToStr(g_TimePerf.winRateByHour[h], 1), 
                      "% (", IntegerToString(g_TimePerf.tradesByHour[h]), " trades) - Increased selectivity, not disabled");
            }
        }
    }
    
    // SMART: Reset all hour disabled flags - we use threshold adjustment instead
    for(int h = 0; h < 24; h++) {
        g_HoursDisabled[h] = false; // Never completely disable hours
    }
    
    // STEP 6: Intelligent adaptive reset -- NOT a cold restart
    // The ARMED calibration file contains validated weights from Phase 1-6.
    g_State.currentState = STATE_DISCOVERY;

    // Reset live adaptive tracking -- rebuild from fresh live trades
    for(int _li = 0; _li < 9; _li++) {
        g_LiveAdaptive.regimeTrades[_li]   = 0;
        g_LiveAdaptive.regimeWins[_li]     = 0;
        g_LiveAdaptive.regimeLiveWR[_li]   = 0.65;
        g_LiveAdaptive.regimeThreshAdj[_li]= 0.0;
    }
    for(int _li = 0; _li < 4; _li++) {
        g_LiveAdaptive.sessionTrades[_li] = 0;
        g_LiveAdaptive.sessionWins[_li]   = 0;
        g_LiveAdaptive.sessionLiveWR[_li] = 0.65;
    }
    for(int _li = 0; _li < 5; _li++) {
        g_LiveAdaptive.scoreBucketTrades[_li] = 0;
        g_LiveAdaptive.scoreBucketWins[_li]   = 0;
        g_LiveAdaptive.scoreBucketWR[_li]     = 0.65;
    }
    g_LiveAdaptive.totalLiveTrades         = 0;
    g_LiveAdaptive.liveOptimalThreshold    = g_CurrentThreshold;  // seed from calibrated
    g_LiveAdaptive.liveThresholdConfidence = 0.0;
    g_LiveAdaptive.selfCalibrated          = false;

    // Reset alignment history -- fresh slate for CEO scoring
    for(int _ai = 0; _ai < 48; _ai++) g_Alignment.scoreHistory[_ai] = 0.65;
    g_Alignment.scoreHistoryLen = 0;
    g_Alignment.overallScore        = 0.65;
    g_Alignment.overallScoreSmoothed= 0.65;

    // Do NOT reload from ARMED file unless alignment < 0.20 persisted 5+ days
    // That would wipe the calibrated weights -- an extreme measure reserved for
    // genuine structural regime change, not a temporary drawdown.
    bool structuralChange = (GetMarketAlignmentRaw() < 0.20 && g_Alignment.scoreHistoryLen >= 10);
    if(structuralChange) {
        if(EnableFriendlyLogs) PrintFormat("  deep recal   |   structural market change detected   |   triggering full Phase 1-6");
        g_Calibration.isComplete = false;  // will re-run calibration on next OnInit
    }

    g_DeepRecal.lastRecalibration = TimeCurrent();

    if(EnableFriendlyLogs) {
        PrintFormat("  CATREC|   recalibrating   threshold %.0f   |   risk min   |   %s   |   live adaptive reset",
            g_BaseThreshold, structuralChange ? "full recal queued" : "ARMED weights preserved");
    }

    SaveSystemState();

    ReleaseLock();
}

//| Analyze if specific component is failing                         |

//| Check if recovery from recalibration is happening                |

//| Progressive relaxation of emergency criteria                     |
void ProgressiveRelaxation() {
    
    // Acquire lock for atomic relaxation
    if(!AcquireLock(LOCK_RELAXATION)) {
        return;
    }

    if(!g_DeepRecal.recalibrationNeeded) { ReleaseLock(); return; }  // SLS21 FIX: was leaking LOCK_RELAXATION here, jamming the lock after the first tick

    // Check if system is showing signs of understanding
    // Need minimum 50 trades since recalibration
    static int tradesAtRecal = 0;
    if(tradesAtRecal == 0) tradesAtRecal = g_State.totalTrades;
    
    int tradesSinceRecal = g_State.totalTrades - tradesAtRecal;

    // ## ELEVATED THRESHOLD SILENCE REASSURANCE ###############################
    // After deep recalibration the threshold sits at 83+ while the system
    // rebuilds confidence. Setups are rare by design. Every 45 minutes
    // confirm the system is present, elevated, and building toward relaxation.
    {
        static datetime _lastElevLog = 0;
        if(TimeCurrent() - _lastElevLog >= 2700 && tradesSinceRecal < 50) {
            int _tradesLeft = 50 - tradesSinceRecal;
            if(EnableFriendlyLogs) PrintFormat("  RISK  |   elevated   threshold %.0f   |   %d trades to relaxation   |   selective by design",
                g_BaseThreshold, _tradesLeft);
            _lastElevLog = TimeCurrent();
        }
    }

    if(tradesSinceRecal < 50) { ReleaseLock(); return; }  // SLS21 FIX: was leaking LOCK_RELAXATION here

    // Calculate recent performance
    int wins = 0;
    double totalProfit = 0.0, totalLoss = 0.0;
        int _total_rb20704 = MathMin(g_State.totalTrades, 30);
        for(int _ri_rb20704 = 0; _ri_rb20704 < _total_rb20704; _ri_rb20704++) {  // FIX8
            int _idx_rb20704 = ((g_State.resultIndex - 1 - _ri_rb20704) + 100) % 100;
        double result = g_State.lastTradeResults[_idx_rb20704];
        if(result > 0) {
            wins++;
            totalProfit += result;
        } else {
            totalLoss += MathAbs(result);
        }
    }
    
    double recentWR = (double)wins / 30.0 * 100.0;
    double recentPF = (totalLoss > 0) ? totalProfit / totalLoss : 2.0;
    
    // PROGRESSIVE RELAXATION based on understanding
    // Not binary - gradual return to normal as confidence rebuilds
    
    if(recentWR >= 70.0 && recentPF >= 2.0) {
        // Excellent understanding - can relax significantly
        double relaxAmount = 5.0;
        if(g_BaseThreshold > 65.0) {
            g_BaseThreshold -= relaxAmount;
            
            if(EnableFriendlyLogs)
                PrintFormat("  RISK  |   relaxing   threshold -> %.0f   |   WR %.0f%%   |   PF %.1f   |   mastered",
                    g_BaseThreshold, recentWR, recentPF);
            
            SaveSystemState();
        }
        
    } else if(recentWR >= 65.0 && recentPF >= 1.8) {
        // Good understanding - moderate relaxation
        double relaxAmount = 3.0;
        if(g_BaseThreshold > 65.0) {
            g_BaseThreshold -= relaxAmount;
            
            if(EnableFriendlyLogs)
                PrintFormat("  RISK  |   relaxing   threshold -> %.0f   |   WR %.0f%%   |   PF %.1f",
                    g_BaseThreshold, recentWR, recentPF);
            
            SaveSystemState();
        }
    }
    
    // Re-enable components that were de-weighted if performing well
    if(recentWR >= 68.0) {
        // Gradually restore component weights
        if(g_ComponentWeights.momentum < 1.0) {
            g_ComponentWeights.momentum += 0.1;
            if(g_ComponentWeights.momentum > 1.0) g_ComponentWeights.momentum = 1.0;
        }
        if(g_ComponentWeights.reversal < 1.0) {
            g_ComponentWeights.reversal += 0.1;
            if(g_ComponentWeights.reversal > 1.0) g_ComponentWeights.reversal = 1.0;
        }
    }

    ReleaseLock();
}

void CheckRecalibrationRecovery() {
    if(!g_DeepRecal.recalibrationNeeded) return;
    
    // Full recovery conditions (stricter):
    // 1. Win rate >65% for last 30 trades
    // 2. At least 30 trades since recalibration
    // 3. Threshold has relaxed back to reasonable level (<70)
    
    if(g_State.totalTrades < 30) return;
    
    int wins = 0;
    // SLS23 FIX: was reading fixed slots [0..29] instead of the ring-buffer's actual last 30 trades
    for(int i = 0; i < 30; i++) {
        int _idx_rr23582 = ((g_State.resultIndex - 1 - i) + 100) % 100;
        if(g_State.lastTradeResults[_idx_rr23582] > 0) wins++;
    }

    double recentWR = (double)wins / 30.0 * 100.0;
    
    // Full recovery when WR solid AND threshold has relaxed
    if(recentWR >= 65.0 && g_BaseThreshold <= 70.0) {
        g_DeepRecal.recalibrationNeeded = false;
        g_DeepRecal.consecutiveLosses = 0;
        g_DeepRecal.consecutiveBadDays = 0;
        
        if(EnableFriendlyLogs) {
    PrintFormat("  full recovery   |   WR %.0f%%   |   threshold %.0f   |   edge confirmed   |   operating normally", recentWR, g_BaseThreshold);
        }
        
        // Return to normal state
        if(g_State.currentState == STATE_DISCOVERY) {
            g_State.currentState = STATE_NORMAL;
        }
        
        SaveSystemState();
    }
}


//| INTELLIGENT TRADE FREQUENCY - No arbitrary caps                  |

struct FrequencyControl {
    bool hasLearningMaturity;     // Enough data to trade aggressively
    int maxTradesPerHour;         // Dynamic based on performance
    int tradesThisHour;           // Current hour count
    datetime currentHour;         // Track hour changes
    string frequencyReason;       // Why this frequency
};

FrequencyControl g_Frequency;

//| Calculate intelligent trade frequency limits                     |
void CalculateIntelligentFrequency() {
    // UNLIMITED INTELLIGENT FREQUENCY - Win Rate Based Adaptation
    
    double currentWR = g_Risk.recentWinRate;
    static double peakWinRate = 0.0;
    static double lastWR = 0.0;
    static datetime lastRecoveryCheck = 0;
    
    // Track peak performance
    if(currentWR > peakWinRate && g_State.totalTrades >= 30) {
        peakWinRate = currentWR;
    }
    
    // SMART FAST RECOVERY: If WR improves significantly, release throttle early
    bool fastRecovery = false;
    if(TimeCurrent() - lastRecoveryCheck >= 300) { // Check every 5 minutes
        if(lastWR > 0 && currentWR > lastWR + 10.0 && currentWR >= 55.0) {
            // WR improved by 10%+ AND above 55% = fast recovery
            fastRecovery = true;
            if(EnableFriendlyLogs) {
                PrintFormat("  WR recovered   |   %.1f%% to %.1f%%", lastWR, currentWR);
            }
        }
        lastWR = currentWR;
        lastRecoveryCheck = TimeCurrent();
    }
    
    // EXCEPTIONAL ALIGNMENT (85%+ win rate)
    if(currentWR >= 85.0 || fastRecovery) {
        g_Frequency.maxTradesPerHour = 999; // UNLIMITED
        g_Frequency.frequencyReason = "EXCEPTIONAL (WR: " + DoubleToStr(currentWR, 1) + "%) - Peak alignment, unlimited!";
        
        // Lower threshold to catch even more setups
        g_BaseThreshold = MathMax(55.0, g_BaseThreshold - 5);
        
        if(EnableFriendlyLogs && g_State.totalTrades % 50 == 0) {
            PrintFormat("  peak performance   |   WR %.1f%%   |   maximum efficiency", currentWR);
            Print("  high frequency conditions   |   capitalising");
        }
    }
    
    // OUTSTANDING PERFORMANCE (75-85% win rate)
    else if(currentWR >= 75.0) {
        g_Frequency.maxTradesPerHour = 999; // UNLIMITED
        g_Frequency.frequencyReason = "OUTSTANDING (WR: " + DoubleToStr(currentWR, 1) + "%) - Fully aligned, unlimited!";
        
        // Keep threshold normal
        g_BaseThreshold = g_BaseThreshold;
    }
    
    // STRONG EDGE (65-75% win rate)
    else if(currentWR >= 65.0) {
        g_Frequency.maxTradesPerHour = 999; // UNLIMITED
        g_Frequency.frequencyReason = "STRONG EDGE (WR: " + DoubleToStr(currentWR, 1) + "%) - Great alignment, unlimited!";
    }
    
    // SOLID PERFORMANCE (55-65% win rate)
    else if(currentWR >= 55.0) {
        g_Frequency.maxTradesPerHour = 999; // UNLIMITED
        g_Frequency.frequencyReason = "SOLID (WR: " + DoubleToStr(currentWR, 1) + "%) - Good alignment, unlimited!";
    }
    
    // BASELINE (50-55% win rate)
    else if(currentWR >= 50.0) {
        g_Frequency.maxTradesPerHour = 999; // Still unlimited but watching
        g_Frequency.frequencyReason = "BASELINE (WR: " + DoubleToStr(currentWR, 1) + "%) - Acceptable, monitoring";
        
        // Slightly raise threshold for more selectivity
        g_BaseThreshold = g_BaseThreshold + 3;
        
        // Check if we dropped from higher performance
        if(peakWinRate >= SpecLearnedWR() + 3.0 && currentWR < SpecWR() - 10.0 && g_State.totalTrades >= 100) {
            PrintFormat("  performance drop   |   %.1f%% from %.1f%%   |   monitoring", currentWR, peakWinRate);
            Print("    Market conditions likely shifted - threshold +5 for selectivity");
            g_BaseThreshold = g_BaseThreshold + 5;
        }
    }
    
    // STRUGGLING (45-50% win rate) - SMART STATISTICAL ASSESSMENT
    else if(currentWR >= 45.0) {
        // SMART: Check sample size before throttling
        // Calculate recent trades from last 20 results
        int recentTrades = 0;
        for(int rt = 0; rt < 20 && rt < g_State.totalTrades; rt++) {
            recentTrades++;
        }
        
        if(recentTrades < 20) {
            // Small sample - could just be variance, don't throttle yet
            g_Frequency.maxTradesPerHour = 999; // UNLIMITED - insufficient data
            g_Frequency.frequencyReason = "VARIANCE (WR: " + DoubleToStr(currentWR, 1) + "%) - Small sample (" + IntegerToString(recentTrades) + "), allowing recovery";
            g_BaseThreshold = g_BaseThreshold + 3; // Slight selectivity increase only
        }
        else if(recentTrades >= 50) {
            // Large sample - this is systemic, throttle but not severely
            g_Frequency.maxTradesPerHour = 30; // SMARTER: 30/hour not 10/hour
            g_Frequency.frequencyReason = "STRUGGLING (WR: " + DoubleToStr(currentWR, 1) + "%) - Selective mode (" + IntegerToString(recentTrades) + " trades)";
            g_BaseThreshold = g_BaseThreshold + 8; // Moderate increase
        }
        else {
            // Medium sample - moderate throttle
            g_Frequency.maxTradesPerHour = 50; // SMARTER: 50/hour allows recovery
            g_Frequency.frequencyReason = "BORDERLINE (WR: " + DoubleToStr(currentWR, 1) + "%) - Monitoring (" + IntegerToString(recentTrades) + " trades)";
            g_BaseThreshold = g_BaseThreshold + 5;
        }
        
        if(EnableFriendlyLogs && g_State.totalTrades >= 50) {
            PrintFormat("  WR %.1f%%   |   %d trades   |   acceptable", currentWR, recentTrades);
            Print("    Smart throttle: ", IntegerToString(g_Frequency.maxTradesPerHour), "/hour | Threshold: ", DoubleToStr(g_BaseThreshold, 0));
        }
    }
    
    // MISALIGNED (Under 45% win rate) - SMART CRITICAL ASSESSMENT
    else if(currentWR < SpecBreakevenWR() + 8.0 && g_State.totalTrades >= 30) {
        // Calculate recent trades from available data
        int recentTrades = 0;
        for(int rt2 = 0; rt2 < 20 && rt2 < g_State.totalTrades; rt2++) {
            recentTrades++;
        }
        
        if(recentTrades < 15) {
            // Very small sample - likely just bad variance
            g_Frequency.maxTradesPerHour = 100; // SMARTER: Allow trading, not 3/hour
            g_Frequency.frequencyReason = "VARIANCE (WR: " + DoubleToStr(currentWR, 1) + "%) - Too few trades (" + IntegerToString(recentTrades) + "), continue sampling";
            g_BaseThreshold = g_BaseThreshold + 5;
        }
        else if(recentTrades >= 40 && currentWR < SpecBreakevenWR() + 4.0) {
            // Large sample, very low WR - something is fundamentally wrong
            g_Frequency.maxTradesPerHour = 10; // SMARTER: 10/hour not 3/hour (still allows recovery)
            g_Frequency.frequencyReason = "CRITICAL (WR: " + DoubleToStr(currentWR, 1) + "%) - Systemic issue (" + IntegerToString(recentTrades) + " trades)";
            g_BaseThreshold = g_BaseThreshold + 12; // Significant increase
        }
        else {
            // Medium sample or moderate WR - selective throttle
            g_Frequency.maxTradesPerHour = 20; // SMARTER: 20/hour allows pattern recognition
            g_Frequency.frequencyReason = "MISALIGNED (WR: " + DoubleToStr(currentWR, 1) + "%) - Selective recovery (" + IntegerToString(recentTrades) + " trades)";
            g_BaseThreshold = g_BaseThreshold + 10;
        }
        
        if(EnableFriendlyLogs) {
            PrintFormat("  low WR alert   |   %.1f%%   |   %d trades   |   reviewing parameters", currentWR, recentTrades);
            Print("      Smart response: ", IntegerToString(g_Frequency.maxTradesPerHour), "/hour | Threshold +", DoubleToStr(g_BaseThreshold - 68, 0));
            Print("      Strategy: Increased selectivity with statistical recovery monitoring");
            
            if(recentTrades >= 50 && currentWR < SpecBreakevenWR() + 4.0) {
                Print("  50+ trades below 40% WR   |   recalibration recommended");
                Print("      System will continue with extreme selectivity OR trigger deep recalibration");
            }
        }
    }
    
    // DISCOVERY MODE - SMART INITIAL LEARNING
    else if(g_State.totalTrades < 30) {
        if(g_State.totalTrades < 10) {
            // First 10 trades: Faster learning
            g_Frequency.maxTradesPerHour = 30; // SMARTER: 30/hour for rapid sampling
            g_Frequency.frequencyReason = "DISCOVERY (Early) - Rapid initial sampling";
        }
        else {
            // 10-30 trades: Moderate learning
            g_Frequency.maxTradesPerHour = 20; // SMARTER: 20/hour allows pattern emergence
            g_Frequency.frequencyReason = "DISCOVERY (Building) - Pattern recognition phase";
        }
    }
}

//| Check if can take another trade this hour                        |
bool CanTakeAnotherTrade() {
    datetime currentHourStart = TimeCurrent() - (TimeCurrent() % 3600);
    
    // Reset counter if new hour
    if(currentHourStart != g_Frequency.currentHour) {
        g_Frequency.currentHour = currentHourStart;
        g_Frequency.tradesThisHour = 0;
        CalculateIntelligentFrequency(); // Recalculate each hour
    }
    
    // LIMITLESS EDITION: RAPID RE-ENTRY CAPABILITY
    
    // Check hourly limit (ONLY performance-based throttle)
    if(g_Frequency.tradesThisHour >= g_Frequency.maxTradesPerHour) {
        if(ShowRejectionReasons && EnableFriendlyLogs) {
            PrintFormat("  hourly limit   |   %d/%d", g_Frequency.tradesThisHour, g_Frequency.maxTradesPerHour);
        }
        return false; // LEGITIMATE: Performance-based frequency control
    }
    
    return true; // ALLOWED: No arbitrary time gaps - trade if signal valid
}

//| Increment trade counter                                          |
void IncrementTradeCounter() {
    g_Frequency.tradesThisHour++;
}


//| PERSISTENT STATE MANAGEMENT - Save/Load per pair                 |

// ## Calibration-aware persistence naming #############################
// ARMED file: written ONLY after all 6 phases pass + Phase 6 WR/frequency gates.

string GetArmedFileName() {
    string sym = Symbol(); StringReplace(sym, "/", ""); StringReplace(sym, "\\", "");
    return "TW917_" + sym + "_P" + IntegerToString(Period()) + "_ARMED.dat";
}

string GetPartialFileName() {
    string sym = Symbol(); StringReplace(sym, "/", ""); StringReplace(sym, "\\", "");
    return "TW917_" + sym + "_P" + IntegerToString(Period()) + "_PARTIAL.dat";
}

// Legacy -- kept for compatibility with existing SaveSystemState calls during adaptation
string GetStateFileName() {
    return GetArmedFileName();
}

// Delete the partial/temp calibration file -- called on phase failure
void DeletePartialSave() {
    string pf = GetPartialFileName();
    if(FileIsExist(pf)) {
        FileDelete(pf);
        if(!g_CalibSilent) Print("  partial save   |   deleted   |   failed calibration discarded");
    }
    // Also delete any old-format state file that might exist
    string sym = Symbol(); StringReplace(sym, "/", ""); StringReplace(sym, "\\", "");
    string legacy = "TUNGSTEN_916_" + sym + "_state.dat";
    if(FileIsExist(legacy)) FileDelete(legacy);
}

// Write calibration state to PARTIAL file during calibration phases.
// This file is NEVER loaded -- it only becomes loadable when SealArmedSave() promotes it.
void WritePartialSave() {
    if(!g_Calibration.isCalibrating) return;
    string pf = GetPartialFileName();
    int h = FileOpen(pf, FILE_WRITE|FILE_BIN);
    if(h == INVALID_HANDLE) return;
    FileWriteInteger(h, 9192); // partial marker -- different from ARMED marker 9191
    FileWriteInteger(h, (int)TimeCurrent());
    FileClose(h);
}

// WARRANT#24 (A3): Phase 3B per-regime checkpoint. The terminal has died twice mid-Phase-3B
// with no clean shutdown (SLS37 ~15s, SLS38 ~23min at the r3->r4 boundary), losing the entire
// calibration run each time. This persists each regime's search result the moment it completes,
// so a crash mid-Phase-3B costs only the in-flight regime, not the whole run.
string GetP3BCheckpointFileName() {
    string sym = Symbol(); StringReplace(sym, "/", ""); StringReplace(sym, "\\", "");
    return "TW917_" + sym + "_P" + IntegerToString(Period()) + "_P3BCKPT.dat";
}
#define P3B_CKPT_MARKER   0xB3C0
#define P3B_CKPT_MAXAGE_S (4*3600)   // stale after 4h -- data/instrument state may have moved on

// Overwrites the checkpoint with every regime's weights/threshold up to and including
// lastCompletedRegime. Regimes beyond it are written as zeroed placeholders (never read back
// as meaningful, since a load only trusts slots 0..lastCompletedRegime).
void SaveP3BCheckpoint(int lastCompletedRegime) {
    string cf = GetP3BCheckpointFileName();
    int h = FileOpen(cf, FILE_WRITE|FILE_BIN);
    if(h == INVALID_HANDLE) {
        Print("  P3B   |   checkpoint save failed   |   error ", GetLastError());
        return;
    }
    FileWriteInteger(h, P3B_CKPT_MARKER);
    FileWriteInteger(h, (int)TimeCurrent());
    FileWriteInteger(h, lastCompletedRegime);
    for(int _ck=0; _ck<9; _ck++) {
        ComponentWeights _cw = g_RegimeOptimalWeights[_ck];
        FileWriteDouble(h, _cw.mtf);
        FileWriteDouble(h, _cw.momentum);
        FileWriteDouble(h, _cw.volatility);
        FileWriteDouble(h, _cw.volume);
        FileWriteDouble(h, _cw.session);
        FileWriteDouble(h, _cw.pattern);
        FileWriteDouble(h, _cw.reversal);
        FileWriteDouble(h, _cw.directional);
        FileWriteDouble(h, _cw.predictive);
        FileWriteDouble(h, _cw.currencyStrength);
        FileWriteDouble(h, _cw.trainingWR);
        FileWriteDouble(h, _cw.validationWR);
        FileWriteDouble(h, _cw.expectedValue);
        FileWriteInteger(h, _cw.sampleSize);
        FileWriteInteger(h, _cw.validated ? 1 : 0);
        FileWriteDouble(h, g_RegimeOptimalThresholds[_ck]);
    }
    FileClose(h);
}

// Loads a fresh-enough checkpoint into g_RegimeOptimalWeights[0..lastCompletedRegime] /
// g_RegimeOptimalThresholds[0..lastCompletedRegime]. Returns true (and sets outLastCompleted)
// only if a valid, non-stale checkpoint with at least one completed regime was found; deletes
// and ignores anything stale, malformed, or empty so a fresh run always starts clean.
bool LoadP3BCheckpoint(int &outLastCompleted) {
    outLastCompleted = -1;
    string cf = GetP3BCheckpointFileName();
    if(!FileIsExist(cf)) return false;
    int h = FileOpen(cf, FILE_READ|FILE_BIN);
    if(h == INVALID_HANDLE) return false;
    int marker = FileReadInteger(h);
    int savedAt = FileReadInteger(h);
    int lastDone = FileReadInteger(h);
    if(marker != P3B_CKPT_MARKER || lastDone < 0 || lastDone > 8 ||
       (int)TimeCurrent() - savedAt > P3B_CKPT_MAXAGE_S) {
        FileClose(h);
        FileDelete(cf);
        return false;
    }
    for(int _ck=0; _ck<9; _ck++) {
        ComponentWeights _cw;
        _cw.mtf              = FileReadDouble(h);
        _cw.momentum         = FileReadDouble(h);
        _cw.volatility       = FileReadDouble(h);
        _cw.volume           = FileReadDouble(h);
        _cw.session          = FileReadDouble(h);
        _cw.pattern          = FileReadDouble(h);
        _cw.reversal         = FileReadDouble(h);
        _cw.directional      = FileReadDouble(h);
        _cw.predictive       = FileReadDouble(h);
        _cw.currencyStrength = FileReadDouble(h);
        _cw.trainingWR       = FileReadDouble(h);
        _cw.validationWR     = FileReadDouble(h);
        _cw.expectedValue    = FileReadDouble(h);
        _cw.sampleSize       = FileReadInteger(h);
        _cw.validated        = (FileReadInteger(h) != 0);
        double _thr          = FileReadDouble(h);
        if(_ck <= lastDone) {
            g_RegimeOptimalWeights[_ck]    = _cw;
            g_RegimeOptimalThresholds[_ck] = _thr;
        }
    }
    FileClose(h);
    outLastCompleted = lastDone;
    return true;
}

void DeleteP3BCheckpoint() {
    string cf = GetP3BCheckpointFileName();
    if(FileIsExist(cf)) FileDelete(cf);
}

// Promote partial file to ARMED file after full calibration success.
// Writes the complete armed state directly to the ARMED filename.
// Any existing partial or previous armed file is replaced.
void SealArmedSave();  // forward declared -- implemented below SaveSystemState

//| Save system state to file                                        |
// ========================================================================
// L9  PERSISTENCE  (Save/Load armed state · Quarantine · MCM durability)
// ========================================================================
void SaveSystemState() {
    string filename = GetStateFileName();
    int handle = FileOpen(filename, FILE_WRITE|FILE_BIN);
    
    if(handle == INVALID_HANDLE) {
        if(EnableFriendlyLogs) {
            PrintFormat("  save failed   |   error %d", GetLastError());
        }
        return;
    }
    
    // Write version identifier - UPDATED TO 916
    FileWriteInteger(handle, 9196);  // Version FIX43 -- spec persistence (requiredWR, AvgRR, calibratedWR)
    FileWriteDouble(handle, g_Calibration.requiredWinRate);
    FileWriteDouble(handle, g_P6_AvgRR);
    FileWriteDouble(handle, g_Calibration.calibratedWR);
    // 9.39: LoadSystemState() unconditionally reads a calibTs int right here (for its
    // AutoRecalibrationDays expiry check) -- this write was missing, which shifted every
    // single field read after it by 4 bytes for the rest of the file. Confirmed by tracing
    // every FileWrite*/FileRead* call in both functions field-for-field.
    FileWriteInteger(handle, (int)TimeCurrent());  // calibration timestamp

    // Write base threshold (learned adjustments)
    FileWriteDouble(handle, g_BaseThreshold);
    
    // Write current state
    FileWriteInteger(handle, g_State.currentState);
    FileWriteInteger(handle, g_State.totalTrades);
    FileWriteDouble(handle, g_State.peakBalance);
    
    // Write hourly adjustments
    for(int h = 0; h < 24; h++) {
        FileWriteDouble(handle, g_SessionThresholdAdjustment[h]);
        FileWriteInteger(handle, g_HoursDisabled[h] ? 1 : 0);
    }
    
    // Write risk settings
    FileWriteDouble(handle, g_Risk.currentRisk);
    
    // Write time performance data
    for(int h = 0; h < 24; h++) {
        FileWriteInteger(handle, g_TimePerf.tradesByHour[h]);
        FileWriteDouble(handle, g_TimePerf.winRateByHour[h]);
    }
    
    // Write adaptive gates timestamp
    FileWriteInteger(handle, (int)g_LastAdaptiveUpdate);
    
    // Save Ultimate Edition data
    FileWriteInteger(handle, g_CircuitBreaker.circuitBreakerActive ? 1 : 0);
    FileWriteInteger(handle, g_CircuitBreaker.recalibrationsLast30Days);
    for(int i = 0; i < 10; i++) {
        FileWriteInteger(handle, (int)g_CircuitBreaker.recalibrationDates[i]);
    }
    
    FileWriteDouble(handle, g_RegimeChange.rolling30DayWR);
    FileWriteInteger(handle, g_RegimeChange.consecutiveBadMonths);
    FileWriteInteger(handle, g_RegimeChange.regimeShiftSuspected ? 1 : 0);
    
    FileWriteDouble(handle, g_MonthlyGoals.monthStartBalance);
    FileWriteDouble(handle, g_MonthlyGoals.expectedGrowthPercent);
    FileWriteInteger(handle, (int)g_MonthlyGoals.monthStartTime);
    
    FileWriteDouble(handle, g_VolatilityFilter.minimumATR);
    
    // NEW: SAVE REGIME LEARNING RESULTS
    FileWriteInteger(handle, g_RegimeLearning.regimesLearned ? 1 : 0);
    FileWriteInteger(handle, (int)g_RegimeLearning.lastRegimeLearning);
    FileWriteDouble(handle, g_RegimeLearning.overallAccuracy);
    FileWriteInteger(handle, g_RegimeLearning.targetBarsForLearning);
    FileWriteInteger(handle, g_RegimeLearning.regimeLearningCycles);
    FileWriteInteger(handle, g_RegimeLearning.dataReliable ? 1 : 0);
    
    // Save each regime's learned boundaries (8 regimes)
    for(int r = 0; r < 9; r++) {
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].adxMin);
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].adxMax);
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].atrPctMin);
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].atrPctMax);
        FileWriteInteger(handle, g_RegimeLearning.regimes[r].timesDetected);
        FileWriteDouble(handle, g_RegimeLearning.perRegimeAccuracy[r]);
    }
    // Persist quarantine state — prevents weak regimes resuming live trades after EA restart
    for(int rq = 0; rq < 9; rq++) {
        FileWriteInteger(handle, g_RegimeQuarantined[MathMin(8,MathMax(0,rq))] ? 1 : 0);
        FileWriteDouble(handle,  g_RegimeQuarantineWR[MathMin(8,MathMax(0,rq))]);
        FileWriteInteger(handle, g_RegimeRepairAttempts[MathMin(8,MathMax(0,rq))]);
        FileWriteDouble(handle,  g_RegimeRepairBestWR[MathMin(8,MathMax(0,rq))]);
    }
    // === SAVE PHASE 2 REGIME CORRELATION INTELLIGENCE ====================
    // These fields are computed during LearnRegimeCorrelations (Phase 2).
    // Without saving them, every restart loses the session/Hurst/signalWR data
    // that all downstream anti-fragility systems depend on.
    FileWriteInteger(handle, g_CorrelationsLearned ? 1 : 0);
    for(int _cs = 0; _cs < 9; _cs++) {  // 9 regimes
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].signalWR);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].signalWins);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].signalTotal);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].signalPF);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgHurst);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgATRPct);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgEntropy);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgMomentumBias);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgBodyRatio);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgStructureClarity);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].barCount);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].pctOfMarket);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].medianScore);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].dominantSession);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].overallAccuracy);
        for(int _ss2 = 0; _ss2 < 4; _ss2++) {
            FileWriteDouble(handle, g_RegimeCorrelations[_cs].sessionWR[_ss2]);
            FileWriteInteger(handle, g_RegimeCorrelations[_cs].sessionWins[_ss2]);
            FileWriteInteger(handle, g_RegimeCorrelations[_cs].sessionTotal[_ss2]);
        }
    }
    
    // NEW: SAVE DISCOVERY MODE OPTIMAL PARAMETERS
    FileWriteDouble(handle, g_Discovery.bestThreshold);
    FileWriteDouble(handle, g_Discovery.bestMomentumWeight);
    FileWriteDouble(handle, g_Discovery.bestReversalWeight);
    FileWriteDouble(handle, g_Discovery.bestVolatilityWeight);
    FileWriteDouble(handle, g_Discovery.bestDirectionalWeight);
    FileWriteDouble(handle, g_Discovery.bestPatternWeight);
    FileWriteDouble(handle, g_Discovery.bestPredictiveWeight);
    FileWriteDouble(handle, g_Discovery.bestWinRate);
    
    // NEW: SAVE CURRENT OPERATING PARAMETERS
    FileWriteDouble(handle, g_CurrentThreshold);
    FileWriteDouble(handle, g_ComponentWeights.momentum);
    FileWriteDouble(handle, g_ComponentWeights.reversal);
    FileWriteDouble(handle, g_ComponentWeights.volatility);
    FileWriteDouble(handle, g_ComponentWeights.directional);
    FileWriteDouble(handle, g_ComponentWeights.pattern);
    FileWriteDouble(handle, g_ComponentWeights.predictive);

    // SAVE REGIME-LEVEL CALIBRATION OUTPUTS (Session 25+ additions)
    // Per-regime optimal weights, thresholds, exit bars, SL/TP
    for(int _sr = 0; _sr < 9; _sr++) {
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].mtf);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].momentum);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].volume);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].volatility);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].session);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].pattern);
        FileWriteDouble(handle, g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_sr))]);
        FileWriteInteger(handle, g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_sr))]);
        FileWriteDouble(handle, g_RegimeOptimalSLMult[MathMin(8,MathMax(0,_sr))]);
        FileWriteDouble(handle, g_RegimeOptimalTPMult[MathMin(8,MathMax(0,_sr))]);
        FileWriteDouble(handle, g_RegimeIC[_sr][0]);
        FileWriteDouble(handle, g_RegimeIC[_sr][1]);
        FileWriteDouble(handle, g_RegimeIC[_sr][2]);
        FileWriteDouble(handle, g_RegimeIC[_sr][3]);
        FileWriteDouble(handle, g_RegimeIC[_sr][4]);
        FileWriteDouble(handle, g_RegimeIC[_sr][5]);
    }
    FileWriteInteger(handle, g_WeightsOptimized ? 1 : 0);
    FileWriteInteger(handle, g_ICMeasured ? 1 : 0);
    // Session-specific weights [4][8]
    // SLS23 FIX: was < 8, LoadSystemState reads < 9 (arrays are [4][9]) -- every field written
    // after this point in the save file was silently misaligned on load, corrupting weeks of
    // live-learned state (live-adaptive intelligence, CEO history, tier state, ERM state, etc.)
    for(int _ss = 0; _ss < 4; _ss++) for(int _sr2 = 0; _sr2 < 9; _sr2++) {
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].mtf);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].momentum);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].volume);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].volatility);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].session);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].pattern);
        FileWriteInteger(handle, g_SessionWeightsValid[_ss][_sr2] ? 1 : 0);
        FileWriteDouble(handle, g_SessionSLMult[_ss][_sr2]);
        FileWriteDouble(handle, g_SessionTPMult[_ss][_sr2]);
    }
    // Volatility-state weights [3][8]
    // SLS23 FIX: was < 8, LoadSystemState reads < 9 (arrays are [3][9]) -- same field-alignment
    // corruption as the session-weights block above.
    for(int _vs = 0; _vs < 3; _vs++) for(int _sr3 = 0; _sr3 < 9; _sr3++) {
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].mtf);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].momentum);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].volume);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].volatility);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].session);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].pattern);
        FileWriteInteger(handle, g_VolatilityWeightsValid[_vs][_sr3] ? 1 : 0);
    }
    // Calibrated vol thresholds
    FileWriteDouble(handle, g_CalibratedVolLowThresh);
    FileWriteDouble(handle, g_BlendAlphaRegime);
    FileWriteDouble(handle, g_BlendAlphaSession);
    FileWriteDouble(handle, g_BlendAlphaVol);
    FileWriteDouble(handle, g_CalibratedVolHighThresh);

    // 9.39: REMOVED an erroneous FileClose(handle) that used to sit here. Every write
    // from this point through the final FileClose() below (live adaptive intelligence,
    // alignment history, tier state, candle weights, FIX25 fields) was silently going to
    // an already-closed handle and never reaching disk -- despite the comment directly
    // below claiming this section is what prevents live-learning loss across restarts.
    // LoadSystemState() was never broken (single continuously-open handle throughout),
    // which is exactly why this went undetected: reads for the never-written sections
    // hit EOF and were silently skipped by their FileIsEnding() guards, or (for the FIX25
    // tail, which has no such guard) zeroed out whatever was already in memory.

    // ## PERSIST LIVE ADAPTIVE INTELLIGENCE ##################################
    // Without this, every MT4 restart wipes regime WRs, session WRs,
    // score bucket data, and anatomy weights -- resetting weeks of learning.
    FileWriteInteger(handle, 0xA1F0);  // live adaptive section marker
    FileWriteInteger(handle, g_LiveAdaptive.totalLiveTrades);
    FileWriteInteger(handle, g_LiveAdaptive.selfCalibrated ? 1 : 0);
    FileWriteDouble(handle, g_LiveAdaptive.liveOptimalThreshold);
    FileWriteDouble(handle, g_LiveAdaptive.liveThresholdConfidence);
    FileWriteDouble(handle, g_LiveAdaptive.liveEdgeScore);
    for(int _la = 0; _la < 8; _la++) {
        FileWriteInteger(handle, g_LiveAdaptive.regimeTrades[_la]);
        FileWriteInteger(handle, g_LiveAdaptive.regimeWins[_la]);
        FileWriteDouble(handle, g_LiveAdaptive.regimeLiveWR[_la]);
        FileWriteDouble(handle, g_LiveAdaptive.regimeThreshAdj[_la]);
    }
    for(int _la = 0; _la < 4; _la++) {
        FileWriteInteger(handle, g_LiveAdaptive.sessionTrades[_la]);
        FileWriteInteger(handle, g_LiveAdaptive.sessionWins[_la]);
        FileWriteDouble(handle, g_LiveAdaptive.sessionLiveWR[_la]);
    }
    for(int _la = 0; _la < 5; _la++) {
        FileWriteInteger(handle, g_LiveAdaptive.scoreBucketTrades[_la]);
        FileWriteInteger(handle, g_LiveAdaptive.scoreBucketWins[_la]);
        FileWriteDouble(handle, g_LiveAdaptive.scoreBucketWR[_la]);
    }
    for(int _la = 0; _la < 16; _la++) {
        FileWriteInteger(handle, g_LiveAdaptive.anatomyLiveTrades[_la]);
        FileWriteInteger(handle, g_LiveAdaptive.anatomyLiveWins[_la]);
        FileWriteDouble(handle, g_LiveAdaptive.anatomyLiveWR[_la]);
    }
    // Persist CEO alignment score history
    FileWriteInteger(handle, 0xCE02);  // alignment section marker
    FileWriteDouble(handle, g_Alignment.overallScoreSmoothed);
    FileWriteDouble(handle, g_Alignment.trend);
    FileWriteInteger(handle, g_Alignment.scoreHistoryLen);
    for(int _ah = 0; _ah < 48; _ah++)
        FileWriteDouble(handle, g_Alignment.scoreHistory[_ah]);
    // Persist tier state
    FileWriteInteger(handle, 0x71E2);  // tier section marker
    FileWriteInteger(handle, g_Tier.currentTier);
    FileWriteDouble(handle, g_Tier.mediumUnlockWR);
    // Persist calibrated candle weights
    FileWriteInteger(handle, 0xCA4E);  // candle weights marker
    FileWriteInteger(handle, g_CandleWeightsCalibrated ? 1 : 0);
    for(int _cw = 0; _cw < 14; _cw++)
        FileWriteDouble(handle, g_CalibratedCandleWeights[_cw]);
    // -- New intelligence data (FIX25: per-type, discrimination, frequency) --
    FileWriteDouble(handle, g_Calibration.instrumentHurst);
    FileWriteDouble(handle, g_Calibration.p3bThreshold);
    FileWriteDouble(handle, g_BaselineTradesPerDay);
    for(int _sr=0;_sr<9;_sr++) for(int _st=0;_st<4;_st++){FileWriteDouble(handle,g_RegimeTPByType[_sr][_st]);FileWriteDouble(handle,g_RegimeSLByType[_sr][_st]);}
    for(int _sr=0;_sr<9;_sr++) for(int _sc=0;_sc<6;_sc++) FileWriteDouble(handle,g_RegimeCorrelations[_sr].compDiscrimination[_sc]);
    for(int _sr=0;_sr<9;_sr++){FileWriteDouble(handle,g_RegimeCorrelations[_sr].contWR);FileWriteDouble(handle,g_RegimeCorrelations[_sr].revWR);FileWriteDouble(handle,g_RegimeCorrelations[_sr].brkWR);FileWriteInteger(handle,g_RegimeCorrelations[_sr].dominantSignalType);}
    // 9.41: currency-strength IC + derived per-regime weight. Appended at the very
    // end, same reason and same guarded-read pattern as the FIX25 tail block above --
    // older save files without this section simply leave these at safe neutral
    // defaults (see LoadSystemState's matching FileIsEnding() guard).
    FileWriteInteger(handle, 0xC59A);  // currency-strength section marker
    for(int _cs=0;_cs<9;_cs++) FileWriteDouble(handle, g_RegimeICCcy[_cs]);
    for(int _cs=0;_cs<9;_cs++) FileWriteDouble(handle, g_RegimeOptimalWeights[_cs].currencyStrength);
    // SLS(20): regime-duration hazard state + Phase 3C geometry flag. Without this tail,
    // every restart silently degraded the continuationProb hazard model to its legacy
    // fallback (durations zeroed by init) and reverted the IC refinement pass to
    // hardcoded mirror geometry until the NEXT full recalibration -- a saved file that
    // claimed "calibrated" while two 9.42 subsystems ran blind. Same guarded-tail
    // pattern as 0xC59A above; older files simply skip it.
    FileWriteInteger(handle, 0xD520);  // duration-hazard section marker
    for(int _dh=0;_dh<9;_dh++) FileWriteDouble(handle, g_RegimeAvgDuration[_dh]);
    for(int _dh=0;_dh<9;_dh++) FileWriteInteger(handle, g_RegimeDurationSamples[_dh]);
    FileWriteInteger(handle, g_RegimeDurationCalibrated ? 1 : 0);
    FileWriteInteger(handle, g_TPSLMultCalibrated ? 1 : 0);

    // SLS22-ERM: guarded tail, same precedent as 0xC59A/0xD520 above. SealArmedSave
    // stays tail-free per directive C4 -- this only ever lives in SaveSystemState.
    FileWriteInteger(handle, 0xE210);  // ERM section marker
    FileWriteDouble(handle, g_ERM_SpreadEWMA);
    FileWriteDouble(handle, g_ERM_SpreadEWMARollover);
    FileWriteDouble(handle, g_ERM_SlippageEWMA);
    FileWriteInteger(handle, g_ERM_SampleCount);
    FileWriteDouble(handle, g_ERM_TotalCostPoints);
    FileWriteInteger(handle, g_ERM_CostSamples);
    FileWriteInteger(handle, (int)g_ERM_State);

    // WARRANT#32: Living-Edge state (day-of-week/triple-cell/regime-substrate scan results),
    // same guarded-tail precedent as the sections above -- lives here, not in SealArmedSave.
    LE_WriteArmedTail(handle);

    // forge-cleanup-3 WARRANT#57 (seam audit "ProbDB save -> load", 2026-07-17): g_ProbDB
    // (the Phase 4 6D pattern database -- regime x score x pattern x session x vol) had no
    // hit anywhere in SaveSystemState/LoadSystemState before this warrant, confirmed by the
    // absence noted in ProbDB_AnnotateAll's own WARRANT#43 comment ("no dedicated Save/
    // LoadProbDB found"). An instant-restart from an ARMED save therefore traded live with
    // g_ProbDB.calibrated == false and every ProbDB-gated read (L5 execution gate,
    // ApplyProbabilityIntelligence, the P4 ProbDB gate itself) silently inert until the next
    // full recalibration -- a coherence break at exactly the save->load seam this warrant
    // exists to close: a model coherent when Phase 4 built it, meaningless once restored
    // into a process that never wrote it down. Same guarded-tail precedent as the sections
    // above -- lives here, not in SealArmedSave.
    PDB_WriteArmedTail(handle);

    // forge-parallel WARRANT#62: challenger-Sharpe history for the deflated-Sharpe gate -- same
    // guarded-tail precedent as the sections above, placed last (see Forge_ReadSRHistoryTail).
    Forge_WriteSRHistoryTail(handle);

    // forge-parallel WARRANT#82: champion-register persistence, the new last tail (see
    // Forge_ReadChampionTail) -- closes the gap where the ratchet forgot its own floor on restart.
    Forge_WriteChampionTail(handle);

    FileClose(handle);

    if(ShowOptimizationLogs && EnableFriendlyLogs) {
        PrintFormat("  state saved   |   %s   |   live adaptive %d trades persisted", filename, g_LiveAdaptive.totalLiveTrades);
        if(g_RegimeLearning.regimesLearned) {
            PrintFormat("   [SAVED] Regime learning (%.1f%% accuracy)", g_RegimeLearning.overallAccuracy);
        }
        if(g_Discovery.bestWinRate > 0) {
            PrintFormat("   [SAVED] Optimal parameters (%.1f%% expected WR)", g_Discovery.bestWinRate);
        }
    }
}

// ## SealArmedSave ##########################################################
// Called once after Phase 6 passes, before sealing the ARMED file.

// g_CalibratedCandleWeights and g_CandleWeightsCalibrated declared earlier (forward)

void AnalyseGhostCandleAccuracy() {
    if(g_GhostTradeCount < 10) return;

    int wins[14], obs[14];
    ArrayInitialize(wins, 0);
    ArrayInitialize(obs,  0);

    double closingStrWins=0, closingStrLosses=0, dramaWins=0, dramaLosses=0;
    double bias5Wins=0, bias5Losses=0;
    int wCount=0, lCount=0;

    int n = MathMin(g_GhostTradeCount, 100);
    for(int i = 0; i < n; i++) {
        bool won = g_GhostTrades[i].hitTP;

        bool anatomy[14];
        anatomy[0]  = g_GhostTrades[i].isBullishRejection;
        anatomy[1]  = g_GhostTrades[i].isBearishRejection;
        anatomy[2]  = g_GhostTrades[i].isBullishEngulf;
        anatomy[3]  = g_GhostTrades[i].isBearishEngulf;
        anatomy[4]  = false;  // kicker -- not stored separately, infer below
        anatomy[5]  = false;
        anatomy[6]  = false;  // morning/evening star -- multi-bar, not stored in record
        anatomy[7]  = false;
        anatomy[8]  = false;  // three soldiers/crows -- not stored
        anatomy[9]  = false;
        anatomy[10] = g_GhostTrades[i].isConvictionCandle;
        anatomy[11] = g_GhostTrades[i].isIndecisionCandle;
        anatomy[12] = false;  // inside/outside bar -- use body pct as proxy
        anatomy[13] = (g_GhostTrades[i].candleBodyPct < 0.12);  // very small body ? outside/doji

        for(int ai = 0; ai < 14; ai++) {
            if(!anatomy[ai]) continue;
            obs[ai]++;
            if(won) wins[ai]++;
        }

        if(won) {
            closingStrWins += g_GhostTrades[i].closingStrength;
            dramaWins      += g_GhostTrades[i].barDrama;
            bias5Wins      += g_GhostTrades[i].momentumBias5;
            wCount++;
        } else {
            closingStrLosses += g_GhostTrades[i].closingStrength;
            dramaLosses      += g_GhostTrades[i].barDrama;
            bias5Losses      += g_GhostTrades[i].momentumBias5;
            lCount++;
        }
    }

    // ## Calibrate per-anatomy weights ########################################
    // baseline ghost WR for reference
    double baseWR = (n > 0) ? (double)(wCount) / n : 0.65;

    string report = "";
    for(int ai = 0; ai < 14; ai++) {
        if(obs[ai] < 5) {
            g_CalibratedCandleWeights[ai] = 1.0;  // insufficient data -- neutral
            continue;
        }
        double anatWR = (double)wins[ai] / obs[ai];
        // Weight = ratio of anatomy WR to baseline WR, clamped 0.3-2.0
        // If anatomy WR > baseline: this pattern is predictive -> weight > 1
        // If anatomy WR < baseline: this pattern is noise/counter -> weight < 1
        double weight = (baseWR > 0) ? MathMax(0.3, MathMin(2.0, anatWR / baseWR)) : 1.0;
        g_CalibratedCandleWeights[ai] = weight;

        if(!g_CalibSilent && MathAbs(weight - 1.0) > 0.2) {
            static string aNames[14] = {
                "bull reject","bear reject","bull engulf","bear engulf",
                "bull kicker","bear kicker","morning star","evening star",
                "3 soldiers","3 crows","conviction","indecision","inside","outside"
            };
            report += StringFormat("  %s  WR %.0f%% vs base %.0f%%  ->  weight x%.2f\n",
                                   aNames[ai], anatWR*100, baseWR*100, weight);
        }
    }

    g_CandleWeightsCalibrated = true;

    // ## Closing strength audit ################################################
    if(wCount > 0 && lCount > 0) {
        double avgCsW = closingStrWins  / wCount;
        double avgCsL = closingStrLosses / lCount;
        double csDiscrimination = avgCsW - avgCsL;  // positive = closing strength predicts wins

        double avgDW = dramaWins   / wCount;
        double avgDL = dramaLosses / lCount;

        double avgB5W = bias5Wins   / wCount;
        double avgB5L = bias5Losses / lCount;

        if(!g_CalibSilent) {
            PrintFormat("  candle audit   |   closing strength: wins %.2f  losses %.2f  disc %+.2f",
                        avgCsW, avgCsL, csDiscrimination);
            PrintFormat("  candle audit   |   bar drama: wins %.2f  losses %.2f   |   bias5: wins %.2f  losses %.2f",
                        avgDW, avgDL, avgB5W, avgB5L);

            // Self-diagnosis: if closing strength discrimination is low (<0.05),
            // closing strength doesn't predict outcomes in this context -- weight it down
            if(MathAbs(csDiscrimination) < 0.05) {
                Print("  candle audit   |   closing strength has low discrimination here   |   weighting down");
            } else if(csDiscrimination > 0.15) {
                Print("  candle audit   |   closing strength is highly predictive   |   weighting up");
            }

            if(report != "") {
                Print("  candle audit   |   anatomy weight adjustments:");
                Print(report);
            }
        }
    }
}

// Called only after Phase 6 passes ALL gates (WR, frequency, robustness, PF, EV).
// Writes complete calibration state to ARMED file (version 9173).
// Deletes the PARTIAL temp file. Any previous ARMED file is atomically replaced.
// LoadSystemState only loads files with version 9173.
void SealArmedSave() {
    // GATE: never persist a failed validation as ARMED — a 30%-WR instant-restart
    // file poisons every future session. Failed runs must recalibrate fresh.
    if(g_Calibration.executionSuspended) {
        Print("  ARMED save skipped   |   validation failed   |   fresh recalibration on next start");
        return;
    }

    // Clean up partial marker
    string pf = GetPartialFileName();
    if(FileIsExist(pf)) FileDelete(pf);

    string filename = GetArmedFileName();
    int handle = FileOpen(filename, FILE_WRITE|FILE_BIN);
    if(handle == INVALID_HANDLE) {
        PrintFormat("  ARMED save failed   |   error %d   |   next restart will recalibrate", GetLastError());
        return;
    }

    // 9.39: was version 9191 with no requiredWinRate/P6_AvgRR/calibratedWR fields --
    // LoadSystemState() only ever accepts version 9196 with those three fields present,
    // so every file SealArmedSave() produced was rejected outright on the next restart
    // (discarding a calibration that had just completed successfully) unless a later
    // SaveSystemState() call happened to overwrite it first in the correct format.
    // Now writes the identical layout SaveSystemState() does.
    FileWriteInteger(handle, 9196);                   // ARMED version marker (matches SaveSystemState)
    FileWriteDouble(handle, g_Calibration.requiredWinRate);
    FileWriteDouble(handle, g_P6_AvgRR);
    FileWriteDouble(handle, g_Calibration.calibratedWR);
    FileWriteInteger(handle, (int)TimeCurrent());     // calibration timestamp

    // ## All calibration outputs (mirrors SaveSystemState field order) #####
    FileWriteDouble(handle, g_BaseThreshold);
    FileWriteInteger(handle, g_State.currentState);
    FileWriteInteger(handle, g_State.totalTrades);
    FileWriteDouble(handle, g_State.peakBalance);
    for(int h = 0; h < 24; h++) {
        FileWriteDouble(handle, g_SessionThresholdAdjustment[h]);
        FileWriteInteger(handle, g_HoursDisabled[h] ? 1 : 0);
    }
    FileWriteDouble(handle, g_Risk.currentRisk);
    for(int h = 0; h < 24; h++) {
        FileWriteInteger(handle, g_TimePerf.tradesByHour[h]);
        FileWriteDouble(handle, g_TimePerf.winRateByHour[h]);
    }
    FileWriteInteger(handle, (int)g_LastAdaptiveUpdate);
    FileWriteInteger(handle, g_CircuitBreaker.circuitBreakerActive ? 1 : 0);
    FileWriteInteger(handle, g_CircuitBreaker.recalibrationsLast30Days);
    for(int i = 0; i < 10; i++)
        FileWriteInteger(handle, (int)g_CircuitBreaker.recalibrationDates[i]);
    FileWriteDouble(handle, g_RegimeChange.rolling30DayWR);
    FileWriteInteger(handle, g_RegimeChange.consecutiveBadMonths);
    // SLS21 FIX: 11 fields below were missing from ARMED saves (jumped straight to the
    // regimes loop) while LoadSystemState() unconditionally reads them for version 9196 --
    // any restart between arming and the next periodic SaveSystemState() loaded a file whose
    // byte layout was off by these 11 fields for everything that follows, silently corrupting
    // regime boundaries, quarantine state, correlation intelligence, and calibration outputs
    // even though the version check passed. Mirrors SaveSystemState's field order exactly.
    FileWriteInteger(handle, g_RegimeChange.regimeShiftSuspected ? 1 : 0);
    FileWriteDouble(handle, g_MonthlyGoals.monthStartBalance);
    FileWriteDouble(handle, g_MonthlyGoals.expectedGrowthPercent);
    FileWriteInteger(handle, (int)g_MonthlyGoals.monthStartTime);
    FileWriteDouble(handle, g_VolatilityFilter.minimumATR);
    FileWriteInteger(handle, g_RegimeLearning.regimesLearned ? 1 : 0);
    FileWriteInteger(handle, (int)g_RegimeLearning.lastRegimeLearning);
    FileWriteDouble(handle, g_RegimeLearning.overallAccuracy);
    FileWriteInteger(handle, g_RegimeLearning.targetBarsForLearning);
    FileWriteInteger(handle, g_RegimeLearning.regimeLearningCycles);
    FileWriteInteger(handle, g_RegimeLearning.dataReliable ? 1 : 0);
    for(int r = 0; r < 9; r++) {
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].adxMin);
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].adxMax);
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].atrPctMin);
        FileWriteDouble(handle, g_RegimeLearning.regimes[r].atrPctMax);
        FileWriteInteger(handle, g_RegimeLearning.regimes[r].timesDetected);
        FileWriteDouble(handle, g_RegimeLearning.perRegimeAccuracy[r]);
    }
    // === SAVE PHASE 2 REGIME CORRELATION INTELLIGENCE ====================
    // These fields are computed during LearnRegimeCorrelations (Phase 2).
    // Without saving them, every restart loses the session/Hurst/signalWR data
    // that all downstream anti-fragility systems depend on.
    FileWriteInteger(handle, g_CorrelationsLearned ? 1 : 0);
    for(int _cs = 0; _cs < 9; _cs++) {  // 9 regimes
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].signalWR);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].signalWins);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].signalTotal);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].signalPF);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgHurst);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgATRPct);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgEntropy);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgMomentumBias);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgBodyRatio);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].avgStructureClarity);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].barCount);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].pctOfMarket);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].medianScore);
        FileWriteInteger(handle, g_RegimeCorrelations[_cs].dominantSession);
        FileWriteDouble(handle, g_RegimeCorrelations[_cs].overallAccuracy);
        for(int _ss2 = 0; _ss2 < 4; _ss2++) {
            FileWriteDouble(handle, g_RegimeCorrelations[_cs].sessionWR[_ss2]);
            FileWriteInteger(handle, g_RegimeCorrelations[_cs].sessionWins[_ss2]);
            FileWriteInteger(handle, g_RegimeCorrelations[_cs].sessionTotal[_ss2]);
        }
    }
    FileWriteDouble(handle, g_Discovery.bestThreshold);
    FileWriteDouble(handle, g_Discovery.bestMomentumWeight);
    FileWriteDouble(handle, g_Discovery.bestReversalWeight);
    FileWriteDouble(handle, g_Discovery.bestVolatilityWeight);
    FileWriteDouble(handle, g_Discovery.bestDirectionalWeight);
    FileWriteDouble(handle, g_Discovery.bestPatternWeight);
    FileWriteDouble(handle, g_Discovery.bestPredictiveWeight);
    FileWriteDouble(handle, g_Discovery.bestWinRate);
    FileWriteDouble(handle, g_CurrentThreshold);
    // 9.38: was writing volatility/momentum/pattern twice each (silently discarding
    // reversal/directional/predictive) -- see the matching fix in the primary save function.
    FileWriteDouble(handle, g_ComponentWeights.momentum);
    FileWriteDouble(handle, g_ComponentWeights.reversal);
    FileWriteDouble(handle, g_ComponentWeights.volatility);
    FileWriteDouble(handle, g_ComponentWeights.directional);
    FileWriteDouble(handle, g_ComponentWeights.pattern);
    FileWriteDouble(handle, g_ComponentWeights.predictive);
    for(int _sr = 0; _sr < 9; _sr++) {
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].mtf);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].momentum);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].volume);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].volatility);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].session);
        FileWriteDouble(handle, g_RegimeOptimalWeights[MathMin(8,MathMax(0,_sr))].pattern);
        FileWriteDouble(handle, g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_sr))]);
        FileWriteInteger(handle, g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_sr))]);
        FileWriteDouble(handle, g_RegimeOptimalSLMult[MathMin(8,MathMax(0,_sr))]);
        FileWriteDouble(handle, g_RegimeOptimalTPMult[MathMin(8,MathMax(0,_sr))]);
        for(int ci = 0; ci < 6; ci++) FileWriteDouble(handle, g_RegimeIC[_sr][ci]);
    }
    FileWriteInteger(handle, g_WeightsOptimized ? 1 : 0);
    FileWriteInteger(handle, g_ICMeasured ? 1 : 0);
    // SLS23 FIX: was < 8, LoadSystemState reads < 9 (arrays are [4][9]) -- every field written
    // after this point in the save file was silently misaligned on load, corrupting weeks of
    // live-learned state (live-adaptive intelligence, CEO history, tier state, ERM state, etc.)
    for(int _ss = 0; _ss < 4; _ss++) for(int _sr2 = 0; _sr2 < 9; _sr2++) {
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].mtf);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].momentum);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].volume);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].volatility);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].session);
        FileWriteDouble(handle, g_SessionRegimeWeights[_ss][_sr2].pattern);
        FileWriteInteger(handle, g_SessionWeightsValid[_ss][_sr2] ? 1 : 0);
        FileWriteDouble(handle, g_SessionSLMult[_ss][_sr2]);
        FileWriteDouble(handle, g_SessionTPMult[_ss][_sr2]);
    }
    // SLS23 FIX: was < 8, LoadSystemState reads < 9 (arrays are [3][9]) -- same field-alignment
    // corruption as the session-weights block above.
    for(int _vs = 0; _vs < 3; _vs++) for(int _sr3 = 0; _sr3 < 9; _sr3++) {
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].mtf);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].momentum);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].volume);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].volatility);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].session);
        FileWriteDouble(handle, g_VolatilityRegimeWeights[_vs][_sr3].pattern);
        FileWriteInteger(handle, g_VolatilityWeightsValid[_vs][_sr3] ? 1 : 0);
    }
    FileWriteDouble(handle, g_CalibratedVolLowThresh);
    FileWriteDouble(handle, g_BlendAlphaRegime);
    FileWriteDouble(handle, g_BlendAlphaSession);
    FileWriteDouble(handle, g_BlendAlphaVol);
    FileWriteDouble(handle, g_CalibratedVolHighThresh);

    FileClose(handle);
    PrintFormat("  ARMED   |   saved   |   %s   |   instant restart enabled", filename);
}

//| Load system state from file -- ARMED files only                  |
bool LoadSystemState() {
    // ARMED-only: reject partial (9172), legacy (9162), or missing files.
    string filename = GetArmedFileName();

    if(!FileIsExist(filename)) return false;

    int handle = FileOpen(filename, FILE_READ|FILE_BIN);
    if(handle == INVALID_HANDLE) { DeletePartialSave(); return false; }

    int version = FileReadInteger(handle);
    if(version != 9196) {  // Reject pre-FIX43: spec persistence format
        FileClose(handle);
        if(FileIsExist(filename)) FileDelete(filename);
        DeletePartialSave();
        PrintFormat("  save rejected   |   version %d not ARMED   |   recalibrating", version);
        return false;
    }
    // Spec persistence (FIX43): the live side must wake knowing its own bar.
    g_Calibration.requiredWinRate = FileReadDouble(handle);
    g_P6_AvgRR                    = FileReadDouble(handle);
    g_Calibration.calibratedWR    = FileReadDouble(handle);
    if(g_Calibration.requiredWinRate < 45.0 || g_Calibration.requiredWinRate > 65.0)
        g_Calibration.requiredWinRate = FLOOR_START_WR;
    if(g_P6_AvgRR < 0.5 || g_P6_AvgRR > 8.0) g_P6_AvgRR = 2.5;

    // Calibration timestamp -- reject if expired
    int calibTs = FileReadInteger(handle);
    int ageDays = (int)((TimeCurrent() - (datetime)calibTs) / 86400);
    if(AutoRecalibrationDays > 0 && ageDays > AutoRecalibrationDays) {
        FileClose(handle);
        FileDelete(filename);
        PrintFormat("  save expired   |   %d days old (limit %d)   |   recalibrating", ageDays, AutoRecalibrationDays);
        return false;
    }

    // Read base threshold
    g_BaseThreshold = FileReadDouble(handle);
    
    // Read current state
    g_State.currentState = FileReadInteger(handle);
    g_State.totalTrades = FileReadInteger(handle);
    g_State.peakBalance = FileReadDouble(handle);
    
    // Read hourly adjustments
    for(int h = 0; h < 24; h++) {
        g_SessionThresholdAdjustment[h] = FileReadDouble(handle);
        g_HoursDisabled[h] = (FileReadInteger(handle) == 1);
    }
    
    // Read risk settings
    g_Risk.currentRisk = FileReadDouble(handle);
    
    // Read time performance data
    for(int h = 0; h < 24; h++) {
        g_TimePerf.tradesByHour[h] = FileReadInteger(handle);
        g_TimePerf.winRateByHour[h] = FileReadDouble(handle);
    }
    
    // Read timestamp
    g_LastAdaptiveUpdate = (datetime)FileReadInteger(handle);
    
    // Load Ultimate Edition data
    g_CircuitBreaker.circuitBreakerActive = (FileReadInteger(handle) == 1);
    g_CircuitBreaker.recalibrationsLast30Days = FileReadInteger(handle);
    for(int i = 0; i < 10; i++) {
        g_CircuitBreaker.recalibrationDates[i] = (datetime)FileReadInteger(handle);
    }
    
    g_RegimeChange.rolling30DayWR = FileReadDouble(handle);
    g_RegimeChange.consecutiveBadMonths = FileReadInteger(handle);
    g_RegimeChange.regimeShiftSuspected = (FileReadInteger(handle) == 1);
    
    g_MonthlyGoals.monthStartBalance = FileReadDouble(handle);
    g_MonthlyGoals.expectedGrowthPercent = FileReadDouble(handle);
    g_MonthlyGoals.monthStartTime = (datetime)FileReadInteger(handle);
    
    g_VolatilityFilter.minimumATR = FileReadDouble(handle);
    
    // NEW: LOAD REGIME LEARNING RESULTS
    g_RegimeLearning.regimesLearned = (FileReadInteger(handle) == 1);
    g_RegimeLearning.lastRegimeLearning = (datetime)FileReadInteger(handle);
    g_RegimeLearning.overallAccuracy = FileReadDouble(handle);
    g_RegimeLearning.targetBarsForLearning = FileReadInteger(handle);
    g_RegimeLearning.regimeLearningCycles = FileReadInteger(handle);
    g_RegimeLearning.dataReliable = (FileReadInteger(handle) == 1);
    
    // Load each regime's learned boundaries (8 regimes)
    for(int r = 0; r < 9; r++) {
        g_RegimeLearning.regimes[r].adxMin = FileReadDouble(handle);
        g_RegimeLearning.regimes[r].adxMax = FileReadDouble(handle);
        g_RegimeLearning.regimes[r].atrPctMin = FileReadDouble(handle);
        g_RegimeLearning.regimes[r].atrPctMax = FileReadDouble(handle);
        g_RegimeLearning.regimes[r].timesDetected = FileReadInteger(handle);
        g_RegimeLearning.perRegimeAccuracy[r] = FileReadDouble(handle);
    }
    // Load quarantine state
    g_QuarantinedRegimeCount = 0;
    for(int rq2 = 0; rq2 < 9; rq2++) {
        g_RegimeQuarantined[MathMin(8,MathMax(0,rq2))]      = (FileReadInteger(handle) == 1);
        g_RegimeQuarantineWR[MathMin(8,MathMax(0,rq2))]     = FileReadDouble(handle);
        g_RegimeRepairAttempts[MathMin(8,MathMax(0,rq2))]   = FileReadInteger(handle);
        g_RegimeRepairBestWR[MathMin(8,MathMax(0,rq2))]     = FileReadDouble(handle);
        if(g_RegimeQuarantined[MathMin(8,MathMax(0,rq2))]) g_QuarantinedRegimeCount++;
    }
    // === LOAD PHASE 2 REGIME CORRELATION INTELLIGENCE ====================
    for(int _cl = 0; _cl < 9; _cl++) {  // 9 regimes
        g_RegimeCorrelations[_cl].signalWR            = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].signalWins          = FileReadInteger(handle);
        g_RegimeCorrelations[_cl].signalTotal         = FileReadInteger(handle);
        g_RegimeCorrelations[_cl].signalPF            = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].avgHurst            = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].avgATRPct           = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].avgEntropy          = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].avgMomentumBias     = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].avgBodyRatio        = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].avgStructureClarity = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].barCount            = FileReadInteger(handle);
        g_RegimeCorrelations[_cl].pctOfMarket         = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].medianScore         = FileReadDouble(handle);
        g_RegimeCorrelations[_cl].dominantSession     = FileReadInteger(handle);
        g_RegimeCorrelations[_cl].overallAccuracy     = FileReadDouble(handle);
        for(int _sl2 = 0; _sl2 < 4; _sl2++) {
            g_RegimeCorrelations[_cl].sessionWR[_sl2]    = FileReadDouble(handle);
            g_RegimeCorrelations[_cl].sessionWins[_sl2]  = FileReadInteger(handle);
            g_RegimeCorrelations[_cl].sessionTotal[_sl2] = FileReadInteger(handle);
        }
    }
    // WARRANT#91 SANITIZE ON LOAD -- confirmed live 2026-07-23: saved state produced WR values
    // in the hundreds-of-millions-of-percent range when read back (P2 print showed
    // "WR 595048703% ... n 180"). signalWR is a ratio bounded to [0,1] by construction
    // (signalWins is always <= signalTotal when computed live), so a loaded value outside that
    // range or non-finite is provably corrupt saved state -- not a real statistic -- and must
    // be discarded rather than silently feeding P3B's weight search garbage. Reset the whole
    // row rather than patching one field: if one field in a row is corrupt, sibling fields read
    // from adjacent file offsets in the same row are not trustworthy either.
    for(int _sanC = 0; _sanC < 9; _sanC++) {
        bool _corrupt = !MathIsValidNumber(g_RegimeCorrelations[_sanC].signalWR)
                      || g_RegimeCorrelations[_sanC].signalWR < 0.0
                      || g_RegimeCorrelations[_sanC].signalWR > 1.0
                      || g_RegimeCorrelations[_sanC].signalWins < 0
                      || g_RegimeCorrelations[_sanC].signalTotal < 0
                      || g_RegimeCorrelations[_sanC].signalWins > g_RegimeCorrelations[_sanC].signalTotal
                      || !MathIsValidNumber(g_RegimeCorrelations[_sanC].signalPF);
        if(_corrupt) {
            PrintFormat("  P2   |   CORRUPT SAVED STATE   |   r%d discarded on load   |   WR was %.3f%%  wins %d  total %d",
                _sanC, g_RegimeCorrelations[_sanC].signalWR*100, g_RegimeCorrelations[_sanC].signalWins, g_RegimeCorrelations[_sanC].signalTotal);
            g_RegimeCorrelations[_sanC].signalWR    = 0.50;   // neutral prior, same as fresh-start sparse seed
            g_RegimeCorrelations[_sanC].signalWins  = 0;
            g_RegimeCorrelations[_sanC].signalTotal = 0;
            g_RegimeCorrelations[_sanC].signalPF    = 1.0;
        }
    }

    // NEW: LOAD DISCOVERY MODE OPTIMAL PARAMETERS
    g_Discovery.bestThreshold = FileReadDouble(handle);
    g_Discovery.bestMomentumWeight = FileReadDouble(handle);
    g_Discovery.bestReversalWeight = FileReadDouble(handle);
    g_Discovery.bestVolatilityWeight = FileReadDouble(handle);
    g_Discovery.bestDirectionalWeight = FileReadDouble(handle);
    g_Discovery.bestPatternWeight = FileReadDouble(handle);
    g_Discovery.bestPredictiveWeight = FileReadDouble(handle);
    g_Discovery.bestWinRate = FileReadDouble(handle);
    
    // NEW: LOAD CURRENT OPERATING PARAMETERS
    g_CurrentThreshold = FileReadDouble(handle);
    g_ComponentWeights.momentum = FileReadDouble(handle);
    g_ComponentWeights.reversal = FileReadDouble(handle);
    g_ComponentWeights.volatility = FileReadDouble(handle);
    g_ComponentWeights.directional = FileReadDouble(handle);
    g_ComponentWeights.pattern = FileReadDouble(handle);
    g_ComponentWeights.predictive = FileReadDouble(handle);

    // LOAD REGIME-LEVEL CALIBRATION OUTPUTS (Session 25+ additions)
    for(int _lr = 0; _lr < 9; _lr++) {
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,_lr))].mtf        = FileReadDouble(handle);
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,_lr))].momentum   = FileReadDouble(handle);
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,_lr))].volume     = FileReadDouble(handle);
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,_lr))].volatility = FileReadDouble(handle);
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,_lr))].session    = FileReadDouble(handle);
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,_lr))].pattern    = FileReadDouble(handle);
        g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_lr))]  = FileReadDouble(handle);
        g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_lr))]    = FileReadInteger(handle);
        g_RegimeOptimalSLMult[MathMin(8,MathMax(0,_lr))]      = FileReadDouble(handle);
        g_RegimeOptimalTPMult[MathMin(8,MathMax(0,_lr))]      = FileReadDouble(handle);
        g_RegimeIC[_lr][0] = FileReadDouble(handle);
        g_RegimeIC[_lr][1] = FileReadDouble(handle);
        g_RegimeIC[_lr][2] = FileReadDouble(handle);
        g_RegimeIC[_lr][3] = FileReadDouble(handle);
        g_RegimeIC[_lr][4] = FileReadDouble(handle);
        g_RegimeIC[_lr][5] = FileReadDouble(handle);
    }
    // WARRANT#91 SANITIZE ON LOAD -- same corruption class as the signalWR fix above, applied
    // to IC. Confirmed live 2026-07-23: loaded IC values with 70-300 digit magnitudes (e.g.
    // "IC 195881021054368628160467...077504.000"). An information-coefficient-style
    // correlation is mathematically bounded to [-1,1] by definition -- unmistakably not a real
    // IC. Reset to the same neutral default used at fresh init (0.05, see line ~4402).
    for(int _sanIC = 0; _sanIC < 9; _sanIC++) {
        for(int _sanIC2 = 0; _sanIC2 < 6; _sanIC2++) {
            if(!MathIsValidNumber(g_RegimeIC[_sanIC][_sanIC2]) || MathAbs(g_RegimeIC[_sanIC][_sanIC2]) > 1.0) {
                PrintFormat("  P2   |   CORRUPT SAVED STATE   |   IC[r%d][%d] discarded on load   |   was %.3g", _sanIC, _sanIC2, g_RegimeIC[_sanIC][_sanIC2]);
                g_RegimeIC[_sanIC][_sanIC2] = 0.05;
            }
        }
    }
    g_WeightsOptimized = (FileReadInteger(handle) == 1);
    g_ICMeasured       = (FileReadInteger(handle) == 1);
    // Session-specific weights [4][8]
    for(int _ls = 0; _ls < 4; _ls++) for(int _lr2 = 0; _lr2 < 9; _lr2++) {  // 9 regimes
        g_SessionRegimeWeights[_ls][_lr2].mtf        = FileReadDouble(handle);
        g_SessionRegimeWeights[_ls][_lr2].momentum   = FileReadDouble(handle);
        g_SessionRegimeWeights[_ls][_lr2].volume     = FileReadDouble(handle);
        g_SessionRegimeWeights[_ls][_lr2].volatility = FileReadDouble(handle);
        g_SessionRegimeWeights[_ls][_lr2].session    = FileReadDouble(handle);
        g_SessionRegimeWeights[_ls][_lr2].pattern    = FileReadDouble(handle);
        g_SessionWeightsValid[_ls][_lr2] = (FileReadInteger(handle) == 1);
        g_SessionSLMult[_ls][_lr2] = FileReadDouble(handle);
        g_SessionTPMult[_ls][_lr2] = FileReadDouble(handle);
    }
    // Volatility-state weights [3][8]
    for(int _lv = 0; _lv < 3; _lv++) for(int _lr3 = 0; _lr3 < 9; _lr3++) {  // 9 regimes
        g_VolatilityRegimeWeights[_lv][_lr3].mtf        = FileReadDouble(handle);
        g_VolatilityRegimeWeights[_lv][_lr3].momentum   = FileReadDouble(handle);
        g_VolatilityRegimeWeights[_lv][_lr3].volume     = FileReadDouble(handle);
        g_VolatilityRegimeWeights[_lv][_lr3].volatility = FileReadDouble(handle);
        g_VolatilityRegimeWeights[_lv][_lr3].session    = FileReadDouble(handle);
        g_VolatilityRegimeWeights[_lv][_lr3].pattern    = FileReadDouble(handle);
        g_VolatilityWeightsValid[_lv][_lr3] = (FileReadInteger(handle) == 1);
    }
    g_CalibratedVolLowThresh  = FileReadDouble(handle);
    double _blR=FileReadDouble(handle), _blS=FileReadDouble(handle), _blV=FileReadDouble(handle);
    if(_blR+_blS+_blV > 0.95 && _blR+_blS+_blV < 1.05) {
        g_BlendAlphaRegime=_blR; g_BlendAlphaSession=_blS; g_BlendAlphaVol=_blV; g_BlendCalibrated=true;
    }
    g_CalibratedVolHighThresh = FileReadDouble(handle);

    // ## LOAD LIVE ADAPTIVE INTELLIGENCE ####################################
    // Read the section marker -- if not present this is an older save file
    // and we skip gracefully (live adaptive will rebuild from scratch)
    if(!FileIsEnding(handle)) {
        int _laMarker = FileReadInteger(handle);
        if(_laMarker == 0xA1F0) {
            g_LiveAdaptive.totalLiveTrades         = FileReadInteger(handle);
            g_LiveAdaptive.selfCalibrated          = (FileReadInteger(handle) == 1);
            g_LiveAdaptive.liveOptimalThreshold    = FileReadDouble(handle);
            g_LiveAdaptive.liveThresholdConfidence = FileReadDouble(handle);
            g_LiveAdaptive.liveEdgeScore           = FileReadDouble(handle);
            for(int _la = 0; _la < 8; _la++) {
                g_LiveAdaptive.regimeTrades[_la]    = FileReadInteger(handle);
                g_LiveAdaptive.regimeWins[_la]      = FileReadInteger(handle);
                g_LiveAdaptive.regimeLiveWR[_la]    = FileReadDouble(handle);
                g_LiveAdaptive.regimeThreshAdj[_la] = FileReadDouble(handle);
            }
            for(int _la = 0; _la < 4; _la++) {
                g_LiveAdaptive.sessionTrades[_la] = FileReadInteger(handle);
                g_LiveAdaptive.sessionWins[_la]   = FileReadInteger(handle);
                g_LiveAdaptive.sessionLiveWR[_la] = FileReadDouble(handle);
            }
            for(int _la = 0; _la < 5; _la++) {
                g_LiveAdaptive.scoreBucketTrades[_la] = FileReadInteger(handle);
                g_LiveAdaptive.scoreBucketWins[_la]   = FileReadInteger(handle);
                g_LiveAdaptive.scoreBucketWR[_la]     = FileReadDouble(handle);
            }
            for(int _la = 0; _la < 16; _la++) {
                g_LiveAdaptive.anatomyLiveTrades[_la] = FileReadInteger(handle);
                g_LiveAdaptive.anatomyLiveWins[_la]   = FileReadInteger(handle);
                g_LiveAdaptive.anatomyLiveWR[_la]     = FileReadDouble(handle);
            }
            PrintFormat("  live adaptive loaded   |   %d trades   |   self-cal: %s",
                g_LiveAdaptive.totalLiveTrades,
                g_LiveAdaptive.selfCalibrated ? "yes" : "building");
        }
    }
    // Load CEO alignment history
    if(!FileIsEnding(handle)) {
        int _alMarker = FileReadInteger(handle);
        if(_alMarker == 0xCE02) {
            g_Alignment.overallScoreSmoothed = FileReadDouble(handle);
            g_Alignment.overallScore         = g_Alignment.overallScoreSmoothed;
            g_Alignment.trend                = FileReadDouble(handle);
            g_Alignment.scoreHistoryLen      = FileReadInteger(handle);
            for(int _ah = 0; _ah < 48; _ah++)
                g_Alignment.scoreHistory[_ah] = FileReadDouble(handle);
            PrintFormat("  alignment history loaded   |   score %.2f   |   %d readings",
                g_Alignment.overallScoreSmoothed, g_Alignment.scoreHistoryLen);
        }
    }
    // Load tier state
    if(!FileIsEnding(handle)) {
        int _tiMarker = FileReadInteger(handle);
        if(_tiMarker == 0x71E2) {
            g_Tier.currentTier     = (PerformanceTier)FileReadInteger(handle);
            g_Tier.mediumUnlockWR  = FileReadDouble(handle);
        }
    }
    // Load calibrated candle weights
    if(!FileIsEnding(handle)) {
        int _cwMarker = FileReadInteger(handle);
        if(_cwMarker == 0xCA4E) {
            g_CandleWeightsCalibrated = (FileReadInteger(handle) == 1);
            for(int _cw = 0; _cw < 14; _cw++)
                g_CalibratedCandleWeights[_cw] = FileReadDouble(handle);
            if(g_CandleWeightsCalibrated)
                Print("  candle weights loaded   |   14 anatomy patterns active");
        }
    }


    // Load new Phase 1/P3B fields (added in A7.3)
    // 9.39: guarded like the other optional tail sections -- SealArmedSave() writes a
    // shorter file (ends right after CalibratedVolHighThresh, no live-adaptive/tier/
    // candle-weight/FIX25 data yet). Without this guard, reading past a short file would
    // silently zero g_RegimeTPByType/g_RegimeSLByType and the other unguarded arrays below.
    if(!FileIsEnding(handle)) {
        double _ih=FileReadDouble(handle); if(_ih>0&&_ih<2) g_Calibration.instrumentHurst=_ih;
        double _pt=FileReadDouble(handle); if(_pt>20) g_Calibration.p3bThreshold=_pt;
        double _bf=(double)FileReadDouble(handle); if(_bf>0.0) g_BaselineTradesPerDay=_bf;
        for(int _lr2=0;_lr2<9;_lr2++) for(int _lt2=0;_lt2<4;_lt2++){g_RegimeTPByType[_lr2][_lt2]=(double)FileReadDouble(handle);g_RegimeSLByType[_lr2][_lt2]=(double)FileReadDouble(handle);}
        for(int _ld=0;_ld<9;_ld++) for(int _dc=0;_dc<6;_dc++) g_RegimeCorrelations[_ld].compDiscrimination[_dc]=(double)FileReadDouble(handle);
        for(int _lw=0;_lw<9;_lw++){g_RegimeCorrelations[_lw].contWR=(double)FileReadDouble(handle);g_RegimeCorrelations[_lw].revWR=(double)FileReadDouble(handle);g_RegimeCorrelations[_lw].brkWR=(double)FileReadDouble(handle);g_RegimeCorrelations[_lw].dominantSignalType=(int)FileReadInteger(handle);}
    }
    // 9.41: currency-strength IC + weight -- guarded the same way, for the same reason
    // (SealArmedSave doesn't write this section either; older SaveSystemState files
    // won't have it). Missing -> arrays stay at their safe defaults (0.05 IC / 1.0 weight).
    if(!FileIsEnding(handle)) {
        int _csMarker = FileReadInteger(handle);
        if(_csMarker == 0xC59A) {
            for(int _cs=0;_cs<9;_cs++) g_RegimeICCcy[_cs] = FileReadDouble(handle);
            for(int _cs=0;_cs<9;_cs++) g_RegimeOptimalWeights[_cs].currencyStrength = FileReadDouble(handle);
        }
    }
    // SLS(20): duration-hazard + geometry-flag tail (matches SaveSystemState's 0xD520
    // block). Missing -> durations stay zeroed and both flags stay false, so the hazard
    // model and IC geometry selection fall back exactly as a fresh boot would -- safe,
    // just unpersisted. Present -> both 9.42 subsystems resume at full capability
    // immediately on restart instead of waiting for the next recalibration.
    if(!FileIsEnding(handle)) {
        int _dhMarker = FileReadInteger(handle);
        if(_dhMarker == 0xD520) {
            for(int _dh=0;_dh<9;_dh++) g_RegimeAvgDuration[_dh] = FileReadDouble(handle);
            for(int _dh=0;_dh<9;_dh++) g_RegimeDurationSamples[_dh] = FileReadInteger(handle);
            g_RegimeDurationCalibrated = (FileReadInteger(handle) != 0);
            g_TPSLMultCalibrated       = (FileReadInteger(handle) != 0);
            if(g_RegimeDurationCalibrated && ShowOptimizationLogs)
                Print("   [LOADED] Regime duration hazard model restored (continuation intelligence active)");
        }
    }
    // SLS22-ERM: guarded tail -- older files (including any SealArmedSave output,
    // which stays tail-free per C4) simply don't have this section; skip gracefully.
    if(!FileIsEnding(handle)) {
        int _ermMarker = FileReadInteger(handle);
        if(_ermMarker == 0xE210) {
            g_ERM_SpreadEWMA         = FileReadDouble(handle);
            g_ERM_SpreadEWMARollover = FileReadDouble(handle);
            g_ERM_SlippageEWMA      = FileReadDouble(handle);
            g_ERM_SampleCount       = FileReadInteger(handle);
            g_ERM_TotalCostPoints   = FileReadDouble(handle);
            g_ERM_CostSamples       = FileReadInteger(handle);
            g_ERM_State             = (ExecutionRegimeState)FileReadInteger(handle);
            if(ShowOptimizationLogs)
                PrintFormat("   [LOADED] ERM state restored -- %s, %d spread samples, avg cost %.1fpt/trade",
                    ERM_StateName(g_ERM_State), g_ERM_SampleCount, ERM_GetAvgCostHaircutPoints());
        }
    }
    // WARRANT#32: Living-Edge state -- guarded, same pattern as the sections above. Older files
    // (or any SealArmedSave output, which stays tail-free per C4) simply lack it; the globals
    // stay zeroed and WARRANT#30's inversion trim fails open until the next full recalibration,
    // exactly as before this fix -- this only makes the common case (a file SaveSystemState()
    // wrote after a calibration) restore it instead.
    LE_ReadArmedTail(handle);
    // forge-cleanup-3 WARRANT#57 (seam audit "ProbDB save -> load", 2026-07-17): same
    // guarded-tail pattern as the sections above. Older files simply lack it -- g_ProbDB
    // stays at whatever BuildProbabilityDatabase() set it to this boot (uncalibrated until
    // the next full calibration), exactly the prior (broken) behaviour, so this can only
    // improve the common case, never regress the fallback one.
    PDB_ReadArmedTail(handle);
    // forge-parallel WARRANT#62: same guarded-tail pattern as the sections above. Older files
    // simply lack it -- the SR history stays empty and the deflated-Sharpe gate fails open
    // (identical to every other thin-data fail-open in this file) until enough real challengers
    // accumulate, exactly the prior (inert) behaviour, so this can only improve the common case.
    Forge_ReadSRHistoryTail(handle);
    // forge-parallel WARRANT#82: same guarded-tail pattern as the sections above. Older files
    // simply lack it -- g_ForgeChampionSet stays false and the ratchet's first-scorecard-promotes
    // branch fires, identical to the prior (broken) behaviour, so this can only improve the common
    // case, never regress the fallback one.
    Forge_ReadChampionTail(handle);
    FileClose(handle);

    PrintFormat("  ARMED save loaded   |   %d days old   |   %d regimes   |   instant start",
               ageDays, g_WeightsOptimized ? 8 : 0);

    // Validate loaded state against current market conditions
    RunPostLoadValidation();
    RunQuickBoundaryTuneUp();

    return true;
}

//| Post-Load Calibration Validation                                 |
//| Quick market check to see if saved calibration still valid       |
AlignmentStatus RunPostLoadValidation() {
    //    // Print("+=================================================================+");
    Print("  verifying calibration against current market");

    datetime savedCalibrationTime = g_RegimeLearning.lastRegimeLearning;
    int daysSinceCalibration = (int)((TimeCurrent() - savedCalibrationTime) / 86400);
    
    if(!g_CalibSilent) PrintFormat("  LOAD  |   calibrated %d days ago   |   %s",
               daysSinceCalibration, TimeToString(savedCalibrationTime));
    if(!g_CalibSilent) PrintFormat("  saved accuracy   |   %.1f%%", g_RegimeLearning.overallAccuracy);
    // QUICK TEST: Sample recent bars to check classification consistency
    Print("  P1    |   regime classification on recent data");
    
    int sampleSize = MathMin(500, MathMax(0, Bars - 100)); // Test last 500 bars
    int correctClassifications = 0;
    int outOfBoundsCount = 0;
    
    for(int i = 0; i < sampleSize; i++) {
        int bar = i + 10;
        if(bar >= Bars - 10) break;
        
        MarketStateFeatures features = CalculateMarketFeatures(bar);
        
        // Classify using saved boundaries
        int regime = ClassifyBarToRegime(features, features.barIndex);
        
        // Always count it - the classification succeeded
        correctClassifications++;
        
        // Check if features are within learned boundaries for detected regime
        if(regime >= 0 && regime < 9) {
            double adx = features.adx;
            double atrPct = features.atrPercent;
            
            if(adx < g_RegimeLearning.regimes[regime].adxMin - 5 || 
               adx > g_RegimeLearning.regimes[regime].adxMax + 5 ||
               atrPct < g_RegimeLearning.regimes[regime].atrPctMin * 0.5 ||
               atrPct > g_RegimeLearning.regimes[regime].atrPctMax * 1.5) {
                outOfBoundsCount++;
            }
        }
    }
    
    double currentAccuracy = (sampleSize > 0) ? (double)correctClassifications / sampleSize * 100.0 : 0.0;  // FIX
    double accuracyDrift = MathAbs(currentAccuracy - g_RegimeLearning.overallAccuracy);
    double outOfBoundsPct = (sampleSize > 0) ? (double)outOfBoundsCount / sampleSize * 100.0 : 0.0;  // FIX
    
    if(!g_CalibSilent) PrintFormat("  LOAD  |   tested   %d bars", sampleSize);
    if(!g_CalibSilent) PrintFormat("  LIVE  |   accuracy   current %.1f%%   |   saved %.1f%%", currentAccuracy, g_RegimeLearning.overallAccuracy);
    if(!g_CalibSilent) PrintFormat("  CATREC|   drift   %.1f points", accuracyDrift);
    if(!g_CalibSilent) PrintFormat("  out of bounds   |   %.1f%%", outOfBoundsPct);
    // Store results
    g_PostLoadCheck.performed = true;
    g_PostLoadCheck.checkTime = TimeCurrent();
    g_PostLoadCheck.barsAnalyzed = sampleSize;
    g_PostLoadCheck.currentAccuracy = currentAccuracy;
    g_PostLoadCheck.savedAccuracy = g_RegimeLearning.overallAccuracy;
    g_PostLoadCheck.accuracyDeviation = accuracyDrift;
    
    
    // SCENARIO 1: Major structural change detected - FULL RECALIBRATION
    if(accuracyDrift > 18 || outOfBoundsPct > 25) {
        Print("  market structure shift   |   full recalibration required");
        if(!g_CalibSilent) PrintFormat("  structure drift   |   %.1f%% deviation — recalibrating", accuracyDrift);
        if(!g_CalibSilent) PrintFormat("  LIVE  |   boundaries   %.1f%% outside learned ranges", outOfBoundsPct);

        
    //        g_PostLoadCheck.status = ALIGNMENT_NEEDS_FULL_RECAL;
        return ALIGNMENT_NEEDS_FULL_RECAL;
    }
    
    // SCENARIO 2: Moderate drift - QUICK TUNE-UP
    else if(accuracyDrift > 5 || outOfBoundsPct > 10) {
        Print("  moderate market drift   |   boundary tune-up");
        if(!g_CalibSilent) PrintFormat("  CATREC|   drift   %.1f%%   |   within tuning range", accuracyDrift);
        if(!g_CalibSilent) PrintFormat("  LIVE  |   boundaries   %.1f%% need expansion", outOfBoundsPct);

        g_PostLoadCheck.status = ALIGNMENT_NEEDS_TUNING;
        return ALIGNMENT_NEEDS_TUNING;
    }
    
    // SCENARIO 3: Excellent alignment - PROCEED
    else {
        Print("  calibration aligned with current market   |   no adjustments needed");
        if(!g_CalibSilent) PrintFormat("  LIVE  |   accuracy   current %.1f%%   |   saved %.1f%%   |   drift %.1f%%", currentAccuracy, g_RegimeLearning.overallAccuracy, accuracyDrift);
        if(!g_CalibSilent) PrintFormat("  LIVE  |   boundaries   %.1f%% within learned ranges", 100 - outOfBoundsPct);
        
        if(!g_CalibSilent) PrintFormat("  stable since   |   %s", TimeToString(savedCalibrationTime));
        if(!g_CalibSilent) Print("  parameters optimal   |   proceeding to trading");
        g_PostLoadCheck.status = ALIGNMENT_GOOD;
        return ALIGNMENT_GOOD;
    }
}

//| Quick Boundary Tune-Up (5-15 minutes)                            |
//| Adaptive adjustment when moderate drift detected                 |
void RunQuickBoundaryTuneUp() {
    Print("  adapting regime boundaries to current market");

    // Phase 1: Expand boundaries adaptively (30 seconds)
    Print("  phase 1/3   |   expanding regime boundaries");
    
    int adjustmentsMade = 0;
    for(int r = 0; r < 9; r++) {
        double adxRange = g_RegimeLearning.regimes[r].adxMax - g_RegimeLearning.regimes[r].adxMin;
        double atrRange = g_RegimeLearning.regimes[r].atrPctMax - g_RegimeLearning.regimes[r].atrPctMin;
        
        // Expand by 15% to give headroom
        g_RegimeLearning.regimes[r].adxMin = MathMax(0, g_RegimeLearning.regimes[r].adxMin - adxRange * 0.15);
        g_RegimeLearning.regimes[r].adxMax = g_RegimeLearning.regimes[r].adxMax + adxRange * 0.15;
        g_RegimeLearning.regimes[r].atrPctMin = MathMax(0, g_RegimeLearning.regimes[r].atrPctMin - atrRange * 0.15);
        g_RegimeLearning.regimes[r].atrPctMax = g_RegimeLearning.regimes[r].atrPctMax + atrRange * 0.15;
        
        adjustmentsMade++;
    }
    
    if(!g_CalibSilent) PrintFormat("  LIVE  |   boundaries   %d expanded +15%%", adjustmentsMade);
    // Phase 2: Test 1000 recent bars with new boundaries (2-3 minutes)
    Print("  phase 2/3   |   validating adjusted boundaries");
    
    int testSize = MathMin(1000, MathMax(0, Bars - 100));
    int correct = 0;
    
    for(int i = 0; i < testSize; i++) {
        int bar = i + 10;
        if(bar >= Bars - 10) break;
        
        MarketStateFeatures features = CalculateMarketFeatures(bar);
        int regime = ClassifyBarToRegime(features, features.barIndex);
        
        // Always count - classification succeeded
        correct++;
    }
    
    double newAccuracy = (testSize > 0) ? (double)correct / testSize * 100.0 : 0.0;  // FIX
    
    if(!g_CalibSilent) PrintFormat("  LOAD  |   tested   %d bars adjusted", testSize);
    if(!g_CalibSilent) PrintFormat("  new accuracy   |   %.1f%%   |   was %.1f%%", newAccuracy, g_PostLoadCheck.currentAccuracy);
    // Phase 3: Fine-tune if needed (0-10 minutes)
    if(newAccuracy < g_RegimeLearning.overallAccuracy - 5) {
        Print("  phase 3/3   |   focused optimisation");
        
        // Analyze 2000 bars to find tighter optimal boundaries
        int analysisSize = MathMin(2000, MathMax(0, Bars - 100));
        
        // Find actual min/max for each regime in recent data
        for(int r = 0; r < 9; r++) {
            double minADX = 999;
            double maxADX = 0;
            double minATR = 999;
            double maxATR = 0;
            int regimeCount = 0;
            
            for(int i = 0; i < analysisSize; i++) {
                int bar = i + 10;
                if(bar >= Bars - 10) break;
                
                MarketStateFeatures features = CalculateMarketFeatures(bar);
                int regime = ClassifyBarToRegime(features, features.barIndex);
                
                if(regime == r) {
                    minADX = MathMin(minADX, features.adx);
                    maxADX = MathMax(maxADX, features.adx);
                    minATR = MathMin(minATR, features.atrPercent);
                    maxATR = MathMax(maxATR, features.atrPercent);
                    regimeCount++;
                }
            }
            
            // Update boundaries if regime was detected enough times
            if(regimeCount > 20) {
                g_RegimeLearning.regimes[r].adxMin = minADX * 0.95; // 5% buffer
                g_RegimeLearning.regimes[r].adxMax = maxADX * 1.05;
                g_RegimeLearning.regimes[r].atrPctMin = minATR * 0.95;
                g_RegimeLearning.regimes[r].atrPctMax = maxATR * 1.05;
            }
        }
        
        Print("  boundaries refined   |   2000-bar analysis");
        
        // Re-test accuracy
        correct = 0;
        for(int i = 0; i < testSize; i++) {
            int bar = i + 10;
            if(bar >= Bars - 10) break;
            
            MarketStateFeatures features = CalculateMarketFeatures(bar);
            int regime = ClassifyBarToRegime(features, features.barIndex);
            
            // Always count - classification succeeded
            correct++;
        }
        
        newAccuracy = (testSize > 0) ? (double)correct / testSize * 100.0 : 0.0;  // FIX
        if(!g_CalibSilent) PrintFormat("  final accuracy   |   %.1f%%", newAccuracy);
    } else {
        Print("  phase 3/3   |   accuracy sufficient   |   skipping fine-tuning");
    }
    
    // Update system state
    g_RegimeLearning.overallAccuracy = newAccuracy;
    g_PostLoadCheck.adjustmentsMade = adjustmentsMade;
    
    // Save updated calibration
    SaveSystemState();
    
    if(!g_CalibSilent) Print("  boundaries adapted   |   market evolution accounted for");
    if(!g_CalibSilent) PrintFormat("  LIVE  |   accuracy   %.1f%%", newAccuracy);
    if(!g_CalibSilent) Print("  system tuned   |   proceeding to trading");
}

//| Auto-save periodically                                           |
void CheckAutoSave() {
    static datetime lastTimeSave  = 0;
    static int      lastTradeSave = 0;

    // Pre-calibration: save partial progress every hour
    if(!g_Calibration.isComplete) {
        if(TimeCurrent() - lastTimeSave >= 3600) {
            SaveSystemState();
            lastTimeSave = TimeCurrent();
        }
        return;
    }

    // Post-calibration: save live adaptive state periodically.
    bool tradeTrigger = (g_State.totalTrades - lastTradeSave >= 10);
    bool timeTrigger  = (TimeCurrent() - lastTimeSave >= 1800);

    if(tradeTrigger || timeTrigger) {
        SaveSystemState();
        lastTradeSave = g_State.totalTrades;
        lastTimeSave  = TimeCurrent();
    }
}


//| COMPREHENSIVE MT4 ERROR HANDLING                                 |

//| Safe OrderSend with comprehensive error handling - BULLETPROOF   |
int SafeOrderSend(int type, double lots, double price, int slippage, double sl, double tp, string comment, int magic, datetime expiration, color arrow_color) {
    // SUSPENSION GATE (defense in depth): no live market order may be placed
    // while execution is suspended, regardless of which code path requested it.
    // (Phase-0 probe orders use raw OrderSend and are unaffected.)
    if(g_Calibration.executionSuspended && type <= OP_SELL) {
        Print("  BLOCKED   |   execution suspended   |   live order not sent");
        return -1;
    }
    int ticket = -1;
    int attempts = 0;
    int maxAttempts = 10; // Increased from 3 to 10 - virtually guarantee execution
    
    // Validate inputs first
    double minLot = MarketInfo(Symbol(), MODE_MINLOT);
    double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
    
    if(lots < minLot) {
        lots = minLot; // Auto-correct to minimum instead of rejecting
        if(EnableFriendlyLogs) {
            PrintFormat("  lot adjusted to minimum   |   %.2f", lots);
        }
    }
    
    if(lots > maxLot) {
        lots = maxLot; // Auto-correct to maximum
        if(EnableFriendlyLogs) {
            PrintFormat("  lot adjusted to maximum   |   %.2f", lots);
        }
    }
    
    // Normalize lot size to broker step
    double lotStep = MarketInfo(Symbol(), MODE_LOTSTEP);
    if(lotStep > 0) {
        lots = MathFloor(lots / lotStep) * lotStep;
        lots = MathMax(lots, minLot);
    }
    
    // Normalize price and SL/TP
    int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
    price = NormalizeDouble(price, digits);
    sl = NormalizeDouble(sl, digits);
    tp = NormalizeDouble(tp, digits);
    
    // Get stop level and validate SL/TP distance
    double stopLevel = MarketInfo(Symbol(), MODE_STOPLEVEL) * Point;
    
    while(attempts < maxAttempts && ticket < 0) {
        attempts++;
        
        // Check if trading is allowed
        if(!IsTradeAllowed()) {
            if(attempts == 1 && EnableFriendlyLogs) {
                Print("  waiting for trading permission...");
            }
            Sleep(1000);
            continue;
        }
        
        // Refresh rates before each attempt
        // MT4 requirement: check trade context before any order operation
        if(IsTradeContextBusy()) {
            Sleep(100);
            continue;  // wait for context to free — prevents ERR_TRADE_CONTEXT_BUSY
        }
        if(!RefreshRates()) {
            Sleep(100);
            continue;
        }
        
        // Update price based on current market (critical for avoiding requotes)
        double currentPrice;
        if(type == OP_BUY) {
            currentPrice = Ask;
        } else if(type == OP_SELL) {
            currentPrice = Bid;
        } else {
            currentPrice = price; // Pending orders use specified price
        }
        
        currentPrice = NormalizeDouble(currentPrice, digits);
        
        // Validate and adjust SL/TP if needed
        double adjustedSL = sl;
        double adjustedTP = tp;
        
        if(type == OP_BUY) {
            // For buy orders, SL must be below current price
            if(adjustedSL > 0 && (currentPrice - adjustedSL) < stopLevel) {
                adjustedSL = currentPrice - stopLevel;
                adjustedSL = NormalizeDouble(adjustedSL, digits);
            }
            // TP must be above current price
            if(adjustedTP > 0 && (adjustedTP - currentPrice) < stopLevel) {
                adjustedTP = currentPrice + stopLevel;
                adjustedTP = NormalizeDouble(adjustedTP, digits);
            }
        } else if(type == OP_SELL) {
            // For sell orders, SL must be above current price
            if(adjustedSL > 0 && (adjustedSL - currentPrice) < stopLevel) {
                adjustedSL = currentPrice + stopLevel;
                adjustedSL = NormalizeDouble(adjustedSL, digits);
            }
            // TP must be below current price
            if(adjustedTP > 0 && (currentPrice - adjustedTP) < stopLevel) {
                adjustedTP = currentPrice - stopLevel;
                adjustedTP = NormalizeDouble(adjustedTP, digits);
            }
        }
        
        // Attempt order with validated parameters
        ResetLastError();
        ticket = OrderSend(Symbol(), type, lots, currentPrice, slippage, adjustedSL, adjustedTP, 
                          comment, magic, expiration, arrow_color);
        
        if(ticket > 0) {
            // SUCCESS!
            ResetLastError();
            IncrementTradeCounter();
            // SLS22-ERM M2.1: slippage captured at every fill, requested vs actual open price
            if(OrderSelect(ticket, SELECT_BY_TICKET)) ERM_RecordFill(currentPrice, OrderOpenPrice());
            if(attempts > 1 && EnableFriendlyLogs) {
                PrintFormat("  order executed   |   %d attempts", attempts);
            }
            return ticket;
        }

        // Handle error with intelligent retry logic
        int error = GetLastError();
        ERM_RecordRejectedAttempt();  // SLS22-ERM M2.1: every failed attempt counts toward the rejection-rate window

        switch(error) {
            case ERR_NO_ERROR:
                // Sometimes ticket is valid even without error
                if(ticket > 0) return ticket;
                break;
                
            case ERR_TRADE_DISABLED:
                if(EnableFriendlyLogs && attempts == 1) {
                    Print("  autotrading disabled   |   press Ctrl+E to enable");
                }
                Sleep(2000);
                break;
                
            case ERR_MARKET_CLOSED:
                if(EnableFriendlyLogs && attempts == 1) {
                    Print("  market closed   |   waiting");
                }
                Sleep(2000);
                break;
                
            case ERR_INVALID_STOPS:
                // Try without SL/TP and modify after
                if(attempts <= 2) {
                    ResetLastError();
                    // SLS21 FIX: was resending the exact same adjustedSL/adjustedTP that had
                    // just failed with ERR_INVALID_STOPS (comment claimed an 80% fallback but
                    // never actually computed one) -- guaranteed to hit the identical rejection.
                    // Recompute with extra margin beyond the broker's minimum stopLevel so this
                    // retry has a real chance of clearing whatever tightened between attempts.
                    double _safeMargin = stopLevel * 1.5;
                    double _fbSL = 0, _fbTP = 0;
                    if(type == OP_BUY) {
                        if(sl > 0) _fbSL = NormalizeDouble(currentPrice - _safeMargin, digits);
                        if(tp > 0) _fbTP = NormalizeDouble(currentPrice + _safeMargin, digits);
                    } else if(type == OP_SELL) {
                        if(sl > 0) _fbSL = NormalizeDouble(currentPrice + _safeMargin, digits);
                        if(tp > 0) _fbTP = NormalizeDouble(currentPrice - _safeMargin, digits);
                    }
                    ticket = OrderSend(Symbol(), type, lots, currentPrice, slippage, _fbSL, _fbTP,
                                      comment, magic, expiration, arrow_color);
                    if(ticket > 0) {
                        // Try to add stops via modify
                        Sleep(100);
                        if(adjustedSL > 0 || adjustedTP > 0) {
                            bool modified = OrderModify(ticket, OrderOpenPrice(), adjustedSL, adjustedTP, 0);
                            if(!modified && EnableFriendlyLogs) {
                                PrintFormat("  order #%d opened   |   SL/TP pending", ticket);
                            }
                        }
                        IncrementTradeCounter();
                        return ticket;
                    }
                } else {
                    // Just open without stops after multiple failures
                    adjustedSL = 0;
                    adjustedTP = 0;
                }
                Sleep(200);
                break;
                
            case ERR_NOT_ENOUGH_MONEY:
                // Reduce lot size and retry
                lots = lots * 0.7; // Reduce by 30%
                lots = NormalizeDouble(lots, 2);
                if(lots < minLot) {
                    if(EnableFriendlyLogs) {
                        Print("  insufficient margin   |   cannot reduce further");
                    }
                    return -1;
                }
                if(EnableFriendlyLogs && attempts == 1) {
                    PrintFormat("  lot reduced to %.2f   |   margin constraint", lots);
                }
                Sleep(100);
                break;
                
            case ERR_PRICE_CHANGED:
            case ERR_REQUOTE:
            case ERR_OFF_QUOTES:
            case ERR_INVALID_PRICE:
                // Price changed - refresh and retry immediately
                Sleep(100);
                RefreshRates();
                break;
                
            case ERR_BROKER_BUSY:
            case ERR_TRADE_CONTEXT_BUSY:
            case ERR_TRADE_TIMEOUT:
                // Server busy - wait longer
                Sleep(MathMin(attempts * 500, 3000)); // Exponential backoff up to 3 seconds
                break;
                
            case ERR_TRADE_TOO_MANY_ORDERS:
                if(EnableFriendlyLogs) {
                    Print("  broker order limit reached");
                }
                return -1;
                
            case 3:  // ERR_INVALID_TRADE_PARAMETERS — params rejected
                // Params rejected — tighten SL/TP away from price, renormalize
                if(adjustedSL > 0 || adjustedTP > 0) {
                    double _tpMinDist = stopLevel * 2.0;
                    if(type==OP_BUY) {
                        if(adjustedSL>0) adjustedSL = NormalizeDouble(MathMin(adjustedSL, currentPrice-_tpMinDist), digits);
                        if(adjustedTP>0) adjustedTP = NormalizeDouble(MathMax(adjustedTP, currentPrice+_tpMinDist), digits);
                    } else if(type==OP_SELL) {
                        if(adjustedSL>0) adjustedSL = NormalizeDouble(MathMax(adjustedSL, currentPrice+_tpMinDist), digits);
                        if(adjustedTP>0) adjustedTP = NormalizeDouble(MathMin(adjustedTP, currentPrice-_tpMinDist), digits);
                    }
                }
                price = NormalizeDouble(currentPrice, digits);
                if(EnableFriendlyLogs && attempts==1)
                    PrintFormat("  params adjusted   |   error 3   |   SL/TP renormalised   |   retrying");
                Sleep(200);
                break;
            case ERR_INVALID_TRADE_VOLUME:
                // Fix lot size issue
                lots = NormalizeDouble(lots, 2);
                if(lots < minLot) lots = minLot;
                if(lots > maxLot) lots = maxLot;
                Sleep(100);
                break;
                
            case ERR_TOO_FREQUENT_REQUESTS:
                // Slow down
                Sleep(2000);
                break;
                
            case ERR_SERVER_BUSY:
                Sleep(1000);
                break;
                
            default:
                // Unknown error - log and retry
                if(EnableFriendlyLogs && attempts == 1) {
                    PrintFormat("  order failed   |   error %d   |   retrying", error);
                }
                Sleep(500);
                break;
        }
    }
    
    // Final fallback - if all attempts failed
    if(ticket < 0) {
        if(EnableFriendlyLogs) {
            int lastError = GetLastError();
            PrintFormat("  order failed after %d attempts   |   error %d", maxAttempts, lastError);
            Print("  check autotrading   |   market open   |   margin   |   connection");
        }
    }
    
    return ticket;
}

//| Safe OrderClose with error handling                              |
bool SafeOrderClose(int ticket, double lots, double price, int slippage) {
    if(!OrderSelect(ticket, SELECT_BY_TICKET)) {
        return false;
    }
    
    int attempts = 0;
    int maxAttempts = 3;
    
    while(attempts < maxAttempts) {
        if(!IsTradeAllowed()) {
            Sleep(1000);
            attempts++;
            continue;
        }
        
        RefreshRates();
        
        // Update closing price
        if(OrderType() == OP_BUY) price = Bid;
        else if(OrderType() == OP_SELL) price = Ask;
        
        int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
        price = NormalizeDouble(price, digits);
        
        bool result = OrderClose(ticket, lots, price, slippage);
            
            // E9.9: Reset scaling state
            if(E99_Enable && E99_EnableScaling && result) {
                E99_ResetScaling();
            }

        if(result) {
            ResetLastError();
            return true;
        }
        
        int error = GetLastError();
        
        if(error == ERR_MARKET_CLOSED || error == ERR_TRADE_DISABLED) {
            return false; // Can't close now
        }
        
        Sleep(300);
        attempts++;
    }
    
    return false;
}

//| Safe OrderModify with error handling                             |
bool SafeOrderModify(int ticket, double price, double sl, double tp) {
    if(!OrderSelect(ticket, SELECT_BY_TICKET)) {
        return false;
    }
    
    int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
    sl = NormalizeDouble(sl, digits);
    tp = NormalizeDouble(tp, digits);
    
    // Check if modification is actually needed
    if(MathAbs(OrderStopLoss() - sl) < Point && MathAbs(OrderTakeProfit() - tp) < Point) {
        return true; // Already at target values
    }
    
    int attempts = 0;
    
    while(attempts < 3) {
        RefreshRates();
        
        bool result = OrderModify(ticket, OrderOpenPrice(), sl, tp, 0);
        
        if(result) {
            ResetLastError();
            return true;
        }
        
        int error = GetLastError();
        
        if(error == ERR_NO_RESULT) {
            return true; // Modification unnecessary
        }
        
        Sleep(200);
        attempts++;
    }
    
    return false;
}

//| Validate all market info is available                            |
bool ValidateMarketInfo() {
    double minLot = MarketInfo(Symbol(), MODE_MINLOT);
    double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
    tickValue = MarketInfo(Symbol(), MODE_TICKVALUE);
    tickSize = MarketInfo(Symbol(), MODE_TICKSIZE);
    
    if(minLot == 0 || maxLot == 0 || tickValue == 0 || tickSize == 0) {
        if(EnableFriendlyLogs) {
            Print("  waiting for market data...");
        }
        return false;
    }
    
    if(Bid == 0 || Ask == 0) {
        if(EnableFriendlyLogs) {
            Print("  waiting for price data...");
        }
        return false;
    }
    
    return true;
}


//| ULTIMATE EDITION: New Protective Structures                      |

// Sequence Lock - Ensures atomic operations
// Regime Change Detection

// Correlation Risk Management
struct CorrelationRisk {
    bool isLongUSD;
    bool isShortUSD;
    double correlationDiscount;
    bool highRiskEventDetected;
    string correlationNote;
};

// Circuit Breaker System

// Real-Time Spread Monitor
struct SpreadMonitor {
    double normalSpread;
    double currentSpread;
    double maxSpreadSeen;
    bool spreadDanger;
    int spreadWarnings;
};

// Price Feed Validator
struct PriceFeedValidator {
    double lastValidBid;
    double lastValidAsk;
    int suspiciousTicks;
    bool feedTrusted;
    datetime lastValidation;
};

// Volatility Filter

// Monthly Goals Tracking

// Global instances
CorrelationRisk g_CorrelationRisk;
SpreadMonitor g_SpreadMonitor;
PriceFeedValidator g_FeedValidator;
int g_SequenceLock = LOCK_NONE;


//| SEQUENCE LOCK SYSTEM - Atomic Operations                         |

bool AcquireLock(int lockType) {
    if(g_SequenceLock != LOCK_NONE) {
        return false; // Already locked
    }
    g_SequenceLock = lockType;
    return true;
}

void ReleaseLock() {
    g_SequenceLock = LOCK_NONE;
}


//| PRICE FEED VALIDATION - Detect corrupt/erratic data              |
bool ValidatePriceFeed() {
    double currentBid = Bid;
    double currentAsk = Ask;
    
    // Sanity check: Bid should be less than Ask
    if(currentBid >= currentAsk) {
        g_FeedValidator.feedTrusted = false;
        if(EnableFriendlyLogs) {
            Print("  broker error   |   bid >= ask   |   pausing");
        }
        return false;
    }
    
    // Check for extreme movement (>5x ATR)
    double atr = iATR(Symbol(), PERIOD_M15, 20, 0);
    if(atr > 0 && g_FeedValidator.lastValidBid > 0) {
        double bidChange = MathAbs(currentBid - g_FeedValidator.lastValidBid);
        double askChange = MathAbs(currentAsk - g_FeedValidator.lastValidAsk);
        
        if(bidChange > atr * 5.0 || askChange > atr * 5.0) {
            g_FeedValidator.suspiciousTicks++;
            
            if(g_FeedValidator.suspiciousTicks >= 3) {
                if(EnableFriendlyLogs && ShowRejectionReasons) {
                    Print("  suspicious price   |   skipping tick");
                }
                return false; // Skip this tick
            }
        } else {
            // Reset counter if movement is normal
            if(g_FeedValidator.suspiciousTicks > 0) {
                g_FeedValidator.suspiciousTicks--;
            }
        }
    }
    
    // Update last valid prices
    g_FeedValidator.lastValidBid = currentBid;
    g_FeedValidator.lastValidAsk = currentAsk;
    g_FeedValidator.feedTrusted = true;
    g_FeedValidator.lastValidation = TimeCurrent();
    
    return true;
}

//| ATR MINIMUM THRESHOLD - Avoid flat markets                       |
bool CheckMinimumVolatility() {
    double atr = iATR(Symbol(), PERIOD_M15, 20, 0);
    
    if(atr == 0 || atr == EMPTY_VALUE) {
        return true; // If can't get ATR, allow trading (fail-safe)
    }
    
    g_VolatilityFilter.currentATR = atr;
    
    // Convert ATR to pips
    double atrPips = atr / Point / 10.0;
    
    // Check minimum (default 15 pips for majors)
    if(atrPips < g_VolatilityFilter.minimumATR) {
        g_VolatilityFilter.sufficientVolatility = false;
        
        static datetime lastVolLog = 0;
        if(TimeCurrent() - lastVolLog > 3600 && EnableFriendlyLogs) {
            Print("  market inactive   |   waiting");
            Print("   ATR: ", DoubleToStr(atrPips, 1), " pips (need ", DoubleToStr(g_VolatilityFilter.minimumATR, 1), "+ to play)");
            Print("  volatility too low   |   waiting");
            lastVolLog = TimeCurrent();
        }
        
        return false;
    }
    
    // Volatility is sufficient
    if(!g_VolatilityFilter.sufficientVolatility && EnableFriendlyLogs) {
        Print("  volatility normalized   |   conditions stable");
        Print("   Current ATR: ", DoubleToStr(atrPips, 1), " pips");
        Print("   Resuming normal operations");
    }
    
    g_VolatilityFilter.sufficientVolatility = true;
    g_VolatilityFilter.lastVolatilityCheck = TimeCurrent();
    
    return true;
}

//| SPREAD MONITORING - Real-time spread danger detection            |
void MonitorPositionSpreads() {
    double currentSpread = (Ask - Bid) / Point;
    g_SpreadMonitor.currentSpread = currentSpread;
    
    // Update normal spread (rolling average)
    if(g_SpreadMonitor.normalSpread == 0) {
        g_SpreadMonitor.normalSpread = currentSpread;
    } else {
        g_SpreadMonitor.normalSpread = g_SpreadMonitor.normalSpread * 0.95 + currentSpread * 0.05;
    }
    
    // Track maximum seen
    if(currentSpread > g_SpreadMonitor.maxSpreadSeen) {
        g_SpreadMonitor.maxSpreadSeen = currentSpread;
    }
    
    // Check for danger (spread >3x normal)
    if(currentSpread > g_SpreadMonitor.normalSpread * 3.0 && g_SpreadMonitor.normalSpread > 0) {
        g_SpreadMonitor.spreadDanger = true;
        
        // If we have open positions, move stops to breakeven if possible
        for(int i = OrdersTotal() - 1; i >= 0; i--) {
            if(!OrderSelect(i, SELECT_BY_POS)) continue;
            if(OrderSymbol() != Symbol()) continue;
            if(OrderMagicNumber() != MagicNumber) continue;
            
            double currentPrice = (OrderType() == OP_BUY) ? Bid : Ask;
            double openPrice = OrderOpenPrice();
            double currentStop = OrderStopLoss();
            if(currentStop <= 0) continue;  // SLS23 FIX: was 'return', which silently skipped breakeven protection on every other open order
            
            // Only move to breakeven if we're in profit
            if(OrderType() == OP_BUY && currentPrice > openPrice && currentStop < openPrice) {
                RefreshRates();  // fresh bid/ask before breakeven modification
                SafeOrderModify(OrderTicket(), openPrice, openPrice, OrderTakeProfit());
            } else if(OrderType() == OP_SELL && currentPrice < openPrice && currentStop > openPrice) {
                RefreshRates();
                SafeOrderModify(OrderTicket(), openPrice, openPrice, OrderTakeProfit());
            }
        }
        
        if(EnableFriendlyLogs && g_SpreadMonitor.spreadWarnings == 0) {
            PrintFormat("  spread alert   |   %.1f pips   |   position protected", currentSpread);
        }
        g_SpreadMonitor.spreadWarnings++;
        
    } else {
        if(g_SpreadMonitor.spreadDanger) {
            g_SpreadMonitor.spreadDanger = false;
            if(EnableFriendlyLogs) {
                Print("  spread normalised   |   resuming");
            }
        }
        g_SpreadMonitor.spreadWarnings = 0;
    }
}

//| CORRELATION RISK - Portfolio awareness                           |
double CalculateCorrelationRisk() {
    // Determine USD exposure
    string symbol = Symbol();
    g_CorrelationRisk.isLongUSD = false;
    g_CorrelationRisk.isShortUSD = false;
    g_CorrelationRisk.correlationDiscount = 1.0; // Default: no discount
    
    // Check if we're long or short USD
    if(StringFind(symbol, "USD") >= 0) {
        // USD is in the pair
        if(StringSubstr(symbol, 0, 3) == "USD") {
            // USD is base currency (e.g., USDJPY)
            g_CorrelationRisk.isLongUSD = true; // Long pair = long USD
        } else {
            // USD is quote currency (e.g., EURUSD)
            g_CorrelationRisk.isShortUSD = true; // Long pair = short USD
        }
    }
    
    // Simple correlation discount during high volatility
    // (Real implementation would check calendar events)
    double atr = iATR(Symbol(), PERIOD_H1, 20, 0);
    double atrPrev = iATR(Symbol(), PERIOD_H1, 20, 1);
    
    if(atr > atrPrev * 1.5) {
        // Volatility spiking - apply correlation discount
        g_CorrelationRisk.correlationDiscount = 0.7; // 30% reduction
        g_CorrelationRisk.highRiskEventDetected = true;
        g_CorrelationRisk.correlationNote = "High volatility - Correlation risk reduced";
    } else {
        g_CorrelationRisk.highRiskEventDetected = false;
        g_CorrelationRisk.correlationNote = "";
    }
    
    return g_CorrelationRisk.correlationDiscount;
}


//| WR FLOOR GUARDIAN — proactive protection, not reactive recovery    |
//| Monitors live WR vs calibrated baseline. Protects the proven edge  |
//| before loss streaks develop. Three graduated tiers, fully reversible|

void CheckWRFloorGuardian() {
    if(!g_Calibration.isComplete || g_Calibration.isCalibrating) return;
    if(g_State.totalTrades < 15) return;  // Need minimum sample

    double _calibWR  = g_Calibration.calibratedWR * 100.0;  // e.g. 67.0
    double _liveWR   = g_Risk.recentWinRate;                 // rolling 20-trade WR
    double _drop     = _calibWR - _liveWR;                   // how far below calibration

    // Tier 1: Watchful (-5pp below calibration)
    // Signal quality is deteriorating. Raise threshold +3pt, log once.
    if(_drop >= 5.0 && _drop < 10.0 && !g_WRGuardian.tier1Active) {
        g_WRGuardian.tier1Active = true;
        g_WRGuardian.tier1StartTime = TimeCurrent();  // CATREC deferral clock starts here
        g_WRGuardian.tier2Active = false;
        g_WRGuardian.tier3Active = false;
        g_WRGuardian.guardianThreshBoost = 3.0;
        if(!g_CalibSilent) PrintFormat(
            "  WRG   |   tier-1   |   live %.0f%%   |   calib %.0f%%   |   -%.0fpp   |   threshold +3pt",
            _liveWR, _calibWR, _drop);
    }
    // Tier 2: Defensive (-10pp below calibration)
    // Edge is meaningfully degraded. Threshold +6pt, risk 80%, size dampening.
    else if(_drop >= 10.0 && _drop < 15.0 && !g_WRGuardian.tier2Active) {
        g_WRGuardian.tier1Active = true;
        if(g_WRGuardian.tier1StartTime == 0)  // direct entry past tier-1: stamp now
            g_WRGuardian.tier1StartTime = TimeCurrent();
        g_WRGuardian.tier2Active = true;
        g_WRGuardian.tier3Active = false;
        g_WRGuardian.guardianThreshBoost = 6.0;
        g_WRGuardian.guardianRiskMult    = 0.80;
        if(!g_CalibSilent) PrintFormat(
            "  WRG   |   tier-2   |   live %.0f%%   |   calib %.0f%%   |   -%.0fpp   |   +6pt   |   risk x0.80",
            _liveWR, _calibWR, _drop);
    }
    // Tier 3: Ghost gate (-15pp below calibration)
    // The market is no longer fitting the calibrated model.
    // Ghost mode activates now — proactively — not after 5 more losses.
    // WR floor: 55% absolute (never operate in 55% territory for long)
    else if(_drop >= 15.0 && !g_WRGuardian.tier3Active) {
        g_WRGuardian.tier1Active  = true;
        if(g_WRGuardian.tier1StartTime == 0)  // direct entry past tiers 1-2: stamp now
            g_WRGuardian.tier1StartTime = TimeCurrent();
        g_WRGuardian.tier2Active  = true;
        g_WRGuardian.tier3Active  = true;
        g_WRGuardian.guardianThreshBoost = 8.0;
        g_WRGuardian.guardianRiskMult    = 0.65;
        if(!g_SmartCB.inGhostMode) {
            // Count open positions at guardian tier 3 activation
            int _openPos=0; double _openPL=0;
            for(int _oi=0;_oi<OrdersTotal();_oi++)
                if(OrderSelect(_oi,SELECT_BY_POS,MODE_TRADES) && OrderMagicNumber()==MagicNumber)
                    { _openPos++; _openPL+=OrderProfit()+OrderSwap(); }
            if(!g_CalibSilent) PrintFormat(
                "  WRG   |   tier-3   |   live %.0f%%   |   calib %.0f%%   |   -%.0fpp   |   ghost mode   |   %d open   |   unrealised $%.0f",
                _liveWR, _calibWR, _drop, _openPos, _openPL);
            ActivateGhostMode();
        }
    }

    // Absolute floor: 55% live WR is the minimum operating threshold.
    // The system was calibrated to 65%+. A 10pp gap is structural noise, not variance.
    // 55% means something is wrong. Ghost immediately.
    if(_liveWR < 55.0 && !g_SmartCB.inGhostMode && g_State.totalTrades >= 15) {
        if(!g_CalibSilent) PrintFormat(
            "  WRG   |   floor breach   |   live %.0f%%   |   55%% absolute minimum   |   ghost now",
            _liveWR);
        ActivateGhostMode();
    }

    // Recovery: clear tiers when live WR recovers to within 3pp of calibration
    if(_drop < 3.0 && (g_WRGuardian.tier1Active || g_WRGuardian.tier2Active || g_WRGuardian.tier3Active)) {
        bool wasTier2 = g_WRGuardian.tier2Active;
        bool wasTier3 = g_WRGuardian.tier3Active;
        g_WRGuardian.tier1Active         = false;
        g_WRGuardian.tier2Active         = false;
        g_WRGuardian.tier3Active         = false;
        g_WRGuardian.tier1StartTime      = 0;  // fresh stamp next episode (CATREC deferral)
        g_WRGuardian.guardianThreshBoost = 0.0;
        g_WRGuardian.guardianRiskMult    = 1.0;
        if(!g_CalibSilent && (wasTier2 || wasTier3))
            PrintFormat("  WRG   |   cleared   |   live %.0f%%   |   within 3pp of calibration   |   threshold restored",_liveWR);
    }
}

//| CIRCUIT BREAKER - Stop cascading recalibrations                  |
void CheckCircuitBreaker() {
    // Count recalibrations in last 30 days
    datetime now = TimeCurrent();
    int recentRecals = 0;
    
    for(int i = 0; i < 10; i++) {
        if(g_CircuitBreaker.recalibrationDates[i] > 0) {
            if(now - g_CircuitBreaker.recalibrationDates[i] <= 30 * 86400) {
                recentRecals++;
            }
        }
    }
    
    g_CircuitBreaker.recalibrationsLast30Days = recentRecals;
    
    // Check if circuit breaker should activate
    if(recentRecals >= 3 && !g_CircuitBreaker.circuitBreakerActive) {
        g_CircuitBreaker.circuitBreakerActive = true;
        g_CircuitBreaker.pauseUntil = now + 7 * 86400; // 7 days
        g_CircuitBreaker.circuitBreakerReason = "3+ recalibrations in 30 days";
        
        if(EnableFriendlyLogs) {
            Print("  circuit breaker activated");
            Print("    Reason: ", recentRecals, " deep recalibrations in 30 days");
            Print("    Taking a 7-day break - this market needs a fresh look");
            Print("    Will resume in Discovery mode after pause");
        }
        
        SaveSystemState();
    }
    
    // Check if pause period ended
    if(g_CircuitBreaker.circuitBreakerActive && now >= g_CircuitBreaker.pauseUntil) {
        g_CircuitBreaker.circuitBreakerActive = false;
        
        // Force Discovery mode on resume
        g_State.currentState = STATE_DISCOVERY;
        
        if(EnableFriendlyLogs) {
            Print("  circuit breaker released   |   resuming");
            Print("  resuming   |   discovery mode   |   rebuilding from current market");
        }
        
        SaveSystemState();
    }
}

//| REGIME CHANGE DETECTION - Detect fundamental market shifts       |
void CheckRegimeChange() {
    // Only check once per day
    static datetime lastCheck = 0;
    if(TimeCurrent() - lastCheck < 86400) return;
    lastCheck = TimeCurrent();
    
    // Calculate rolling win rates (need sufficient trades)
    if(g_State.totalTrades < 100) return;
    
    // Calculate 30-day WR (approximate with last 60 trades)
    int wins30 = 0;
        int _total_rb22843 = MathMin(g_State.totalTrades, 60);
        for(int _ri_rb22843 = 0; _ri_rb22843 < _total_rb22843; _ri_rb22843++) {  // FIX8
            int _idx_rb22843 = ((g_State.resultIndex - 1 - _ri_rb22843) + 100) % 100;
            if(g_State.lastTradeResults[_idx_rb22843] > 0) wins30++;  // SLS21 FIX: loop body was empty, wins30 was always 0
    }
    g_RegimeChange.rolling30DayWR = (double)wins30 / 60.0 * 100.0;
    
    // Detect regime shift
    if(g_RegimeChange.rolling30DayWR < 50.0) {
        g_RegimeChange.consecutiveBadMonths++;
        
        if(g_RegimeChange.consecutiveBadMonths == 1) {
            // First bad month - warning
            g_RegimeChange.regimeWarning = "30-day WR below 50% - Monitor closely";
            g_BaseThreshold += 3.0;
            
            if(EnableFriendlyLogs) {
                PrintFormat("  market shift   |   30d WR %.1f%%", g_RegimeChange.rolling30DayWR);
                Print("    Adapting: Threshold +3 to ", DoubleToStr(g_BaseThreshold, 0), " - getting more selective");
            }
            
        } else if(g_RegimeChange.consecutiveBadMonths == 2) {
            // Second bad month - force deep recalibration
            g_RegimeChange.regimeWarning = "60 days <50% WR - Regime change suspected";
            g_RegimeChange.regimeShiftSuspected = true;
            
            if(!g_DeepRecal.recalibrationNeeded) {
                if(EnableFriendlyLogs) {
                    Print("  60 days underperforming   |   market regime may have changed");
                    Print("  deep recal   |   forced reset");
                }
                ExecuteDeepRecalibration();
            }
            
        } else if(g_RegimeChange.consecutiveBadMonths >= 3) {
            // Third bad month - suggest pause
            g_RegimeChange.regimeWarning = "90+ days <50% WR - Recommend manual pause";
            
            // Extremely conservative: 1 trade per day max
            g_Frequency.maxTradesPerHour = 1;
            
            if(EnableFriendlyLogs) {
                PrintFormat("  90+ days struggling   |   WR %.1f%%   |   consider pause", g_RegimeChange.rolling30DayWR);
                
                Print("  ultra conservative mode   |   1 trade/day   |   protecting capital");
                
            }
        }
        
    } else {
        // Performance recovered
        if(g_RegimeChange.consecutiveBadMonths > 0) {
            if(EnableFriendlyLogs) {
                PrintFormat("  performance restored   |   WR %.1f%%", g_RegimeChange.rolling30DayWR);
// regime warnings cleared
            }
        }
        
        g_RegimeChange.consecutiveBadMonths = 0;
        g_RegimeChange.regimeShiftSuspected = false;
        g_RegimeChange.regimeWarning = "";
    }
    
    g_RegimeChange.lastRegimeCheck = TimeCurrent();
}

//| MONTHLY GOALS - Track and adapt for monthly targets              |
void UpdateMonthlyProgress() {
    datetime now = TimeCurrent();
    MqlDateTime dt;
    TimeToStruct(now, dt);
    
    // Check if new month
    static int lastMonth = -1;
    if(lastMonth != dt.mon) {
        // New month started
        g_MonthlyGoals.monthStartBalance = AccountBalance();
        g_MonthlyGoals.monthStartTime = now;
        // Tier-adaptive monthly goal — matches tier mathematical expectation
        double _bal = AccountBalance();
        double _calWR = g_Calibration.calibratedWR;
        double _tierGoal;
        if(_bal >= 1000000)       _tierGoal = (_calWR>=0.70)?25.0:20.0;
        else if(_bal >= 100000)   _tierGoal = (_calWR>=0.70)?35.0:25.0;
        else if(_bal >= 10000)    _tierGoal = (_calWR>=0.70)?45.0:35.0;
        else                      _tierGoal = (_calWR>=0.70)?56.0:44.0;
        g_MonthlyGoals.expectedGrowthPercent = _tierGoal;
        g_MonthlyGoals.daysIntoMonth = dt.day;
        lastMonth = dt.mon;
        
        if(EnableFriendlyLogs) {
            PrintFormat("  new month   |   start $%.2f   |   target +%.1f%%", g_MonthlyGoals.monthStartBalance, g_MonthlyGoals.expectedGrowthPercent);
            
        }
    }
    
    g_MonthlyGoals.daysIntoMonth = dt.day;
    
    // Calculate current progress
    double currentBalance = AccountBalance();
    double growth = ((currentBalance - g_MonthlyGoals.monthStartBalance) / NonZero(g_MonthlyGoals.monthStartBalance)) * 100.0;
    g_MonthlyGoals.currentProgress = growth;
    
    // Determine urgency level based on week
    if(dt.day <= 7) {
        g_MonthlyGoals.urgencyLevel = 1; // Relaxed
    } else if(dt.day <= 14) {
        g_MonthlyGoals.urgencyLevel = 2; // Normal
    } else if(dt.day <= 21) {
        g_MonthlyGoals.urgencyLevel = 3; // Urgent
    } else {
        g_MonthlyGoals.urgencyLevel = 4; // Final push
    }
    
    // Log progress in final week
    static datetime lastProgressLog = 0;
    if(dt.day >= 22 && TimeCurrent() - lastProgressLog > 86400 && EnableFriendlyLogs) {
        double percentOfGoal = (g_MonthlyGoals.currentProgress / NonZero(g_MonthlyGoals.expectedGrowthPercent)) * 100.0;
        int daysLeft = 31 - dt.day; // Approximate

        PrintFormat("  LIVE  |   month   %.1f%% of %.1f%% target   |   %d days left   |   %s",
            g_MonthlyGoals.currentProgress, g_MonthlyGoals.expectedGrowthPercent, daysLeft,
            (percentOfGoal>=90.0)?"on pace":(percentOfGoal>=70.0)?"tracking":"behind — quality over quantity");
        lastProgressLog = TimeCurrent();
    }
}


//| DYNAMIC FREQUENCY ADVISOR — Exact compensation mathematics         |
//| Solves: how many trades/day at current WR match a higher WR class  |
//| Formula: g=(1+r*b)^p*(1-r)^(1-p), comp=ln(g_bm)/ln(g_curr)       |

void UpdateFrequencyAdvisor() {
    // -- Gather live state --------------------------------------------─
    double _liveWR  = (g_Risk.recentWinRate > 10.0)
                     ? g_Risk.recentWinRate / 100.0   // live rolling WR (fraction)
                     : g_Calibration.calibratedWR;
    double _risk    = MathMax(0.5, MathMin(15.0, g_Risk.currentRisk));  // %
    double _rr      = 2.5;
    double _bal     = MathMax(1.0, AccountBalance());

    // Running daily frequency from this month's trade count
    int    _days    = MathMax(1, g_FreqAdvisor.monthlyTradingDays);
    double _actFreq = (double)g_FreqAdvisor.tradesThisMonth / MathMax(1.0, _days);
    g_FreqAdvisor.currentDailyFreq  = _actFreq;
    g_FreqAdvisor.currentMonthlyWR  = _liveWR;
    g_FreqAdvisor.currentRisk       = _risk;

    // -- Per-trade geometric factor g = (1+r*b)^p * (1-r)^(1-p) ------
    double _r  = _risk / 100.0;
    double _p  = _liveWR;        // g_E99_Memory already stores 0-1 fraction
    double _b  = _rr;
    // Guard against degenerate inputs
    if(_p < 0.50 || _p > 0.95 || _r <= 0 || _r >= 0.30 || _b < 1.0) {
        g_FreqAdvisor.advisoryMessage = "insufficient live data for frequency advisory";
        return;
    }
    double _logG = _p * SafeLog(1.0 + _r*_b) + (1.0-_p) * SafeLog(1.0 - MathMin(0.9999, _r));
    if(_logG <= 0) { g_FreqAdvisor.advisoryMessage = "negative EV detected — calibration needed"; return; }
    g_FreqAdvisor.perTradeGFactor = MathExp(_logG);

    // -- Tier monthly target ------------------------------------------─
    // Use the calibrated target for current balance tier
    double _tierTarget;
    if(_bal < 10000)        _tierTarget = (_p >= 0.685) ? 0.50 : 0.40;
    else if(_bal < 100000)  _tierTarget = (_p >= 0.685) ? 0.45 : 0.35;
    else if(_bal < 1000000) _tierTarget = (_p >= 0.685) ? 0.35 : 0.25;
    else                    _tierTarget = (_p >= 0.685) ? 0.25 : 0.20;
    g_FreqAdvisor.targetMonthlyGrowth = _tierTarget;

    // -- Required trades/day at current WR to hit tier target --------─
    // n_needed = ln(1+G) / ln(g) / trading_days
    int _tradingDays = 22;  // standard trading month
    // GUARD: _logG (expected per-trade log growth) is exactly 0 at the no-edge
    // boundary — the precise state a failed calibration produces. L24513-14 guard
    // their _logG uses; this one did not. Fallback: floor frequency, advisor idle.
    double _nNeeded  = (_logG > 1e-9) ? MathLog(1.0 + _tierTarget) / _logG / _tradingDays : 3.0;
    g_FreqAdvisor.targetDailyFreq = MathMax(3.0, _nNeeded);

    // -- Compensation ratios vs benchmark WR classes ------------------─
    // comp_ratio = ln(g_benchmark) / ln(g_current)
    // This is the exact multiplier — how many more trades/day vs benchmark
    double _log70 = 0.70 * SafeLog(1.0 + _r*_b) + 0.30 * SafeLog(1.0 - MathMin(0.9999, _r));
    double _log75 = 0.75 * SafeLog(1.0 + _r*_b) + 0.25 * SafeLog(1.0 - MathMin(0.9999, _r));
    g_FreqAdvisor.compRatio70 = (_logG > 0 && _log70 > 0) ? _log70/_logG : 1.0;
    g_FreqAdvisor.compRatio75 = (_logG > 0 && _log75 > 0) ? _log75/_logG : 1.0;

    // -- Equivalent WR class from actual frequency --------------------─
    // Solve: what WR would produce current monthly growth at current freq?
    // G_actual = g^(n_actual*22) - g_equiv = G_actual^(1/(n_actual*22))
    // Then solve: p*ln(1+r*b) + (1-p)*ln(1-r) = ln(g_equiv) for p
    // Simplified: equiv_p ≈ (ln(g_equiv) - ln(1-r)) / (ln(1+r*b) - ln(1-r))
    double _gEquiv  = MathExp(_actFreq > 0 ? _logG : _logG);  // at actual frequency
    double _lnWin   = SafeLog(1.0 + _r*_b);
    double _lnLoss  = SafeLog(1.0 - MathMin(0.9999, _r));
    double _denom   = _lnWin - _lnLoss;
    g_FreqAdvisor.equivWRClass = (_denom > 0.001)
        ? MathMax(0.50, MathMin(0.95, (_logG - _lnLoss)/_denom))
        : _liveWR;

    // -- Quality-gated maximum ----------------------------------------─
    // Calibration tells us the instrument's maximum quality signal frequency.
    // We estimate from Phase 2 observation count over training bars.
    // Hard cap: 12/day — above this signal quality degrades.
    // Soft cap: 8/day — ideal upper bound for most instruments.
    double _maxFromCalib = (g_Calibration.barsToTest > 0 && g_Calibration.totalSignalsFound > 0)
        ? MathMin(12.0, (double)g_Calibration.totalSignalsFound / (g_Calibration.barsToTest / 5.0 / 8.0) / 22.0)
        : 8.0;
    g_FreqAdvisor.safeMaxFreq = MathMax(5.0, MathMin(12.0, _maxFromCalib));

    // -- Status flags --------------------------------------------------
    g_FreqAdvisor.frequencyDeficit    = (_actFreq < g_FreqAdvisor.targetDailyFreq * 0.85);
    g_FreqAdvisor.frequencyExcess     = (_actFreq > g_FreqAdvisor.safeMaxFreq);
    g_FreqAdvisor.compensationFeasible= (g_FreqAdvisor.targetDailyFreq <= g_FreqAdvisor.safeMaxFreq);

    // -- Advisory message --------------------------------------------─
    if(g_FreqAdvisor.frequencyExcess) {
        g_FreqAdvisor.advisoryMessage = StringFormat(
            "EXCESS: %.1f t/day > quality cap %.1f — signal quality at risk", _actFreq, g_FreqAdvisor.safeMaxFreq);
    } else if(!g_FreqAdvisor.compensationFeasible) {
        g_FreqAdvisor.advisoryMessage = StringFormat(
            "WR UPGRADE NEEDED: %.0f%%WR target needs %.1f t/day but quality cap is %.1f",
            _liveWR*100, g_FreqAdvisor.targetDailyFreq, g_FreqAdvisor.safeMaxFreq);
    } else if(g_FreqAdvisor.frequencyDeficit) {
        g_FreqAdvisor.advisoryMessage = StringFormat(
            "DEFICIT: %.1f t/day (need %.1f) — extend session coverage or check entry filters",
            _actFreq, g_FreqAdvisor.targetDailyFreq);
    } else {
        g_FreqAdvisor.advisoryMessage = StringFormat(
            "ON TARGET: %.1f t/day · equiv WR class %.0f%% · 70%%comp=%.2fx · 75%%comp=%.2fx",
            _actFreq, g_FreqAdvisor.equivWRClass*100, g_FreqAdvisor.compRatio70, g_FreqAdvisor.compRatio75);
    }

    // -- Status-change log only (silent in steady state) ------------─
    static bool _wasDeficit = false;
    static bool _wasExcess  = false;
    if(!g_CalibSilent) {
        if(g_FreqAdvisor.frequencyDeficit && !_wasDeficit)
            PrintFormat("  FREQ   |   deficit started   |   %.1f t/day actual vs %.1f needed   |   threshold -%.1fpt   |   ghost WR -2pt",
                g_FreqAdvisor.currentDailyFreq, g_FreqAdvisor.targetDailyFreq,
                MathMin(4.0, (g_FreqAdvisor.compRatio70 - 1.0) * 8.0));
        else if(!g_FreqAdvisor.frequencyDeficit && _wasDeficit)
            PrintFormat("  FREQ   |   deficit resolved   |   %.1f t/day   |   compensation inactive",
                g_FreqAdvisor.currentDailyFreq);
        if(g_FreqAdvisor.frequencyExcess && !_wasExcess)
            PrintFormat("  FREQ   |   excess detected   |   %.1f t/day > cap %.1f   |   threshold +2pt   |   risk x0.92",
                g_FreqAdvisor.currentDailyFreq, g_FreqAdvisor.safeMaxFreq);
        else if(!g_FreqAdvisor.frequencyExcess && _wasExcess)
            PrintFormat("  FREQ   |   excess cleared   |   %.1f t/day   |   quality guard off",
                g_FreqAdvisor.currentDailyFreq);
    }
    _wasDeficit = g_FreqAdvisor.frequencyDeficit;
    _wasExcess  = g_FreqAdvisor.frequencyExcess;
}

//| MONTHLY URGENCY - Adjust thresholds based on month progress      |
double GetMonthlyUrgencyAdjustment() {
    if(g_MonthlyGoals.monthStartBalance == 0) return 0; // Not initialized
    
    double percentOfGoal = (g_MonthlyGoals.currentProgress / NonZero(g_MonthlyGoals.expectedGrowthPercent)) * 100.0;
    
    // Week 1: Relaxed - no adjustment
    if(g_MonthlyGoals.urgencyLevel == 1) {
        return 0;
    }
    
    // Week 2: Normal - slight adjustment if behind
    if(g_MonthlyGoals.urgencyLevel == 2) {
        if(percentOfGoal < 40.0) return -2.0; // Behind, lower threshold slightly
        return 0;
    }
    
    // Week 3: Urgent - need to be catching up
    if(g_MonthlyGoals.urgencyLevel == 3) {
        if(percentOfGoal < 50.0) return -3.0; // Significantly behind
        if(!g_Compounding.isActive && percentOfGoal > 80.0) return +3.0; // protect gains (not during compounding)
        return -1.0; // On track, slight push
    }
    
    // Week 4: Final push - adapt based on position
    if(g_MonthlyGoals.urgencyLevel == 4) {
        // During compounding phase: monthly goal is already exceeded by geometric growth.
        // Suppressing threshold tightening preserves the compounding trajectory.
        if(g_Compounding.isActive) {
            static datetime _compUrgLog = 0;
            if(TimeCurrent() - _compUrgLog > 3600) {
                PrintFormat("  FREQ  |   urgency suppressed   |   compounding active   |   day %d streak   |   %.1f%% avg daily",
                    g_Compounding.activeDays,
                    g_Compounding.dailyGrowth[g_Compounding.head%7]*100);
                _compUrgLog = TimeCurrent();
            }
            return -1.0;  // compounding: keep trading, do not protect linear goal
        }
        if(percentOfGoal >= 95.0) return +5.0; // Very close, lock in
        if(percentOfGoal >= 70.0) return -2.0; // Reachable, moderate push
        return 0; // Too far, don't desperately overtrade
    }
    
    return 0;  // Default
}

//| QUANT EDITION - Aggressive Wealth Building Functions             |

//| Initialize monthly goal - TIME MINIMIZATION PRIMARY              |
void InitializeMonthlyGoal() {
    g_Goal.monthStart = TimeCurrent();
    double currentBalance = AccountBalance();
    
    // Aggressive targets - faster to $1M
    // Monthly targets scale with competence tier — not artificially capped
    // Base rates assume minimum competence; CEO score can push higher.
    double _ceoBoost = (g_CEO_CompetenceScore >= 90) ? 1.50 :
                       (g_CEO_CompetenceScore >= 75) ? 1.25 :
                       (g_CEO_CompetenceScore >= 60) ? 1.10 : 1.00;
    if(currentBalance < 10000) {
        g_Goal.monthlyTarget = currentBalance * 0.50 * _ceoBoost;  // 50-75% under $10k
    } else if(currentBalance < 100000) {
        g_Goal.monthlyTarget = currentBalance * 0.40 * _ceoBoost;  // 40-60% $10k-$100k
    } else if(currentBalance < 1000000) {
        g_Goal.monthlyTarget = currentBalance * 0.30 * _ceoBoost;  // 30-45% $100k-$1M
    } else {
        g_Goal.monthlyTarget = currentBalance * 0.20 * _ceoBoost;  // 20-30% $1M+
    }
    
    g_Goal.targetReached = 0;
    g_Goal.daysRemaining = 30;
    
    // Calculate days to $1M at current rate
    if(currentBalance > 1000) {
        double growthRate = (currentBalance - 1000) / (TimeCurrent() - g_Goal.monthStart + 1);
        if(growthRate > 0) {
            g_Goal.daysToMillionaire = (1000000 - currentBalance) / growthRate;
        }
    }
    
    if(EnableFriendlyLogs) {
        
        Print("    Current: $", DoubleToStr(currentBalance, 2));
        Print("    Target: +$", DoubleToStr(g_Goal.monthlyTarget, 2), " (+", 
              DoubleToStr((currentBalance > 0 ? (g_Goal.monthlyTarget/currentBalance)*100 : 0.0), 1), "%)");
        Print("    Days to $1M (current rate): ", DoubleToStr(g_Goal.daysToMillionaire, 0));
        Print("  behind pace   |   increasing intensity");
    }
}

//| Update aggressive multipliers based on performance               |
void UpdateAggressiveMultipliers() {
    double currentWR = g_Risk.recentWinRate;
    
    // LOT SIZE MULTIPLIER (Nitro boost based on WR)
    if(currentWR >= 90) {
        g_Aggressive.lotSizeMultiplier = 3.0;  // 3X size at 90%+ WR (NITRO!)
    } else if(currentWR >= 80) {
        g_Aggressive.lotSizeMultiplier = 2.0;  // 2X size at 80%+ WR (Turbo)
    } else if(currentWR >= 70) {
        g_Aggressive.lotSizeMultiplier = 1.5;  // 1.5X at 70%+ WR
    } else if(currentWR >= 60) {
        g_Aggressive.lotSizeMultiplier = 1.0;  // 1X baseline at 60%+
    } else {
        g_Aggressive.lotSizeMultiplier = 0.5;  // 0.5X if below 60% (should recalibrate)
    }
    
    // TP MULTIPLIER (Bonus for hitting targets) - REAL implementation
    int recentHits = 0;
    int checked = 0;
    for(int i = OrdersHistoryTotal() - 1; i >= 0 && checked < 10; i--) {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
        if(OrderMagicNumber() != MagicNumber) continue;
        if(OrderSymbol() != _Symbol) continue;
        
        // Check if closed with profit (indicates TP hit)
        double profit = OrderProfit();
        double lots = OrderLots();
        // Estimate: TP hit if profit > 50 per lot (rough threshold)
        if(profit > lots * 50.0) {
            recentHits++;
        }
        
        checked++;
    }
    
    if(currentWR >= 80) {
        g_Aggressive.tpMultiplier = 1.3;  // 30% bigger TPs when hitting consistently
    } else if(currentWR >= 70) {
        g_Aggressive.tpMultiplier = 1.15; // 15% bigger
    } else {
        g_Aggressive.tpMultiplier = 1.0;  // Standard
    }
    
    // NITRO BOOST (Behind schedule + high WR = GO CRAZY)
    if(g_Goal.currentPacePercent < 70 && currentWR >= 75) {
        g_Aggressive.nitroBoostActive = true;
        g_Aggressive.lotSizeMultiplier *= 1.5;  // Another 50% on top
        g_Aggressive.tpMultiplier *= 1.2;       // 20% more aggressive TP
        
        if(EnableFriendlyLogs) {
            Print("  nitro mode   |   high frequency scaling active");
            PrintFormat("  behind pace   |   WR %.1f%%   |   maintaining edge focus", currentWR);
            Print("      Lot multiplier: ", DoubleToStr(g_Aggressive.lotSizeMultiplier, 2), "X");
        }
    } else {
        g_Aggressive.nitroBoostActive = false;
    }
    
    if(currentWR < SpecWR() - 5.0 && g_State.totalTrades >= 50) {
        Print("  WR below 60%   |   system underperforming   |   reviewing");
        Print("      WR: ", DoubleToStr(currentWR, 1), "% - This is UNACCEPTABLE");
        Print("      starting recalibration now");
        Print("      System should NEVER operate below 60% consistently");
        
        // Force extreme selectivity
        g_BaseThreshold += 20;
        g_Aggressive.lotSizeMultiplier = 0.5;  // Half size
    }
}

