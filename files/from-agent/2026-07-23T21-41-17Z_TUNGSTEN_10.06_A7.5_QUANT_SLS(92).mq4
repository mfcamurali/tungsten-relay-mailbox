//| Light Ghost System - Quick recalibration for minor drawdowns     |
struct LightGhostSystem {
    bool isActive;
    bool isComplete;
    int barsScanned;
    int tradesSimulated;
    double currentThreshold;
    double bestThreshold;
    double bestWR;
    int currentRegime;
    datetime startTime;
};

//| Component Weight Profiles for Different Market Conditions        |
enum WeightProfile {
    WEIGHT_MOMENTUM_HEAVY,    // Trending markets - momentum rules
    WEIGHT_STRUCTURE_HEAVY,   // Ranging markets - support/resistance rules
    WEIGHT_BALANCED,          // Transition/unclear - equal weights
    WEIGHT_CURRENT            // Keep current weights
};

// Apply weight profile to component weights array
void ApplyWeightProfile(WeightProfile profile, double &weights[]) {
    if(ArraySize(weights) < 10) return;
    
    if(profile == WEIGHT_MOMENTUM_HEAVY) {
        // Trending market weights - favor momentum indicators
        weights[0] = 1.5;  // Component 0: Momentum
        weights[1] = 1.8;  // Component 1: Directional (ADX)
        weights[2] = 1.2;  // Component 2: Volatility
        weights[3] = 0.6;  // Component 3: Reversal
        weights[4] = 0.7;  // Component 4: Pattern
        weights[5] = 1.0;  // Component 5: Predictive
        weights[6] = 0.8;  // Component 6: Volume
        weights[7] = 0.9;  // Component 7: Trend
        weights[8] = 0.8;  // Component 8: Market memory
        weights[9] = 1.1;  // Component 9: Intelligence
        
    } else if(profile == WEIGHT_STRUCTURE_HEAVY) {
        // Ranging market weights - favor structure indicators
        weights[0] = 0.7;  // Component 0: Momentum (less important)
        weights[1] = 0.5;  // Component 1: Directional (less important)
        weights[2] = 0.8;  // Component 2: Volatility
        weights[3] = 1.8;  // Component 3: Reversal (VERY important in ranges)
        weights[4] = 1.6;  // Component 4: Pattern (VERY important in ranges)
        weights[5] = 1.0;  // Component 5: Predictive
        weights[6] = 1.2;  // Component 6: Volume
        weights[7] = 0.6;  // Component 7: Trend (less important)
        weights[8] = 1.3;  // Component 8: Market memory
        weights[9] = 1.4;  // Component 9: Intelligence
        
    } else if(profile == WEIGHT_BALANCED) {
        // Balanced weights - all equal
        for(int i = 0; i < 10; i++) {
            weights[i] = 1.0;
        }
        
    } else if(profile == WEIGHT_CURRENT) {
        // Keep existing weights (already set by system)
        // Don't modify
    }
}

