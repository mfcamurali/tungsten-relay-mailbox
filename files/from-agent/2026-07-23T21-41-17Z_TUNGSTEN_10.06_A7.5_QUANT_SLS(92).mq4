// --─ Signal decision types ------------------------------------------─
enum MarketDecision {
    DECISION_BUY,           // Strong conviction to buy
    DECISION_SELL,          // Strong conviction to sell
    DECISION_WAIT,          // Insufficient clarity - wait
    DECISION_CONFLICTED     // Mixed signals - dangerous
};

// --─ Intelligent assessment structure ----------------------------------
struct IntelligentAssessment {
    MarketDecision decision;
    double confidence;
    string reasoning;
    string concerns;
    string strengths;
    
    bool momentumSupports;
    bool directionalSupports;
    bool reversalSupports;
    bool volatilitySupports;
    bool patternSupports;
    bool predictiveSupports;
    
    double distanceFromThreshold;
    bool nearResistance;
    bool nearSupport;
    int regime;
    double regimeConfidence;
    
    bool shouldTrade;
    double adjustedScore;
};

