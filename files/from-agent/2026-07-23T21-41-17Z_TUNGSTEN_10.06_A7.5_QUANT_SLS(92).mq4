        case REJ_EDGE_TOO_WEAK: return "EDGE_TOO_WEAK";
        case REJ_RISK_BLOCK:    return "RISK_BLOCK";
        case REJ_THROTTLED:     return "THROTTLED";
        case REJ_INTEL_WARN:    return "INTEL_WARN";
        case REJ_NONE:          return "NONE";
        default:                return "UNSPECIFIED";
    }
}
