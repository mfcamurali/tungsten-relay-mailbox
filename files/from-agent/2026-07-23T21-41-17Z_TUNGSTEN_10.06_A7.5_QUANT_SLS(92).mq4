//| Initialize Phase Diagnostic                                      |

// ========================================================================
// PHASE RETRY INTELLIGENCE ENGINE (PRI)
// ========================================================================
// Purpose: When a calibration phase fails to meet its quality target,
//          PRI reverse-engineers the gap and constructs a targeted
//          structural correction for the next attempt.
//
// Philosophy:
//   - Retry 1: identify and fix the specific bottleneck
//   - Retry 2: relax the secondary constraint (not the quality floor)
//   - Retry 3: best-effort arm — never block, always produce a usable result
//
// Each phase has three distinct retry strategies.
// After all retries are exhausted, the system arms at whatever confidence
// the best attempt achieved. Calibration never halts.

struct PRIPhaseState {
    int     attempt;            // 0 = first run, 1-3 = retries
    double  bestWR;             // Best WR seen across all attempts
    double  bestThreshold;      // Threshold that produced bestWR
    int     bestTrades;         // Trade count at best WR
    double  measuredGap;        // bestWR - targetWR (negative = shortfall)
    bool    sessionRestricted;  // Whether session restriction was applied
    bool    thresholdLowered;   // Whether threshold was already loosened
    bool    obsRelaxed;         // Whether min-observation floor was relaxed
    bool    armedWithBest;      // Whether we armed with less-than-ideal result
    string  lastStrategy;       // Description of last retry strategy applied
};

PRIPhaseState g_PRI[7];  // Indexed by phase number (1-6, index 0 unused)

// ========================================================================
// SIGNAL OUTCOME MONITOR (SOM)
// ========================================================================
// Two jobs:
//   A) Near-miss wins: signals that were REJECTED but price moved in the
//      right direction — evidence the threshold is too conservative.
//   B) Near-pass losses: signals that were TAKEN with marginal scores and
//      LOST — evidence the threshold is too permissive.
// After each outcome resolves, SOM feeds the result into:
//   - liveOptimalThreshold (nudge ±1pt per event)
//   - OWA (synthetic trade update for components that were right)
//   - PLDS self-calibration (was the risk signal accurate?)
// This creates the bidirectional feedback loop that prevents both
// "wins left on the table" (threshold too high) and "avoidable losses"
// (threshold too low).

#define SOM_SLOTS 30  // ring buffer

struct SOMSignal {
    datetime entryTime;    // when the signal fired
    double   entryPrice;   // price at signal time
    double   score;        // signal score (raw CEUS)
    double   threshold;    // threshold at the time
    bool     isBuy;        // direction
    int      regime;       // market state
    double   atr;          // ATR at signal time
    bool     wasExecuted;  // true = taken, false = rejected
    bool     resolved;     // have we checked the outcome?
    bool     wasCorrect;   // if resolved: did price move in the right direction?
    int      barsResolved; // how many bars we waited
    double   nearMissRatio; // score/threshold — 1.0 = exactly at threshold
};

SOMSignal g_SOM[SOM_SLOTS];
int g_SOM_Idx     = 0;
int g_SOM_Count   = 0;

// Running tally of near-miss outcomes for threshold nudging
double g_SOM_NearMissWins    = 0;  // rejected signals that would have won
double g_SOM_NearMisses      = 0;  // total rejected near-miss signals resolved
double g_SOM_NearPassLosses  = 0;  // marginal executions that lost
double g_SOM_NearPasses      = 0;  // total marginal executions resolved
// Self-calibration accuracy: PLDS risk vs actual loss rate
double g_SOM_PLDSHighRiskCalls = 0;
double g_SOM_PLDSHighRiskLosses = 0;  // PLDS called high risk - actual loss
double g_SOM_PLDSLowRiskCalls  = 0;
double g_SOM_PLDSLowRiskLosses = 0;   // PLDS called low risk - actual loss

void SOM_RecordSignal(double score, double threshold, bool isBuy, int regime,
                      double entryPrice, double atr, bool wasExecuted) {
    if(atr <= 0) return;
    double ratio = threshold > 0 ? MathAbs(score) / threshold : 1.0;
    // Only track near events: executed signals with score < 1.15x threshold
    // or rejected signals with score > 0.82x threshold
    bool isNearMiss  = (!wasExecuted && ratio >= 0.82);
    bool isNearPass  = ( wasExecuted && ratio <= 1.15);
    if(!isNearMiss && !isNearPass) return;

    g_SOM[g_SOM_Idx].entryTime    = TimeCurrent();
    g_SOM[g_SOM_Idx].entryPrice   = entryPrice;
    g_SOM[g_SOM_Idx].score        = score;
    g_SOM[g_SOM_Idx].threshold    = threshold;
    g_SOM[g_SOM_Idx].isBuy        = isBuy;
    g_SOM[g_SOM_Idx].regime       = regime;
    g_SOM[g_SOM_Idx].atr          = atr;
    g_SOM[g_SOM_Idx].wasExecuted  = wasExecuted;
    g_SOM[g_SOM_Idx].resolved     = false;
    g_SOM[g_SOM_Idx].wasCorrect   = false;
    g_SOM[g_SOM_Idx].barsResolved = 0;
    g_SOM[g_SOM_Idx].nearMissRatio= ratio;
    g_SOM_Idx = (g_SOM_Idx + 1) % SOM_SLOTS;
    if(g_SOM_Count < SOM_SLOTS) g_SOM_Count++;
}

// Called once per bar — resolves pending SOM signals
void SOM_ResolvePending() {
    if(!g_WeightsOptimized || g_SOM_Count == 0) return;
    int _reg = g_RegimeState.currentRegime;
    if(_reg < 0 || _reg >= 9) return;

    // Resolution horizon: same as the regime's optimal exit bars
    int resolveHorizon = (g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_reg))] > 0)
                         ? g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_reg))] : 15;

    double _curPrice = Bid;
    double _atr0 = iATR(Symbol(), 0, 14, 1);
    if(_atr0 <= 0) return;

    int resolved_this_bar = 0;

    for(int i = 0; i < SOM_SLOTS; i++) {
        if(g_SOM[i].resolved || g_SOM[i].entryTime == 0) continue;

        int barsSince = (int)((TimeCurrent() - g_SOM[i].entryTime) /
                               PeriodSeconds(PERIOD_CURRENT));
        g_SOM[i].barsResolved = barsSince;

        if(barsSince < resolveHorizon) continue;

        // Resolve: check if price moved in the right direction by ≥ 0.5 ATR
        double priceDelta = _curPrice - g_SOM[i].entryPrice;
        bool movedRight = g_SOM[i].isBuy ? (priceDelta > g_SOM[i].atr * 0.50)
                                          : (priceDelta < -g_SOM[i].atr * 0.50);

        g_SOM[i].resolved   = true;
        g_SOM[i].wasCorrect = movedRight;
        resolved_this_bar++;

        int sig_regime = g_SOM[i].regime;
        if(sig_regime < 0 || sig_regime >= 9) sig_regime = _reg;

        if(!g_SOM[i].wasExecuted) {
            // -- NEAR-MISS: signal was REJECTED --------------------------─
            g_SOM_NearMisses++;
            if(movedRight) {
                g_SOM_NearMissWins++;
                // Win left on the table - nudge threshold down
                if(!g_Calibration.isCalibrating &&  // never adjust during recal
                   g_LiveAdaptive.liveOptimalThreshold > 52.0) {
                    g_LiveAdaptive.liveOptimalThreshold -= 1.0;
                    g_CurrentThreshold = MathMax(48.0, g_CurrentThreshold - 0.5);
                }
                // OWA synthetic win: reinforce the components that were high
                OWA_ApplyPostTradeLearning(sig_regime, true);
                if(!g_CalibSilent && EnableFriendlyLogs)
                    PrintFormat("  SOM   |   near-miss win     score %.0f (thr %.0f)   |   %s   |   threshold nudged",
                        g_SOM[i].score, g_SOM[i].threshold, GetRegimeName(sig_regime));
            }
            // Near-miss loss: gate was right — no adjustment needed
        } else {
            // -- NEAR-PASS: marginal signal was EXECUTED ------------------─
            g_SOM_NearPasses++;
            if(!movedRight) {
                g_SOM_NearPassLosses++;
                // Avoidable loss - nudge threshold up
                if(!g_Calibration.isCalibrating &&  // never adjust during recal
                   g_LiveAdaptive.liveOptimalThreshold < 82.0) {
                    g_LiveAdaptive.liveOptimalThreshold += 1.5;
                    g_CurrentThreshold = MathMin(88.0, g_CurrentThreshold + 0.75);
                }
                if(!g_CalibSilent && EnableFriendlyLogs)
                    PrintFormat("  SOM   |   near-pass loss    score %.0f (thr %.0f)   |   %s   |   threshold tightened",
                        g_SOM[i].score, g_SOM[i].threshold, GetRegimeName(sig_regime));
            }
            // Near-pass win: marginal signal worked — no adjustment needed
        }

        if(resolved_this_bar >= 3) break;  // throttle: max 3 resolutions per bar
    }
}

// ========================================================================
// PLDS SELF-CALIBRATION
// ========================================================================
// After each closed trade, record whether PLDS risk level matched reality.
// If PLDS calls high risk (riskScaleFactor < 0.75) and the trade wins,
//   PLDS is too sensitive — reduce composite risk sensitivity by 5%.
// If PLDS calls low risk (riskScaleFactor > 0.90) and the trade loses,
//   PLDS missed a real deterioration — increase composite sensitivity by 5%.
// Correction is applied to g_PLDS.compositeRisk dampening factor.

double g_PLDS_SensitivityFactor = 1.0;  // 0.70-1.30 range

void PLDS_RecordOutcome(bool won) {
    if(!g_PLDS.active) return;
    double scale = g_PLDS.riskScaleFactor;
    bool highRisk = (scale < 0.75);
    bool lowRisk  = (scale > 0.90);

    if(highRisk) {
        g_SOM_PLDSHighRiskCalls++;
        if(!won) g_SOM_PLDSHighRiskLosses++;
        // PLDS called high risk and WON - slightly over-sensitive
        if(won && g_SOM_PLDSHighRiskCalls >= 5) {
            double fp_rate = 1.0 - (g_SOM_PLDSHighRiskLosses / g_SOM_PLDSHighRiskCalls);
            if(fp_rate > 0.60) {  // >60% of high-risk calls are false alarms
                g_PLDS_SensitivityFactor = MathMax(0.70, g_PLDS_SensitivityFactor - 0.02);
                if(!g_CalibSilent && EnableFriendlyLogs)
                    PrintFormat("  PLDS   |   sensitivity reduced to %.2f   |   false-alarm rate %.0f%%",
                        g_PLDS_SensitivityFactor, fp_rate*100);
            }
        }
    }
    if(lowRisk) {
        g_SOM_PLDSLowRiskCalls++;
        if(!won) g_SOM_PLDSLowRiskLosses++;
        // PLDS called low risk and LOST - under-sensitive
        if(!won && g_SOM_PLDSLowRiskCalls >= 5) {
            double miss_rate = g_SOM_PLDSLowRiskLosses / g_SOM_PLDSLowRiskCalls;
            if(miss_rate > 0.35) {  // >35% of low-risk calls result in loss
                g_PLDS_SensitivityFactor = MathMin(1.30, g_PLDS_SensitivityFactor + 0.03);
                if(!g_CalibSilent && EnableFriendlyLogs)
                    PrintFormat("  PLDS   |   sensitivity raised to %.2f   |   miss rate %.0f%%",
                        g_PLDS_SensitivityFactor, miss_rate*100);
            }
        }
    }
}

// ========================================================================
// SLS22-SEG: SCHEDULED-EVENT GATE
// ========================================================================
// Knows about published economic-calendar events (NFP/CPI/FOMC/BoJ/etc) --
// the one market discontinuity that's known in advance. Sessions know hours;
// this knows catalysts. Feed: MQL4\Files\TUNGSTEN_events.csv, regenerated
// weekly by the tungsten-events-refresh skill (TungstenEventsRefresh scheduled
// task). Fail-open per directive: if the feed is missing/stale, trades exactly
// as SLS21 did (no gate at all) -- logged once at init, once per session, not spammed.
#define SEG_MAX_EVENTS 200
struct SEGEvent {
    datetime utcTime;      // event time, UTC (converted to server-time on load, see ParseISO8601ToServerTime)
    string   currency;
    int      impact;       // 1=low 2=med 3=high
    string   name;
};
SEGEvent g_SEGEvents[SEG_MAX_EVENTS];
int      g_SEGEventCount    = 0;
bool     g_SEGFeedFresh     = false;
bool     g_SEGGateActive    = false;
datetime g_SEGLastLoadTime  = 0;
datetime g_SEGNextEventTime = 0;
int      g_SEGNextEventImpact = 0;
string   g_SEGNextEventName   = "";
bool     g_SEGStaleWarnedThisSession = false;  // one WARN per session per C7, not per check
bool     g_SEGTightenedThisEvent      = false; // avoid re-tightening every tick inside the same window
bool     g_SEGPostEventWindow         = false; // true only in the post-event half of an active window (M1.3 ERM interlock)

// Converts "2026-07-08T18:00:00Z" (UTC) into a datetime directly comparable
// with TimeCurrent() (broker/server time), using the same offset convention
// as every other GMT-correction in this file: gmtHour = serverHour - offset.
datetime SEG_ParseISO8601ToServerTime(string iso) {
    if(StringLen(iso) < 19) return 0;
    string y  = StringSubstr(iso, 0, 4);
    string mo = StringSubstr(iso, 5, 2);
    string d  = StringSubstr(iso, 8, 2);
    string h  = StringSubstr(iso, 11, 2);
    string mi = StringSubstr(iso, 14, 2);
    string s  = StringSubstr(iso, 17, 2);
    datetime utc = StrToTime(y + "." + mo + "." + d + " " + h + ":" + mi + ":" + s);
    if(utc <= 0) return 0;
    return utc + g_ServerTimeOffsetHours * 3600;
}

// SLS22-SEG: loads/reloads TUNGSTEN_events.csv, filters to the chart symbol's
// two currencies, sorts ascending. Called from OnInit and hourly from OnTick.
// Missing/unparseable/stale file -> g_SEGFeedFresh=false -> SEG_AllowNewEntry()
// always returns true (fail-open, per directive C7) -- never blocks trading
// just because the feed itself is unavailable.
void SEG_LoadEventsFile() {
    g_SEGLastLoadTime = TimeCurrent();
    string baseC = "", quoteC = "";
    DecomposeCurrencyPair(_Symbol, baseC, quoteC);

    int handle = FileOpen("TUNGSTEN_events.csv", FILE_READ | FILE_TXT | FILE_ANSI);
    if(handle == INVALID_HANDLE) {
        if(g_SEGFeedFresh || !g_SEGStaleWarnedThisSession) {
            Print("  SEG   |   WARN   |   TUNGSTEN_events.csv not found -- trading without event gate (fail-open)");
            g_SEGStaleWarnedThisSession = true;
        }
        g_SEGFeedFresh  = false;
        g_SEGEventCount = 0;
        return;
    }

    SEGEvent parsed[SEG_MAX_EVENTS];
    int count = 0;
    datetime newestEvent = 0;

    while(!FileIsEnding(handle) && count < SEG_MAX_EVENTS) {
        string line = FileReadString(handle);
        if(StringLen(line) < 10) continue;
        string parts[];
        int n = StringSplit(line, ';', parts);
        if(n < 4) continue;

        datetime t = SEG_ParseISO8601ToServerTime(parts[0]);
        if(t <= 0) continue;
        string cur = parts[1];
        int impact = (int)StringToInteger(parts[2]);
        if(impact < 1 || impact > 3) continue;
        if(cur != baseC && cur != quoteC) continue;  // M1.2: filter to this symbol's two currencies only

        parsed[count].utcTime  = t;
        parsed[count].currency = cur;
        parsed[count].impact   = impact;
        parsed[count].name     = parts[3];
        count++;
        if(t > newestEvent) newestEvent = t;
    }
    FileClose(handle);

    // Simple ascending insertion sort -- at most 200 elements, runs once/hour
    for(int i = 1; i < count; i++) {
        SEGEvent key = parsed[i];
        int j = i - 1;
        while(j >= 0 && parsed[j].utcTime > key.utcTime) {
            parsed[j+1] = parsed[j];
            j--;
        }
        parsed[j+1] = key;
    }
    for(int k = 0; k < count; k++) g_SEGEvents[k] = parsed[k];
    g_SEGEventCount = count;

    // Staleness rule (M1.2): newest event older than now, or feed simply empty -> stale -> fail-open
    int staleDaysLimit = MathMax(1, SEG_FeedStaleDays);
    bool stale = (count == 0) || (newestEvent < TimeCurrent()) ||
                 ((TimeCurrent() - newestEvent) > staleDaysLimit * 86400 * 2);  // safety margin beyond just "newest already passed"
    bool wasFresh = g_SEGFeedFresh;
    g_SEGFeedFresh = !stale;

    if(stale && (wasFresh || !g_SEGStaleWarnedThisSession)) {
        PrintFormat("  SEG   |   WARN   |   feed stale or empty (%d events, newest %s)   |   trading without event gate (fail-open)",
            count, count > 0 ? TimeToString(newestEvent) : "n/a");
        g_SEGStaleWarnedThisSession = true;
    } else if(!stale && !wasFresh) {
        PrintFormat("  SEG   |   feed loaded   |   %d events for %s/%s   |   next: %s",
            count, baseC, quoteC, count > 0 ? TimeToString(g_SEGEvents[0].utcTime) : "none");
    }
}

// SLS22-SEG: recomputes nextEvent*/gate-active state. Cheap -- call every tick
// (or at least every bar); the heavy work (file read/parse) is SEG_LoadEventsFile,
// called far less often.
void SEG_UpdateGateState() {
    g_SEGNextEventTime   = 0;
    g_SEGNextEventImpact = 0;
    g_SEGNextEventName   = "";
    bool wasActive = g_SEGGateActive;
    bool wasPostEventExtension = g_SEGPostEventWindow;
    g_SEGGateActive = false;
    g_SEGPostEventWindow = false;

    if(!g_SEGFeedFresh || g_SEGEventCount == 0) {
        g_Awareness.nextEventTime   = 0;
        g_Awareness.nextEventImpact = 0;
        g_Awareness.eventGateActive = false;
        g_Awareness.eventFeedFresh  = false;
        return;
    }

    datetime now = TimeCurrent();
    for(int i = 0; i < g_SEGEventCount; i++) {
        if(g_SEGEvents[i].utcTime < now - 3600) continue;  // fully in the past, skip
        if(g_SEGNextEventTime == 0) {
            g_SEGNextEventTime   = g_SEGEvents[i].utcTime;
            g_SEGNextEventImpact = g_SEGEvents[i].impact;
            g_SEGNextEventName   = g_SEGEvents[i].name;
        }
        int preMin, postMin;
        if(g_SEGEvents[i].impact == 3)      { preMin = SEG_Impact3PreMin; postMin = SEG_Impact3PostMin; }
        else if(g_SEGEvents[i].impact == 2) { preMin = SEG_Impact2PreMin; postMin = SEG_Impact2PostMin; }
        else continue;  // impact 1: annotate only, never blocks (M1.3)

        if(now >= g_SEGEvents[i].utcTime - preMin*60 && now <= g_SEGEvents[i].utcTime + postMin*60) {
            g_SEGGateActive = true;
        }
        // M1.3 interlock: the fixed post-window has just closed (event+postMin
        // already passed) -- if ERM isn't reporting NORMAL yet, extend the block
        // a bounded amount (3x postMin beyond the fixed window) rather than
        // reopening on the clock alone. Bounded so a stuck/never-recovering ERM
        // reading can't block forever -- falls open past the bound regardless,
        // same fail-open philosophy as the rest of this module. If ERM is
        // absent/stale (UNKNOWN), this extension never triggers -- fixed
        // T+ window alone is what governed re-entry, per directive.
        datetime fixedWindowEnd = g_SEGEvents[i].utcTime + postMin*60;
        if(now > fixedWindowEnd && now <= fixedWindowEnd + postMin*60*3) {
            if(g_ERM_State == ERM_STATE_DEGRADED || g_ERM_State == ERM_STATE_HOSTILE) {
                g_SEGGateActive = true;
                g_SEGPostEventWindow = true;
            }
        }
    }

    g_Awareness.nextEventTime   = g_SEGNextEventTime;
    g_Awareness.nextEventImpact = g_SEGNextEventImpact;
    g_Awareness.eventGateActive = g_SEGGateActive;
    g_Awareness.eventFeedFresh  = g_SEGFeedFresh;

    if(g_SEGPostEventWindow && !wasPostEventExtension) {
        PrintFormat("  SEG   |   ERM interlock   |   %s (%s)   |   fixed window closed but ERM not NORMAL   |   entries extended-blocked",
            g_SEGNextEventName, ERM_StateName(g_ERM_State));
    } else if(g_SEGGateActive && !wasActive) {
        PrintFormat("  SEG   |   gate ARM   |   %s (impact %d)   |   window active", g_SEGNextEventName, g_SEGNextEventImpact);
        g_SEGTightenedThisEvent = false;
    } else if(!g_SEGGateActive && wasActive) {
        Print("  SEG   |   gate RELEASE   |   entries unblocked");
    }
}

// SLS22-SEG integration point: called from CanTradeNow(). Fail-open if the
// feed isn't fresh (per C7) -- an absent/stale feed must never itself block
// trading, only a genuinely active gate window does.
bool SEG_AllowNewEntry() {
    if(!g_SEGFeedFresh) return true;
    // M1.3 ERM interlock is folded into g_SEGGateActive itself (see
    // SEG_UpdateGateState's bounded post-window extension) -- a single check here.
    return !g_SEGGateActive;
}

// SLS22-SEG M1.3: at T-10min before an impact-3 event, tighten SL to
// breakeven-or-better where price allows. Never widens, never market-closes
// solely for the event -- this only ever makes an existing stop safer.
void SEG_TightenStopsForEvent() {
    if(!g_SEGFeedFresh || g_SEGNextEventTime == 0 || g_SEGNextEventImpact < 3) return;
    if(g_SEGTightenedThisEvent) return;

    datetime now = TimeCurrent();
    if(now < g_SEGNextEventTime - SEG_TightenPreMin*60 || now >= g_SEGNextEventTime) return;

    int tightened = 0;
    for(int i = OrdersTotal() - 1; i >= 0; i--) {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
        if(OrderSymbol() != _Symbol || OrderMagicNumber() != MagicNumber) continue;
        if(OrderType() != OP_BUY && OrderType() != OP_SELL) continue;

        double be = OrderOpenPrice();
        bool isBuy = (OrderType() == OP_BUY);
        double curSL = OrderStopLoss();
        bool improves = isBuy ? (curSL < be) : (curSL > be || curSL == 0);
        double curPrice = isBuy ? Bid : Ask;
        bool priceAllows = isBuy ? (curPrice > be) : (curPrice < be);

        if(improves && priceAllows) {
            if(OrderModify(OrderTicket(), OrderOpenPrice(), be, OrderTakeProfit(), 0)) tightened++;
        }
    }
    if(tightened > 0)
        PrintFormat("  SEG   |   pre-event tighten   |   %s in %d min   |   %d position(s) moved to breakeven-or-better",
            g_SEGNextEventName, SEG_TightenPreMin, tightened);
    g_SEGTightenedThisEvent = true;
}

// ========================================================================
// SLS22-ERM: EXECUTION-REGIME MONITOR
// ========================================================================
// Ghost validation proves the logic on historical bars; it can't see spread
// widening, slippage, or requotes. ERM measures whether the live plumbing
// still resembles what the edge was validated under, and throttles when it
// doesn't. Three states: NORMAL / DEGRADED / HOSTILE, with asymmetric
// hysteresis (fast to flag risk, slow to relax it).
// NOTE: enum ExecutionRegimeState + g_ERM_State are declared earlier (top-of-file
// forward-declarations block) because SEG's post-event interlock needs them first.

#define ERM_ATTEMPT_WINDOW 20
#define ERM_MARGIN_WINDOW  50

double g_ERM_SpreadEWMA         = 0.0;   // points, general session
double g_ERM_SpreadEWMARollover = 0.0;   // points, 21:00-23:00 UTC only (rollover widening is normal, not hostile)
double g_ERM_SlippageEWMA       = 0.0;   // points
int    g_ERM_SampleCount        = 0;     // total spread samples -- warmup gate
int    g_ERM_PendingSeverity     = -1;   // severity rank being accumulated toward (0=NORMAL,1=DEGRADED,2=HOSTILE)
int    g_ERM_PendingStreak       = 0;

bool   g_ERM_Attempts[ERM_ATTEMPT_WINDOW];  // true = filled, false = rejected/requoted
int    g_ERM_AttemptIdx  = 0;
int    g_ERM_AttemptCount = 0;

double g_ERM_MarginHistory[ERM_MARGIN_WINDOW];  // rolling g_LastSignalMargin values, for the DEGRADED below-median-skip rule
int    g_ERM_MarginIdx   = 0;
int    g_ERM_MarginCount = 0;

double g_ERM_TotalCostPoints = 0.0;   // sum of (spread+slippage) per filled trade, points
int    g_ERM_CostSamples     = 0;

// SLS22-ERM helper: is TimeCurrent() inside the 21:00-23:00 UTC rollover window?
// Uses the same GMT-correction convention as every other session check in this file.
bool ERM_InRolloverWindow() {
    int gmtH = (TimeHour(TimeCurrent()) - g_ServerTimeOffsetHours + 24) % 24;
    return (gmtH >= 21 && gmtH < 23);
}

int ERM_SeverityOf(ExecutionRegimeState s) {
    if(s == ERM_STATE_HOSTILE)  return 2;
    if(s == ERM_STATE_DEGRADED) return 1;
    return 0;  // NORMAL and UNKNOWN both behave as NORMAL for gating, per directive
}

string ERM_StateName(ExecutionRegimeState s) {
    if(s == ERM_STATE_HOSTILE)  return "HOSTILE";
    if(s == ERM_STATE_DEGRADED) return "DEGRADED";
    if(s == ERM_STATE_NORMAL)   return "NORMAL";
    return "UNKNOWN";
}

// SLS22-ERM: median of the rolling signal-margin window -- feeds the DEGRADED
// "skip below-median" rule. Reuses g_LastSignalMargin (the existing conviction
// margin metric), does not invent a new one, per directive.
double ERM_GetRollingMedianMargin() {
    if(g_ERM_MarginCount == 0) return 0.0;
    double tmp[ERM_MARGIN_WINDOW];
    ArrayInitialize(tmp, 0.0);
    for(int i = 0; i < g_ERM_MarginCount; i++) tmp[i] = g_ERM_MarginHistory[i];
    // simple insertion sort -- at most 50 elements
    for(int i = 1; i < g_ERM_MarginCount; i++) {
        double key = tmp[i]; int j = i - 1;
        while(j >= 0 && tmp[j] > key) { tmp[j+1] = tmp[j]; j--; }
        tmp[j+1] = key;
    }
    int mid = g_ERM_MarginCount / 2;
    if(g_ERM_MarginCount % 2 == 1) return tmp[mid];
    return (tmp[mid-1] + tmp[mid]) / 2.0;
}

// Called from OptimizePrecisionLotSize right after g_LastSignalMargin is set,
// so the DEGRADED below-median rule always has a fresh distribution to compare against.
void ERM_RecordSignalMargin(double margin) {
    g_ERM_MarginHistory[g_ERM_MarginIdx] = margin;
    g_ERM_MarginIdx = (g_ERM_MarginIdx + 1) % ERM_MARGIN_WINDOW;
    if(g_ERM_MarginCount < ERM_MARGIN_WINDOW) g_ERM_MarginCount++;
}

// SLS22-ERM core hysteresis: recompute raw severity from current EWMAs, only
// commit a state change after ERM_UpgradeSamples (worsening) or
// ERM_DowngradeSamples (improving) CONSECUTIVE qualifying samples.
void ERM_Reclassify() {
    if(g_ERM_SampleCount < ERM_WarmupSamples) {
        g_ERM_State = ERM_STATE_UNKNOWN;
        return;  // UNKNOWN behaves as NORMAL for gating (see ERM_SeverityOf), logged distinctly
    }

    double baselinePoints;
    double pointsPerPip = (Digits == 3 || Digits == 5) ? 10.0 : 1.0;
    if(g_CalibratedAvgSpread > 0) baselinePoints = g_CalibratedAvgSpread * pointsPerPip;  // calibration-time assumed spread, if recorded
    else                          baselinePoints = MathMax(1.0, g_ERM_SpreadEWMA);        // else the long EWMA itself, per directive

    double currentSpreadPoints = ERM_InRolloverWindow() ? g_ERM_SpreadEWMARollover : g_ERM_SpreadEWMA;

    int rejects = 0;
    for(int i = 0; i < g_ERM_AttemptCount; i++) if(!g_ERM_Attempts[i]) rejects++;
    double rejectPct = (g_ERM_AttemptCount > 0) ? (double)rejects / g_ERM_AttemptCount * 100.0 : 0.0;

    int rawSeverity = 0;
    if(currentSpreadPoints > baselinePoints * ERM_HostileSpreadX ||
       (g_ERM_AttemptCount >= ERM_ATTEMPT_WINDOW && rejectPct > ERM_HostileRejectPct)) {
        rawSeverity = 2;  // HOSTILE
    } else if(currentSpreadPoints > baselinePoints * ERM_DegradedSpreadX ||
              g_ERM_SlippageEWMA > ERM_SlippageTolPts) {
        rawSeverity = 1;  // DEGRADED
    }

    int curSeverity = ERM_SeverityOf(g_ERM_State);

    if(rawSeverity == curSeverity) {
        g_ERM_PendingSeverity = -1;
        g_ERM_PendingStreak   = 0;
        return;
    }

    if(g_ERM_PendingSeverity == rawSeverity) g_ERM_PendingStreak++;
    else { g_ERM_PendingSeverity = rawSeverity; g_ERM_PendingStreak = 1; }

    int neededStreak = (rawSeverity > curSeverity) ? ERM_UpgradeSamples : ERM_DowngradeSamples;
    if(g_ERM_PendingStreak < neededStreak) return;

    ExecutionRegimeState newState = (rawSeverity == 2) ? ERM_STATE_HOSTILE :
                                     (rawSeverity == 1) ? ERM_STATE_DEGRADED : ERM_STATE_NORMAL;
    ExecutionRegimeState oldState = g_ERM_State;
    g_ERM_State = newState;
    g_ERM_PendingSeverity = -1;
    g_ERM_PendingStreak   = 0;

    PrintFormat("  ERM   |   %s -> %s   |   spread %.1fpt vs baseline %.1fpt   |   slippage EWMA %.1fpt   |   reject %.0f%% (%d/%d)",
        ERM_StateName(oldState), ERM_StateName(newState), currentSpreadPoints, baselinePoints,
        g_ERM_SlippageEWMA, rejectPct, rejects, g_ERM_AttemptCount);
}

// SLS22-ERM M2.1: sampled once per entry-decision evaluation (not every tick),
// called from GenerateHighFrequencySignals right after CanTradeNow() passes.
void ERM_RecordEvaluationSample() {
    double spreadPoints = MarketInfo(Symbol(), MODE_SPREAD);
    if(spreadPoints <= 0) return;  // no valid quote this instant, skip the sample rather than pollute the EWMA

    if(ERM_InRolloverWindow()) {
        g_ERM_SpreadEWMARollover = (g_ERM_SampleCount == 0) ? spreadPoints :
            ERM_EWMA_Alpha * spreadPoints + (1.0 - ERM_EWMA_Alpha) * g_ERM_SpreadEWMARollover;
    } else {
        g_ERM_SpreadEWMA = (g_ERM_SampleCount == 0) ? spreadPoints :
            ERM_EWMA_Alpha * spreadPoints + (1.0 - ERM_EWMA_Alpha) * g_ERM_SpreadEWMA;
    }
    g_ERM_SampleCount++;

    g_Awareness.ermState    = ERM_StateName(g_ERM_State);
    g_Awareness.ermWarmedUp = (g_ERM_SampleCount >= ERM_WarmupSamples);

    ERM_Reclassify();
}

// SLS22-ERM M2.1: captured at every fill inside SafeOrderSend's success path.
// requestedPrice = the price actually submitted this attempt (post-refresh),
// filledPrice = OrderOpenPrice() of the resulting ticket.
void ERM_RecordFill(double requestedPrice, double filledPrice) {
    double slipPts = MathAbs(requestedPrice - filledPrice) / NonZero(Point);
    g_ERM_SlippageEWMA = (g_ERM_CostSamples == 0) ? slipPts :
        ERM_EWMA_Alpha * slipPts + (1.0 - ERM_EWMA_Alpha) * g_ERM_SlippageEWMA;

    double spreadNow = MarketInfo(Symbol(), MODE_SPREAD);
    if(spreadNow < 0) spreadNow = 0;
    g_ERM_TotalCostPoints += (spreadNow + slipPts);  // M2.3: spread + slippage, per filled trade
    g_ERM_CostSamples++;

    g_ERM_Attempts[g_ERM_AttemptIdx] = true;
    g_ERM_AttemptIdx = (g_ERM_AttemptIdx + 1) % ERM_ATTEMPT_WINDOW;
    if(g_ERM_AttemptCount < ERM_ATTEMPT_WINDOW) g_ERM_AttemptCount++;
}

// SLS22-ERM M2.1: rejection-rate tracking. Called from SafeOrderSend's retry
// loop on any non-success attempt (requote/invalid-stops/etc, not the final
// give-up) so the rolling window reflects genuine broker friction.
void ERM_RecordRejectedAttempt() {
    g_ERM_Attempts[g_ERM_AttemptIdx] = false;
    g_ERM_AttemptIdx = (g_ERM_AttemptIdx + 1) % ERM_ATTEMPT_WINDOW;
    if(g_ERM_AttemptCount < ERM_ATTEMPT_WINDOW) g_ERM_AttemptCount++;
}

// SLS22-ERM integration point: called from CanTradeNow(). HOSTILE blocks new
// entries entirely (manage-only); NORMAL/DEGRADED/UNKNOWN all allow entry
// (DEGRADED's throttling happens via size + below-median skip, not a hard block).
bool ERM_AllowNewEntry() {
    return (g_ERM_State != ERM_STATE_HOSTILE);
}

// SLS22-ERM integration point: called from OptimizePrecisionLotSize. Halves
// size in DEGRADED; HOSTILE never reaches sizing (blocked earlier by
// ERM_AllowNewEntry via CanTradeNow); NORMAL/UNKNOWN = no adjustment.
double ERM_GetSizeMultiplier() {
    if(g_ERM_State == ERM_STATE_DEGRADED) return 0.5;
    return 1.0;
}

// SLS22-ERM M2.3: average realized (spread+slippage) cost per filled trade,
// in points. Exposed for CalculateDefensibleDailyGrowthRate to price in real
// friction instead of assumed friction. 0 until at least one trade has filled.
double ERM_GetAvgCostHaircutPoints() {
    if(g_ERM_CostSamples == 0) return 0.0;
    return g_ERM_TotalCostPoints / g_ERM_CostSamples;
}

// SLS22-ERM M2.5: one-line daily summary. Called once/day from the existing
// daily-log cadence (see OnTick integration) -- never per-tick.
void ERM_LogDailySummary() {
    int rejects = 0;
    for(int i = 0; i < g_ERM_AttemptCount; i++) if(!g_ERM_Attempts[i]) rejects++;
    double rejectPct = (g_ERM_AttemptCount > 0) ? (double)rejects / g_ERM_AttemptCount * 100.0 : 0.0;
    PrintFormat("  ERM   |   daily   |   spread EWMA %.1fpt (rollover %.1fpt)   |   slippage EWMA %.1fpt   |   reject %.0f%%   |   state %s   |   avg cost/trade %.1fpt",
        g_ERM_SpreadEWMA, g_ERM_SpreadEWMARollover, g_ERM_SlippageEWMA, rejectPct,
        ERM_StateName(g_ERM_State), ERM_GetAvgCostHaircutPoints());
}

// ========================================================================
// MODE CONFLICT GUARD
// ========================================================================
// Single function checks all mode flags before any trade is considered.
// Returns false + logs the specific reason if trading is not allowed.

bool CanTradeNow(string caller = "") {
    // SLS22-SEG: single gate integration point, checked first -- before edge
    // validation spends any computation, per directive M1.3. Fail-open inside
    // SEG_AllowNewEntry() itself if the feed is missing/stale.
    if(!SEG_AllowNewEntry()) return false;
    // SLS22-ERM: HOSTILE blocks new entries entirely (manage-only). NORMAL/
    // DEGRADED/UNKNOWN all pass here -- DEGRADED throttles via size + the
    // below-median signal skip instead of a hard block.
    if(!ERM_AllowNewEntry()) return false;
    // During calibration: no trades whatsoever
    if(g_Calibration.isCalibrating) {
        static datetime _lastCalibLog = 0;
        if(TimeCurrent() - _lastCalibLog > 300 && EnableFriendlyLogs) {
            Print("  paused   |   calibrating   |   trading resumes on completion");
            _lastCalibLog = TimeCurrent();
        }
        return false;
    }
    // Ghost mode: shadow trades only, no real execution
    if(g_SmartCB.inGhostMode) return false;
    // CATREC confirmation ghost: 30 shadow trades before live
    if(g_CATREC_ConfirmGhostActive) return false;
    // Emergency drawdown stop
    // Validate market data quality before any trade decision
    if(!ValidateMarketInfo())  return false;  // Missing tick/lot data
    if(!ValidatePriceFeed())   return false;  // Bid >= Ask or stale feed
    if(!CheckMinimumVolatility()) return false; // Below ATR floor
    MonitorPositionSpreads();  // Track spread anomalies

    if(g_CircuitBreaker.circuitBreakerActive) {
        static datetime _lastEmergLog = 0;
        if(TimeCurrent() - _lastEmergLog > 1800 && EnableFriendlyLogs) {
            Print("  paused   |   maximum drawdown reached   |   waiting for manual review");
            _lastEmergLog = TimeCurrent();
        }
        return false;
    }
    // Proactive recalibration in progress
    if(g_Calibration.isCalibrating && !g_Calibration.isComplete) {
        static datetime _lastProLog = 0;
        if(TimeCurrent() - _lastProLog > 300 && EnableFriendlyLogs) {
            Print("  paused   |   proactive recalibration running");
            _lastProLog = TimeCurrent();
        }
        return false;
    }
    return true;
}

// ========================================================================
// END SOM / PLDS-CALIBRATION / MODE GUARD
// ========================================================================

// -- Global GIS gate counters (feeds block-rate monitor) --------------
int g_GIS_SignalsEvaluated = 0;
int g_GIS_GateBlocks       = 0;


void PRI_Reset() {
    for(int p = 0; p < 7; p++) {
        g_PRI[p].attempt          = 0;
        g_PRI[p].bestWR           = 0.0;
        g_PRI[p].bestThreshold    = 0.0;
        g_PRI[p].bestTrades       = 0;
        g_PRI[p].measuredGap      = 0.0;
        g_PRI[p].sessionRestricted= false;
        g_PRI[p].thresholdLowered = false;
        g_PRI[p].obsRelaxed       = false;
        g_PRI[p].armedWithBest    = false;
        g_PRI[p].lastStrategy     = "";
    }
}

void PRI_RecordAttempt(int phase, double measuredWR, double targetWR, int trades, double threshold) {
    if(phase < 1 || phase > 6) return;
    g_PRI[phase].attempt++;
    g_PRI[phase].measuredGap = measuredWR - targetWR;
    if(measuredWR > g_PRI[phase].bestWR || g_PRI[phase].bestWR == 0.0) {
        g_PRI[phase].bestWR        = measuredWR;
        g_PRI[phase].bestThreshold = threshold;
        g_PRI[phase].bestTrades    = trades;
    }
}

// Returns true if a retry should be attempted, false if best-effort arm
bool PRI_ShouldRetry(int phase) {
    if(phase < 1 || phase > 6) return false;
    return (g_PRI[phase].attempt < 3);
}

// -- Phase 1 Retry Intelligence ----------------------------------------
// Phase 1 measures: baseline WR vs edgeFloor (random + spread)
// Strategy cascade:
//   Attempt 1: Lower score filter floor by 6 pts (catches more signals)
//   Attempt 2: Restrict to best session only, reset score floor
//   Attempt 3: Accept whatever WR is available — arm with 50% confidence

double PRI_Phase1_AdjustThreshold(double currentThreshold, double measuredWR, double targetWR) {
    int att = g_PRI[1].attempt;
    double gap = targetWR - measuredWR;  // shortfall

    if(att == 1) {
        // Shortfall analysis: lower score floor to widen the trade funnel
        // For every 3pp below target, lower floor by 4 pts (proportional)
        double reduction = MathMin(12.0, MathMax(4.0, gap * 100.0 * 1.3));
        double newThr = MathMax(28.0, currentThreshold - reduction);
        g_PRI[1].lastStrategy = StringFormat("widening score floor %.0f→%.0f (%.1fpp shortfall)", currentThreshold, newThr, gap*100);
        g_PRI[1].thresholdLowered = true;
        PrintFormat("  phase 1 retry 1   |   %s", g_PRI[1].lastStrategy);
        return newThr;
    } else if(att == 2) {
        // Session restriction already attempted? Try with ATR-normalised TP widened
        // Give a larger TP target to give the signal more room to profit
        double newThr = MathMax(55.0, currentThreshold - 6.0);  // 9/10: floor 55 — below this is noise
        g_PRI[1].lastStrategy = StringFormat("widening TP target, floor %.0f (attempt 2)", newThr);
        PrintFormat("  phase 1 retry 2   |   %s", g_PRI[1].lastStrategy);
        return newThr;
    } else {
        // Attempt 3: accept best result, arm at reduced confidence
        g_PRI[1].armedWithBest = true;
        g_PRI[1].lastStrategy = StringFormat("armed with best available %.1f%% WR (target was %.0f%%)", measuredWR*100, targetWR*100);
        PrintFormat("  P1    |   best-effort arm   |   WR %.1f%%   |   threshold %.0f   |   continues at reduced confidence", measuredWR*100, currentThreshold);
        return currentThreshold;  // keep what we have
    }
}

// -- Phase 2 Retry Intelligence ----------------------------------------
// Phase 2 measures: viableRegimes (those with 20+ observations)
// Strategy cascade:
//   Attempt 1: Lower observation floor 20→10 (data-thin instruments)
//   Attempt 2: Treat any detected regime as viable (even 5 observations)
//   Attempt 3: Use minimum 1 regime — arm as thin-regime mode

int PRI_Phase2_MinObservations() {
    int att = g_PRI[2].attempt;
    if(att == 1) {
        Print("  phase 2 retry 1   |   relaxing observation floor to 10 per regime");
        g_PRI[2].lastStrategy = "min observations 20→10";
        g_PRI[2].obsRelaxed = true;
        return 10;  // halved floor
    } else if(att == 2) {
        Print("  phase 2 retry 2   |   accepting sparse regimes (5 observations minimum)");
        g_PRI[2].lastStrategy = "min observations 10→5 (sparse mode)";
        return 5;
    } else {
        // Attempt 3: accept whatever is there
        g_PRI[2].armedWithBest = true;
        Print("  P2    |   best-effort arm   |   using most-observed regime only   |   thin-regime mode");
        g_PRI[2].lastStrategy = "single-regime mode";
        return 1;
    }
}

// -- Phase 3 Retry Intelligence ----------------------------------------
// Phase 3 measures: regimesOptimized (those that beat holdout WR)
// Strategy cascade:
//   Attempt 1: Relax holdout WR requirement 60%→55% (allow marginal edge)
//   Attempt 2: Fix 3 lowest-IC components at 1.0, optimise remaining 3
//   Attempt 3: Use equal weights but optimise per-regime threshold only

double PRI_Phase3_HoldoutTarget() {
    int att = g_PRI[3].attempt;
    if(att == 1) {
        Print("  phase 3 retry 1   |   relaxing holdout target to 55%% WR   |   looking for marginal edge");
        g_PRI[3].lastStrategy = "holdout target 60%→55%";
        return 0.55;
    } else if(att == 2) {
        Print("  phase 3 retry 2   |   fixing low-IC components   |   narrowing search to top contributors");
        g_PRI[3].lastStrategy = "top-component focus (low-IC pinned)";
        return 0.52;  // further relaxed — search is narrower so need lower bar
    } else {
        g_PRI[3].armedWithBest = true;
        Print("  P3    |   best-effort arm   |   equal weights   |   threshold-only optimisation per regime");
        g_PRI[3].lastStrategy = "equal weights, threshold-only";
        return 0.0;  // signal: use equal weights, skip component search
    }
}

// -- Phase 4 Retry Intelligence ----------------------------------------
// Phase 4 measures: g_ProbDB.patternCount vs target (10+)
// Strategy cascade:
//   Attempt 1: Lower minimum pattern count threshold 10→5 (sparse instrument)
//   Attempt 2: Widen score bucket width (better coverage)
//   Attempt 3: Build minimal 3-bucket ProbDB from whatever is available

int PRI_Phase4_MinPatterns() {
    int att = g_PRI[4].attempt;
    if(att == 1) {
        Print("  phase 4 retry 1   |   relaxing pattern minimum to 5   |   sparse instrument mode");
        g_PRI[4].lastStrategy = "min patterns 10→5";
        return 5;
    } else if(att == 2) {
        Print("  phase 4 retry 2   |   widening score buckets   |   broadening coverage");
        g_PRI[4].lastStrategy = "wider score buckets";
        return 3;
    } else {
        g_PRI[4].armedWithBest = true;
        Print("  P4    |   best-effort arm   |   minimal ProbDB   |   live data will fill gaps");
        g_PRI[4].lastStrategy = "minimal viable ProbDB";
        return 1;
    }
}

// -- Phase 6 Retry Intelligence ----------------------------------------
// Phase 6 measures: ghostWR vs FLOOR_START_WR, plus 7 sub-gates
// Strategy cascade:
//   Attempt 1: Lower threshold by measured gap x 1.5 (signal quality adjustment)
//   Attempt 2: Restrict to best 2 regimes only (quality-over-volume approach)
//   Attempt 3: Arm if any 4/7 gates pass — fragile flag set

bool PRI_Phase6_ShouldArm(double ghostWR, double targetWR, int gatesMet, int totalGates) {
    int att = g_PRI[6].attempt;
    double gap = targetWR - ghostWR;

    if(att <= 2) return false;  // still retrying — don't force-arm yet

    // Attempt 3: arm if reasonable
    // 9/10 arm floor: 62% WR minimum — below this, spread costs erode the edge
    bool armable = (gatesMet >= 5 && ghostWR >= 0.62) || (ghostWR >= 0.65 && gatesMet >= 4);
    if(armable) {
        g_PRI[6].armedWithBest = true;
        g_Calibration.fragileFlag = true;  // Walk-forward instability flag
        PrintFormat("  P6    |   best-effort arm   |   WR %.1f%%   |   %d/7 gates   |   fragile flag set",
                    ghostWR*100, gatesMet);
        g_PRI[6].lastStrategy = StringFormat("fragile arm %.1f%% WR %d/%d gates", ghostWR*100, gatesMet, totalGates);
        return true;
    }
    // Still not armable: WR below 62% minimum floor
    // Arm only if WR >= 58% (minimum viable with equal weights + tightest threshold)
    // Below 58%: ghost observation mode only — log clearly, do not execute live
    PrintFormat("  P6    |   insufficient edge   |   WR %.1f%%   |   %d/7 gates   |   arming with equal weights",
                ghostWR*100, gatesMet);
    g_PRI[6].armedWithBest = true;
    g_Calibration.fragileFlag = true;
    if(ghostWR < 0.58) {
        g_PRI[6].lastStrategy = StringFormat("WR %.1f%% below 58%% minimum — observation mode only", ghostWR*100);
        PrintFormat("  P6    |   WR %.1f%% < 58%% floor   |   live execution suspended   |   ghost observation active", ghostWR*100);
        g_Calibration.fragileFlag = true;
        g_Calibration.executionSuspended = true;  // signal to GIS: no live trades
        return true;  // arm state saved — resume when live WR recovers
    }
    g_PRI[6].lastStrategy = StringFormat("ultra-conservative arm %.1f%% WR — tightest threshold", ghostWR*100);
    return true;  // always arm — never halt
}

double PRI_Phase6_AdjustThreshold(double currentThreshold, double measuredWR, double targetWR) {
    int att = g_PRI[6].attempt;
    double gap = (targetWR - measuredWR) * 100.0;  // in pp

    if(att == 1) {
        // Lower threshold — gap x 1.5 adjustment
        double reduction = MathMin(15.0, MathMax(3.0, gap * 1.5));
        double newThr = MathMax(16.0, currentThreshold - reduction);  // floor: signed conviction minimum (==58 live)
        g_PRI[6].lastStrategy = StringFormat("threshold %.0f→%.0f (%.1fpp gapx1.5)", currentThreshold, newThr, gap);
        PrintFormat("  phase 6 retry 1   |   %s", g_PRI[6].lastStrategy);
        return newThr;
    } else if(att == 2) {
        // Larger reduction — also enables regime restriction in ghost sim
        double reduction = MathMin(20.0, MathMax(5.0, gap * 2.0));
        double newThr = MathMax(16.0, currentThreshold - reduction);  // floor: signed conviction minimum (==58 live)
        g_PRI[6].lastStrategy = StringFormat("threshold %.0f→%.0f   |   restricting to top-2 regimes", currentThreshold, newThr);
        PrintFormat("  phase 6 retry 2   |   %s", g_PRI[6].lastStrategy);
        return newThr;
    }
    return currentThreshold;
}

// -- Calibration completion guarantee --------------------------------─
// Called at the end of RunE8_CompleteCalibration after all phases.
// Ensures the system always arms at some confidence level.
void PRI_GuaranteeCompletion(int phasesPassed, double ctrlWR) {
    // Compute which phases armed with reduced confidence
    int phasesBestArmed = 0;
    string armNotes = "";
    for(int p = 1; p <= 6; p++) {
        if(g_PRI[p].armedWithBest) {
            phasesBestArmed++;
            armNotes += StringFormat("P%d: %s   ", p,
                StringLen(g_PRI[p].lastStrategy) > 0 ? g_PRI[p].lastStrategy : "best-effort (no detail recorded)");
        }
    }

    if(phasesBestArmed > 0) {
        PrintFormat("  calibration complete   |   %d/6 phases fully verified   |   %d best-effort",
                    phasesPassed, phasesBestArmed);
        if(!g_CalibSilent)
            PrintFormat("  best-effort phases   |   %s", armNotes);
        // Boost fragile flag if 2+ phases were best-effort
        if(phasesBestArmed >= 2) g_Calibration.fragileFlag = true;
    } else {
        PrintFormat("  calibration complete   |   all 6 phases fully verified   |   WR %.1f%%", ctrlWR*100);
    }
}

