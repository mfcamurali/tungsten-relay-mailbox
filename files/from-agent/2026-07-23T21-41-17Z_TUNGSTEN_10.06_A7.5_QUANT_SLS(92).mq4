    int failedResumes;             // How many times resumed but hit CB again quickly
    
    // Smart iteration tracking
    bool hasHistoricalKnowledge;
    datetime lastSuccessfulResumeTime;
    double lastSuccessfulResumeWinRate;

    // ## Active ghost position tracking ######################################
    // Each slot tracks a live-simulated ghost position evaluated tick-by-tick.
    // This is what makes ghost mode a genuine simulation with real outcomes,
    // not a counter that never moves.
    double ghostEntryPrice[5];
    double ghostSL[5];
    double ghostTP[5];
    int    ghostDirection[5];  // 1=long, -1=short
    datetime ghostOpenTime[5];
    double ghostATR[5];
    bool   ghostActive[5];
    int    activeGhostCount;
    datetime lastGhostEntry;   // throttle -- min 5s between ghost entries
      // Per-regime win/loss tracking for live ghost adaptation
      int    ghostRegimeWin[9];  // wins per regime in current ghost session
      int    ghostRegimeLoss[9]; // losses per regime in current ghost session
};

