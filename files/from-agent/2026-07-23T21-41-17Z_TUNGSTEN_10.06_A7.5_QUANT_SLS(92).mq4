    for(int i = 0; i < 100; i++) {
        performanceAnalytics.tradeReturns[i] = 0.0;
        performanceAnalytics.tradeDurations[i] = 0;
        performanceAnalytics.tradeDrawdowns[i] = 0.0;
    }
    
    for(int i = 0; i < 50; i++) {
        performanceAnalytics.dailyReturns[i] = 0.0;
        performanceAnalytics.dailyVolatility[i] = 0.0;
    }
    
    for(int i = 0; i < 12; i++) {
        performanceAnalytics.regimePerformance[i] = 0.0;
        performanceAnalytics.regimeTrades[i] = 0;
        performanceAnalytics.regimeWins[i] = 0;
    }
    
    // Initialize performance metrics
    performanceAnalytics.totalTrades = 0;
    performanceAnalytics.winningTrades = 0;
    performanceAnalytics.losingTrades = 0;
    performanceAnalytics.winRate = 0.0;
    performanceAnalytics.profitFactor = 0.0;
    performanceAnalytics.sharpeRatio = 0.0;
    performanceAnalytics.sortinoRatio = 0.0;
    performanceAnalytics.maxDrawdown = 0.0;
    performanceAnalytics.averageWin = 0.0;
    performanceAnalytics.averageLoss = 0.0;
    performanceAnalytics.averageRR = 0.0;
    performanceAnalytics.expectancy = 0.0;
    performanceAnalytics.recoveryFactor = 0.0;
    performanceAnalytics.volatility = 0.0;
    performanceAnalytics.riskAdjustedReturn = 0.0;
    performanceAnalytics.averageLatency = 0.0;
    performanceAnalytics.lastCalculation = TimeCurrent();
    
    // Performance analytics initialized
}

void UpdatePerformanceAnalytics() {
    if((TimeCurrent() - performanceAnalytics.lastCalculation) < 60) return; // NonZero(Update.every) minute
    performanceAnalytics.lastCalculation = TimeCurrent();
    
    // Calculate basic performance metrics
