    regimeStrategies[7].maxPositionSize = 1.3;
    regimeStrategies[7].maxRiskPercent = 1.4;
    regimeStrategies[7].requiredEdgeStrength = 0.26;  // FIX: Lowered from 0.30 to 0.26
