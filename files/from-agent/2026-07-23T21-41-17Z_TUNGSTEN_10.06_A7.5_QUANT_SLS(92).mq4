struct MarketCalibration {
    // Calibration status
    bool isComplete;                    // Has calibration finished successfully?
    bool isCalibrating;                 // Currently in calibration phase?
    datetime calibrationStartTime;      // When calibration began
    datetime calibrationEndTime;        // When calibration completed
    int calibrationDurationSeconds;     // How long it took
    
    // Phase tracking
    int currentPhase;                   // 1=Calibration, 2=Ghost, 3=Validation, 4=Complete
    string currentPhaseDescription;     // Human-readable phase
    
    // Calibration sweep results
    int totalConfigsTested;             // Total configs tested
    int calibrationIterations;          // How many calibration runs completed
    bool calibrationComplete;           // Has calibration sweep finished?
    double bestHistoricalWR;            // Best WR found in history
    double bestThreshold;               // Optimal threshold found
    double bestMomentumWeight;          // Optimal momentum weight
    double bestReversalWeight;          // Optimal reversal weight
    double bestDirectionalWeight;       // Optimal directional weight
    
    // Ghost Mode validation results
    int ghostTradesExecuted;            // Virtual trades executed
    int ghostWins;                      // Virtual wins
    int ghostLosses;                    // Virtual losses
    double ghostWinRate;                // Achieved ghost WR
    double ghostProfitFactor;           // Ghost PF
    bool ghostModeSucceeded;            // Did ghost achieve 65%+ WR?

    // Walk-forward instability flag (non-blocking)
    bool fragileFlag;
    bool catastrophicMode;      // true = prev calibration was fundamentally wrong
    int  catastrophicReason;    // 0=age, 1=WR collapse, 2=PF collapse, 3=regime shift, 4=multi
    datetime catastrophicStartTime;
    double   preCalibLiveWR;    // live WR before catastrophic recalib started (for comparison)
    double   preCalibThreshold; // threshold before recalib (for comparison)
    
    // Regime optimization results
    bool regimesOptimized;              // Have regime thresholds been tuned?
    double optimizedBreakoutBuy;        // Tuned BREAKOUT buy threshold
    double optimizedBreakoutSell;       // Tuned BREAKOUT sell threshold
    double optimizedTrendingBuy;        // Tuned TRENDING buy threshold
    double optimizedTrendingSell;       // Tuned TRENDING sell threshold
    double optimizedRangingBuy;         // Tuned RANGING buy threshold
    double optimizedRangingSell;        // Tuned RANGING sell threshold
    double optimizedVolatileBuy;        // Tuned VOLATILE buy threshold
    double optimizedVolatileSell;       // Tuned VOLATILE sell threshold
    
    // Duration management
    int baseCalibrationMinutes;         // Base: 15 minutes
    int extensionsAdded;                // How many 5-min extensions
    int maxExtensions;                  // Max: 6 (total 45 min)
    datetime nextExtensionCheck;        // When to check if extension needed
    
    // Validation criteria
    double requiredWinRate;             // Minimum: 65%
    int minimumGhostTrades;             // Minimum: 30 virtual trades
    bool meetsWinRateRequirement;       // Achieved 65%+ WR?
    bool meetsTradeRequirement;         // Executed 30+ trades?
    bool meetsAllCriteria;              // Ready for live trading?
    
    // Adaptive retry system (NEW)
    int calibrationRetries;             // How many times retested
    int maxCalibrationRetries;          // Max: 2 retries
    bool needsMoreTesting;              // Flag for adaptive expansion
    datetime lastRetryTime;             // When last retry happened
    
    // Additional weight storage for best config (NEW)
    double bestVolatilityWeight;        // Optimal volatility weight
    double bestPredictiveWeight;        // Optimal predictive weight
    double bestPatternWeight;           // Optimal pattern weight
    
    // Testing period
    int barsToTest;                     // Number of bars to test (adaptive)
    
    // Failure handling
    int calibrationAttempts;            // How many times tried
    int maxCalibrationAttempts;         // Max: 3 attempts
    string failureReason;               // Why calibration failed
    bool calibrationFailed;             // Permanent failure flag

    // MATHEMATICAL CONSTANTS - Baseline measurements for comparison
    double baselineWR;              // Equal-weights WR (control group)
    double randomBaselineWR;        // Random entry WR (~50%)
    double marketSpreadCost;        // Average spread cost per trade
    double baselinePF;              // Equal-weights profit factor
    bool baselinesEstablished;      // Phase 0 complete

    // COMPREHENSIVE KNOWLEDGE EXTRACTION SYSTEM
    // Test across ALL contexts to build complete insight map
    
    // Multi-Context Testing Results
    double regimeWeights[9][6];           // Optimal weights per regime (8 regimes ? 6 components)
    double sessionWeights[4][6];          // Optimal weights per session (London/NY/Asian/Sydney)
    double volatilityWeights[3][6];       // Optimal weights per volatility (Low/Med/High)
    double trendWeights[3][6];            // Optimal weights per trend (Bull/Bear/Range)
    
    // Context-Specific Performance Maps
    double regimeWR[9];                   // WR per regime
    double sessionWR[4];                  // WR per session
    double volatilityWR[3];               // WR per volatility
    double trendWR[3];                    // WR per trend
    
    // Cross-Context Validation
    double regimeSessionWR[9][4];         // WR per regime+session combination (32 contexts)
    double regimeVolatilityWR[9][3];      // WR per regime+volatility (24 contexts)
    
    // Total Insight Points
    int totalTestsExecuted;               // Total optimization tests run
    int totalContextsTested;              // Total unique contexts validated
    int totalInsightPoints;               // Total data points in knowledge base
    
    // Unfalsifiable Validation
    double outOfSampleWR;                 // WR on completely unseen data
    double differentPairWR;               // WR tested on different pair (if available)
    double differentTimeframeWR;          // WR tested on different timeframe
    bool crossValidationPassed;           // All cross-validation criteria met

    double expectedWinRate;         // Expected win rate from calibration
    int databaseEntries;            // Number of probability database entries

    // SVJ additions — operational fields
    double calibratedWR;         // Proven OOS win rate fraction (0-1) from Phase 5/6
    double baselineATR;          // Calibration-time ATR baseline — floors live ATR at 30%
    int    chartPeriod;          // PERIOD_CURRENT at calibration time — detects TF switch
    // Live Proof Phase
    // Three-phase live validation
    int    liveTrades;           // total live trades completed since ARMED
    bool   warmupComplete;       // phase 1 done (10 trades operational check)
    bool   scalingComplete;      // phase 2 done (50 trades conservative scaling)
    bool   compoundingActive;    // phase 3: equity-based risk (100 trades + WR ok)
    // Ghost quality metadata (informational — not used for gating)
    int    ghostGatesScore;      // p6Met: 0–7 gates passed at arming
    double ghostPFScore;         // Phase 6 profit factor
    bool   ghostWalkForwardOK;   // walk-forward consistency (histRobust)
    double spreadAtCalibPct;     // spread as % of ATR at Phase 0
    int    totalSignalsFound;    // Phase 2 signal scan count — FrequencyAdvisor cap
    bool   executionSuspended;
    double instrumentHurst;   // Mean Hurst over training — set in Phase 1
    double p3bThreshold;       // Phase 3B calibrated threshold, preserved across Phase 5
};

// RISK PERCENTAGE - Controls position size as % of account equity

input int MagicNumber = 21001;
input int Slippage = 3;
input double RiskPercentPerTrade = 3.5;  // Risk % per trade (1.0-8.5% strategic range)

// E9 RECALIBRATION SETTINGS
input bool ForceRecalibrationOnStartup = false;  // Force full recalibration on EA restart
input int AutoRecalibrationDays = 30;            // Auto-recalibrate every X days (0 = never)
input bool EnableMarketHoursCheck = true;        // Only trade during market hours
// forge-parallel WARRANT#76 (2026-07-19, calibration budget upgrade, per Manuel's explicit
// request: "budget shouldn't ever be an issue"): default raised 90 -> 240. Real evidence this was
// tight, not just theoretical: the 2026-07-17 SLS(68) live run logged multiple "budget tight"
// warnings and CalibrationTimedOut() firing during Phase 3B, and Phase 3B alone (9 regimes x
// 50,000-draw search each) consumed most of a 90-minute window on its own before Phase 4-6 even
// ran. 240 gives ~4x headroom (per-regime cap _p3RegMaxSec scales directly: ~330s/regime at 90min
// -> ~880s/regime at 240min, per the formula MaxCalibrationMinutes*60*0.55/9 immediately below)
// with room to spare for WARRANT#75's PBO sampling and any future
// deeper search (e.g. a real CSCV retrofit, which would need materially more per-candidate time).
// Every phase already fails open on timeout (uses best-so-far, never crashes) -- raising this only
// ever means "more time before that fallback triggers," never a new failure mode. This is an
// `input` (user-configurable at attach time in the MT4 Inputs dialog) -- this is only the shipped
// DEFAULT; Manuel can still override it per-run same as any other input.
input int MaxCalibrationMinutes = 240;           // Maximum calibration time before fallback

// AUTO RISK SCALING - Automatically reduces risk as balance grows
// This protects your gains and is CRITICAL for long-term success

input bool EnableAutoRiskScaling = true;   // Auto-reduce risk as balance grows
input double StartingBalance = 100.0;      // Starting balance -- MUST match your deposit (used for risk tier scaling)


