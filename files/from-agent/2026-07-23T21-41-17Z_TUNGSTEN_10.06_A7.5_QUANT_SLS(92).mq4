// --─ L7 LIVE ADAPTATION — Threshold and optimization tracking ----------─

void AdjustThresholdBasedOnPerformance() {
    int recentTrades = g_DailyWins + g_DailyLosses;
    if(recentTrades < 10) return; // Need data
    // Certainty gate: if system is uncertain about its environment,
    // don't make aggressive threshold moves (performance may be noise).
    if(g_Awareness.isValid && g_Awareness.certainty < 0.35) return;  // skip in fog
    
    double recentWR = (recentTrades > 0) ? (double)g_DailyWins / recentTrades * 100.0 : 0.0;  // FIX59c: guard /0
    
    // ELITE DYNAMIC ADJUSTMENT: Alter threshold AND component weights
    
    static datetime lastAdjustment = 0;
    if(TimeCurrent() - lastAdjustment < 1800) return; // Only adjust every 30 min
    lastAdjustment = TimeCurrent();
    
    // SCENARIO 1: Struggling (WR <60%) - MAKE THRESHOLD HARDER
    // Calibrated floor — anchored to Phase 2 signal WR for this regime+session
    int _curReg2  = g_RegimeState.currentRegime;
    int _gmtCurH2 = (TimeHour(TimeCurrent()) - g_ServerTimeOffsetHours + 24) % 24;
    int _curSess2 = (_gmtCurH2 < 8) ? 0 : (_gmtCurH2 < 13) ? 1 : (_gmtCurH2 < 17) ? 2 : 3;
    double _calFloor2 = 65.0;  // default floor
    if(g_CorrelationsLearned && _curReg2 >= 0 && _curReg2 < 9) {
        double _calSWR2 = g_RegimeCorrelations[_curReg2].signalWR;
        double _calSSWR2 = g_RegimeCorrelations[_curReg2].sessionWR[_curSess2];
        if(g_RegimeCorrelations[_curReg2].sessionTotal[_curSess2] >= 5 && _calSSWR2 > 0)
            _calFloor2 = _calSSWR2 * 100.0;
        else if(_calSWR2 > 0)
            _calFloor2 = _calSWR2 * 100.0;
    }
    // Dynamic floor: anchored to calibrated signal WR
    if(recentWR < _calFloor2) {
        // Increase threshold (harder to reach)
        double thresholdIncrease = _calFloor2 - recentWR;  // proportional to deviation from floor
        thresholdIncrease = MathMax(1.0, MathMin(thresholdIncrease, 10.0)); // 1-10 pts, proportional
        g_BaseThreshold += thresholdIncrease;
        g_BaseThreshold = MathMin(g_BaseThreshold, 90.0); // Never above 90
        
        // Reduce component weights (soften signals - less likely to reach threshold)
        double reductionFactor = 0.90; // 10% reduction
        if(recentWR < 55.0) reductionFactor = 0.85; // 15% if very bad

        // Surgical IC-aware reduction: only penalise low-IC components
        int _atbpReg = g_RegimeState.currentRegime;
        double _icThr = 0.018;
        bool _useIC = (g_ICMeasured && _atbpReg >= 0 && _atbpReg < 9);  // R8 = 9th regime
        double _rfM = (!_useIC || MathAbs(g_RegimeIC[_atbpReg][1]) < _icThr) ? reductionFactor : 0.97;
        double _rfV = (!_useIC || MathAbs(g_RegimeIC[_atbpReg][3]) < _icThr) ? reductionFactor : 0.97;
        double _rfP = (!_useIC || MathAbs(g_RegimeIC[_atbpReg][5]) < _icThr) ? reductionFactor : 0.97;
        double _rfT = (!_useIC || MathAbs(g_RegimeIC[_atbpReg][0]) < _icThr) ? reductionFactor : 0.97;
        g_ComponentWeights.momentum   *= _rfM;
        g_ComponentWeights.volatility *= _rfV;
        g_ComponentWeights.pattern    *= _rfP;
        g_ComponentWeights.mtf        *= _rfT;
        g_ComponentWeights.momentum   = MathMax(0.3, g_ComponentWeights.momentum);
        g_ComponentWeights.volatility = MathMax(0.3, g_ComponentWeights.volatility);
        g_ComponentWeights.pattern    = MathMax(0.3, g_ComponentWeights.pattern);
        g_ComponentWeights.mtf        = MathMax(0.3, g_ComponentWeights.mtf);
        
        if(EnableFriendlyLogs && ShowOptimizationLogs) {
            PrintFormat("  LIVE  |   adaptive   WR %.1f%%   |   thr +%.1f -> %.1f   |   weights x%.2f",
                       recentWR, thresholdIncrease, g_BaseThreshold, reductionFactor);
        }
    }
    
    // SCENARIO 2: Good performance (WR 65-70%) - Maintain balance
    else if(recentWR >= _calFloor2 && recentWR < _calFloor2 + 5.0) {
        // Gradual recovery of weights toward 1.0
        // [FIX-C] Each weight field recovered exactly once. Removed duplicated /* was: X */ lines.
        if(g_ComponentWeights.momentum < 1.0) {
            g_ComponentWeights.momentum = MathMin(1.0, g_ComponentWeights.momentum + 0.05);
        }
        if(g_ComponentWeights.volatility < 1.0) {
            g_ComponentWeights.volatility = MathMin(1.0, g_ComponentWeights.volatility + 0.05);
        }
        if(g_ComponentWeights.pattern < 1.0) {
            g_ComponentWeights.pattern = MathMin(1.0, g_ComponentWeights.pattern + 0.05);
        }
        
        // Gradual threshold reduction toward optimal
        if(g_BaseThreshold > 70.0) {
            g_BaseThreshold -= 1.0;
        } else if(g_BaseThreshold < 68.0) {
            g_BaseThreshold += 1.0;
        }
    }
    
    // SCENARIO 3: Excellent performance (WR 70%+) - MAKE THRESHOLD SOFTER
    else if(recentWR >= 70.0) {
        // Decrease threshold (easier to reach)
        double thresholdDecrease = (recentWR - 70.0) * 0.5; // 75% WR = -2.5, 80% WR = -5
        thresholdDecrease = MathMin(thresholdDecrease, 5.0); // Cap at -5
        g_BaseThreshold -= thresholdDecrease;
        g_BaseThreshold = MathMax(g_BaseThreshold, 63.0); // Never below 63
        
        // Increase component weights (amplify signals - easier to reach threshold)
        double amplificationFactor = 1.05; // 5% boost
        if(recentWR >= 75.0) amplificationFactor = 1.10; // 10% boost if very good
        if(recentWR >= 80.0) amplificationFactor = 1.15; // 15% boost if excellent
        
        // [FIX-C] Each weight field amplified exactly once. Removed duplicated /* was: X */ lines.
        g_ComponentWeights.momentum  *= amplificationFactor;
        g_ComponentWeights.volatility *= amplificationFactor;
        g_ComponentWeights.pattern   *= amplificationFactor;
        
        // Cap at 1.5X (never amplify above 150% of original)
        g_ComponentWeights.momentum  = MathMin(1.5, g_ComponentWeights.momentum);
        g_ComponentWeights.volatility = MathMin(1.5, g_ComponentWeights.volatility);
        g_ComponentWeights.pattern   = MathMin(1.5, g_ComponentWeights.pattern);
        
        if(EnableFriendlyLogs && ShowOptimizationLogs) {
            PrintEmptyLine();
            PrintFormat("  LIVE  |   adaptive   WR %.1f%%   |   threshold -%.1f   |   weights +%.0f%%   |   thr %.1f",
                       recentWR, thresholdDecrease, (amplificationFactor-1)*100, g_BaseThreshold);
        }
    }
}


//| HYBRID SLINGSHOT SYSTEM - "BUFFALO HUNTER" MODE                  |
//| Recovery through ultra-premium setups + intelligent learning     |

// Slingshot state tracking

// ## PERFORMANCE TIER #########################################################
enum PerformanceTier { TIER_FLOOR = 0, TIER_MEDIUM = 1 };

struct TierState {
    PerformanceTier currentTier;
    int consecutiveMediumDays;    // Days sustaining medium tier
    int consecutiveFallbackDays;  // Consecutive days below sustain threshold
    datetime tierUnlockedAt;      // When medium tier was last unlocked
    double peakTierWR;            // Best rolling WR seen in current tier
    bool mediumEverUnlocked;      // Has medium tier been unlocked this session
    double mediumUnlockWR;        // WR threshold at time of medium unlock
};
TierState g_Tier;

// ## LIVE ADAPTIVE INTELLIGENCE ##############################################
// INDEPENDENTLY of whether a formal Phase 1-6 calibration has run.
struct LiveAdaptiveState {
    // Per-regime live WR (last 30 trades in each regime)
    int   regimeTrades[9];
    int   regimeWins[9];
    double regimeLiveWR[9];       // Observed WR per regime from live trades
    double regimeThreshAdj[9];    // Threshold adjustment per regime (+/-)

    // Per-session live WR (last 30 trades per hour bucket)
    int   sessionTrades[4];       // 0=Asian 1=London 2=NY 3=Overlap
    int   sessionWins[4];
    double sessionLiveWR[4];

    // Rolling score accuracy -- did high-score signals win more?
    // Bucketed by decile: 0-10 pts above neutral, 10-20, 20-30, 30-40, 40-50
    int   scoreBucketTrades[5];
    int   scoreBucketWins[5];
    double scoreBucketWR[5];      // If top bucket WR >> bottom -> score is discriminating

    // Self-calibrated threshold
    double liveOptimalThreshold;   // Learned from score bucket discrimination
    double liveThresholdConfidence;// 0-1: how much to weight vs formal calibration

    // Candle anatomy live accuracy
    double anatomyLiveWR[16];     // Live WR per anatomy: 14 named + [14]=conv bull + [15]=conv bear
    int    anatomyLiveTrades[16];
    int    anatomyLiveWins[16];

    // Overall health
    int   totalLiveTrades;
    double liveWR30;              // Rolling 30-trade WR
    double liveEdgeScore;         // 0-1: how much edge the system is demonstrating live
    bool  selfCalibrated;         // True after 30+ trades in at least 2 regimes
    datetime lastUpdate;
};
LiveAdaptiveState g_LiveAdaptive;

// Slingshot trigger mode constants (file-scope for MQL4 compatibility)
#define SLING_EARLY   0   // Pre-emptive: 2 consecutive bad days
#define SLING_EQUITY  1   // Reactive: equity drawdown >= threshold
#define SLING_CRISIS  2   // Last resort: ghost failed + equity still down

struct SlingshotState {
    // === ACTIVATION & TIMING ===
    bool isActive;
    datetime activationTime;
    datetime lastCheck;
    bool canActivate;
    int activationCount;          // Total activations this session

    // === TRIGGER INTELLIGENCE ===
    int triggerMode;   // use SLING_EARLY/SLING_EQUITY/SLING_CRISIS constants
    bool ghostWasActive;          // True if ghost mode preceded this activation
    int ghostTradesBeforeActivation; // How many ghost trades ran before slingshot
    double ghostWRBeforeActivation;  // Ghost WR when slingshot took over
    bool postGhostMode;           // Running in tandem awareness with ghost history
    int consecutiveFailedRecoveries; // Slingshot fired but didn't recover -- escalate

    // === DRAWDOWN & BALANCE TRACKING ===
    double startDrawdown;
    double drawdownStartBalance;
    double recoveryTarget;

    // === PERFORMANCE TRACKING ===
    int tradesInSlingshot;
    int slingshotWins;
    int slingshotLosses;
    double slingshotProfit;

    // === LEARNING & INTELLIGENCE ===
    string drawdownCause;
    string activationReason;
    bool learningComplete;
    double normalThresholdAdjustment;
    double aggressiveThresholdAdjustment;
    string fixApplied;

    // === DEEP RECAL ESCALATION ===
    bool escalatedToDeepRecal;    // Slingshot exhausted -- deep recal triggered
    // Post-slingshot proven-edge conservative window (20 trades at 80% risk)
    bool   provenEdgeWindowActive;   // Conservative 20-trade period after success
    int    provenEdgeTradesLeft;     // Countdown to full parameter restoration
    double provenEdgeWinCount;       // Wins in window
    double provenEdgeLossCount;      // Losses in window
    datetime deepRecalTriggeredAt;
};

SlingshotState g_Slingshot;

// Post-Load Alignment Check Results

struct PostLoadCheck {
    bool performed;                  // Check was performed
    datetime checkTime;              // When check ran
    int barsAnalyzed;               // Sample size used
    double currentAccuracy;          // Accuracy in current market
    double savedAccuracy;            // Accuracy from saved state
    double accuracyDeviation;        // Percentage difference
    AlignmentStatus status;          // Result of check
    int adjustmentsMade;             // How many boundaries adjusted
};

PostLoadCheck g_PostLoadCheck;

// Drawdown analysis results
struct DrawdownAnalysis {
    bool trendReversed;           // Market reversed direction
    bool volatilityChanged;       // ATR regime changed
    bool sessionProblem;          // Specific session underperforming
    bool componentFailed;         // Specific component not working
    bool spreadIncreased;         // Spread conditions worsened
    bool falseBreakouts;          // Breakout signals failing
    
    string primaryCause;          // Main reason
    string secondaryCause;        // Secondary factor
    double confidenceLevel;       // How sure we are
};

DrawdownAnalysis g_DrawdownAnalysis;

//| Analyze what caused the drawdown                                 |
void ActivateSlingshotWithMode(int mode);  // forward decl -- defined after ActivateHybridSlingshot
void AnalyzeDrawdownCause() {
    // Initialize
    g_DrawdownAnalysis.primaryCause = "";
    g_DrawdownAnalysis.secondaryCause = "";
    g_DrawdownAnalysis.confidenceLevel = 0.0;
    
    // Check 1: Trend reversal
    double ma20_current = iMA(NULL, PERIOD_H1, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
    double ma50_current = iMA(NULL, PERIOD_H1, 50, 0, MODE_EMA, PRICE_CLOSE, 0);
    double ma20_start = iMA(NULL, PERIOD_H1, 20, 0, MODE_EMA, PRICE_CLOSE, 20);
    double ma50_start = iMA(NULL, PERIOD_H1, 50, 0, MODE_EMA, PRICE_CLOSE, 20);
    
    bool wasAbove = ma20_start > ma50_start;
    bool nowBelow = ma20_current < ma50_current;
    if((wasAbove && nowBelow) || (!wasAbove && !nowBelow)) {
        g_DrawdownAnalysis.trendReversed = true;
        g_DrawdownAnalysis.primaryCause = "TREND_REVERSAL";
        g_DrawdownAnalysis.confidenceLevel = 0.85;
    }
    
    // Check 2: Volatility regime change
    double currentATR = iATR(NULL, PERIOD_H1, 14, 0);
    double historicalATR = 0.0;
    for(int i = 20; i < 50; i++) {
        historicalATR += iATR(NULL, PERIOD_H1, 14, i);
    }
    historicalATR /= 30.0;
    
    double atrRatio = historicalATR > 0 ? currentATR / historicalATR : 1.0;
    if(atrRatio > 2.0 || atrRatio < 0.5) {
        g_DrawdownAnalysis.volatilityChanged = true;
        if(g_DrawdownAnalysis.primaryCause == "") {
            g_DrawdownAnalysis.primaryCause = "VOLATILITY_SPIKE";
            g_DrawdownAnalysis.confidenceLevel = 0.75;
        } else {
            g_DrawdownAnalysis.secondaryCause = "VOLATILITY_CHANGE";
        }
    }
    
    // Check 3: Session performance degradation
    if(g_AsianTrades > 5) {
        double asianWR = (g_AsianTrades > 0) ? (double)g_AsianWins / NonZero(g_AsianTrades) : 0.0;
        if(asianWR < 0.45) {
            g_DrawdownAnalysis.sessionProblem = true;
            if(g_DrawdownAnalysis.primaryCause == "") {
                g_DrawdownAnalysis.primaryCause = "ASIAN_SESSION_LOSSES";
                g_DrawdownAnalysis.confidenceLevel = 0.70;
            }
        }
    }
    
    // Check 4: Spread increase
    double currentSpread = (Ask - Bid) / Point;
    double avgSpread = 1.5; // Typical
    if(currentSpread > avgSpread * 2.0) {
        g_DrawdownAnalysis.spreadIncreased = true;
        if(g_DrawdownAnalysis.primaryCause == "") {
            g_DrawdownAnalysis.primaryCause = "SPREAD_INCREASE";
            g_DrawdownAnalysis.confidenceLevel = 0.65;
        }
    }
    
    // Default if nothing specific found
    if(g_DrawdownAnalysis.primaryCause == "") {
        g_DrawdownAnalysis.primaryCause = "VARIANCE";
        g_DrawdownAnalysis.confidenceLevel = 0.50;
    }
    
    g_Slingshot.drawdownCause = g_DrawdownAnalysis.primaryCause;

    // FIX9: Bridge DrawdownForensics from DrawdownAnalysis results
    if(g_DrawdownAnalysis.primaryCause == "TREND_REVERSAL" ||
       g_DrawdownAnalysis.primaryCause == "VOLATILITY_SPIKE") {
        int _worstReg = 0;
        for(int _r = 1; _r < 9; _r++)
            if(g_DrawdownForensics.lossRegimes[_r] > g_DrawdownForensics.lossRegimes[_worstReg]) _worstReg = _r;
        if(g_DrawdownForensics.lossRegimes[_worstReg] >= 3)
            g_DrawdownForensics.blacklistedRegime = _worstReg;
    }
    if(g_DrawdownAnalysis.primaryCause == "ASIAN_SESSION_LOSSES")
        g_DrawdownForensics.blacklistedSession = 3;
    if(g_DrawdownForensics.consecutiveLosses >= 5)
        g_DrawdownForensics.temporaryThreshold = MathMin(82.0,
            GetLearnedOptimalThreshold() + (double)g_DrawdownForensics.consecutiveLosses * 1.5);
    g_DrawdownForensics.inDrawdown = (g_DrawdownForensics.consecutiveLosses >= 3);
    g_DrawdownForensics.analysisTime = TimeCurrent();
}

//| Apply adaptive fixes based on analysis                           |
void ApplyAdaptiveFixes() {
    string fixDescription = "";
    
    if(g_DrawdownAnalysis.primaryCause == "TREND_REVERSAL") {
        // Raise threshold for normal mode - market less predictable
        g_Slingshot.normalThresholdAdjustment = 5.0;
        g_Slingshot.aggressiveThresholdAdjustment = 8.0;
        fixDescription = "Raised normal threshold +5 (trend instability)";
        
    } else if(g_DrawdownAnalysis.primaryCause == "VOLATILITY_SPIKE") {
        // Raise threshold - need stronger signals in volatile conditions
        g_Slingshot.normalThresholdAdjustment = 8.0;
        g_Slingshot.aggressiveThresholdAdjustment = 10.0;
        fixDescription = "Raised thresholds +8/+10 (high volatility)";
        
    } else if(g_DrawdownAnalysis.primaryCause == "ASIAN_SESSION_LOSSES") {
        // Increase Asian session threshold only
        g_Slingshot.normalThresholdAdjustment = 3.0;
        fixDescription = "Raised Asian session threshold +10";
        
    } else if(g_DrawdownAnalysis.primaryCause == "SPREAD_INCREASE") {
        // Raise threshold - need more edge to overcome spread
        g_Slingshot.normalThresholdAdjustment = 5.0;
        fixDescription = "Raised threshold +5 (spread compensation)";
        
    } else {
        // Variance - minor adjustment
        g_Slingshot.normalThresholdAdjustment = 2.0;
        fixDescription = "Minor threshold +2 (variance adaptation)";
    }
    
    g_Slingshot.fixApplied = fixDescription;
    g_Slingshot.learningComplete = true;
}

//| Activate Hybrid Slingshot Mode                                   |

//| Pre-Optimization: Try to self-correct before buffalo mode        |
bool TryPreOptimization() {
    // When approaching drawdown trigger, try optimization first
    // This gives system a chance to self-correct without going survival
    
    if(g_State.currentDrawdown < RecoveryDrawdownTrigger - 2.0) {
        return false; // Not close enough to trigger
    }
    
    static bool preOptAttempted = false;
    static datetime lastPreOptTime = 0;
    
    // Only attempt once per session approaching drawdown
    if(preOptAttempted && TimeCurrent() - lastPreOptTime < 3600) {
        return false;
    }
    
    preOptAttempted = true;
    lastPreOptTime = TimeCurrent();
    
    // Calculate recent performance
    int recentTrades = g_DailyWins + g_DailyLosses;
    if(recentTrades < 5) return false; // Need data
    
    double recentWR = (recentTrades > 0) ? (double)g_DailyWins / recentTrades : 0.0;
    
    // Apply smart adjustments
    if(recentWR < 0.60) {
        // Win rate declining - raise threshold
        g_CurrentThreshold += 8.0;
        
        if(EnableFriendlyLogs) {
            PrintEmptyLine();
        PrintFormat("  pre-optimisation   |   DD -%.1f%%   |   threshold raised   |   selectivity increased", g_State.currentDrawdown);
            PrintEmptyLine();
            PrintEmptyLine();
        }
        return true;
    }
    
    return false;
}

//| Quick optimization pass before entering buffalo mode             |
void PreBuffaloOptimization() {
    // OPTIMIZED: Analyze last 30 trades (was 20) for better insights
    int sampleSize = 30;
    if(g_State.totalTrades < sampleSize) sampleSize = g_State.totalTrades;
    if(sampleSize < 10) return; // Need minimum data
    
    int wins = 0;
    double totalProfit = 0;
    double totalLoss = 0;
    
    // SLS23 FIX: was reading fixed slots [0..sampleSize-1] instead of the ring-buffer's actual last N trades
    for(int i = 0; i < sampleSize; i++) {
        int _idx_pb20856 = ((g_State.resultIndex - 1 - i) + 100) % 100;
        double result = g_State.lastTradeResults[_idx_pb20856];
        if(result > 0) {
            wins++;
            totalProfit += result;
        } else {
            totalLoss += MathAbs(result);
        }
    }

    double winRate = (double)wins / (double)sampleSize * 100.0;
    double profitFactor = (totalLoss > 0) ? totalProfit / totalLoss : 1.0;
    
    if(EnableFriendlyLogs) {
        PrintFormat("  SLING |   recovery scan   |   WR %.0f%%   |   assessing component performance", winRate);
    }
    
    // OPTIMIZATION 1: If WR catastrophically low, emergency threshold boost
    if(winRate < 40.0) {
        g_BaseThreshold += 8.0;
        if(EnableFriendlyLogs) {
            PrintFormat("  SLING |   recovery   |   WR %.0f%% critical   |   threshold +8 - %.0f   |   edge protection active", winRate, g_BaseThreshold);
        }
    } else if(winRate < 50.0) {
        g_BaseThreshold += 5.0;
        if(EnableFriendlyLogs) {
            PrintFormat("  SLING |   recovery   |   WR %.0f%% below 50%%   |   threshold +5 - %.0f", winRate, g_BaseThreshold);
        }
    }
    
    // OPTIMIZATION 2: Identify top 2 failing factors (not just 1)
    double momentumWR = AnalyzeComponentPerformance("Momentum", sampleSize);
    double reversalWR = AnalyzeComponentPerformance("Reversal", sampleSize);
    double volatilityWR = AnalyzeComponentPerformance("Volatility", sampleSize);
    double directionalWR = AnalyzeComponentPerformance("Directional", sampleSize);
    
    // Find worst two components
    double worst1 = 100.0, worst2 = 100.0;
    string worst1Name = "", worst2Name = "";
    
    // SLS23 FIX: each check only compared against worst1, so a value that wasn't the new overall
    // worst but WAS lower than the current worst2 (e.g. 10,3,5,8 in this order) never got a chance
    // to displace worst2, leaving the wrong "second-worst" component de-weighted below.
    if(momentumWR < worst1) { worst2 = worst1; worst2Name = worst1Name; worst1 = momentumWR; worst1Name = "Momentum"; }
    else if(momentumWR < worst2) { worst2 = momentumWR; worst2Name = "Momentum"; }
    if(reversalWR < worst1) { worst2 = worst1; worst2Name = worst1Name; worst1 = reversalWR; worst1Name = "Reversal"; }
    else if(reversalWR < worst2) { worst2 = reversalWR; worst2Name = "Reversal"; }
    if(volatilityWR < worst1) { worst2 = worst1; worst2Name = worst1Name; worst1 = volatilityWR; worst1Name = "Volatility"; }
    else if(volatilityWR < worst2) { worst2 = volatilityWR; worst2Name = "Volatility"; }
    if(directionalWR < worst1) { worst2 = worst1; worst2Name = worst1Name; worst1 = directionalWR; worst1Name = "Directional"; }
    else if(directionalWR < worst2) { worst2 = directionalWR; worst2Name = "Directional"; }
    
    // De-weight both failing components
    if(worst1 < 45.0 && worst1Name != "") {
        if(worst1Name == "Momentum") g_ComponentWeights.momentum *= 0.5;
        else if(worst1Name == "Reversal") g_ComponentWeights.reversal *= 0.5;
        else if(worst1Name == "Volatility") g_ComponentWeights.volatility *= 0.5;
        else if(worst1Name == "Directional") g_ComponentWeights.directional *= 0.5;
        
        if(EnableFriendlyLogs) {
            PrintFormat("  SLING |   recovery   |   component %s   |   WR %.0f%%   |   weight halved", worst1Name, worst1);
        }
    }
    
    if(worst2 < 45.0 && worst2Name != "" && worst2Name != worst1Name) {
        if(worst2Name == "Momentum") g_ComponentWeights.momentum *= 0.5;
        else if(worst2Name == "Reversal") g_ComponentWeights.reversal *= 0.5;
        else if(worst2Name == "Volatility") g_ComponentWeights.volatility *= 0.5;
        else if(worst2Name == "Directional") g_ComponentWeights.directional *= 0.5;
        
        if(EnableFriendlyLogs) {
            PrintFormat("  SLING |   recovery   |   component %s   |   WR %.0f%%   |   weight halved", worst2Name, worst2);
        }
    }
    
    if(EnableFriendlyLogs) {
        PrintFormat("  SLING |   recovery   |   adaptation complete   |   WR %.0f%%   |   PF %.2f", winRate, profitFactor);
    }
}

enum SEQUENCE_LOCK {
    LOCK_NONE = 0,
    LOCK_DEEP_RECAL = 1,
    LOCK_BUFFALO_ACTIVATION = 2,
    LOCK_STATE_IO = 3,
    LOCK_ADAPTIVE_UPDATE = 4,
    LOCK_RELAXATION = 5
};

// Helper function for component analysis
double AnalyzeComponentPerformance(string componentName, int trades) {
    // REAL implementation: Analyze actual trade history
    if(g_State.totalTrades < 10) return 50.0;  // Not enough data yet
    
    int wins = 0;
    int total = 0;
    int lookback = MathMin(30, OrdersHistoryTotal());
    
    // Check recent trade history
    for(int i = OrdersHistoryTotal() - 1; i >= 0 && total < lookback; i--) {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
        if(OrderMagicNumber() != MagicNumber) continue;
        if(OrderSymbol() != _Symbol) continue;
        
        // Track win/loss
        if(OrderProfit() > 0) wins++;
        total++;
    }
    
    return total > 0 ? (double)wins / total * 100.0 : 50.0;
}


void ActivateHybridSlingshot() {
    ActivateSlingshotWithMode(SLING_EQUITY);
}

void ActivateSlingshotWithMode(int mode) {
    if(!AcquireLock(LOCK_BUFFALO_ACTIVATION)) return;

    // ## ESCALATION GUARD #####################################################
    // If slingshot previously failed to recover AND this is crisis mode,
    // skip straight to deep recalibration rather than firing again uselessly.
    if(g_Slingshot.consecutiveFailedRecoveries >= 2 && mode == SLING_CRISIS) {
        if(!g_Slingshot.escalatedToDeepRecal) {
            g_Slingshot.escalatedToDeepRecal = true;
            g_Slingshot.deepRecalTriggeredAt = TimeCurrent();
            Print("  slingshot exhausted   |   two failed recoveries   |   engaging deep recalibration");
            Print("  recalibrating ON TOP of existing ARMED data   |   incorporating current conditions");
            ReleaseLock();
            // Deep recal: runs on top of existing calibration to tune for current conditions
            g_DeepRecal.recalibrationNeeded = true;
            g_DeepRecal.primaryIssue = "Slingshot exhausted -- market conditions fundamentally shifted";
            ExecuteDeepRecalibration();
        }
        ReleaseLock();
        return;
    }

    PreBuffaloOptimization();

    // ## CAPTURE GHOST CONTEXT #################################################
    // If ghost mode was running before this activation, inherit its intelligence.
    // Slingshot knows WHY ghost mode failed and can adjust strategy accordingly.
    bool ghostPreceded = g_SmartCB.inGhostMode || (g_SmartCB.successfulResumes == 0 &&
                         g_SmartCB.ghostWins + g_SmartCB.ghostLosses > 0);
    double ghostWR = (g_SmartCB.ghostWins + g_SmartCB.ghostLosses > 0)
                    ? (double)g_SmartCB.ghostWins / (g_SmartCB.ghostWins + g_SmartCB.ghostLosses) * 100.0
                    : 0.0;

    g_Slingshot.isActive = true;
    g_Slingshot.triggerMode = mode;
    g_Slingshot.activationTime = TimeCurrent();
    g_Slingshot.startDrawdown = g_State.currentDrawdown;
    g_Slingshot.drawdownStartBalance = AccountBalance();
    g_Slingshot.recoveryTarget = g_State.peakBalance;
    g_Slingshot.tradesInSlingshot = 0;
    g_Slingshot.slingshotWins = 0;
    g_Slingshot.slingshotLosses = 0;
    g_Slingshot.slingshotProfit = 0.0;
    g_Slingshot.canActivate = false;
    g_Slingshot.lastCheck = TimeCurrent();
    g_Slingshot.learningComplete = false;
    g_Slingshot.ghostWasActive = ghostPreceded;
    g_Slingshot.ghostWRBeforeActivation = ghostWR;
    g_Slingshot.postGhostMode = ghostPreceded;
    g_Slingshot.escalatedToDeepRecal = false;
    g_Slingshot.activationCount++;

    // ## INTELLIGENT THRESHOLD ADJUSTMENT #####################################
    double _slAlign = GetMarketAlignment();
    double _slMod   = (_slAlign < 0.40) ? 1.5 : (_slAlign < 0.60) ? 1.2 : 1.0;
    double baseAdj = ((mode == SLING_EARLY) ? 5.0
                   : (mode == SLING_EQUITY) ? 8.0 : 12.0) * _slMod;
    if(ghostPreceded && ghostWR < 60.0) baseAdj += 5.0;
    baseAdj = MathMin(baseAdj, 20.0);  // hard cap -- never exceed 20pt above normal
    g_Slingshot.normalThresholdAdjustment = baseAdj;

    // ## RISK SCALING ##########################################################
    // EARLY mode: x1.2 (mild acceleration -- no equity damage yet)
    // EQUITY/CRISIS mode: x1.0 (no size increase -- protect capital, earn back through selectivity)
    // The old x1.2 on all modes was wrong for crisis -- don't compound a hole.
    g_Slingshot.aggressiveThresholdAdjustment = (mode == SLING_EARLY) ? 1.2 : 1.0;

    string modeStr = (mode==SLING_EARLY)?"EARLY WARNING":
                     (mode==SLING_EQUITY)?"EQUITY PROTECTION":"CRISIS";
    g_Slingshot.activationReason = modeStr + (ghostPreceded?" (post-ghost)":"");

    AnalyzeDrawdownCause();
    ApplyAdaptiveFixes();

    PrintFormat("  slingshot %s   |   DD -%.1f%%   |   ghost WR %.0f%%   |   thr +%.0fp   |   premium only",
               modeStr, g_Slingshot.startDrawdown, ghostWR, baseAdj);
    if(ghostPreceded)
        PrintFormat("  ghost context   |   %d trades at %.0f%% WR   |   cause: %s",
                   g_SmartCB.ghostWins + g_SmartCB.ghostLosses, ghostWR, g_Slingshot.drawdownCause);

    ReleaseLock();
}

//| Check if setup qualifies as "Buffalo" (80+)                      |
bool IsBuffaloSetup(double score) {
    // Buffalo = 70+ score = Premium opportunity
    // Lowered from 80 for faster recovery
    return MathAbs(score) >= BuffaloMinScore;
}

//| Calculate how many positions for this buffalo                    |

//| Execute multiple positions with MT4-safe timing                  |
// [SLS13 C3] retired dead function ExecuteBuffaloTrade (83 lines, zero refs)

//| Update slingshot progress                                        |
void UpdateSlingshotProgress(bool wasWin, double rMultiple) {
    if(!g_Slingshot.isActive) return;
    
    if(wasWin) {
        g_Slingshot.slingshotWins++;
    } else {
        g_Slingshot.slingshotLosses++;
    }
    
    // Check if recovered
    double currentBalance = AccountBalance();
    double recoveryProgress = ((currentBalance - g_Slingshot.drawdownStartBalance) / 
                               (g_Slingshot.recoveryTarget - g_Slingshot.drawdownStartBalance)) * 100.0;
    
    if(currentBalance >= g_Slingshot.recoveryTarget) {
        // RECOVERY COMPLETE!
        DeactivateHybridSlingshot(true);
    } else if(TimeCurrent() - g_Slingshot.activationTime > 86400 * 7) {
        // Been in slingshot for 7 days - something wrong, return to normal
        DeactivateHybridSlingshot(false);
    } else {
        // Progress update (every 25%)
        if(ShowOptimizationLogs && recoveryProgress > 0 && 
           (int)recoveryProgress % 25 == 0 && EnableFriendlyLogs) {
            
            static double lastProgressLog = 0;
            if(MathAbs(recoveryProgress - lastProgressLog) >= 24.0) {
                PrintEmptyLine();
                PrintFormat("  SLING |   recovery %.0f%%   |   %d trades   |   %dW/%dL   |   $%.0f of $%.0f",
                           recoveryProgress, g_Slingshot.tradesInSlingshot,
                           g_Slingshot.slingshotWins, g_Slingshot.slingshotLosses,
                           currentBalance, g_Slingshot.recoveryTarget);
                PrintEmptyLine();
                lastProgressLog = recoveryProgress;
            }
        }
    }
}

//| Deactivate slingshot and return to smarter normal mode           |
void DeactivateHybridSlingshot(bool successful) {
    if(!g_Slingshot.isActive) return;
    
    g_Slingshot.isActive = false;
    
    if(EnableFriendlyLogs) {
        double _rWR2 = (g_Slingshot.slingshotWins + g_Slingshot.slingshotLosses > 0) ?
                        (double)g_Slingshot.slingshotWins /
                        (g_Slingshot.slingshotWins + g_Slingshot.slingshotLosses) * 100 : 0;
        PrintFormat("  %s   |   %d trades   |   %.0f%% WR   |   %.1f hours",
                   successful?"recovered":"timeout", g_Slingshot.tradesInSlingshot, _rWR2,
                   (TimeCurrent() - g_Slingshot.activationTime) / 3600.0);
    }
    
    // Apply learned adjustments to normal thresholds
    g_BaseThreshold += g_Slingshot.normalThresholdAdjustment;
    g_CurrentThreshold = g_BaseThreshold;
    
    // Reset state to normal
    g_State.currentState = STATE_NORMAL;
}


