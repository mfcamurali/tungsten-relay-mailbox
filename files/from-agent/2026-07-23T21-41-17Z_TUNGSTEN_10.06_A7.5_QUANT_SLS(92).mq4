double g_CompLossAcc[9][6];  // [regime][component]
int    g_CompWinCount[9];    // wins per regime
int    g_CompLossCount[9];   // losses per regime
// EMA-based recency: components tracked with exponential decay
// alpha=0.1: 10% weight to newest trade, 90% to history
// This prevents ancient data from locking in wrong conclusions
#define COMP_EMA_ALPHA  0.10
double g_CompWinEMA[9][6];   // EMA of component scores on wins
double g_CompLossEMA[9][6];  // EMA of component scores on losses
