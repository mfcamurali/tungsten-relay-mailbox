    predictiveSystem.predictedTrend = 0.0;
    predictiveSystem.predictedRange = 0.0;
    
    predictiveSystem.predictedPatternType = 0;
    predictiveSystem.predictedPatternStrength = 0;
    predictiveSystem.patternPredictionConfidence = 0.5;
    predictiveSystem.patternFormationProbability = 0.5;
    predictiveSystem.breakoutImminent = false;
    predictiveSystem.reversalImminent = false;
    
