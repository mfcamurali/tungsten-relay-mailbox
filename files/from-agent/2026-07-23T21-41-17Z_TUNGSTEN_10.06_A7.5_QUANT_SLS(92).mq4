    regimeStrategies[10].riskTolerance = 1.3;
    regimeStrategies[10].allowAggressive = true;
    
    // UNDEFINED (11) - VERY DEFENSIVE
    regimeStrategies[11].maxPositionSize = 0.7;       // Small positions
    regimeStrategies[11].maxRiskPercent = 1.0;
    regimeStrategies[11].requiredEdgeStrength = 0.35; // FIX: Realistic - undefined = cautious
    regimeStrategies[11].momentumWeight = 1.0;
    regimeStrategies[11].reversalWeight = 1.0;
    regimeStrategies[11].volatilityWeight = 1.0;
    regimeStrategies[11].biasWeight = 1.0;
    regimeStrategies[11].patternWeight = 1.0;
    regimeStrategies[11].predictiveWeight = 1.0;
