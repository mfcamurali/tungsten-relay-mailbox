    regimeStrategies[9].riskTolerance = 0.7;          // LOW risk tolerance
    regimeStrategies[9].allowAggressive = false;
    
    // MICRO BREAKOUT (10) - Aggressive but with confirmation
    regimeStrategies[10].maxPositionSize = 1.5;       // Can be aggressive
    regimeStrategies[10].maxRiskPercent = 1.6;
    regimeStrategies[10].requiredEdgeStrength = 0.35; // FIX: Realistic - breakouts have good clarity
    regimeStrategies[10].momentumWeight = 1.8;
    regimeStrategies[10].reversalWeight = 0.5;
