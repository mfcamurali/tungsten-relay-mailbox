    regimeStrategies[3].maxRiskPercent = 1.2;
    regimeStrategies[3].requiredEdgeStrength = 0.28;  // FIX: Lowered from 0.32 to 0.28
    regimeStrategies[3].momentumWeight = 1.0;
    regimeStrategies[3].reversalWeight = 1.0;
    regimeStrategies[3].volatilityWeight = 1.0;
    regimeStrategies[3].biasWeight = 1.0;
