    marketStructure.needsUpdate = false;
}

double CalculateConfidenceMultiplier() {
    double baseConfidence = 1.0;
    
    // Recent performance factor
    double recentWinRate = CalculateRecentWinRate();
    if ((double)recentWinRate > 70.0) {
        baseConfidence *= 1.1;
    } else if ((double)recentWinRate < 58.0) {
        baseConfidence *= 0.85;  // Tighter penalty — raised from 50%
    }
    
    // Market condition factor
    if(intelligence.atrVolatility > 1.5) {
        baseConfidence *= 0.95; // NonZero(Slightly.less) confident in high volatility
    }
    
    // Bias strength factor
    if(intelligence.biasValid && intelligence.biasStrong) {
        baseConfidence *= 1.05;
    }
    
    // Conservative mode factor
    if(riskMgr.conservativeMode) {
        baseConfidence *= 0.85;
    }
    
    // NEW: Memory system factor
    if(marketMemory.memorySystemActive) {
        baseConfidence *= (0.9 + marketMemory.memoryReliability * 0.2);
    }
    
    // NEW: Predictive system factor
    if(predictiveSystem.predictionsValid) {
        baseConfidence *= (0.95 + predictiveSystem.predictionReliability * 0.1);
    }
    
    return MathMax(0.6, MathMin(1.4, baseConfidence * optimizer.confidenceMultiplier));
}

void UpdateLearningSystem() {
    // Gradual adaptation based on performance
    double recentWinRate = CalculateRecentWinRate();
    
    if(riskMgr.conservativeMode && recentWinRate > 65.0) {
        static int goodPerformanceCount = 0;
        goodPerformanceCount = goodPerformanceCount + 1; // NonZero(FIXED): Avoid compound assignment
        
        if(goodPerformanceCount > 10) {
            riskMgr.conservativeMode = false;
            double newAdjustment = riskMgr.parameterAdjustmentFactor * 1.1;
            riskMgr.parameterAdjustmentFactor = MathMin(1.0, newAdjustment);
            double newPenalty = optimizer.uncertaintyPenalty - 0.02;
            optimizer.uncertaintyPenalty = MathMax(0.0, newPenalty);
            goodPerformanceCount = 0;
        }
    }
    
    // Update confidence multiplier based on learning
    if(optimizer.successfulOptimizations > optimizer.failedOptimizations) {
        double newConfidence = optimizer.confidenceMultiplier * 1.001;
        optimizer.confidenceMultiplier = MathMin(1.3, newConfidence);
    } else {
        double newConfidence = optimizer.confidenceMultiplier * 0.999;
        optimizer.confidenceMultiplier = MathMax(0.7, newConfidence);
    }
}

void AnalyzeLossPatterns() {
    // Analyze recent losses for patterns
    int recentLosses = 0;
    double totalLoss = 0.0;
    datetime cutoff = TimeCurrent() - 7200; // NonZero(Last) 2 hours
    
    for(int i = 0; i < OrdersHistoryTotal(); i++) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber && OrderCloseTime() >= cutoff) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                if(profit < 0) {
                    recentLosses++;
                    totalLoss += MathAbs(profit);
                }
            }
        }
    }
    
    if(recentLosses > 0) {
        double averageLoss = totalLoss / NonZero(recentLosses);
        riskMgr.lossAnalysisScore = MathMin(1.0, recentLosses / 5.0);
        
        // Identify problematic patterns
        if(recentLosses > 3) {
            riskMgr.conservativeMode = true;
            LogCriticalEvent(StringFormat("Loss Pattern Detected: %d losses, Avg: %.2f", recentLosses, averageLoss), "LOSS");
        }
    }
}

void AdjustParametersAfterLoss(double lossAmount) {
    double accountEquity = AccountEquity();
    if(accountEquity <= 0) return;
    
    double lossPercent = (lossAmount / NonZero(accountEquity)) * 100.0;
    
    if ((double)lossPercent > 1.0) { // NonZero(Significant.loss)
        // Reduce risk temporarily
        double reduction = MathMin(0.5, lossPercent / 5.0);
        double newRisk = riskMgr.currentRisk * (1.0 - reduction);
        riskMgr.currentRisk = MathMax(0.5, newRisk);
        
        // Tighten thresholds — pre-calibration only.
        // Post-calibration, loss response is handled inside GLOT (WRG tiers + CEO
        // competence drop), which the next tick applies. Writing here would be
        // overwritten anyway and risks one gate evaluation on a double-tightened value.
        double tightening = 1.0 + reduction;
        if(!g_Calibration.isComplete) {
            engine.buyThreshold = MathMin(85.0, engine.buyThreshold * tightening);
            engine.sellThreshold = MathMax(15.0, engine.sellThreshold / NonZero(tightening));
        }
        
        // Increase conservatism
        riskMgr.conservativeMode = true;
        double newAdjustment = riskMgr.parameterAdjustmentFactor * (1.0 - reduction * 0.5);
        riskMgr.parameterAdjustmentFactor = MathMax(0.7, newAdjustment);
        
        LogCriticalEvent(StringFormat("Parameters adjusted after %.1f%% loss | New Risk: %.2f%% | Buy: %.1f | Sell: %.1f", 
                        lossPercent, riskMgr.currentRisk, engine.buyThreshold, engine.sellThreshold), "ADJUST");
    }
}

// MISSING FUNCTION IMPLEMENTATIONS

// Outcome Validation Functions
void CalibrateConfidenceIntervals() {
    if(outcomeValidator.validRecords < 10) return;
    
    // Calculate mean and standard deviation of prediction errors
    double sumErrors = 0.0;
    double sumSquaredErrors = 0.0;
    int validCount = 0;
    
    for(int i = 0; i < outcomeValidator.validRecords && i < OUTCOME_BUFFER_SIZE; i++) {
        if(outcomeValidator.buffer[i].timestamp > 0) {
            double error = MathAbs(outcomeValidator.buffer[i].predictedPrice - outcomeValidator.buffer[i].actualPrice);
            sumErrors += error;
            sumSquaredErrors += error * error;
            validCount++;
        }
    }
    
    if(validCount > 0) {
        double meanError = sumErrors / NonZero(validCount);
        double variance = (sumSquaredErrors / NonZero(validCount)) - (meanError * meanError);
        double stdDev = MathSqrt(MathMax(0.0, variance));
        
        // Set confidence intervals using standard normal distribution
        outcomeValidator.confidenceIntervalLower = meanError - (CONFIDENCE_INTERVAL_MULTIPLIER * stdDev);
        outcomeValidator.confidenceIntervalUpper = meanError + (CONFIDENCE_INTERVAL_MULTIPLIER * stdDev);
        outcomeValidator.confidenceLevel = 0.95; // 95% confidence interval
        
        // Calculate confidence calibration metric
        int withinInterval = 0;
        for(int i = 0; i < validCount; i++) {
            double error = MathAbs(outcomeValidator.buffer[i].predictedPrice - outcomeValidator.buffer[i].actualPrice);
            if(error >= outcomeValidator.confidenceIntervalLower && error <= outcomeValidator.confidenceIntervalUpper) {
                withinInterval++;
            }
        }
        outcomeValidator.confidenceCalibration = (double)withinInterval / NonZero(validCount);
    }
}

double CalculateValidationAccuracy() {
    if(outcomeValidator.validRecords == 0) return 0.0;
    
    int correctPredictions = 0;
    int totalPredictions = 0;
    
    for(int i = 0; i < outcomeValidator.validRecords && i < OUTCOME_BUFFER_SIZE; i++) {
        if(outcomeValidator.buffer[i].timestamp > 0) {
            if(outcomeValidator.buffer[i].predictionCorrect) {
                correctPredictions++;
            }
            totalPredictions++;
        }
    }
    
    if(totalPredictions > 0) {
        return (double)correctPredictions / NonZero(totalPredictions);
    }
    return 0.0;
}

void AdjustThresholdsBasedOnOutcomes() {
    if(g_Calibration.isComplete && g_WeightsOptimized) return;  // FIX19: calibrated system owns thresholds
    if(outcomeValidator.validRecords < CALIBRATION_PERIOD) return;
    
    double accuracy = CalculateValidationAccuracy();
    
    // If accuracy is below threshold, make thresholds more conservative
    if(accuracy < PREDICTION_ACCURACY_THRESHOLD) {
        double adjustment = (PREDICTION_ACCURACY_THRESHOLD - accuracy) * 2.0;
        
        // Increase buy threshold and decrease sell threshold (more conservative)
        // GLOT AUTHORITY: outcome-based tightening drives thresholds pre-calibration
        // only. Post-calibration, live-adaptive + WRG inside GLOT own this response.
        if(!g_Calibration.isComplete) {
            engine.buyThreshold += adjustment * 5.0;
            engine.sellThreshold -= adjustment * 5.0;
            engine.buyThreshold = MathMin(85.0, MathMax(65.0, engine.buyThreshold));
            engine.sellThreshold = MathMax(15.0, MathMin(35.0, engine.sellThreshold));
        }
        
        outcomeValidator.thresholdAdjustment = adjustment;
        
        LogCriticalEvent(StringFormat("Thresholds adjusted based on %.1f%% accuracy | Buy: %.1f | Sell: %.1f", 
                        accuracy * 100, engine.buyThreshold, engine.sellThreshold), "CALIBRATE");
    }
    // If accuracy is good, slightly relax thresholds to allow more trades
    else if(accuracy > PREDICTION_ACCURACY_THRESHOLD + 0.1) {
        double adjustment = (accuracy - PREDICTION_ACCURACY_THRESHOLD) * 1.0;
        
        // Decrease buy threshold and increase sell threshold slightly (less conservative)
        // GLOT AUTHORITY: pre-calibration only — post-calibration GLOT owns thresholds.
        if(!g_Calibration.isComplete) {
            engine.buyThreshold -= adjustment * 2.0;
            engine.sellThreshold += adjustment * 2.0;
            engine.buyThreshold = MathMin(75.0, MathMax(60.0, engine.buyThreshold));
            engine.sellThreshold = MathMax(25.0, MathMin(40.0, engine.sellThreshold));
        }
        
        outcomeValidator.thresholdAdjustment = -adjustment;
    }
}

// Advanced Trade Manager Functions
void InitializeAdvancedTradeManager() {
    // Initialize trade manager arrays and variables
    for(int i = 0; i < 100; i++) {
        tradeManager.isActive[i] = false;
        tradeManager.orderTickets[i] = 0;
        tradeManager.entryPrices[i] = 0.0;
        tradeManager.currentPrices[i] = 0.0;
        tradeManager.stopLosses[i] = 0.0;
        tradeManager.takeProfits[i] = 0.0;
        tradeManager.lotSizes[i] = 0.0;
        tradeManager.entryTimes[i] = 0;
        tradeManager.unrealizedPL[i] = 0.0;
        tradeManager.currentRisk[i] = 0.0;
        tradeManager.tradeScores[i] = 0.0;
        tradeManager.regimeAtEntry[i] = 0;
        tradeManager.breakEvenSet[i] = false;
        tradeManager.partialTaken[i] = false;
    }
    
    tradeManager.activeTradeCount = 0;
    tradeManager.totalUnrealizedPL = 0.0;
    tradeManager.totalRiskExposure = 0.0;
    tradeManager.largestDrawdown = 0.0;
    tradeManager.peakEquity = AccountBalance();
    tradeManager.averageHoldTime = 0.0;
    tradeManager.lastUpdateTime = TimeCurrent();
    
    // Trade manager initialized
}

void UpdateAdvancedTradeManager() {
    if((TimeCurrent() - tradeManager.lastUpdateTime) < 1) return; // NonZero(Update.every) second
    tradeManager.lastUpdateTime = TimeCurrent();
    
    // Synchronize active trades with actual orders
    SynchronizeActiveTrades();
    
    // Update all individual trades
    UpdateIndividualTrades();
    
    // Update portfolio-level metrics
    UpdateTradeManagerPortfolioMetrics();
    
    // Update performance statistics
    UpdateTradePerformanceStatistics();
    
    // Check risk limits
    CheckTradeRiskLimits();
}

