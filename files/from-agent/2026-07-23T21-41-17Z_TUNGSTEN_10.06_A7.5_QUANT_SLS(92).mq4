// LAYER 1: CREATIVE ADAPTATION - Learns patterns beyond 12 predefined regimes
struct PatternEvolution {
    // Temporal pattern drift detection
    double baselineVolatility;           // Established volatility norm
    double baselineSpread;               // Established spread norm
    double baselineMomentum;             // Established momentum norm
    double driftThreshold;               // When to trigger adaptation
    bool patternDriftDetected;           // Market behaving abnormally
    
    // Adaptive hybrid regimes (when market doesn't fit predefined)
    bool useAdaptiveRegime;              // Enable hybrid regime mode
    double adaptiveEdgeAdjustment;       // Edge modifier for hybrid conditions
    double adaptiveStopMultiplier;       // Custom stop for weird markets
    int consecutiveAnomalies;            // Count of unusual behaviors
    
    // New pattern learning
    string emergingPattern;              // Detected new pattern name
    double emergingPatternEdge;          // Edge for this new pattern
    int emergingPatternOccurrences;      // How many times seen
    double emergingPatternWinRate;       // Performance of new pattern
};

// LAYER 2: INTELLIGENT CURRENCY STRENGTH & CROSS-PAIR VALIDATION
// Professional-grade currency market intelligence
struct MultiAssetIntelligence {
    // CURRENCY STRENGTH ANALYSIS (The Game Changer)
    
    // Current pair decomposition
    string baseCurrency;              // e.g., "EUR" from EURUSD
    string quoteCurrency;             // e.g., "USD" from EURUSD
    bool pairDecomposed;              // Successfully identified
    
    // Synthetic currency strength indices (-1 to +1, updated every 5min)
    double USD_strength;
    double EUR_strength;
    double GBP_strength;
    double JPY_strength;
    double CHF_strength;
    double AUD_strength;
    double CAD_strength;
    
    // Cross-pair validation (auto-detected based on main pair)
    string cross1, cross2, cross3, cross4;  // Validation symbols
    bool cross1_avail, cross2_avail, cross3_avail, cross4_avail;
    double cross1_signal, cross2_signal, cross3_signal, cross4_signal;
    
    // Intelligent validation results
    bool baseGenuinelyStrong;         // Base currency truly strong
    bool quoteGenuinelyWeak;          // Quote currency truly weak
    double crossPairAgreement;        // 0-1: Cross-pair confirmation
    double currencyDivergence;        // 0-1: Pair vs currency strength mismatch
    
    // Edge adjustments from currency intelligence
    double strengthConfirmationBonus;  // Bonus when currencies align
    double divergencePenalty;          // Penalty when they contradict
    
    // LEGACY MULTI-ASSET (Gold, SPX, Oil - Still Useful)
    bool correlationEnabled;
    string goldSymbol;
    string spxSymbol;
    string oilSymbol;
    double goldCorrelation;
    double spxCorrelation;
    double oilCorrelation;
    datetime lastCorrelationUpdate;
    bool riskOffDetected;
    bool riskOnDetected;
    double systemicRiskScore;
    double correlationBreakdown;
    double correlationEdgeBonus;
    double correlationEdgePenalty;
};

// LAYER 3: ALGORITHMIC INTUITION - "Something feels wrong" detector
struct AlgorithmicIntuition {
    // Market health composite score
    double marketHealthScore;            // 0-1, health of market conditions
    double volumeAnomalyScore;           // Unusual volume patterns
    double spreadAnomalyScore;           // Unusual spread behavior
    double volatilityAnomalyScore;       // Unusual volatility spikes
    double priceActionAnomalyScore;      // Unusual candle patterns
    
    // Confidence erosion (death by 1000 cuts)
    int microRedFlags;                   // Count of small warning signs
    double confidenceErosion;            // Cumulative confidence penalty
    bool intuitionWarning;               // Multiple subtle signals = caution
    
    // Statistical outlier detection
    double zScore_spread;                // How many std devs from normal
    double zScore_volatility;            // How many std devs from normal
    double zScore_momentum;              // How many std devs from normal
    bool extremeOutlierDetected;         // 3+ sigma event happening
    
    // Hidden divergences (subtle disagreements)
    bool priceVsMomentumDivergence;      // Price up but momentum down
    bool volumeVsPriceDivergence;        // Price move without volume
    bool shortTermVsLongTermDivergence;  // M5 vs H1 fighting
    int totalDivergences;                // Count of all divergences
};

