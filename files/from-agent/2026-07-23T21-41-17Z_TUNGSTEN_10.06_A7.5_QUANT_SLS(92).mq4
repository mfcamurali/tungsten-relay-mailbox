            bestWeights.trainingWR=trainWR;bestWeights.validationWR=valWR;
            bestWeights.sampleSize=tw+tl;bestWeights.validated=true;
        }
        }  // end inner a1-a5 loop body
    }  // FIX21: end a0 outer loop
    TLog(StringFormat("  P3B  ·  r%d %-20s  scan-ext    ->  %.1f%% WR  val %.1f%%  [MTF%.2f Mo%.2f Vo%.2f Vt%.2f Se%.2f Pa%.2f]",
        regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, bestWeights.validationWR*100,
        bestWeights.mtf, bestWeights.momentum, bestWeights.volume,
        bestWeights.volatility, bestWeights.session, bestWeights.pattern));

    // STAGE 3.5: BOUNDARY EXTENSION
    //   If any weight dimension ended at or near the 2.5 ceiling after Stage 3,
    //   the search was artificially truncated. Extend ceiling to 4.0 for those
    {
        double bwArr[6]; bwArr[0]=bestWeights.mtf; bwArr[1]=bestWeights.momentum;
        bwArr[2]=bestWeights.volume; bwArr[3]=bestWeights.volatility;
        bwArr[4]=bestWeights.session; bwArr[5]=bestWeights.pattern;
        bool anyBoundary = false;
        for(int _ci=0;_ci<6;_ci++) if(bwArr[_ci]>=2.3) anyBoundary=true;

        if(anyBoundary) {
            TLog(StringFormat("  P3B  ·  r%d %-20s  boundary ext  ->  weight ceiling hit, extending to 4.0", regime+1, GetRegimeName(regime)));
            double gExt[18]; ArrayInitialize(gExt,1.0); // flat[ci*3+vi]
            for(int _ci=0;_ci<6;_ci++) {
                if(bwArr[_ci]>=2.3) {
                    // Extend beyond boundary: {best, best+0.5, best+1.0} -- but cap at 4.0
                    gExt[_ci*3+0]=bwArr[_ci]; gExt[_ci*3+1]=MathMin(4.0,bwArr[_ci]+0.5); gExt[_ci*3+2]=MathMin(4.0,bwArr[_ci]+1.0);
                } else {
                    // Stay near current best for non-boundary dims
                    gExt[_ci*3+0]=MathMax(0.1,bwArr[_ci]-0.1); gExt[_ci*3+1]=bwArr[_ci]; gExt[_ci*3+2]=MathMin(4.0,bwArr[_ci]+0.1);
                }
            }
