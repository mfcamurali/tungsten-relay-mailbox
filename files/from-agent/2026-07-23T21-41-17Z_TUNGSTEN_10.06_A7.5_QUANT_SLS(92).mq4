            for(int a3=0;a3<3;a3++) for(int a4=0;a4<3;a4++) for(int a5=0;a5<3;a5++) {
                testsTotal++;
                double wt[6]; wt[0]=gExt[0*3+a0];wt[1]=gExt[1*3+a1];wt[2]=gExt[2*3+a2];
                               wt[3]=gExt[3*3+a3];wt[4]=gExt[4*3+a4];wt[5]=gExt[5*3+a5];
                int tw=0,tl=0; double tps=0,tls=0,twR=0.0,tlR=0.0; int _consec=0,_maxC=0;  // CEO1
                for(int i=0;i<trainEnd;i++) {
                    if(barOutcomes[i].atr<=0) continue;
                    double sc=MathMax(-100,MathMin(100,(sc0[i]*wt[0]+sc1[i]*wt[1]+sc2[i]*wt[2]+sc3[i]*wt[3]+sc4[i]*wt[4]+sc5[i]*wt[5])*seqMult[i]));  // seqMult: multi-bar pattern persistence
                    if(MathAbs(sc)<bestPreThresh) continue;
                    double pnl=(sc>0)?barOutcomes[i].longPnL:barOutcomes[i].shortPnL;
                    double _sw=MathMin(2.0,0.6+MathMax(0.0,MathAbs(sc)-(double)bestPreThresh)/35.0);
            if(pnl>0){tw++;twR+=barOutcomes[i].recency*_sw;tps+=pnl*barOutcomes[i].recency*_sw;_consec=0;}else if(pnl<0){tl++;tlR+=barOutcomes[i].recency*_sw;tls+=MathAbs(pnl)*barOutcomes[i].recency*_sw;_consec++;if(_consec>_maxC)_maxC=_consec;}
                }
                if(tw+tl<3) continue;
                int _regCap=(regime==4||regime==5)?10:(regime==6)?12:7;  // CEO2
                if(_maxC >= _regCap) continue;  // Skip configs with 7+ consecutive losses
                double trainWR=(twR+tlR>0.01)?(twR/(twR+tlR)):(tw+tl>0?(double)tw/(tw+tl):0.0);  // CEO1 recency-WR
                double trainPF=(tls>0)?tps/tls:2.0;
                // CEO-D (9.18A): EV-enhanced composite — rewards asymmetric payoff profiles
        double _evBonus = (tps>0&&tls>0) ? MathMin(0.30, (tps/(tw>0?tw:1) - tls/(tl>0?tl:1)) * 5.0) : 0.0;
        double comp=trainWR*MathMin(trainPF,3.0)*MathLog10(1.0+tw+tl)*(1.0+MathMax(0.0,_evBonus));  // EV-enhanced
        { double _l2=0; for(int _lw=0;_lw<6;_lw++) _l2+=MathPow(wt[_lw]-1.0,2.0); comp*=(1.0-MathMin(0.18,_l2*0.012)); }  // L2 regularisation: penalises extreme weight deviations from 1.0
                int vw=0,vl=0;
                for(int i=trainEnd;i<barCount;i++) {
                    if(barOutcomes[i].atr<=0) continue;
                    double sc=MathMax(-100,MathMin(100,(sc0[i]*wt[0]+sc1[i]*wt[1]+sc2[i]*wt[2]+sc3[i]*wt[3]+sc4[i]*wt[4]+sc5[i]*wt[5])*seqMult[i]));  // seqMult: multi-bar pattern persistence
                    if(MathAbs(sc)<bestPreThresh) continue;
                    double pnl=(sc>0)?barOutcomes[i].longPnL:barOutcomes[i].shortPnL;
                    if(pnl>0)vw++;else if(pnl<0)vl++;
                }
                int dynMin=MathMax(1,(tw+tl)/(8*_wsStride));  // FIX(54): scale with stride so strided validation counts compare fairly
                if(vw+vl<dynMin) continue;
                double valWR=(vw+vl>0)?(double)vw/(vw+vl):0;
                double _genGap = MathAbs(trainWR - valWR);
        double _genComp = comp * valWR / MathMax(0.01, trainWR) * (1.0 - MathMin(0.5, _genGap));  // FIX61: re-score on holdout, penalize train/holdout divergence
        if(_genComp>bestComposite && valWR>trainWR-0.08 && valWR>=trainWR*0.85 && tw+tl>=8) {
                    bestComposite=_genComp;  // FIX61: store the generalization-scored metric
                    bestWeights.mtf=wt[0];bestWeights.momentum=wt[1];bestWeights.volume=wt[2];
                    bestWeights.volatility=wt[3];bestWeights.session=wt[4];bestWeights.pattern=wt[5];
                    bestWeights.trainingWR=trainWR;bestWeights.validationWR=valWR;
                    bestWeights.sampleSize=tw+tl;bestWeights.validated=true;
                }
            }
            TLog(StringFormat("  P3B  ·  r%d %-20s  scan-ext    ->  %.1f%% WR  [MTF%.2f Mo%.2f Vo%.2f Vt%.2f Se%.2f Pa%.2f]",
                regime+1, GetRegimeName(regime), bestWeights.trainingWR*100,
                bestWeights.mtf,bestWeights.momentum,bestWeights.volume,
                bestWeights.volatility,bestWeights.session,bestWeights.pattern));
        }
    }

    // STAGE 4: THRESHOLD CO-OPTIMISATION
    double finalWTS[6]; finalWTS[0]=bestWeights.mtf; finalWTS[1]=bestWeights.momentum;
    finalWTS[2]=bestWeights.volume; finalWTS[3]=bestWeights.volatility;
    finalWTS[4]=bestWeights.session; finalWTS[5]=bestWeights.pattern;

    // STAGE 4: threshold search on full dataset [25,82] step 1.
    // Lower bound 25 allows mild-threshold regimes to find their true optimum.
    // Step 1 gives fine resolution -- the quality/frequency trade-off is non-linear.
    double bestThreshScore = 0;
    double optimalThreshold = DEFAULT_REGIME_THRESHOLD;
    double bestThreshWR = 0.5;  // FIX6
    // CEO-A (9.18A): Threshold search on trainEnd only — no val-set contamination
    // CEO-B (9.18A): Recency-weighted WR*sqrt(recency-n) — recent market matters more
    for(double thr=16.0; thr<=70.0; thr+=1.5) {  // signed-margin grid: ==normalized 58..85  // 1.5pt step: good resolution, faster
        double _twRt=0.0,_tlRt=0.0;
        int _rawCt=0;  // FIX(29): track actual qualifying bar count — prevents thr=16 winning with 14 memorised bars
        for(int i=0;i<trainEnd;i++) {  // CEO-A: trainEnd only
            if(barOutcomes[i].atr<=0) continue;
            double sc=MathMax(-100,MathMin(100,sc0[i]*finalWTS[0]+sc1[i]*finalWTS[1]+sc2[i]*finalWTS[2]+sc3[i]*finalWTS[3]+sc4[i]*finalWTS[4]+sc5[i]*finalWTS[5]));
            if(MathAbs(sc)<thr) continue;
            _rawCt++;
            double pnl=(sc>0)?barOutcomes[i].longPnL:barOutcomes[i].shortPnL;
            double rec=barOutcomes[i].recency;
            if(pnl>0)_twRt+=rec;else if(pnl<0)_tlRt+=rec;  // CEO-B: recency-weighted
        }
        if(_twRt+_tlRt>=2.0 && _rawCt>=500) {  // WARRANT#14 (forge pass 4): was ≥50 -- Standing Prohibition #5 floor (n>=500), not just "not tiny"
            double tWR=_twRt/(_twRt+_tlRt);
            double tScore=tWR*SafeSqrt(_twRt+_tlRt);  // recency-weighted n
            if(tScore>bestThreshScore) { bestThreshScore=tScore; optimalThreshold=thr; bestThreshWR=tWR; }
        }
    }

    // ## Log how long the search took ##########################################
    {
        int _elapsed = (int)(TimeCurrent() - _p3RegimeStart);
        TLog(StringFormat("  P3B  ·  r%d %-20s  grids done  ->  %.1f%% WR  val %.1f%%  ·  %ds",
            regime+1, regimeName, bestWeights.trainingWR*100.0, bestWeights.validationWR*100.0, _elapsed));
    }

    // STAGE 4-CA: COORDINATE ASCENT — relentless hill-climbing from Stage 4 best  // FIX20
    // Iterates ±delta over all 6 weights until convergence (no improvement for 3 passes).
    // Validates on holdout to prevent training-set overfit. Up to 50 passes, 4 delta levels.
    {
        double _caW[6];
        _caW[0]=bestWeights.mtf;        _caW[1]=bestWeights.momentum;
        _caW[2]=bestWeights.volume;     _caW[3]=bestWeights.volatility;
        _caW[4]=bestWeights.session;    _caW[5]=bestWeights.pattern;
        double _caDeltas[4] = {0.15, 0.07, 0.03, 0.01};
        double _caBest = bestComposite;
        int _caNoImprove = 0;
        TLog(StringFormat("  P3B  ·  r%d %-20s  ascent-50   seeded %.1f%% WR  ·  up to 50 passes",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100));

        for(int _caPass = 0; _caPass < 50 && _caNoImprove < 3; _caPass++) {
            bool _caImproved = false;
            for(int _dIdx = 0; _dIdx < 4 && !_caImproved; _dIdx++) {
                double _caDelta = _caDeltas[_dIdx];
                for(int _cc = 0; _cc < 6 && !_caImproved; _cc++) {
                    double _caOrig = _caW[_cc];
                    for(int _cDir = -1; _cDir <= 1; _cDir += 2) {
                        double _caCand = MathMax(0.30, MathMin(2.50, _caOrig + _cDir * _caDelta));
                        if(MathAbs(_caCand - _caOrig) < 0.001) continue;
                        double _caTW=0, _caTL=0, _caVW=0, _caVL=0;
                        for(int _ci = 0; _ci < barCount; _ci++) {
                            if(barOutcomes[_ci].atr <= 0) continue;
                            double _caSc = MathMax(-100, MathMin(100,
                                sc0[_ci]*(_cc==0?_caCand:_caW[0]) +
                                sc1[_ci]*(_cc==1?_caCand:_caW[1]) +
                                sc2[_ci]*(_cc==2?_caCand:_caW[2]) +
                                sc3[_ci]*(_cc==3?_caCand:_caW[3]) +
                                sc4[_ci]*(_cc==4?_caCand:_caW[4]) +
                                sc5[_ci]*(_cc==5?_caCand:_caW[5])));
                            if(MathAbs(_caSc) < optimalThreshold) continue;
                            double _caPnl = (_caSc > 0) ? barOutcomes[_ci].longPnL : barOutcomes[_ci].shortPnL;
                            double _caRec = barOutcomes[_ci].recency;
                            if(_ci < trainEnd) { if(_caPnl>0)_caTW+=_caRec; else if(_caPnl<0)_caTL+=_caRec; }
                            else               { if(_caPnl>0)_caVW+=_caRec; else if(_caPnl<0)_caVL+=_caRec; }
                        }
                        if(_caTW+_caTL < 4.0 || _caVW+_caVL < 2.0) continue;
                        double _caTrWR = _caTW / (_caTW + _caTL);
                        double _caVaWR = _caVW / (_caVW + _caVL);
                        double _caGap  = MathAbs(_caTrWR - _caVaWR);
                        double _caComp = _caTrWR * _caVaWR / MathMax(0.01, _caTrWR) * (1.0 - MathMin(0.5, _caGap));
                        if(_caComp > _caBest && _caVaWR >= _caTrWR - 0.08 && _caVaWR >= _caTrWR * 0.85) {
                            _caBest    = _caComp;
                            _caW[_cc]  = _caCand;
                            bestWeights.trainingWR   = _caTrWR;
                            bestWeights.validationWR = _caVaWR;
                            _caImproved = true;
                            break;
                        }
                    }
                }
            }
            if(_caImproved) _caNoImprove = 0;
            else            _caNoImprove++;
        }
        bestWeights.mtf        = _caW[0];
        bestWeights.momentum   = _caW[1];
        bestWeights.volume     = _caW[2];
        bestWeights.volatility = _caW[3];
        bestWeights.session    = _caW[4];
        bestWeights.pattern    = _caW[5];
        bestComposite = _caBest;
        TLog(StringFormat("  P3B  ·  r%d %-20s  ascent-50   ->  %.1f%% WR  val %.1f%%",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, bestWeights.validationWR*100));
    }

    // FIX(23): budget gate — skip Stage 5+6 if budget tight after grids + CA
    if(!_stageExit && CalibBudgetUsed() > 0.90) {
        _stageExit = true;
        TLog(StringFormat("  P3B  ·  r%d  budget %s  ->  skip advanced stages (St5+6)", regime+1, BudgetBar(CalibBudgetUsed())));
    }
    // STAGE 5: DENSE COORDINATE ASCENT — 200 passes
    if(!_stageExit) {
    {
        double _caW[6];
        _caW[0]=bestWeights.mtf;     _caW[1]=bestWeights.momentum;
        _caW[2]=bestWeights.volume;  _caW[3]=bestWeights.volatility;
        _caW[4]=bestWeights.session; _caW[5]=bestWeights.pattern;
        double _caDeltas[4]; _caDeltas[0]=0.20; _caDeltas[1]=0.10; _caDeltas[2]=0.04; _caDeltas[3]=0.01;
        int _caNoImprovCount = 0;
        TLog(StringFormat("  P3B  ·  r%d %-20s  ascent-200  seeded %.1f%% WR  ·  running 200 passes",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100));
        for(int _caPass=0; _caPass<200; _caPass++) {
            if(_caPass % 20 == 0) TLog(StringFormat("  P3B  ·  r%d %-20s  ascent-200  pass %d/200  ->  %.1f%% WR", regime+1, GetRegimeName(regime), _caPass+1, bestWeights.trainingWR*100));
            bool _caImproved=false;
            for(int _caDt=0; _caDt<4; _caDt++) {
                double _d=_caDeltas[_caDt];
                for(int _caDim=0; _caDim<6; _caDim++) {
                    for(int _caDir=-1; _caDir<=1; _caDir+=2) {
                        double _caCand=MathMax(0.05,MathMin(4.0,_caW[_caDim]+_caDir*_d));
                        if(MathAbs(_caCand-_caW[_caDim])<0.001) continue;
                        double _caTW=0,_caTL=0,_caPS=0,_caLS=0; int _caCC=0,_caMC=0;
                        for(int _ci=0; _ci<trainEnd; _ci++) {
                            if(barOutcomes[_ci].atr<=0) continue;
                            double _w0=(_caDim==0?_caCand:_caW[0]),_w1=(_caDim==1?_caCand:_caW[1]);
                            double _w2=(_caDim==2?_caCand:_caW[2]),_w3=(_caDim==3?_caCand:_caW[3]);
                            double _w4=(_caDim==4?_caCand:_caW[4]),_w5=(_caDim==5?_caCand:_caW[5]);
                            double _caSc=MathMax(-100,MathMin(100,(sc0[_ci]*_w0+sc1[_ci]*_w1+sc2[_ci]*_w2+sc3[_ci]*_w3+sc4[_ci]*_w4+sc5[_ci]*_w5)*seqMult[_ci]));
                            if(MathAbs(_caSc)<bestPreThresh) continue;
                            double _caPnl=(_caSc>0)?barOutcomes[_ci].longPnL:barOutcomes[_ci].shortPnL;
                            double _caRec=barOutcomes[_ci].recency;
                            if(_caPnl>0){_caTW+=_caRec;_caPS+=_caPnl*_caRec;_caCC=0;}
                            else if(_caPnl<0){_caTL+=_caRec;_caLS+=MathAbs(_caPnl)*_caRec;_caCC++;if(_caCC>_caMC)_caMC=_caCC;}
                        }
                        int _caRCap=(regime==4||regime==5)?10:(regime==6)?12:7;
                        if(_caTW+_caTL<3.0||_caMC>=_caRCap) continue;
                        double _caWR=(_caTW+_caTL>0)?_caTW/(_caTW+_caTL):0;
                        double _caPF=(_caLS>0)?_caPS/_caLS:2.0;
                        double _caEV=(_caPS>0&&_caLS>0)?MathMin(0.30,(_caPS/MathMax(1.0,_caTW)-_caLS/MathMax(1.0,_caTL))*5.0):0.0;
                        double _caL2=0; for(int _lc=0;_lc<6;_lc++){double _tw=(_lc==_caDim?_caCand:_caW[_lc]);_caL2+=MathPow(_tw-1.0,2.0);}
                        double _caComp=_caWR*MathMin(_caPF,3.0)*MathLog10(1.0+_caTW+_caTL)*(1.0+MathMax(0.0,_caEV))*(1.0-MathMin(0.18,_caL2*0.012));
                        if(_caComp>bestComposite) {
                            bestComposite=_caComp;
                            _caW[_caDim]=_caCand;
                            bestWeights.mtf=_caW[0];bestWeights.momentum=_caW[1];bestWeights.volume=_caW[2];
                            bestWeights.volatility=_caW[3];bestWeights.session=_caW[4];bestWeights.pattern=_caW[5];
                            bestWeights.trainingWR=_caWR; bestWeights.validated=true;
                            _caImproved=true;
                        }
                    }
                }
            }
            if(!_caImproved){_caNoImprovCount++;if(_caNoImprovCount>=5)break;}else _caNoImprovCount=0;
        }
        // SLS18 HIGH1: holdout eval of Stage 5 winner — invariant 4 (held-out judgment)
        {
            double _s5VW=0, _s5VL=0;
            double _s5W[6]; _s5W[0]=bestWeights.mtf; _s5W[1]=bestWeights.momentum;
            _s5W[2]=bestWeights.volume; _s5W[3]=bestWeights.volatility;
            _s5W[4]=bestWeights.session; _s5W[5]=bestWeights.pattern;
            for(int _vi=trainEnd; _vi<barCount; _vi+=_wsStride) {
                if(barOutcomes[_vi].atr<=0) continue;
                double _s5sc=MathMax(-100,MathMin(100,(sc0[_vi]*_s5W[0]+sc1[_vi]*_s5W[1]+sc2[_vi]*_s5W[2]+sc3[_vi]*_s5W[3]+sc4[_vi]*_s5W[4]+sc5[_vi]*_s5W[5])*seqMult[_vi]));
                if(MathAbs(_s5sc)<bestPreThresh) continue;
                double _s5pnl=(_s5sc>0)?barOutcomes[_vi].longPnL:barOutcomes[_vi].shortPnL;
                if(_s5pnl>0) _s5VW+=barOutcomes[_vi].recency; else if(_s5pnl<0) _s5VL+=barOutcomes[_vi].recency;
            }
            if(_s5VW+_s5VL>=2.0) bestWeights.validationWR=_s5VW/(_s5VW+_s5VL);
        }
        TLog(StringFormat("  P3B  ·  r%d %-20s  ascent-200  ->  %.1f%% WR  val %.1f%%  [MTF%.2f Mo%.2f Vo%.2f Vt%.2f Se%.2f Pa%.2f]",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, bestWeights.validationWR*100,
            bestWeights.mtf, bestWeights.momentum, bestWeights.volume,
            bestWeights.volatility, bestWeights.session, bestWeights.pattern));
    }
    } // FIX(23): end !_stageExit Stage 5

    // FIX(23): budget gate — skip Stage 6 if budget tight after Stage 5
    if(!_stageExit && CalibBudgetUsed() > 0.86) {
        _stageExit = true;
        TLog(StringFormat("  P3B  ·  r%d  budget %s  ->  skip global-rnd (St6)", regime+1, BudgetBar(CalibBudgetUsed())));
    }

    if(!_stageExit) {  // Stage 6: global random search
    // STAGE 6: GLOBAL RANDOM WEIGHT SEARCH — 50,000 draws with holdout validation
    {
        // forge-parallel WARRANT#75 (real PBO, part 1 of 2): bounded trial-population sample --
        // 100 slots max (50000 draws / 500 = at most 100 hits), local (not static, small enough
        // for the stack unlike regimeBars' deliberate static/30000 sizing above). Reset fresh every
        // call, same as every other per-regime local in this function.
        double _pboTrainWR[100]; double _pboValWR[100]; int _pboSamples=0;
        ArrayInitialize(_pboTrainWR, 0.0); ArrayInitialize(_pboValWR, 0.0);  // suppress uninitialized-variable warning; only indices <_pboSamples are ever read
        MathSrand((uint)(TimeCurrent()+regime*31337));
        for(int _rd=0; _rd<50000; _rd++) {
            // WARRANT#31, Part V (terminal-hang fix): Windows Event 1002 ('Application Hang')
            // confirmed terminal.exe was killed mid-run inside exactly this loop (SLS(43),
            // 2026-07-14, regime 2, draw ~30000/50000). 50,000 outer draws x an inner scan of
            // several thousand bars each is enough uninterrupted computation that the terminal's
            // message pump can go long enough without servicing Windows to be flagged as hung,
            // even though the EA is genuinely still working. A cheap periodic Sleep(1) yields
            // control back often enough to keep the process responsive without materially
            // slowing the search (50 yields x ~1-15ms each is negligible against a multi-minute
            // stage). Same fix should be considered for any other similarly long tight loop.
            if(_rd % 1000 == 0) Sleep(1);
            if(_rd % 10000 == 0) TLog(StringFormat("  P3B  ·  r%d %-20s  global-rnd  draw %d/50000  ->  %.1f%% WR", regime+1, GetRegimeName(regime), _rd, bestWeights.trainingWR*100));
            double wt[6]; ArrayInitialize(wt, 1.0);  // suppress uninitialized warning
            for(int _rc=0;_rc<6;_rc++) wt[_rc]=MathMax(0.05,MathMin(4.0,(double)MathRand()/32767.0*4.0));
            int tw=0,tl=0; int _cc=0,_mc=0; double tps=0,tls=0,twR=0,tlR=0;
            for(int i=0;i<trainEnd;i++) {
                if(barOutcomes[i].atr<=0) continue;
                double sc=MathMax(-100,MathMin(100,(sc0[i]*wt[0]+sc1[i]*wt[1]+sc2[i]*wt[2]+sc3[i]*wt[3]+sc4[i]*wt[4]+sc5[i]*wt[5])));
                if(MathAbs(sc)<bestPreThresh) continue;
                double pnl=(sc>0)?barOutcomes[i].longPnL:barOutcomes[i].shortPnL;
                double rec=barOutcomes[i].recency;
                if(pnl>0){tw++;twR+=rec;tps+=pnl*rec;_cc=0;}else if(pnl<0){tl++;tlR+=rec;tls+=MathAbs(pnl)*rec;_cc++;if(_cc>_mc)_mc=_cc;}
            }
            int _rCap=(regime==4||regime==5)?10:(regime==6)?12:7;
            if(tw+tl<5||_mc>=_rCap) continue;
            double rWR=(twR+tlR>0.01)?twR/(twR+tlR):(tw+tl>0?(double)tw/(tw+tl):0);
            double rPF=(tls>0)?tps/tls:2.0;
            double _evB=(tps>0&&tls>0)?MathMin(0.30,(tps/MathMax(1.0,(double)tw)-tls/MathMax(1.0,(double)tl))*5.0):0.0;
            double rL2=0; for(int _lc=0;_lc<6;_lc++) rL2+=MathPow(wt[_lc]-1.0,2.0);
            double rComp=rWR*MathMin(rPF,3.0)*MathLog10(1.0+tw+tl)*(1.0+MathMax(0.0,_evB))*(1.0-MathMin(0.18,rL2*0.012));
            int vw=0,vl=0;
            for(int i=trainEnd;i<barCount;i+=_wsStride) {
                if(barOutcomes[i].atr<=0) continue;
                double sc=MathMax(-100,MathMin(100,(sc0[i]*wt[0]+sc1[i]*wt[1]+sc2[i]*wt[2]+sc3[i]*wt[3]+sc4[i]*wt[4]+sc5[i]*wt[5])));
                if(MathAbs(sc)<bestPreThresh) continue;
                double pnl=(sc>0)?barOutcomes[i].longPnL:barOutcomes[i].shortPnL;
                if(pnl>0)vw++;else if(pnl<0)vl++;
            }
            int dynMin=MathMax(1,(tw+tl)/(8*_wsStride));
            if(vw+vl<dynMin) continue;
            double valWR=(vw+vl>0)?(double)vw/(vw+vl):0;
            // forge-parallel WARRANT#75 (real PBO, part 1 of 2): sample this candidate's already-
            // computed (rWR, valWR) into the bounded trial population, every 500th draw that
            // reaches this point (i.e., already survived both continue-gates above -- this adds
            // nothing to the expensive bar-scanning work, only an O(1) array write on top of values
            // already sitting in local variables). Gated on tw+tl>=500 (Standing Prohibition #5's
            // own real trading-weight floor) so thin, meaningless candidates aren't counted toward
            // the trial population either.
            if(_rd % 500 == 0 && _pboSamples < 100 && tw+tl >= 500) {
                _pboTrainWR[_pboSamples] = rWR; _pboValWR[_pboSamples] = valWR; _pboSamples++;
            }
            double _gG=MathAbs(rWR-valWR);
            double _gComp=rComp*valWR/MathMax(0.01,rWR)*(1.0-MathMin(0.5,_gG));
            if(_gComp>bestComposite&&valWR>rWR-0.08&&valWR>=rWR*0.85&&tw+tl>=500) {  // WARRANT#14 (forge pass 4): was ≥50 -- Standing Prohibition #5 floor
                bestComposite=_gComp;
                bestWeights.mtf=wt[0];bestWeights.momentum=wt[1];bestWeights.volume=wt[2];
                bestWeights.volatility=wt[3];bestWeights.session=wt[4];bestWeights.pattern=wt[5];
                bestWeights.trainingWR=rWR;bestWeights.validationWR=valWR;
                bestWeights.sampleSize=tw+tl;bestWeights.validated=true;
            }
        }
        TLog(StringFormat("  P3B  ·  r%d %-20s  global-rnd  ->  %.1f%% WR  val %.1f%%  [MTF%.2f Mo%.2f Vo%.2f Vt%.2f Se%.2f Pa%.2f]",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, bestWeights.validationWR*100,
            bestWeights.mtf,bestWeights.momentum,bestWeights.volume,
            bestWeights.volatility,bestWeights.session,bestWeights.pattern));

        // forge-parallel WARRANT#75 (real PBO, part 2 of 2): simplified single-split PBO-style
        // estimate from the sampled trial population above. Ranks samples by in-sample (train) WR,
        // takes the top half (the candidates Stage 6's own search would have preferred in-sample),
        // and measures what fraction of THAT top half falls below the population's own median
        // out-of-sample (holdout) WR -- the classic overfitting signature: looks best in-sample,
        // performs below-average out-of-sample. This runs ONCE, after the loop, on at most 100
        // already-collected numbers -- O(100 log 100) sort, negligible cost, nowhere near the hot
        // path. Requires >=20 samples to report anything (same spirit as this file's other
        // diagnostic power floors) -- fewer than that, g_RegimePBOEstimate stays at its honest -1.0
        // "not computed" default.
        if(_pboSamples >= 20) {
            double _sortedTrain[100]; for(int _pi=0;_pi<_pboSamples;_pi++) _sortedTrain[_pi]=_pboTrainWR[_pi];
            ArraySort(_sortedTrain, _pboSamples, 0, MODE_DESCEND);
            double _trainMedianCutoff = _sortedTrain[_pboSamples/2];  // top-half threshold
            double _sortedVal[100]; for(int _pi=0;_pi<_pboSamples;_pi++) _sortedVal[_pi]=_pboValWR[_pi];
            ArraySort(_sortedVal, _pboSamples, 0, MODE_ASCEND);
            double _valMedian = _sortedVal[_pboSamples/2];
            int _topHalfCount=0, _topHalfBelowMedian=0;
            for(int _pi=0;_pi<_pboSamples;_pi++) {
                if(_pboTrainWR[_pi] >= _trainMedianCutoff) {
                    _topHalfCount++;
                    if(_pboValWR[_pi] < _valMedian) _topHalfBelowMedian++;
                }
            }
            double _pboEst = (_topHalfCount>0) ? (double)_topHalfBelowMedian/_topHalfCount : -1.0;
            if(_pboEst >= 0.0 && regime>=0 && regime<9) {
                g_RegimePBOEstimate[regime] = _pboEst;
                g_RegimePBOEstimateSamples[regime] = _pboSamples;
                TLog(StringFormat("  P3B  ·  r%d %-20s  PBO-est     %.3f  (simplified single-split, %d samples -- NOT full CSCV)",
                    regime+1, GetRegimeName(regime), _pboEst, _pboSamples));
            }
        }

        // ===== forge-parallel, WARRANT#79: FULL CSCV (Bailey & Lopez de Prado 2014) =====
        // COMPLETELY SEPARATE from Stage 6's own 50,000-draw loop above -- does not touch it, does
        // not share its random draws (own MathSrand seed), does not alter its control flow in any
        // way. Runs its own bounded CSCV_N=200-candidate search, evaluating EACH candidate across
        // CSCV_S=8 chronological blocks of this regime's already-collected (sc0..sc5, barOutcomes)
        // arrays -- not one train/holdout split -- building a real candidate x block performance
        // matrix. Partitions those 8 blocks every combinatorially-balanced way (C(8,4)=70 splits,
        // enumerated via an 8-bit mask filter) and checks, for each split, whether the candidate
        // that looked best on the training half of blocks also ranks above its own out-of-sample
        // median on the complementary half -- the actual CSCV statistic (Bailey & Lopez de Prado's
        // logit-of-relative-rank), not an approximation of it.
        //
        // COST DISCIPLINE: CSCV_N=200 candidates x CSCV_S=8 blocks means each candidate scans the
        // SAME total barCount bars as one full Stage-6 evaluation (just chopped into 8 pieces
        // instead of 1 train+1 holdout scan), so total bar-touches here (~200 x barCount) are FAR
        // less than Stage 6's own ~50,000 x trainEnd -- this audit is cheaper than the search it
        // audits, not more expensive. Yields with the same Sleep(1) discipline as every other long
        // loop in this file (WARRANT#31 precedent) and respects this regime's own _p3RegMaxSec
        // budget cap -- if time runs out mid-computation, aborts cleanly and leaves
        // g_RegimePBOEstimate at whatever WARRANT#75's simplified estimate already set (graceful
        // degradation, never a partial/fabricated CSCV number).
        if(barCount >= CSCV_S*50 && (int)(TimeCurrent()-_p3RegimeStart) < _p3RegMaxSec) {
            int _blockSize = barCount / CSCV_S;
            static double _matrix[CSCV_N][CSCV_S];  // static: same off-stack precedent as sc0-sc5/regimeBars above
            for(int _mi=0;_mi<CSCV_N;_mi++) for(int _mj=0;_mj<CSCV_S;_mj++) _matrix[_mi][_mj]=-1.0;
            MathSrand((uint)(TimeCurrent()+regime*7919+54321));  // independent seed from Stage 6's own (regime*31337)
            bool _cscvAborted = false;
            int _cscvYield = 0;
            for(int c=0; c<CSCV_N && !_cscvAborted; c++) {
                double _cwt[6]; ArrayInitialize(_cwt, 1.0);  // suppress uninitialized-variable warning
                for(int _wi=0; _wi<6; _wi++) _cwt[_wi] = MathMax(0.05, MathMin(4.0, (double)MathRand()/32767.0*4.0));
                for(int b=0; b<CSCV_S; b++) {
                    int _bStart = b*_blockSize;
                    int _bEnd   = (b==CSCV_S-1) ? barCount : (b+1)*_blockSize;  // last block absorbs any remainder
                    int _wins=0, _tot=0;
                    for(int i=_bStart; i<_bEnd; i++) {
                        if(barOutcomes[i].atr<=0) continue;
                        double _csc=MathMax(-100.0,MathMin(100.0,sc0[i]*_cwt[0]+sc1[i]*_cwt[1]+sc2[i]*_cwt[2]+sc3[i]*_cwt[3]+sc4[i]*_cwt[4]+sc5[i]*_cwt[5]));
                        if(MathAbs(_csc)<bestPreThresh) continue;
                        double _cpnl=(_csc>0)?barOutcomes[i].longPnL:barOutcomes[i].shortPnL;
                        if(_cpnl>0) {_wins++; _tot++;} else if(_cpnl<0) {_tot++;}
                    }
                    _matrix[c][b] = (_tot>0) ? (double)_wins/_tot : -1.0;
                    if(++_cscvYield % 400 == 0) Sleep(1);
                }
                if((int)(TimeCurrent()-_p3RegimeStart) > _p3RegMaxSec) {
                    _cscvAborted = true;
                    TLog(StringFormat("  P3B  ·  r%d  CSCV budget cap reached mid-search -- aborting cleanly, keeping simplified estimate", regime+1));
                }
            }

            if(!_cscvAborted) {
                int _splitsCounted=0, _splitsOverfit=0;
                for(int _mask=0; _mask<256; _mask++) {
                    int _bits=0; for(int _bi=0;_bi<CSCV_S;_bi++) if((_mask & (1<<_bi))!=0) _bits++;
                    if(_bits != CSCV_S/2) continue;  // only the C(8,4)=70 balanced splits
                    double _bestTrainAvg=-1.0; int _bestC=-1;
                    for(int c=0;c<CSCV_N;c++) {
                        double _sum=0; int _n=0;
                        for(int _bi=0;_bi<CSCV_S;_bi++) if((_mask&(1<<_bi))!=0 && _matrix[c][_bi]>=0.0) {_sum+=_matrix[c][_bi]; _n++;}
                        if(_n==0) continue;
                        double _avg=_sum/_n;
                        if(_avg>_bestTrainAvg) {_bestTrainAvg=_avg; _bestC=c;}
                    }
                    if(_bestC<0) continue;  // no candidate had any valid training-block data this split
                    double _oosAvg[CSCV_N]; ArrayInitialize(_oosAvg, -1.0); int _oosValid=0;  // suppress uninitialized-variable warning
                    for(int c=0;c<CSCV_N;c++) {
                        double _sum=0; int _n=0;
                        for(int _bi=0;_bi<CSCV_S;_bi++) if((_mask&(1<<_bi))==0 && _matrix[c][_bi]>=0.0) {_sum+=_matrix[c][_bi]; _n++;}
                        _oosAvg[c] = (_n>0) ? _sum/_n : -1.0;
                        if(_oosAvg[c]>=0.0) _oosValid++;
                    }
                    if(_oosAvg[_bestC]<0.0 || _oosValid<10) continue;  // this split can't honestly rank the winner
                    int _rankCount=0;
                    for(int c=0;c<CSCV_N;c++) if(_oosAvg[c]>=0.0 && _oosAvg[c]<=_oosAvg[_bestC]) _rankCount++;
                    double _omega = (double)_rankCount/(_oosValid+1);  // in (0,1), never exactly 0 or 1
                    double _logit = MathLog(_omega/(1.0-_omega));
                    _splitsCounted++;
                    if(_logit<=0.0) _splitsOverfit++;
                }
                if(_splitsCounted>=10) {
                    double _realPBO = (double)_splitsOverfit/_splitsCounted;
                    if(regime>=0 && regime<9) {
                        g_RegimePBOEstimate[regime] = _realPBO;  // supersedes WARRANT#75's simplified estimate
                        g_RegimePBOEstimateSamples[regime] = CSCV_N;
                        TLog(StringFormat("  P3B  ·  r%d %-20s  PBO-CSCV    %.3f  (REAL Bailey-Lopez de Prado CSCV, %d/70 splits scored, N=%d candidates x S=%d blocks)",
                            regime+1, GetRegimeName(regime), _realPBO, _splitsCounted, CSCV_N, CSCV_S));
                    }
                } else {
                    TLog(StringFormat("  P3B  ·  r%d  CSCV too thin (%d/70 splits scorable) -- keeping WARRANT#75 simplified estimate", regime+1, _splitsCounted));
                }
            }
        }
        // ===== end WARRANT#79 =====
    }
    } // FIX(23): end !_stageExit Stage 6

    // -- Phase 3B focused second pass (council doctrine) ----------------─
    // If first pass WR < 63%, run a narrowed fine-grained search around
    // the best-found weights. Step ±0.15 within ±0.3 of each best weight.
    // This catches the local optimum that the coarse grid misses.
    if(bestWeights.trainingWR < 0.63 && barCount >= 25 && !g_Calibration.catastrophicMode) {
        double _preFocusedWR = bestWeights.trainingWR;  // capture before focused stage for accurate delta
        TLog(StringFormat("  P3B  ·  r%d %-20s  focused     %.1f%% WR below 63%%  ->  narrowing search",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100));

        double _fw[6];
        _fw[0]=bestWeights.mtf;  _fw[1]=bestWeights.momentum; _fw[2]=bestWeights.volume;
        _fw[3]=bestWeights.volatility; _fw[4]=bestWeights.session; _fw[5]=bestWeights.pattern;
        double _fStep[3] = {0.15, 0.08, 0.04};  // three rounds: coarse, medium, fine

        for(int _fRound = 0; _fRound < 3; _fRound++) {
            double _fs = _fStep[_fRound];
            bool _improved = false;
            for(int _fc = 0; _fc < 6; _fc++) {
                double _origW = _fw[_fc];
                for(int _fd = -2; _fd <= 2; _fd++) {
                    if(_fd == 0) continue;
                    double _candidate = MathMax(0.30, MathMin(2.50, _origW + _fd * _fs));
                    if(MathAbs(_candidate - _fw[_fc]) < 0.001) continue;

                    // Evaluate this weight variation on training set
                    double _fWins = 0, _fTotal = 0;
                    for(int _fi = 0; _fi < trainEnd; _fi++) {
                        if(barOutcomes[_fi].atr <= 0) continue;
                        double _ws[6]; ArrayCopy(_ws, _fw, 0, 0, 6);
                        _ws[_fc] = _candidate;
                        double _fSc = MathMax(-100, MathMin(100,
                            sc0[_fi]*_ws[0] + sc1[_fi]*_ws[1] + sc2[_fi]*_ws[2] +
                            sc3[_fi]*_ws[3] + sc4[_fi]*_ws[4] + sc5[_fi]*_ws[5]));
                        if(MathAbs(_fSc) < optimalThreshold) continue;
                        double _fPnl = (_fSc > 0) ? barOutcomes[_fi].longPnL : barOutcomes[_fi].shortPnL;
                        _fTotal++; if(_fPnl > 0) _fWins++;
                    }
                    if(_fTotal >= 8) {
                        double _fWR = (double)_fWins / _fTotal;  // FIX: was int division (0 or 1 only)
                        if(_fWR > bestWeights.trainingWR + 0.002) {
                            bestWeights.trainingWR = _fWR;
                            _fw[_fc] = _candidate;
                            _improved = true;
                        }
                    }
                }
            }
            if(!_improved) break;  // no improvement at this resolution — stop early
        }

        // Apply focused improvements
        bestWeights.mtf        = _fw[0];
        bestWeights.momentum   = _fw[1];
        bestWeights.volume     = _fw[2];
        bestWeights.volatility = _fw[3];
        bestWeights.session    = _fw[4];
        bestWeights.pattern    = _fw[5];

        // Recount sampleSize with focused weights so sparse-guard uses an accurate count
        { int _fsSz=0;
          for(int _fsi=0;_fsi<trainEnd;_fsi++) {
              if(barOutcomes[_fsi].atr<=0) continue;
              double _fsSc=MathMax(-100,MathMin(100,sc0[_fsi]*_fw[0]+sc1[_fsi]*_fw[1]+sc2[_fsi]*_fw[2]+
                                                    sc3[_fsi]*_fw[3]+sc4[_fsi]*_fw[4]+sc5[_fsi]*_fw[5]));
              if(MathAbs(_fsSc)<optimalThreshold) continue;
              _fsSz++;
          }
          if(_fsSz>0) bestWeights.sampleSize=_fsSz;
        }

        TLog(StringFormat("  P3B  ·  r%d %-20s  focused     ->  %.1f%% WR  (%+.1f%% vs pre-focused)",
            regime+1, GetRegimeName(regime), bestWeights.trainingWR*100,
            (bestWeights.trainingWR - _preFocusedWR)*100));
    }

    // Store results
    if(regime >= 0 && regime < 9) {
        // -- HOLDOUT GENERALIZATION CHECK --------------------------------------
        // Test bestWeights on the 30% holdout to detect overfitting
        { int _hoW=0,_hoT=0;
          // WARRANT#50 (post-live-run methodology fix, 2026-07-17): also track two independent
          // chronological halves of this SAME holdout range. Diagnosed live 2026-07-17 (SLS(62)
          // run): this search tests 562,500 weight combinations against a SINGLE train/holdout
          // split, with no multiple-testing correction and no walk-forward across independent
          // windows -- flagged as "hypothesis #3, DEFERRED" back in the SLS(29)/(30) session and
          // never fixed since. A combo that generalizes on the WHOLE aggregate holdout only
          // because one half's luck offsets a genuinely bad other half is exactly what a single
          // aggregate check cannot catch. This split-half check is strictly ADDITIVE: it can only
          // convert an already-accepted combo into a regularized one (see the else-if branch
          // below), it never touches or overrides the existing aggregate check's own
          // regularization decision, and the aggregate WR/gap numbers already logged are
          // unchanged. A genuine full walk-forward redesign (independent folds spanning the whole
          // training+holdout history, not just this one holdout range split in two) is a larger
          // undertaking, deliberately left as its own future warrant.
          int _hoWFold1=0,_hoTFold1=0,_hoWFold2=0,_hoTFold2=0;
          int _hoMid = (trainingEnd3B + endBar) / 2;
          // FIX(28): holdout must use the same enhanced scorer as live/ghost, not the simplified
          // 3-component scorer. Train/holdout gaps were an artifact of scorer mismatch, not real overfit.
          double _hoW6[6];
          _hoW6[0]=bestWeights.mtf;       _hoW6[1]=bestWeights.momentum;
          _hoW6[2]=bestWeights.volume;    _hoW6[3]=bestWeights.volatility;
          _hoW6[4]=bestWeights.session;   _hoW6[5]=bestWeights.pattern;
          for(int _hob=trainingEnd3B; _hob<endBar&&_hob<Bars-30; _hob++) {
              MarketStateFeatures _hof=CalculateMarketFeatures(_hob);
              if(ClassifyBarToRegime(_hof,_hob)!=regime) continue;
              double _hoSc=CalculateUnifiedScoreCoreAtBar(_hob,_hoW6);  // FIX(28): enhanced scorer
              if(MathAbs(_hoSc)<optimalThreshold) continue;
              double _hoAtr=iATR(Symbol(),0,14,_hob); if(_hoAtr<=0||_hob<2) continue;
              bool _hoL=(_hoSc>0);
              double _hoE=(_hob>=1)?Open[_hob-1]:Close[_hob];
              double _hoTP=_hoL?_hoE+_hoAtr*2.5:_hoE-_hoAtr*2.5;
              double _hoSL=_hoL?_hoE-_hoAtr*1.5:_hoE+_hoAtr*1.5;
              bool _hoWon=false;
              // WARRANT#54 (forge-cleanup-3, seam audit "exit horizon -> Phase 3B", 2026-07-17):
              // was hardcoded -20, diverging from the per-regime validated exitHorizon (WARRANT#51/
              // 52) already used to build barOutcomes above. This check trained on one "win"
              // definition and validated on another -- the training/holdout WR gap it reports was
              // partly an artifact of that mismatch, not real overfit signal.
              for(int _hofb=_hob-1;_hofb>=MathMax(0,_hob-exitHorizon);_hofb--) {
                  if(_hoL){if(High[_hofb]>=_hoTP){_hoWon=true;break;}if(Low[_hofb]<=_hoSL)break;}
                  else{if(Low[_hofb]<=_hoTP){_hoWon=true;break;}if(High[_hofb]>=_hoSL)break;}
              }
              _hoT++; if(_hoWon) _hoW++;
              if(_hob < _hoMid) { _hoTFold1++; if(_hoWon) _hoWFold1++; }
              else              { _hoTFold2++; if(_hoWon) _hoWFold2++; }
          }
          double _hoWR=(_hoT>=10)?(double)_hoW/_hoT:0.60;  // fallback: neutral benchmark
          if(_hoT>=10 && bestWeights.trainingWR>0 && _hoWR < bestWeights.trainingWR*0.85) {  // overfit
              double _rs=0.35;
              bestWeights.mtf       =bestWeights.mtf*(1-_rs)+1.0*_rs;
              bestWeights.momentum  =bestWeights.momentum*(1-_rs)+1.0*_rs;
              bestWeights.volume    =bestWeights.volume*(1-_rs)+1.0*_rs;
              bestWeights.volatility=bestWeights.volatility*(1-_rs)+1.0*_rs;
              bestWeights.session   =bestWeights.session*(1-_rs)+1.0*_rs;
              bestWeights.pattern   =bestWeights.pattern*(1-_rs)+1.0*_rs;
              TLog(StringFormat("  P3B  ·  r%d %-20s  fit-check   train %.1f%%  holdout %.1f%%  gap %+.1fpp  -> regularized 35%%",
                      regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, _hoWR*100, (_hoWR-bestWeights.trainingWR)*100));
          } else if(_hoT>=10) {
              // WARRANT#50: two-fold walk-forward check, evaluated only when each fold has enough
              // trades to mean anything (>=5, half of the existing 10-trade sparse floor) --
              // a fold too thin to measure fails OPEN (can't be used to reject anything), matching
              // this codebase's universal fail-open convention.
              bool _fold1OK = (_hoTFold1 < 5) || ((double)_hoWFold1/_hoTFold1 >= bestWeights.trainingWR*0.85);
              bool _fold2OK = (_hoTFold2 < 5) || ((double)_hoWFold2/_hoTFold2 >= bestWeights.trainingWR*0.85);
              if(!_fold1OK || !_fold2OK) {
                  double _rs=0.35;
                  bestWeights.mtf       =bestWeights.mtf*(1-_rs)+1.0*_rs;
                  bestWeights.momentum  =bestWeights.momentum*(1-_rs)+1.0*_rs;
                  bestWeights.volume    =bestWeights.volume*(1-_rs)+1.0*_rs;
                  bestWeights.volatility=bestWeights.volatility*(1-_rs)+1.0*_rs;
                  bestWeights.session   =bestWeights.session*(1-_rs)+1.0*_rs;
                  bestWeights.pattern   =bestWeights.pattern*(1-_rs)+1.0*_rs;
                  TLog(StringFormat("  P3B  ·  r%d %-20s  fit-check   train %.1f%%  holdout %.1f%%  gap %+.1fpp  -> regularized 35%% (2-fold WF: %d/%d, %d/%d -- one fold failed to generalize)",
                          regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, _hoWR*100, (_hoWR-bestWeights.trainingWR)*100,
                          _hoWFold1, _hoTFold1, _hoWFold2, _hoTFold2));
              } else {
                  string _gapNote = (_hoWR > bestWeights.trainingWR) ? "generalizing" :
                                    (bestWeights.trainingWR - _hoWR > 0.08) ? "mild overfit" : "clean";
                  TLog(StringFormat("  P3B  ·  r%d %-20s  fit-check   train %.1f%%  holdout %.1f%%  gap %+.1fpp  -> %s (2-fold WF: %d/%d, %d/%d -- both generalize)",
                      regime+1, GetRegimeName(regime), bestWeights.trainingWR*100, _hoWR*100,
                      (_hoWR-bestWeights.trainingWR)*100, _gapNote, _hoWFold1, _hoTFold1, _hoWFold2, _hoTFold2));
              }
          } else {
              // Holdout set too small to confirm generalization: weights cannot be validated.
              TLog(StringFormat("  P3B  ·  r%d %-20s  fit-check   holdout %dt < 10 — too sparse, weights unvalidated",
                  regime+1, GetRegimeName(regime), _hoT));
              bestWeights.validated=false;
          }
        }
        // WARRANT#92 CORRECTION (2026-07-23), was "FIX(30): ENHANCED-SCORER CROSS-CHECK":
        // this block's own name, comments, and log labels ("enh-check", "linear X% vs
        // enhanced Y%") CLAIMED it re-evaluates bestWeights against the real live scorer,
        // CalculateEnhancedUnifiedScore (14-layer non-linear, session/volatility-blended,
        // CATREC-damped). It does not, and structurally cannot: CalculateEnhancedUnifiedScore
        // takes only a bar shift, no weight-vector parameter -- it reads g_RegimeOptimalWeights
        // (the GLOBAL, already-committed weights) internally, which does not yet hold this
        // regime's candidate weights while P3B is still searching for them. There is currently
        // no function that evaluates the full enhanced-scorer pipeline against an arbitrary
        // CANDIDATE weight vector at an arbitrary bar -- building one would mean threading a
        // weight-vector parameter through CalculateEnhancedUnifiedScore, which is the live
        // entry-decision function; that is a materially higher-risk change than this pass scope
        // and is intentionally NOT attempted here blind. What this block actually does: re-tests
        // bestWeights with the SAME linear scorer (CalculateUnifiedScoreCoreAtBar) used to fit
        // them, but on a different, strided/backward-sampled subset of the training-portion
        // bars -- a legitimate second overfit check (different sample => a real out-of-sample-
        // flavored signal, just not "enhanced-space"), but the label was actively misleading:
        // it led directly to a wrong read of today's live-run evidence before this was traced.
        // Renamed log labels below from enh-check/enh-reject to resample-check/resample-reject
        // to describe what is actually measured. Zero computation changed, log strings only.
        if(bestWeights.validated && !g_Calibration.catastrophicMode) {
            int _exW=0, _exT=0;
            double _exW6[6];
            _exW6[0]=bestWeights.mtf; _exW6[1]=bestWeights.momentum; _exW6[2]=bestWeights.volume;
            _exW6[3]=bestWeights.volatility; _exW6[4]=bestWeights.session; _exW6[5]=bestWeights.pattern;
            // Sample up to 400 bars from the training portion — enough for statistical significance
            int _exSpan = MathMax(1, trainingEnd3B - startBar);
            int _exStep = MathMax(1, _exSpan / 400);
            for(int _exb=trainingEnd3B-1; _exb>=startBar && _exb<Bars-30; _exb-=_exStep) {
                MarketStateFeatures _exF=CalculateMarketFeatures(_exb);
                if(ClassifyBarToRegime(_exF,_exb)!=regime) continue;
                double _exSc=CalculateUnifiedScoreCoreAtBar(_exb,_exW6);
                if(MathAbs(_exSc)<optimalThreshold) continue;
                double _exAtr=iATR(Symbol(),0,14,_exb); if(_exAtr<=0||_exb<2) continue;
                bool _exLng=(_exSc>0);
                double _exE=(_exb>=1)?Open[_exb-1]:Close[_exb];
                double _exTP=_exLng?_exE+_exAtr*2.5:_exE-_exAtr*2.5;
                double _exSL=_exLng?_exE-_exAtr*1.5:_exE+_exAtr*1.5;
                bool _exWon=false;
                // WARRANT#54 (forge-cleanup-3, seam audit "exit horizon -> Phase 3B", 2026-07-17):
                // same fix as the holdout check above -- was hardcoded -20 instead of the
                // per-regime validated exitHorizon, so this resample cross-check
                // was comparing the fitted-sample WR against the resampled WR measured under a
                // DIFFERENT outcome definition whenever a regime's optimal horizon != 20.
                for(int _exf=_exb-1;_exf>=MathMax(0,_exb-exitHorizon);_exf--) {
                    if(_exLng){if(High[_exf]>=_exTP){_exWon=true;break;}if(Low[_exf]<=_exSL)break;}
                    else{if(Low[_exf]<=_exTP){_exWon=true;break;}if(High[_exf]>=_exSL)break;}
                }
                _exT++; if(_exWon) _exW++;
            }
            if(_exT >= 15) {
                double _exWR=(double)_exW/_exT;
                double _linWR=bestWeights.trainingWR;
                string _exNote=(_exWR>=_linWR-0.08)?"consistent":(_exWR>=0.50)?"mild-gap":"divergent";
                TLog(StringFormat("  P3B  ·  r%d %-20s  resample-check   fit %.1f%%  resampled %.1f%%  (%dt  thr %.0f)  ->  %s",
                    regime+1, GetRegimeName(regime), _linWR*100, _exWR*100, _exT, optimalThreshold, _exNote));
                if(_exWR < 0.50 && (_linWR-_exWR) > 0.12) {
                    // Same-scorer resample overfit: this weight combo's fitted WR did not hold up
                    // on a different (strided/backward) sample of the same training-portion bars.
                    // Equal weights at P1 threshold is a more honest baseline than these.
                    TLog(StringFormat("  P3B  ·  r%d %-20s  resample-reject  fit %.1f%% vs resampled %.1f%% — same-scorer overfit  ->  equal weights",
                        regime+1, GetRegimeName(regime), _linWR*100, _exWR*100));
                    bestWeights.mtf=1.0; bestWeights.momentum=1.0; bestWeights.volume=1.0;
                    bestWeights.volatility=1.0; bestWeights.session=1.0; bestWeights.pattern=1.0;
                    bestWeights.validated=false;
                } else if(_exT>=15) {
                    bestWeights.trainingWR=_exWR;  // Replace fitted-sample WR with the honest resampled WR
                }
                // WARRANT#94 (2026-07-23, "weather ensemble / parameter sensitivity" applied to
                // P3B): standard quant robustness practice -- perturb the found optimum slightly
                // and re-measure. A combo selected as the single best of 562,500 candidates is
                // exactly the shape of result that overfits: a narrow, lucky spike in the search
                // landscape looks identical to a genuine broad edge from a point estimate alone.
                // This is a DIFFERENT, complementary signal from the resample-check immediately
                // above (same weights, different data) -- this measures NEARBY weights on the
                // SAME data. A genuine edge should score similarly on weights close to
                // bestWeights; a lucky spike collapses under small perturbation. Cheap by
                // construction: reuses this same strided sample (no new full rescan), only 4
                // perturbed neighbors evaluated, only runs when bestWeights is still validated
                // (skip the cost entirely once already rejected above).
                if(bestWeights.validated) {
                    double _plWR[4] = {0,0,0,0}; int _plGoodCount=0; double _plSum=0.0;
                    for(int _plK=0; _plK<4; _plK++) {
                        double _plW6[6];
                        double _plJit  = 0.15;                          // +/-15% perturbation -- stays "nearby"
                        double _plSign = (_plK % 2 == 0) ? 1.0 : -1.0;
                        double _plAxis = (_plK / 2 == 0) ? 1.0 : 0.5;    // two different perturbation magnitudes
                        _plW6[0]=bestWeights.mtf        * (1.0 + _plSign*_plJit*_plAxis);
                        _plW6[1]=bestWeights.momentum   * (1.0 - _plSign*_plJit*_plAxis);
                        _plW6[2]=bestWeights.volume      * (1.0 + _plSign*_plJit*_plAxis);
                        _plW6[3]=bestWeights.volatility  * (1.0 - _plSign*_plJit*_plAxis);
                        _plW6[4]=bestWeights.session      * (1.0 + _plSign*_plJit*_plAxis);
                        _plW6[5]=bestWeights.pattern       * (1.0 - _plSign*_plJit*_plAxis);
                        int _plWn=0,_plTn=0;
                        for(int _plb=trainingEnd3B-1; _plb>=startBar && _plb<Bars-30; _plb-=_exStep) {
                            MarketStateFeatures _plF=CalculateMarketFeatures(_plb);
                            if(ClassifyBarToRegime(_plF,_plb)!=regime) continue;
                            double _plSc=CalculateUnifiedScoreCoreAtBar(_plb,_plW6);
                            if(MathAbs(_plSc)<optimalThreshold) continue;
                            double _plAtr=iATR(Symbol(),0,14,_plb); if(_plAtr<=0||_plb<2) continue;
                            bool _plLng=(_plSc>0);
                            double _plE=(_plb>=1)?Open[_plb-1]:Close[_plb];
                            double _plTP=_plLng?_plE+_plAtr*2.5:_plE-_plAtr*2.5;
                            double _plSL=_plLng?_plE-_plAtr*1.5:_plE+_plAtr*1.5;
                            bool _plWon=false;
                            for(int _plfb=_plb-1;_plfb>=MathMax(0,_plb-exitHorizon);_plfb--) {
                                if(_plLng){if(High[_plfb]>=_plTP){_plWon=true;break;}if(Low[_plfb]<=_plSL)break;}
                                else{if(Low[_plfb]<=_plTP){_plWon=true;break;}if(High[_plfb]>=_plSL)break;}
                            }
                            _plTn++; if(_plWon) _plWn++;
                        }
                        if(_plTn >= 10) { _plWR[_plGoodCount]=(double)_plWn/_plTn; _plGoodCount++; _plSum+=_plWR[_plGoodCount-1]; }
                    }
                    if(_plGoodCount >= 3) {
                        double _plMean = _plSum/_plGoodCount;
                        double _plVar=0.0; for(int _pi=0;_pi<_plGoodCount;_pi++) _plVar += MathPow(_plWR[_pi]-_plMean,2);
                        double _plStd = MathSqrt(_plVar/_plGoodCount);
                        string _plNote = (_plStd < 0.08) ? "stable-plateau" : (_plStd < 0.15) ? "moderate-sensitivity" : "narrow-spike";
                        TLog(StringFormat("  P3B  ·  r%d %-20s  plateau-check   neighbors %d  mean %.1f%%  std %.1f pp  ->  %s",
                            regime+1, GetRegimeName(regime), _plGoodCount, _plMean*100, _plStd*100, _plNote));
                        if(_plStd >= 0.15) {
                            // Narrow spike: same bounded 35% regularization pull already used by
                            // the fit-check and resample-check above -- a NEW trigger on an
                            // EXISTING, already-safe mechanism, never a new or looser accept path.
                            double _rs=0.35;
                            bestWeights.mtf       =bestWeights.mtf*(1-_rs)+1.0*_rs;
                            bestWeights.momentum  =bestWeights.momentum*(1-_rs)+1.0*_rs;
                            bestWeights.volume    =bestWeights.volume*(1-_rs)+1.0*_rs;
                            bestWeights.volatility=bestWeights.volatility*(1-_rs)+1.0*_rs;
                            bestWeights.session   =bestWeights.session*(1-_rs)+1.0*_rs;
                            bestWeights.pattern   =bestWeights.pattern*(1-_rs)+1.0*_rs;
                            TLog(StringFormat("  P3B  ·  r%d %-20s  plateau-reject  std %.1f pp >= 15pp — narrow-spike overfit  ->  regularized 35%%",
                                regime+1, GetRegimeName(regime), _plStd*100));
                            bestWeights.validated=false;
                        }
                    }
                }
            } else {
                // Too sparse to cross-check in enhanced-scorer space: cannot trust linear optimizer's
                // weights. Mark unvalidated so downstream stages know the edge estimate is unconfirmed.
                TLog(StringFormat("  P3B  ·  r%d %-20s  resample-skip    %dt < 15 — sparse regime, weights unvalidated",
                    regime+1, GetRegimeName(regime), _exT));
                bestWeights.validated=false;
            }
        }
        // FIX(30): DIRECTIONAL CHECK — when training WR is below 48%, test whether the
        // OPPOSITE direction would have been profitable. If reverse direction beats forward
        // by >5pp, the signal direction is inverted in this regime (e.g. Strong Bear expects
        // long signals but the actual edge is short). Log this as a diagnostic — it drives
        // future architectural decisions about regime-specific direction overrides.
        if(bestWeights.trainingWR < 0.48 && trainEnd >= 30) {
            int _dfW=0,_dfL=0,_drW=0,_drL=0;
            for(int _di=0; _di<trainEnd; _di++) {
                if(barOutcomes[_di].atr<=0) continue;
                double _dsc=(sc0[_di]*bestWeights.mtf+sc1[_di]*bestWeights.momentum+sc2[_di]*bestWeights.volume+
                             sc3[_di]*bestWeights.volatility+sc4[_di]*bestWeights.session+sc5[_di]*bestWeights.pattern)*seqMult[_di];
                if(MathAbs(_dsc)<optimalThreshold) continue;
                bool _dlng=(_dsc>0);
                double _fwd=_dlng?barOutcomes[_di].longPnL:barOutcomes[_di].shortPnL;
                double _rev=_dlng?barOutcomes[_di].shortPnL:barOutcomes[_di].longPnL;
                if(_fwd>0)_dfW++;else if(_fwd<0)_dfL++;
                if(_rev>0)_drW++;else if(_rev<0)_drL++;
            }
            double _dfWR=(_dfW+_dfL>0)?(double)_dfW/(_dfW+_dfL):0;
            double _drWR=(_drW+_drL>0)?(double)_drW/(_drW+_drL):0;
            if(_drWR > _dfWR+0.05)
                TLog(StringFormat("  P3B  ·  r%d %-20s  dir-check   forward %.0f%%  reverse %.0f%%  ->  SIGNAL INVERTED in this regime  (%dt)",
                    regime+1, GetRegimeName(regime), _dfWR*100, _drWR*100, _dfW+_dfL));
            else
                TLog(StringFormat("  P3B  ·  r%d %-20s  dir-check   forward %.0f%%  reverse %.0f%%  ->  no directional edge reversal  (%dt)",
                    regime+1, GetRegimeName(regime), _dfWR*100, _drWR*100, _dfW+_dfL));
        }
        // FIX(51): REAL-SAMPLE INTEGRITY GATE. Regimes bootstrapped from a handful of
        // real bars (Range n=6, Pullback n=10) produce fantasy 82-92% train WR that is
        // pure noise and collapses OOS. If fewer than 30 REAL bars underpin this regime,
        // commit the weights for live adaptation but mark them UNVALIDATED so they cannot
        // contribute a fake edge to the arm decision — they become observe-only.
        int _realSamples = (g_RegimeRealBarCount[MathMin(8,MathMax(0,regime))] > 0)
                           ? g_RegimeRealBarCount[MathMin(8,MathMax(0,regime))] : barCount;
        if(_realSamples < 30) {
            bestWeights.validated = false;
            TLog(StringFormat("  P3B  ·  r%d %-20s  integrity   %d real bars < 30  ->  observe-only, excluded from arm",
                regime+1, GetRegimeName(regime), _realSamples));
        }
        // FIX(29): sparse-signal guard — 6 free weights on <50 qualifying trades is memorisation, not learning
        // FIX(30): also catches sampleSize=0 (MCM/coord-ascent seeds bestWeights without setting sampleSize)
        // FIX(30): threshold falls back to P1 baseline (not 55.0 which kills OOS signals)
        // WARRANT#14 (forge pass 4): was sampleSize<50 -- Standing Prohibition #5's actual floor is 500,
        // not merely "not tiny"; this is the final safety net after the two upstream WARRANT#14 raises
        // above, so it should rarely trip differently now, but it must state the real floor, not a lower one.
        if(bestWeights.validated && bestWeights.sampleSize < 500) {
            TLog(StringFormat("  P3B  ·  r%d %-20s  sparse-guard  %dt < 500  ->  equal weights  thr->%.0f (P1 baseline)",
                regime+1, GetRegimeName(regime), bestWeights.sampleSize, MathMax(g_BaseThreshold,50.0)));
            bestWeights.mtf=1.0; bestWeights.momentum=1.0; bestWeights.volume=1.0;
            bestWeights.volatility=1.0; bestWeights.session=1.0; bestWeights.pattern=1.0;
            bestWeights.validated=false;
            optimalThreshold=MathMax(g_BaseThreshold, 50.0);  // FIX(30): P1 baseline preserves the only proven edge
        }
        // If no validated edge was found, fall back to P1 baseline threshold — not DEFAULT_REGIME_THRESHOLD
        // (55.0 hard-kills OOS signals; P1 baseline is the only proven score floor for this market)
        if(!bestWeights.validated && g_BaseThreshold > 0)
            optimalThreshold = MathMax(g_BaseThreshold, 18.0);  // 18 = minimum live threshold floor
        g_RegimeOptimalWeights[MathMin(8,MathMax(0,regime))]    = bestWeights;
        g_RegimeOptimalThresholds[MathMin(8,MathMax(0,regime))] = optimalThreshold;
    }

    if(bestWeights.validated) {
        double lift = bestWeights.trainingWR - 0.5;
        TLog(StringFormat("  P3B  ·  r%d %-20s  COMPLETE    %.1f%% WR  val %.1f%%  thr %.0f  %dt  %+.1fpp lift",
            regime+1, regimeName, bestWeights.trainingWR*100,
            MathMax(0.0, bestWeights.validationWR)*100,  // FIX(30): prevent -0.0% display (floating-point negative zero)
            optimalThreshold, MathMax(0, bestWeights.sampleSize), lift*100));
    } else {
        TLog(StringFormat("  P3B  ·  r%d %-20s  COMPLETE    no edge found  ->  equal weights  thr %.0f",
            regime+1, regimeName, optimalThreshold));
    }
}

// ===== forge-cleanup-3, WARRANT#56 (seam audit "weight search -> TP/SL", 2026-07-17) =====
// OptimizeComponentWeightsForRegime (above) fits g_RegimeOptimalWeights against a FIXED
// 1.5x SL / 2.5x TP bracket -- Phase 3B runs before Phase 3C picks the real per-regime
// bracket (see "PHASE 3C: TP/SL MULTIPLIER OPTIMIZATION PER REGIME"). Once 3C has run,
// the base regime weights are still whatever 3B found under the OLD fixed bracket --
// internally coherent with what 3B itself validated, but not with the bracket the live
// engine will actually trade with from this point in calibration on. Only Phase 3B.5/3B.6
// (session/vol refinement, which run after 3C) use the real bracket, and even then only
// when a context has >=500 bars to validate on -- otherwise they fall back to these still
// fixed-bracket base weights (see OptimizeSessionWeightsPerRegime's sCnt<500 branch).
// This is a re-validation gate, not a re-optimization: cheap (one holdout-style pass per
// regime on already-computed weights, not a new grid search), same shape as the existing
// FIX(30) enhanced-scorer cross-check inside OptimizeComponentWeightsForRegime -- reused
// here against the bracket seam instead of the linear/enhanced-scorer seam. A regime whose
// weights don't survive contact with the real bracket is pulled toward equal weights and
// marked observe-only, same convention as every other overfit-rejection in this codebase;
// a regime that does survive gets its recorded WR replaced with the honest number measured
// under the bracket that will actually trade.
void ValidateWeightsAgainstFinalBrackets(int startBar, int endBar) {
    if(!g_TPSLMultCalibrated) return;  // Phase 3C hasn't run yet -- nothing to re-validate against
    for(int regime=0; regime<9; regime++) {
        int ri = MathMin(8,MathMax(0,regime));
        if(!g_RegimeOptimalWeights[ri].validated) continue;

        double _vw6[6];
        _vw6[0]=g_RegimeOptimalWeights[ri].mtf;       _vw6[1]=g_RegimeOptimalWeights[ri].momentum;
        _vw6[2]=g_RegimeOptimalWeights[ri].volume;    _vw6[3]=g_RegimeOptimalWeights[ri].volatility;
        _vw6[4]=g_RegimeOptimalWeights[ri].session;   _vw6[5]=g_RegimeOptimalWeights[ri].pattern;

        int _exitH  = (g_RegimeOptimalExitBars[ri] >= 5) ? g_RegimeOptimalExitBars[ri] : 20;
        double _slM = (g_RegimeOptimalSLMult[ri] > 0) ? g_RegimeOptimalSLMult[ri] : 1.5;
        double _tpM = (g_RegimeOptimalTPMult[ri] > 0) ? g_RegimeOptimalTPMult[ri] : 2.5;
        double _thr = (g_RegimeOptimalThresholds[ri] > 0) ? g_RegimeOptimalThresholds[ri] : DEFAULT_REGIME_THRESHOLD;

        int _vW=0, _vT=0;
        int _span = MathMax(1, endBar - startBar);
        int _step = MathMax(1, _span / 400);   // same 400-bar sample cap as FIX(30)
        for(int _vb=endBar-1; _vb>=startBar && _vb<Bars-30; _vb-=_step) {
            MarketStateFeatures _vf = CalculateMarketFeatures(_vb);
            if(ClassifyBarToRegime(_vf,_vb) != regime) continue;
            double _vsc = CalculateUnifiedScoreCoreAtBar(_vb,_vw6);
            if(MathAbs(_vsc) < _thr) continue;
            double _vatr = iATR(Symbol(),0,14,_vb); if(_vatr<=0 || _vb<2) continue;
            bool _vlng = (_vsc>0);
            double _ve  = (_vb>=1)?Open[_vb-1]:Close[_vb];
            double _vtp = _vlng?_ve+_vatr*_tpM:_ve-_vatr*_tpM;
            double _vsl = _vlng?_ve-_vatr*_slM:_ve+_vatr*_slM;
            bool _vwon=false;
            for(int _vfb=_vb-1; _vfb>=MathMax(0,_vb-_exitH); _vfb--) {
                if(_vlng){if(High[_vfb]>=_vtp){_vwon=true;break;}if(Low[_vfb]<=_vsl)break;}
                else{if(Low[_vfb]<=_vtp){_vwon=true;break;}if(High[_vfb]>=_vsl)break;}
            }
            _vT++; if(_vwon) _vW++;
        }
        if(_vT < 15) {
            TLog(StringFormat("  P3B-bracket-recheck  ·  r%d %-20s  %dt < 15 -- too sparse under final bracket (SL%.1f/TP%.1f), left as-is",
                regime+1, GetRegimeName(regime), _vT, _slM, _tpM));
            continue;
        }
        double _vWR = (double)_vW/_vT;
        double _origWR = g_RegimeOptimalWeights[ri].trainingWR;
        if(_vWR < 0.50 && (_origWR - _vWR) > 0.12) {
            TLog(StringFormat("  P3B-bracket-recheck  ·  r%d %-20s  fixed-bracket %.1f%% vs final-bracket(SL%.1f/TP%.1f) %.1f%% -- regularized 35%%",
                regime+1, GetRegimeName(regime), _origWR*100, _slM, _tpM, _vWR*100));
            double _rs=0.35;
            g_RegimeOptimalWeights[ri].mtf        = g_RegimeOptimalWeights[ri].mtf*(1-_rs)+1.0*_rs;
            g_RegimeOptimalWeights[ri].momentum   = g_RegimeOptimalWeights[ri].momentum*(1-_rs)+1.0*_rs;
            g_RegimeOptimalWeights[ri].volume     = g_RegimeOptimalWeights[ri].volume*(1-_rs)+1.0*_rs;
            g_RegimeOptimalWeights[ri].volatility = g_RegimeOptimalWeights[ri].volatility*(1-_rs)+1.0*_rs;
            g_RegimeOptimalWeights[ri].session    = g_RegimeOptimalWeights[ri].session*(1-_rs)+1.0*_rs;
            g_RegimeOptimalWeights[ri].pattern    = g_RegimeOptimalWeights[ri].pattern*(1-_rs)+1.0*_rs;

            // WARRANT#80: the recheck already measured that the fixed default bracket beats the
            // calibrated one for this regime -- act on that, don't just discard it after logging it.
            // Only trusted when the fixed-bracket number is itself a real, decent WR (not merely
            // "less catastrophic" than the calibrated one), and only when explicitly enabled.
            if(EnableBracketFallbackOnRecheck && _origWR >= BracketFallbackMinFixedWR) {
                TLog(StringFormat("  bracket-fallback  ·  r%d %-20s  reverting SL/TP to fixed default (1.5/2.5) -- final-bracket(SL%.1f/TP%.1f) lost to fixed-bracket on this recheck (%.1f%% vs %.1f%%)",
                    regime+1, GetRegimeName(regime), _slM, _tpM, _vWR*100, _origWR*100));
                g_RegimeOptimalSLMult[ri] = 1.5;
                g_RegimeOptimalTPMult[ri] = 2.5;
                g_RegimeBracketFallback[ri] = true;
            }
        } else {
            g_RegimeBracketFallback[ri] = false;
            TLog(StringFormat("  P3B-bracket-recheck  ·  r%d %-20s  fixed-bracket %.1f%% vs final-bracket(SL%.1f/TP%.1f) %.1f%% -- consistent, WR updated to honest final-bracket value",
                regime+1, GetRegimeName(regime), _origWR*100, _slM, _tpM, _vWR*100));
            g_RegimeOptimalWeights[ri].trainingWR = _vWR;  // honest -- matches the bracket that will actually trade
        }
    }
}
// ===== end WARRANT#56 =====

// PHASE 1B: MULTI-DIMENSIONAL PROBABILITY DATABASE FUNCTIONS
// Build and query conditional probability matrix

int FindOrCreateProbabilityEntry(int regime, int scoreRange, PatternType pattern, int session, int vol) {
    // Search for existing entry
    for(int i = 0; i < g_ProbabilityCount; i++) {
        if(g_ProbabilityMatrix[i].regime == regime &&
           g_ProbabilityMatrix[i].scoreRange == scoreRange &&
           g_ProbabilityMatrix[i].pattern == pattern &&
           g_ProbabilityMatrix[i].session == session &&
           g_ProbabilityMatrix[i].volatility == vol) {
            return i;  // Found existing
        }
    }
    
    // Create new entry
    if(g_ProbabilityCount >= 25000) {
        // Matrix at capacity - find and replace least useful entry
        int minObservations = 999999;
        int replaceIdx = 0;
        for(int i = 0; i < g_ProbabilityCount; i++) {
            if(g_ProbabilityMatrix[i].observations < minObservations) {
                minObservations = g_ProbabilityMatrix[i].observations;
                replaceIdx = i;
            }
        }
        // Only replace if new combination will be more useful
        if(minObservations < 5) {
            // Reset this entry for new combination
            g_ProbabilityMatrix[replaceIdx].regime = regime;
            g_ProbabilityMatrix[replaceIdx].scoreRange = scoreRange;
            g_ProbabilityMatrix[replaceIdx].pattern = pattern;
            g_ProbabilityMatrix[replaceIdx].session = session;
            g_ProbabilityMatrix[replaceIdx].volatility = vol;
            g_ProbabilityMatrix[replaceIdx].observations = 0;
            g_ProbabilityMatrix[replaceIdx].wins = 0;
            g_ProbabilityMatrix[replaceIdx].winRate = 0;
            g_ProbabilityMatrix[replaceIdx].avgProfit = 0;
            g_ProbabilityMatrix[replaceIdx].avgLoss = 0;
            g_ProbabilityMatrix[replaceIdx].expectedValue = 0;
            g_ProbabilityMatrix[replaceIdx].confidence = 0;
            g_ProbabilityMatrix[replaceIdx].validated = false;
            g_ProbabilityMatrix[replaceIdx].lastSeen = TimeCurrent();
            return replaceIdx;
        }
        return -1;  // Can't replace, all entries too valuable
    }
    
    int idx = g_ProbabilityCount;
    g_ProbabilityMatrix[idx].regime = regime;
    g_ProbabilityMatrix[idx].scoreRange = scoreRange;
    g_ProbabilityMatrix[idx].pattern = pattern;
    g_ProbabilityMatrix[idx].session = session;
    g_ProbabilityMatrix[idx].volatility = vol;
    g_ProbabilityMatrix[idx].observations = 0;
    g_ProbabilityMatrix[idx].wins = 0;
    g_ProbabilityMatrix[idx].winRate = 0;
    g_ProbabilityMatrix[idx].avgProfit = 0;
    g_ProbabilityMatrix[idx].avgLoss = 0;
    g_ProbabilityMatrix[idx].expectedValue = 0;
    g_ProbabilityMatrix[idx].confidence = 0;
    g_ProbabilityMatrix[idx].validated = false;
    g_ProbabilityMatrix[idx].lastSeen = TimeCurrent();
    
    if(g_ProbabilityCount >= 25000) return -1;  // Matrix full -- never overwrite
    g_ProbabilityCount++;
    return idx;
}

void UpdateProbabilityEntry(int index, bool won, double profitPct) {
    if(index < 0 || index >= g_ProbabilityCount) return;
    
    // MQL4: Cannot use & for array elements - access directly
    g_ProbabilityMatrix[index].observations++;
    
    if(won) {
        g_ProbabilityMatrix[index].wins++;
        // Update average profit using incremental average
        if(g_ProbabilityMatrix[index].wins == 1) {
            g_ProbabilityMatrix[index].avgProfit = profitPct;
        } else {
            g_ProbabilityMatrix[index].avgProfit = g_ProbabilityMatrix[index].avgProfit + 
                                                     (profitPct - g_ProbabilityMatrix[index].avgProfit) / MathMax(1, g_ProbabilityMatrix[index].wins);  // zero-div guard
        }
    } else {
        int losses = g_ProbabilityMatrix[index].observations - g_ProbabilityMatrix[index].wins;
        // Update average loss using incremental average
        if(losses <= 1) {
            g_ProbabilityMatrix[index].avgLoss = MathAbs(profitPct);  // FIX62: was ==1; now <=1 guards losses==0 divide
        } else {
            g_ProbabilityMatrix[index].avgLoss = g_ProbabilityMatrix[index].avgLoss + 
                                                   (MathAbs(profitPct) - g_ProbabilityMatrix[index].avgLoss) / losses;
        }
    }
    
    // Recalculate metrics
    // CEO-C (9.18A): Bayesian winRate — prior=0.65 decays with observation count
    // At n=10: winRate is 40% observation, 60% prior. At n=50: ~75% observation.
    { double _flat = (double)g_ProbabilityMatrix[index].wins / (double)g_ProbabilityMatrix[index].observations;
      double _priorW = MathMax(0.05, 5.0 / (double)g_ProbabilityMatrix[index].observations); // prior weight decays
      g_ProbabilityMatrix[index].winRate = _flat * (1.0-_priorW) + 0.65 * _priorW; }
    g_ProbabilityMatrix[index].expectedValue = (g_ProbabilityMatrix[index].winRate * g_ProbabilityMatrix[index].avgProfit) - 
                                                 ((1 - g_ProbabilityMatrix[index].winRate) * g_ProbabilityMatrix[index].avgLoss);
    g_ProbabilityMatrix[index].confidence = CalculateStatisticalConfidence(g_ProbabilityMatrix[index].observations);
    g_ProbabilityMatrix[index].validated = (g_ProbabilityMatrix[index].observations >= 10 && g_ProbabilityMatrix[index].confidence >= 0.75);
    g_ProbabilityMatrix[index].lastSeen = TimeCurrent();
}

void BuildMultiDimensionalProbabilityDatabase(int _p4Start = -1, int _p4End = -1) {
    if(!g_CalibSilent) Print("  CAL   |   phase 4   |   building probability matrix");
    if(!g_CalibSilent) Print("  Dimensions: Score x Regime x Pattern x Session x Volatility x Direction");
    if(!g_CalibSilent) Print("  Output: conditional win rate + expected value per context combination.");
    datetime startTime = TimeCurrent();
    int barsProcessed = 0;
    int lastMilestone = 0;
    
    // FIX(52): scan the FULL training window (was a fixed 500-8000 = ~7.5k bars, a
    // third of the data). More bars = denser, more reliable conditional probabilities.
    // Bounds default to the true training window beyond the OOS reserve; the OOS window
    // (30..GetOOSWindowBars()) is never scanned, preserving validation purity.
    int _p4Lo = (_p4Start >= 0) ? _p4Start : (GetOOSWindowBars() + 120);
    int _p4Hi = (_p4End   >  0) ? _p4End   : (Bars - 30);
    if(_p4Lo < GetOOSWindowBars() + 1) _p4Lo = GetOOSWindowBars() + 1;  // never enter OOS
    if(_p4Hi > Bars - 30) _p4Hi = Bars - 30;
    int _p4Span = MathMax(1, _p4Hi - _p4Lo);
    for(int bar = _p4Lo; bar < _p4Hi; bar++) {
        barsProcessed++;
        
        // Progress milestones
        int progress = (int)((barsProcessed * 100.0) / _p4Span);
        if(progress >= 25 && lastMilestone == 0) {
            if(!g_CalibSilent) PrintFormat("  %s - Initial correlation patterns emerging...", CalibProgressBar(25));
            lastMilestone = 1;
        } else if(progress >= 50 && lastMilestone == 1) {
            if(!g_CalibSilent) PrintFormat("  %s - Cross-referencing context combinations...", CalibProgressBar(50));
            lastMilestone = 2;
        } else if(progress >= 75 && lastMilestone == 2) {
            if(!g_CalibSilent) PrintFormat("  %s - Validating high-probability setups...", CalibProgressBar(75));
            lastMilestone = 3;
        }
        
        // Calculate features
        MarketStateFeatures features = CalculateMarketFeatures(bar);
        int regime = ClassifyBarToRegime(features, bar);
        
        // Calculate score with optimal weights (if available)
        double score = CalculateEnhancedUnifiedScore(bar);
        int scoreRange = MathMax(0, MathMin(9, (int)((score + 100.0) / 20.0)));  // 0..9: -100->0, 0->5, +100->10->clamp9  // 0-9 ranges
        
        // Detect pattern
        MicroPattern pattern = DetectMicroPatternAt(bar);
        
        // Determine session
        int session = DetermineSession(TimeHour(Time[bar]));
        
        // Determine volatility
        int vol = DetermineVolatility(features.atr);
        
        // Outcome measured with regime-specific ATR TP/SL + time-exit, matching the live EA.
        int regime4db = ClassifyBarToRegime(features, bar);
        int exitBars4 = (g_WeightsOptimized && regime4db >= 0 && regime4db < 9
                         && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,regime4db))] >= 5)
                        ? g_RegimeOptimalExitBars[MathMin(8,MathMax(0,regime4db))] : 20;
        if(bar - exitBars4 < 0) continue;
        double _atrDB = iATR(NULL, PERIOD_CURRENT, 14, bar);
        if(_atrDB <= 0) continue;
        bool isLong = (score > 0);
        double entry = (bar>=1&&bar-1<Bars)?Open[bar-1]:Close[bar];  // no look-ahead
        // FIX(52): use the regime's CALIBRATED TP/SL (from Phase 3C) so the database's
        // probabilities describe the trades the system ACTUALLY takes — not a generic
        // 2.5/1.5 that no live trade uses. Falls back to 2.5/1.5 only if uncalibrated.
        double _tpMdb = (g_RegimeOptimalTPMult[MathMin(8,MathMax(0,regime4db))] > 0.1)
                        ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,regime4db))] : 2.5;
        double _slMdb = (g_RegimeOptimalSLMult[MathMin(8,MathMax(0,regime4db))] > 0.1)
                        ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,regime4db))] : 1.5;
        double tpDB = isLong ? entry + _atrDB * _tpMdb : entry - _atrDB * _tpMdb;
        double slDB = isLong ? entry - _atrDB * _slMdb : entry + _atrDB * _slMdb;
        bool hitTPdb = false, hitSLdb = false;
        for(int _fb = bar - 1; _fb >= MathMax(0, bar - exitBars4); _fb--) {
            double _hi = High[_fb], _lo = Low[_fb];
            if(isLong) { if(_hi >= tpDB) { hitTPdb = true; break; } if(_lo <= slDB) { hitSLdb = true; break; } }
            else       { if(_lo <= tpDB) { hitTPdb = true; break; } if(_hi >= slDB) { hitSLdb = true; break; } }
        }
        bool won = hitTPdb ? true : (hitSLdb ? false : (isLong ? Close[MathMax(0,bar-exitBars4)] > entry : Close[MathMax(0,bar-exitBars4)] < entry));
        double profitPct = hitTPdb ? (_atrDB * _tpMdb / entry * 100.0) : (hitSLdb ? -(_atrDB * _slMdb / entry * 100.0) :
            (isLong ? (Close[MathMax(0,bar-exitBars4)] - entry) / entry * 100.0
                    : (entry - Close[MathMax(0,bar-exitBars4)]) / entry * 100.0));
        
        // Find or create entry in probability matrix
        int index = FindOrCreateProbabilityEntry(regime, scoreRange, pattern.type, session, vol);
        
        if(index >= 0) {
            UpdateProbabilityEntry(index, won, profitPct);
        }
    }
    
    // Count high-probability setups
    int highProbCount = 0;
    int validatedCount = 0;
    
    for(int i = 0; i < g_ProbabilityCount; i++) {
        if(g_ProbabilityMatrix[i].validated) {
            validatedCount++;
            if(g_ProbabilityMatrix[i].winRate >= 0.65 && 
               g_ProbabilityMatrix[i].expectedValue > 0.5) {
                highProbCount++;
            }
        }
    }
    
    int elapsed = (int)((TimeCurrent() - startTime) / 60.0);
    
    if(!g_CalibSilent) PrintFormat("  Probability matrix: %d combinations  |  %d validated  |  %d high-probability  |  %dm",
               g_ProbabilityCount, validatedCount, highProbCount, elapsed);
    
    g_ProbabilityDatabaseBuilt = true;
}

ConditionalProbability QueryProbabilityMatrix(int regime, int scoreRange, PatternType pattern, int session, int vol) {
    ConditionalProbability result;
    result.observations = 0;
    result.wins = 0;
    result.winRate = 0;
    result.expectedValue = 0;
    result.confidence = 0;
    result.validated = false;
    
    if(!g_ProbabilityDatabaseBuilt) return result;
    
    // Find exact match first
    for(int i = 0; i < g_ProbabilityCount; i++) {
        if(g_ProbabilityMatrix[i].regime == regime &&
           g_ProbabilityMatrix[i].scoreRange == scoreRange &&
           g_ProbabilityMatrix[i].pattern == pattern &&
           g_ProbabilityMatrix[i].session == session &&
           g_ProbabilityMatrix[i].volatility == vol) {
            return g_ProbabilityMatrix[i];
        }
    }
    
    // If no exact match, try relaxing constraints
    // First try: Same regime, scoreRange, pattern (ignore session/vol)
    for(int i = 0; i < g_ProbabilityCount; i++) {
        if(g_ProbabilityMatrix[i].regime == regime &&
           g_ProbabilityMatrix[i].scoreRange == scoreRange &&
           g_ProbabilityMatrix[i].pattern == pattern &&
           g_ProbabilityMatrix[i].observations >= 8) {
            return g_ProbabilityMatrix[i];
        }
    }
    
    // Second try: Same regime and scoreRange (ignore pattern/session/vol)
    for(int i = 0; i < g_ProbabilityCount; i++) {
        if(g_ProbabilityMatrix[i].regime == regime &&
           g_ProbabilityMatrix[i].scoreRange == scoreRange &&
           g_ProbabilityMatrix[i].observations >= 15) {
            return g_ProbabilityMatrix[i];
        }
    }
    
    return result;  // No match found
}

// PHASE 2: INTELLIGENT SIGNAL GENERATION (LIVE TRADING INTEGRATION)
// Use ALL learned intelligence: weights, thresholds, probabilities

struct IntelligentSignal {
    bool valid;              // Whether signal passed all checks
    int direction;           // 1 = buy, -1 = sell
    double confidence;       // Overall signal confidence (0-1)
    double expectedValue;    // Expected value per trade (%)
    int regime;              // Detected regime
    double score;            // Calculated score with regime weights
    double regimeThreshold;  // Regime-specific threshold
    double probabilityWR;    // Win rate from probability database
    int    reasonCode;       // 0=generated, see REJ_* constants (was string)
};

IntelligentSignal GenerateIntelligentSignal() {
    static double _sPendingGuardAdj = 0.0;  // post-spike threshold adj, consumed after regimeThreshold declared
    // SLS23 FIX: was accumulated into signal.regimeThreshold in Step 3, below, before the local
    // 'regimeThreshold' variable even existed (declared in Step 5) -- got unconditionally clobbered
    // by 'signal.regimeThreshold = regimeThreshold;' and never affected the actual entry gate.
    double _regimeConfAdj = 0.0;
    // SLS23 FIX: signal.confidence is written by the post-spike guard and the candle-anatomy
    // cross-validation block below, then unconditionally overwritten by the Step 11 formula --
    // none of that work ever reached the confidence value actually used for lot-sizing/logging.
    // Capture their intended effect here and apply it after Step 11 computes the base value.
    double _postSpikeConfCap = -1.0;   // -1 = not active; the guard sets this to 0.57 when armed
    double _alignMultCaptured = 1.0;
    double _anatomyModCaptured = 1.0;
    IntelligentSignal signal;
    signal.valid = false;
    signal.direction = 0;
    signal.confidence = 0;
    signal.expectedValue = 0;
    signal.reasonCode = 0;  // was string reasoning
    
    // Step 1: Calculate features
    MarketStateFeatures features = CalculateMarketFeatures(0);
    
    // Step 2: Classify regime (correlation-enhanced)
    int regime = ClassifyBarToRegime_WithHysteresis(features, 0);
    signal.regime = regime;
    
    // Step 3: Check regime confidence (if correlation learning completed)
    if(g_CorrelationsLearned && regime >= 0 && regime < 9) {
        // Training accuracy from regime correlations
        double trainAccuracy = g_RegimeCorrelations[regime].overallAccuracy;
        // Cross-validated accuracy (blend of training + OOS from Phase 6)
        double crossValAccuracy = g_RegimeLearning.perRegimeAccuracy[regime];
        // Use cross-validated when available (> 0 means we have OOS data),
        // otherwise fall back to training-only. Cross-val is harder to overfit.
        double regimeConfidence = (crossValAccuracy > 0.0)
            ? (trainAccuracy * 0.4 + crossValAccuracy * 0.6)  // weight OOS more
            : trainAccuracy;
        // Below 0.52 = at-random, block
        if(regimeConfidence < 0.52) {
            signal.reasonCode = 0;
            return signal;
        }
        // Moderate confidence (0.52-0.70): tighten threshold
        if(regimeConfidence < 0.70) {
            _regimeConfAdj += 4.0;
        }
        // Dominant regime bonus: if this is the best regime overall, slight relax
        if(regime == g_RegimeLearning.dominantRegime && regimeConfidence >= 0.68)
            _regimeConfAdj -= 1.5;
    }
    
    // Step 4: Score uses context-aware 3-way blend (regime+session+vol weights)
    double score = CalculateEnhancedUnifiedScore(0);
    signal.score = score;

    // -- CEO: POST-SPIKE EMOTIONAL PERIOD GUARD ------------------------------
    {
        static int   g_PostSpikeGuard    = 0;   // bars remaining in guard window
        // _sPendingGuardAdj declared at function scope (line ~6155)
        static datetime g_PostSpikeTime  = 0;
        double _aNow = iATR(Symbol(), 0, 14, 0);
        double _aAvg = 0.0;
        for(int _bk2=1;_bk2<=20;_bk2++) _aAvg += iATR(Symbol(),0,14,_bk2); _aAvg /= 20.0;
        double _spikeRatio = (_aAvg > 0) ? _aNow / _aAvg : 1.0;

        // Detect fresh spike on current bar
        if(_spikeRatio >= 2.0 && iBarShift(Symbol(), Period(), TimeCurrent()) == 0) {
            // New spike bar: open a 4-bar guard window
            if(g_PostSpikeGuard == 0) {  // only reset if not already in guard
                g_PostSpikeGuard = 4;
                g_PostSpikeTime  = TimeCurrent();
                if(EnableFriendlyLogs && !g_CalibSilent) {
                    static datetime _lastSpLog = 0;
                    if(g_PostSpikeTime != _lastSpLog) {
                        PrintFormat("  spike guard OPEN   |   ATR %.2fx   |   4-bar emotional window blocked",
                                    _spikeRatio);
                        _lastSpLog = g_PostSpikeTime;
                    }
                }
            }
        }

        // Decay guard on each new bar (bar time changed = new bar)
        static datetime _lastBar2 = 0;
        if(Time[0] != _lastBar2) {
            if(g_PostSpikeGuard > 0) g_PostSpikeGuard--;
            _lastBar2 = Time[0];
        }

        // Apply guard: tighten confidence + raise threshold
        if(g_PostSpikeGuard > 0) {
            _postSpikeConfCap = 0.57;  // SLS23 FIX: applied at Step 11 now; was capping the still-zero confidence here
            // Threshold raised by remaining guard strength
            // _sPendingGuardAdj declared at function scope above
            _sPendingGuardAdj = g_PostSpikeGuard * 1.5;
        }
    }

    // Step 5: Context-aware threshold = regime-calibrated base + session + vol adjustments
    double regimeThreshold = (g_WeightsOptimized && regime >= 0 && regime < 9) ?
                             g_RegimeOptimalThresholds[MathMin(8,MathMax(0,regime))] : DEFAULT_REGIME_THRESHOLD;
    // SLS23 FIX: fold in the Step 3 regime-confidence adjustment now that this variable exists
    // (it's part of the calibrated base, not a stacking "hostile" adjustment, so applied before
    // _thrBase is snapshotted and doesn't count against the net-adjustment cap below).
    regimeThreshold = MathMax(38.0, MathMin(88.0, regimeThreshold + _regimeConfAdj));
    double _thrBase = regimeThreshold;  // snapshot calibrated base for net-cap calculation
    if(_sPendingGuardAdj>0.0){regimeThreshold=MathMin(82.0,regimeThreshold+_sPendingGuardAdj);_sPendingGuardAdj=0.0;}
    // FIX19: fragile calibration — edge passed gates but context variance was high; require stronger signal
    if(g_Calibration.fragileFlag) regimeThreshold = MathMin(82.0, regimeThreshold + 4.0);
    if(g_WeightsOptimized && regime >= 0 && regime < 9) {
        // Session: valid session weights signal that session has calibrated edge -> lower threshold slightly
        int _gmtH2 = (TimeHour(Time[0]) - g_ServerTimeOffsetHours + 24) % 24;
        int ses2 = (_gmtH2>=7&&_gmtH2<16)?0:(_gmtH2>=16&&_gmtH2<21)?1:(_gmtH2>=21||_gmtH2<6)?3:2;
        if(g_SessionWeightsValid[ses2][regime]) regimeThreshold -= 2.0;
        // Volatility: spiky vol -> +3pt selectivity; clean low-vol -> -1.5pt relax
        double _aLive=iATR(NULL,PERIOD_CURRENT,14,0), _a20L=0;
        for(int _k=0;_k<20;_k++) _a20L+=iATR(NULL,PERIOD_CURRENT,14,_k); _a20L/=20.0;
        double _arL=(_a20L>0)?_aLive/_a20L:1.0;
        if(_arL > g_CalibratedVolHighThresh*1.1) regimeThreshold += 3.0;
        else if(_arL < g_CalibratedVolLowThresh)  regimeThreshold -= 1.5;
        regimeThreshold = MathMax(42.0, MathMin(80.0, regimeThreshold));
    }
    // ## BEHAVIORAL COHERENCE THRESHOLD ADJUSTMENT ######################
    if(g_RegimeBehavioralCoherence < 0.40 && g_RegimeMaturityPhase >= 2) {
        regimeThreshold += 4.0;  // Contradictory bar in established regime
    } else if(g_RegimeBehavioralCoherence > 0.80 && g_RegimeMaturityPhase == 2
              && g_RegimeSubPattern > 0) {
        regimeThreshold -= 1.5;  // Textbook behavior in mature identified regime
    }
    // EXHAUSTING phase raises threshold regardless of coherence
    if(g_RegimeMaturityPhase == 3) regimeThreshold += 3.0;

    // ## DEEP HISTORICAL INTELLIGENCE ADJUSTMENTS #############################
    // Per-hour WR: 400+ observations per hour over 1.4 years of data.
    if(g_HourlyCalibrated) {
        int _gmtNow = (TimeHour(Time[0]) - g_ServerTimeOffsetHours + 24) % 24;
        if(g_HourlyObs[MathMin(23,MathMax(0,_gmtNow))] >= 15) {
            double _hWR = g_HourlyWR[MathMin(23,MathMax(0,_gmtNow))];
            if(_hWR >= 0.72)      regimeThreshold -= 3.0;
            else if(_hWR >= 0.65) regimeThreshold -= 1.5;
            else if(_hWR < 0.50)  regimeThreshold += 6.0;
            else if(_hWR < 0.55)  regimeThreshold += 4.0;
        }
    }
    // Day-of-week WR: 800+ observations per weekday.
    if(g_DayOfWeekCalibrated) {
        int _dow = TimeDayOfWeek(TimeCurrent()) - 1;
        if(_dow >= 0 && _dow < 5 && g_DayOfWeekObs[MathMin(4,MathMax(0,_dow))] >= 20) {
            double _dWR = g_DayOfWeekWR[MathMin(4,MathMax(0,_dow))];
            if(_dWR >= 0.70)      regimeThreshold -= 2.0;
            else if(_dWR < 0.55)  regimeThreshold += 3.0;
        }
    }
    // Regime age: young trends (1-3 bars) are unproven, mature (4-15) are sweet spot.
    if(g_RegimeAgeCalibrated && regime >= 0 && regime < 9) {
        int _barsInReg = g_RegimeState.confirmedBars;
        int _ageIdx = (_barsInReg <= 3) ? 0 : (_barsInReg <= 15) ? 1 : 2;
        regimeThreshold += g_RegimeAgeThreshAdj[regime][_ageIdx];
    }
    // Regime transition: if the dominant next-regime aligns with signal direction, relax.
    if(g_TransitionMatrixBuilt && regime >= 0 && regime < 9 && g_RegimeTransitionCount[regime] >= 20) {
        int _nReg = 0; double _nProb = 0;
        for(int _nr = 0; _nr < 9; _nr++)
            if(g_RegimeTransitionProb[regime][_nr] > _nProb)
                { _nProb = g_RegimeTransitionProb[regime][_nr]; _nReg = _nr; }
        bool _nBull = (_nReg==0 || _nReg==2 || _nReg==7);
        bool _nBear = (_nReg==1 || _nReg==3);
        bool _sBuy  = (signal.score > 0);
        if(_nProb >= 0.60) {
            if((_sBuy&&_nBull)||(!_sBuy&&_nBear))    regimeThreshold -= 2.0;
            else if((_sBuy&&_nBear)||(!_sBuy&&_nBull)) regimeThreshold += 2.0;
        }
    }

    // ## EMA200 STRUCTURE ADJUSTMENT ##########################################
    {
        MarketStateFeatures _sf = CalculateMarketFeatures(0);
        double _ema200d = _sf.ema200Distance;
        bool   _isBuy   = (score > 0);
        // With-trend: signal direction matches EMA200 side
        bool   _withTrend = (_isBuy && _ema200d > 0.5) || (!_isBuy && _ema200d < -0.5);
        bool   _counter   = (_isBuy && _ema200d < -1.0) || (!_isBuy && _ema200d > 1.0);
        double _ema200adj = 0.0;
        if(_withTrend)  _ema200adj = -MathMin(2.0, MathAbs(_ema200d) * 0.6);  // relax up to -2pt
        if(_counter)    _ema200adj = +MathMin(4.0, MathAbs(_ema200d) * 1.2);  // tighten up to +4pt
        regimeThreshold += _ema200adj;
    }
    regimeThreshold = MathMax(42.0, MathMin(82.0, regimeThreshold));

    // -- CEO: BEHAVIORAL EXHAUSTION DETECTOR --------------------------------─
    {
        double _atrNow  = iATR(Symbol(), 0, 14, 0);
        double _atr20   = 0.0;
        for(int _bk=1; _bk<=20; _bk++) _atr20 += iATR(Symbol(),0,14,_bk); _atr20 /= 20.0;
        double _atrRatio = (_atr20 > 0) ? _atrNow / _atr20 : 1.0;

        // Count consecutive directional bars (price run without pullback)
        bool   _scoreDir = (score > 0);
        int    _runBars  = 0;
        for(int _rb=1; _rb<=6; _rb++) {
            if(_rb >= Bars) break;
            bool _barUp = (Close[_rb] > Open[_rb]);
            if(_scoreDir == _barUp) _runBars++; else break;
        }

        // Exhaustion: elevated ATR + 3+ bar run in direction of signal
        // = price has been moving hard, retail is chasing, entry is late
        double _exhaustionScore = 0.0;
        if(_atrRatio > 1.40) _exhaustionScore += 0.35;   // significantly elevated vol
        else if(_atrRatio > 1.20) _exhaustionScore += 0.15;
        if(_runBars >= 4)   _exhaustionScore += 0.40;    // 4+ bar run = momentum chase
        else if(_runBars >= 3) _exhaustionScore += 0.20;

        // Regime entropy penalty: chaotic regime + late-entry = very high risk
        if(regime >= 0 && regime < 9) {
            double _rEntr = g_RegimeCorrelations[regime].avgEntropy;
            if(_rEntr > 0.65) _exhaustionScore += 0.15;
        }

        if(_exhaustionScore >= 0.55) {
            // High exhaustion: this looks like a FOMO trap entry
            double _exAdj = MathMin(8.0, _exhaustionScore * 12.0);  // +5 to +8pt
            regimeThreshold += _exAdj;
            regimeThreshold = MathMin(82.0, regimeThreshold);
            if(EnableFriendlyLogs && !g_CalibSilent) {
                static datetime _lastExLog = 0;
                if(TimeCurrent() - _lastExLog > 180) {
                    PrintFormat("  behav exhaustion   |   +%.0fpt threshold   |   ATR %.2fx   |   %d-bar run",
                                _exAdj, _atrRatio, _runBars);
                    _lastExLog = TimeCurrent();
                }
            }
        }
    }

    // -- S/R Zone Alignment Bias --------------------------------------------─
    {
        // Reuse cached features (already computed at bar-0, no recompute needed)
        MarketStateFeatures _szF = features;
        bool _buySignal = (score > 0);

        // Zone alignment: signal direction matches S/R zone context
        if(_szF.inDiscountZone && _buySignal && _szF.srZoneQuality >= 25.0) {
            // Buying in discount zone: institutionally aligned - relax threshold
            regimeThreshold -= MathMin(3.0, _szF.srZoneQuality * 0.04);
        } else if(_szF.inPremiumZone && !_buySignal && _szF.srZoneQuality >= 25.0) {
            // Selling in premium zone: institutionally aligned - relax threshold
            regimeThreshold -= MathMin(3.0, _szF.srZoneQuality * 0.04);
        } else if(_szF.inPremiumZone && _buySignal && _szF.srZoneQuality >= 30.0) {
            // Buying in premium zone: counter-institutional - tighten
            regimeThreshold += MathMin(4.0, _szF.srZoneQuality * 0.05);
        } else if(_szF.inDiscountZone && !_buySignal && _szF.srZoneQuality >= 30.0) {
            // Selling in discount zone: counter-institutional - tighten
            regimeThreshold += MathMin(4.0, _szF.srZoneQuality * 0.05);
        }

        // Role-reversal levels: these are the strongest S/R signals in all of
        // price action. A former resistance now tested as support - bullish context.
        // Former support now tested as resistance - bearish context.
        if(_szF.supportRoleReversal && _buySignal && _szF.distToSupportATR < 1.5)
            regimeThreshold -= 3.0;  // Role-reversal support + buy = very high conviction
        if(_szF.resistanceRoleReversal && !_buySignal && _szF.distToResistanceATR < 1.5)
            regimeThreshold -= 3.0;  // Role-reversal resistance + sell = very high conviction

        // H4 confluence: higher timeframe confirms current level - earned relaxation
        if(_szF.h4SRConfluence && _szF.h4SRProximity < 1.5)
            regimeThreshold -= MathMin(2.0, (2.0 - _szF.h4SRProximity));
        // Approach direction: trade WITH structure, penalise trading through broken levels
        if(_szF.srZoneQuality >= 20.0) {
            double _ap5 = 0; for(int _ai=1;_ai<=5;_ai++) _ap5+=Close[_ai]; _ap5/=5.0;
            // Long into already-broken support: penalise
            if(_buySignal && _szF.distToSupportATR < 1.0 && _szF.keySupport > 0
               && _ap5 < _szF.keySupport)
                regimeThreshold = MathMin(82.0, regimeThreshold + 5.0);
            // Short into already-broken resistance: penalise
            if(!_buySignal && _szF.distToResistanceATR < 1.0 && _szF.keyResistance > 0
               && _ap5 > _szF.keyResistance)
                regimeThreshold = MathMin(82.0, regimeThreshold + 5.0);
        }

        regimeThreshold = MathMax(42.0, MathMin(82.0, regimeThreshold));
    }

    // -- Regime Transition Intelligence Gate ----------------------------─
    // mostLikelyNextReg: if calibrated transition data anticipates a regime
    // shift, the current signal quality changes. Entering a trade 1 bar
    // before regime turns to Noise/Choppy is the definition of bad timing.
    if(g_Awareness.isValid && g_Awareness.mostLikelyNextReg >= 0 &&
       g_Awareness.mostLikelyNextReg != regime &&
       g_Awareness.continuationProb < 0.60) {  // Transition is likely
        int _nextReg = g_Awareness.mostLikelyNextReg;
        // Hostile next regime: noise, choppy, or opposite trend
        bool _nextHostile = (_nextReg == 5 || _nextReg == 6) ||
                            (_nextReg == 1 && regime == 0) ||
                            (_nextReg == 0 && regime == 1);
        // Favourable next regime: continuation or strengthening
        bool _nextFavourable = (_nextReg == 0 && (regime == 2 || regime == 7)) ||
                               (_nextReg == 1 && (regime == 3 || regime == 7));
        if(_nextHostile)
            regimeThreshold = MathMin(82.0, regimeThreshold + 3.0);
        else if(_nextFavourable)
            regimeThreshold = MathMax(42.0, regimeThreshold - 1.5);
    }

    // -- Forward Path Quality Gate (5-step expected WR) ----------------─
    // If the 5-step forward simulation says the market is heading into
    // hostile territory, require a stronger signal to enter.
    // This is the trading equivalent of not moving a piece into a position
    // where the opponent has a winning response chain.
    if(g_Awareness.isValid && g_CorrelationsLearned) {
        if(g_Awareness.pathExpectedWR < 0.57) {
            // Hostile path: 2-5pt threshold increase proportional to path deterioration
            double _pathPenalty = (0.57 - g_Awareness.pathExpectedWR) * 40.0;  // 0-8pt
            regimeThreshold = MathMin(84.0, regimeThreshold + MathMin(6.0, _pathPenalty));
        } else if(g_Awareness.pathExpectedWR > 0.70 && g_Awareness.certainty > 0.65) {
            // Hospitable path with high certainty: small threshold relaxation
            regimeThreshold = MathMax(42.0, regimeThreshold - 1.5);
        }
        // -- Bayesian belief conviction threshold adjustment --------------
        // When the Bayesian belief state is concentrated on the current regime,
        // the system is operating with high fidelity. Allow that to reduce friction.
        // When belief is diffuse (confused market), raise the bar.
        if(g_Calibration.isComplete) {
            MarketStateFeatures _bTF = CalculateMarketFeatures(0);  // cached
            if(_bTF.beliefConviction > 0.70 && _bTF.dominantBeliefRegime == regime) {
                // Bayesian belief confirms we're in the calibrated regime: small relaxation
                regimeThreshold = MathMax(42.0, regimeThreshold - (_bTF.beliefConviction - 0.70) * 8.0);
            } else if(_bTF.beliefConviction < 0.35) {
                // Market regime unclear: tighten by up to 5pt
                regimeThreshold = MathMin(82.0, regimeThreshold + (0.35 - _bTF.beliefConviction) * 14.0);
            }
        }

        // -- Next-step hostile early warning ------------------------------
        // If the single most probable next regime is noise (R6) or exhaustion (R7)
        // with >40% probability, raise threshold independently.
        // Chess: don't move a piece where the opponent's immediate reply is crushing.
        if(g_TransitionMatrixBuilt && g_RegimeState.currentRegime >= 0 &&
           g_RegimeState.currentRegime < 9 &&
           g_RegimeTransitionCount[g_RegimeState.currentRegime] >= 5) {
            int _nr = g_Awareness.mostLikelyNextReg;
            double _nrProb = (_nr >= 0 && _nr < 9) ?
                g_RegimeTransitionProb[g_RegimeState.currentRegime][_nr] : 0.0;
            bool _nextHostile = (_nr == 6 || _nr == 7);  // R6=noise, R7=exhaustion
            if(_nextHostile && _nrProb > 0.40) {
                double _hostilePenalty = 3.0 + (_nrProb - 0.40) * 10.0;  // 3-4pt
                regimeThreshold = MathMin(85.0, regimeThreshold + MathMin(4.0, _hostilePenalty));
            }
        }
    }

    // -- Market Awareness Signal Legitimacy Gate ------------------------─
    // If the system's self-model says this signal is anomalous (contradicts
    // divergence, premium/discount context, or calibration coverage)
    // tighten the threshold by 5 points. Grounded, not panicked — just careful.
    if(g_Awareness.isValid && !g_Awareness.signalLegitimate) {
        regimeThreshold = MathMin(82.0, regimeThreshold + 5.0);
    }
    // If certainty is high AND environment is familiar, earned small relaxation
    if(g_Awareness.isValid && g_Awareness.certainty >= 0.75 &&
       g_Awareness.environmentFamiliar && g_Awareness.coherence >= 0.70) {
        regimeThreshold = MathMax(42.0, regimeThreshold - 2.0);
    }

    // Pre-transition detection: flag exhausting regime before hysteresis fires

    // ADX declining 3 bars + Hurst trending toward 0.5 = regime about to shift

    if(g_RegimeMaturityPhase == 2 && !g_RegimeState.inTransition) {

    double _adxNow = iADX(Symbol(),0,14,PRICE_CLOSE,MODE_MAIN,0);

    double _adx1   = iADX(Symbol(),0,14,PRICE_CLOSE,MODE_MAIN,1);

    double _adx2   = iADX(Symbol(),0,14,PRICE_CLOSE,MODE_MAIN,2);

    double _hNow   = E99_HurstExponent(0,50);

    double _h1     = E99_HurstExponent(1,50);

    double _vol0   = (double)iVolume(Symbol(),0,0);

    double _vol1   = (double)iVolume(Symbol(),0,1);

    double _vol2   = (double)iVolume(Symbol(),0,2);

    bool _adxDecl  = (_adxNow < _adx1 && _adx1 < _adx2 && _adxNow > 0);

    bool _hurstMid = (MathAbs(_hNow-0.5) < MathAbs(_h1-0.5));  // trending toward 0.5

    bool _volDecl  = (_vol1 > 0 && _vol2 > 0 && _vol0 < _vol1 && _vol1 < _vol2);

    int _preFlags  = (_adxDecl?1:0) + (_hurstMid?1:0) + (_volDecl?1:0);

    if(_preFlags >= 2)  // 2 of 3 = pre-transition warning

    regimeThreshold = MathMin(82.0, regimeThreshold + 3.0);  // tighten before shift

    }

    signal.regimeThreshold = regimeThreshold;
    g_LiveTradeEntryRegime = regime;
    
    // Step 6: Check if score meets threshold
    // -- CEO: TRAPPED TRADER PRESSURE ZONES --------------------------------─
    {
        double _currentPrice = (Close[0] + Open[0]) / 2.0;
        double _atrZ = iATR(Symbol(), 0, 14, 0);
        double _roundUnit = MarketInfo(Symbol(), MODE_POINT) * 100.0;  // 100 pips
        if(_roundUnit <= 0) _roundUnit = 0.01;

        // Nearest round number (multiples of 100 pips / 0.01 for 2dp pairs)
        double _nearestRound = MathRound(_currentPrice / _roundUnit) * _roundUnit;
        double _distToRound  = MathAbs(_currentPrice - _nearestRound);
        bool   _nearRound    = (_distToRound < _atrZ * 0.50);  // within 0.5 ATR of round

        // Nearest recent swing high/low (trapped trader breakeven zones)
        double _swHigh = High[SafeHL(iHighest(Symbol(), Period(), MODE_HIGH, 30, 1))];
        double _swLow  = Low[SafeHL(iLowest(Symbol(), Period(), MODE_LOW,  30, 1))];
        double _distHigh = MathAbs(_currentPrice - _swHigh);
        double _distLow  = MathAbs(_currentPrice - _swLow);
        double _nearSwing= MathMin(_distHigh, _distLow);
        bool   _atSwing  = (_nearSwing < _atrZ * 0.40);  // within 0.4 ATR of swing

        // Direction of signal vs pressure zone
        bool   _buyDir = (score > 0);
        bool   _headingToHigh = (_buyDir && _distHigh < _distLow);  // buying toward recent high
        bool   _headingToLow  = (!_buyDir && _distLow < _distHigh); // selling toward recent low
        bool   _intoZone = (_nearRound && (_headingToHigh || _headingToLow)) ||
                           (_atSwing  && (_headingToHigh || _headingToLow));

        // Tighten entry when trading into a trapped-trader concentration zone
        if(_intoZone) {
            double _zoneAdj = 0.0;
            if(_nearRound) _zoneAdj += 3.0;  // round number confluence
            if(_atSwing)   _zoneAdj += 3.0;  // swing point confluence
            _zoneAdj = MathMin(6.0, _zoneAdj);
            regimeThreshold = MathMin(82.0, regimeThreshold + _zoneAdj);
            if(EnableFriendlyLogs && !g_CalibSilent) {
                static datetime _lastZLog = 0;
                if(TimeCurrent() - _lastZLog > 180) {
                    PrintFormat("  trapped zone   |   +%.0fpt threshold   |   round %.5f   |   swing %.5f",
                                _zoneAdj, _nearestRound, (_distHigh < _distLow ? _swHigh : _swLow));
                    _lastZLog = TimeCurrent();
                }
            }
        }
    }

    // -- TRAP GATE: Block if market just formed a trap in signal direction --
    // This is the causal layer — the system now understands *why* a breakout fails.
    // A bull trap with strong signal score is exactly the kind of loss this gate prevents.
    if(!g_Calibration.isCalibrating) {
        MarketStateFeatures _gf = CalculateMarketFeatures(0);
        bool _signalBuy = (score > 0);
        if(_signalBuy && _gf.bullTrap && _gf.trapStrength > 0.35) {
            signal.reasonCode = 0;  // Trap gate block — would be a trap entry
            return signal;
        }
        if(!_signalBuy && _gf.bearTrap && _gf.trapStrength > 0.35) {
            signal.reasonCode = 0;  // Trap gate block
            return signal;
        }
    }

    // -- NET ADJUSTMENT CAP ----------------------------------------------
    // Prevent pile-on: cumulative hostile adjustments capped at +14pt above base.
    // Cumulative favourable adjustments capped at -10pt below base.
    // Individual signals still fire — they just cannot stack without limit.
    {
        double _netAdj = regimeThreshold - _thrBase;
        if(_netAdj > 14.0)  regimeThreshold = _thrBase + 14.0;
        if(_netAdj < -10.0) regimeThreshold = _thrBase - 10.0;
        regimeThreshold = MathMax(42.0, MathMin(82.0, regimeThreshold));
    }

    // Execution suspension from ultra-conservative arm path
    if(g_Calibration.executionSuspended) {
        signal.reasonCode = 0;  // below 58% WR floor — no live trades
        return signal;
    }

    // Wire CEO ThresholdRelax into GIS primary gate (CEUS -100/+100 space)
    // Positive relax (unproven system) = raise threshold. Negative (elite) = lower.
    // g_CEO_ThresholdRelax: +7 unproven→0 solid→-6 elite — earned through live WR
    if(g_Calibration.isComplete && g_WeightsOptimized)
        regimeThreshold = MathMax(38.0, MathMin(88.0, regimeThreshold + g_CEO_ThresholdRelax));
    // -- VOLATILITY-NORMALISED THRESHOLD ------------------------------
    // If current ATR is 30% above calibrated ATR, market is noisier:
    // require proportionally more conviction. Cap at ±20%.
    if(g_Calibration.isComplete && g_Calibration.baselineATR > 0) {
        double _curATR = iATR(Symbol(), 0, 14, 0);
        if(_curATR > 0) {
            double _atrRatio = MathMax(0.85, MathMin(1.20,
                              _curATR / g_Calibration.baselineATR));
            regimeThreshold = MathMax(38.0, MathMin(88.0, regimeThreshold * _atrRatio));
        }
    }

    // -- MINIMUM CONVICTION MARGIN ----------------------------------------─
    // A signal that clears the threshold by only 1-2 pts is not genuine conviction.
    // Calibration distribution was built without live layers 9-14 — live scores are
    // systematically higher. The minimum margin guards against accidental crossings.
    // As CEO proves itself, the margin shrinks — earned, not assumed.
    double _minMargin;
    if(!g_Calibration.warmupComplete) {
        _minMargin = 6.0;
    } else if(g_CEO_CompetenceScore >= 75.0) {
        _minMargin = 0.0;
    } else if(g_CEO_CompetenceScore >= 60.0) {
        _minMargin = 2.0;
    } else {
        _minMargin = 5.0;
    }
    // -- CALIBRATION FRESHNESS DECAY ----------------------------------
    // As calibration ages toward AutoRecalibrationDays, require more
    // conviction. Day 0 = no addition. Day = AutoRecalibrationDays = +3pt.
    if(g_Calibration.isComplete && g_Calibration.calibrationEndTime > 0
       && AutoRecalibrationDays > 0) {
        double _agedays = (TimeCurrent() - g_Calibration.calibrationEndTime)
                         / 86400.0;
        double _agefrac = MathMax(0.0, MathMin(1.0,
                         _agedays / AutoRecalibrationDays));
        _minMargin += _agefrac * 3.0;  // +0 to +3pt as calibration ages
    }
    // -- PER-HOUR HISTORICAL WR GATE ----------------------------------
    // If this hour has ≥20 calibrated samples and WR < 58%,
    // require 3pt extra conviction (not a block — a tighter filter).
    {
        int _gh = TimeHour(TimeCurrent());
        int _gho = MathMin(23,MathMax(0,_gh));
        if(g_HourlyObs[_gho] >= 20 && g_HourlyWR[_gho] < 0.58)
            _minMargin += 3.0;  // this hour historically underperforms
    }
    // -- REGIME TRANSITION SUPPRESSION ------------------------------─
    // New entries within 3 bars of a regime change are lowest-quality.
    // The classifier is least reliable at transitions.
    if(g_Calibration.isComplete && g_LastRegimeChangeBar > 0
       && (Bars - g_LastRegimeChangeBar) <= 3)
        _minMargin += 4.0;  // require strong conviction near regime boundary

    if(MathAbs(score) < regimeThreshold + _minMargin) {
        signal.reasonCode = 0;
        return signal;
    }

    // Step 7: Detect pattern
    MicroPattern pattern = DetectMicroPatternAt(0);
    
    // Step 8: Query probability database (if built)
    ConditionalProbability prob;
    prob.winRate = 0.50;  // Default neutral
    prob.expectedValue = 0;
    prob.confidence = 0.50;
    prob.observations = 0;
    
    if(g_ProbabilityDatabaseBuilt) {
        int scoreRange = MathMax(0, MathMin(9, (int)((score + 100.0) / 20.0)));  // 0..9: -100->0, 0->5, +100->10->clamp9
        int session = DetermineSession(TimeHour(Time[0]));
        int vol = DetermineVolatility(features.atr);
        
        prob = QueryProbabilityMatrix(regime, scoreRange, pattern.type, session, vol);
        
        // Step 9: Validate probability — gate adapts to calibrated session quality
        // 9.23: P3B→P4 synergy: weak P3B (few validated regimes) means weight-based patterns less discriminating → require more evidence
        int _p4MinObs = (g_P3B_ValidatedRegimes >= 6) ? 4 :
                        (g_P3B_ValidatedRegimes >= 3) ? 5 :
                        (g_P3B_ValidatedRegimes == 0) ? 8 : 6;
        if(prob.observations >= _p4MinObs) {
            // Default WR gate = 0.65. Adjust ±0.07 based on Phase 2 session/regime WR.
            // ProbDB x IC asymmetric gate: high IC = score reliably identifies losers
            // - tighten gate to remove them more aggressively without hurting winners.
            // Low IC = score less reliable - loose gate (ProbDB is the primary filter).
            double _probWRGate = 0.65;
            if(g_CorrelationsLearned && regime >= 0 && regime < 9
               && g_RegimeCorrelations[regime].signalTotal >= 5) {
                int _gmtHp = (TimeHour(Time[0]) - g_ServerTimeOffsetHours + 24) % 24;
                int _sesPb = (_gmtHp < 8) ? 0 : (_gmtHp < 13) ? 1 : (_gmtHp < 17) ? 2 : 3;
                int _domS  = g_RegimeCorrelations[regime].dominantSession;
                double _sesWR = g_RegimeCorrelations[regime].sessionWR[_sesPb];
                if(_sesPb == _domS && _sesWR >= 0.68)
                    _probWRGate = 0.60;  // dominant session — earned relaxation
                else if(_sesWR > 0 && _sesWR < 0.50)
                    _probWRGate = 0.70;  // historically poor session — tighten
            }
            // IC modulation: asymmetric removal (tighter when IC is high - fewer losers pass)
            if(g_ICMeasured && regime >= 0 && regime < 9) {
                double _avgIC = 0.0;
                for(int _ci2 = 0; _ci2 < 6; _ci2++) _avgIC += MathAbs(g_RegimeIC[regime][_ci2]);
                _avgIC /= 6.0;
                // IC above 0.03 = genuinely predictive; each 0.01 tightens gate by 0.005
                // IC below 0.015 = near-noise; loosen gate (score less reliable)
                if(_avgIC > 0.030)
                    _probWRGate += MathMin(0.050, (_avgIC - 0.030) * 0.50);  // tighten max 5pp
                else if(_avgIC < 0.015)
                    _probWRGate -= MathMin(0.050, (0.015 - _avgIC) * 0.50);  // loosen max 5pp
                _probWRGate = MathMax(0.55, MathMin(0.75, _probWRGate));
            }
            if(prob.winRate < _probWRGate) {
                signal.reasonCode = 0;
                return signal;
            }
            if(prob.expectedValue < 0.3) {
                signal.reasonCode = 0;
                return signal;
            }
            // Lowered from 0.65: allows 5+ obs buckets (conf=0.60). WR gate is the real filter.
            if(prob.confidence < 0.55) {
                // Sparse bucket: attempt extrapolation from most similar populated bucket
                if(prob.observations < 3) { signal.reasonCode = 0; return signal; }
                // 3-4 observations: extrapolate from most similar populated pattern
                // Find a pattern in same regime with ≥10 samples as proxy
                double _epWR = -1.0; int _epN = 0;
                // SLS21 FIX: was hardcoded to 5000 against a 25000-capacity matrix -- a fully
                // built matrix can place useful entries past index 5000, which this scan could
                // never reach, causing valid signals to be rejected below for lack of a match.
                for(int _ep=0; _ep<g_ProbabilityCount; _ep++) {
                    if(g_ProbabilityMatrix[_ep].regime       != signal.regime) continue;
                    if(g_ProbabilityMatrix[_ep].observations  < 10)            continue;
                    if(g_ProbabilityMatrix[_ep].observations  > _epN) {
                        _epN  = g_ProbabilityMatrix[_ep].observations;
                        _epWR = g_ProbabilityMatrix[_ep].winRate;
                    }
                }
                if(_epN >= 10 && _epWR >= 0.0) {
                    // Blend: 70% similar regime (better statistics), 30% sparse direct
                    prob.winRate   = _epWR*0.70 + prob.winRate*0.30;
                    prob.confidence = 0.58;  // Extrapolated from similar regime
                } else {
                    signal.reasonCode = 0;
                    return signal;
                }
            }
        }

        // ## CANDLE ANATOMY x PROBABILITY DB CROSS-VALIDATION #################
        if(g_ProbabilityDatabaseBuilt) {
            // Find the matching probability bucket for this context
            for(int pi = 0; pi < g_ProbabilityCount; pi++) {
                if(g_ProbabilityMatrix[pi].regime != regime) continue;
                // SLS21 FIX: yet a third scoreRange formula, inconsistent with the canonical
                // (score+100)/20 absolute-score bucketing used everywhere else in this file.
                int _sr = MathMax(0, MathMin(9, (int)((score + 100.0) / 20.0)));
                if(MathAbs(g_ProbabilityMatrix[pi].scoreRange - _sr) > 1) continue;

                // For now use the current bar anatomy
                MarketStateFeatures _ca = CalculateMarketFeatures(0);

                // Map anatomy to the ConditionalProbability bucket lookup
                // candleWeights[] in ProbabilityPattern would be checked here
                // but we cross-check against regime-level probability matrix

                // Closing strength divergence -- if wins close strong and we're closing weak, warn
                // This is learned from the ProbabilityPattern.avgClosingStrengthWins field
                // which is populated via the feedback loop in UpdateProbabilityPattern

                // ## CEO ALIGNMENT -- NARROW CONFIDENCE ADJUSTMENT ###############
                // corrections. The CEO here is a trim, not a gate.
                double _alignGate = GetMarketAlignment();
                double _alignMult = 1.0;  // default: no effect
                if(_alignGate >= 0.80)
                    _alignMult = 1.08;  // upside: system demonstrably working
                else if(_alignGate < 0.30 && g_LiveAdaptive.selfCalibrated)
                    _alignMult = 0.90;  // mild downside: structural misalignment confirmed
                _alignMultCaptured = _alignMult;  // SLS23 FIX: applied at Step 11 now

                // Apply a confidence modifier based on anatomy alignment
                double anatomyMod = 1.0;

                // Strong closing strength in direction of signal = good
                // SLS23 FIX: was '> 50' against a signed [-100,+100] score (CEUS convention is
                // sign=direction, matching every other direction check in this function) -- real
                // buy signals with scores in (0,50] were misread as sells, running every anatomy
                // check below backwards.
                bool isBuySignal = (score > 0);
                if(isBuySignal && _ca.closingStrength > 0.68)      anatomyMod += 0.08;
                else if(isBuySignal && _ca.closingStrength < 0.35)  anatomyMod -= 0.12;
                if(!isBuySignal && _ca.closingStrength < 0.32)      anatomyMod += 0.08;
                else if(!isBuySignal && _ca.closingStrength > 0.65) anatomyMod -= 0.12;

                // Conviction candle aligned with signal -> boost
                if(_ca.isConvictionCandle) {
                    if((isBuySignal && _ca.isBullishCandle) || (!isBuySignal && _ca.isBearishCandle))
                        anatomyMod += 0.10;
                    else
                        anatomyMod -= 0.08;  // conviction against signal direction = warning
                }

                // Dramatic bar in signal direction = real move, not noise
                if(_ca.barDrama > 0.65) {
                    if((isBuySignal && _ca.wickPressureScore > 0.2) ||
                       (!isBuySignal && _ca.wickPressureScore < -0.2))
                        anatomyMod += 0.06;
                }

                // Indecision candle = reduce confidence regardless of signal
                if(_ca.isIndecisionCandle) anatomyMod -= 0.08;

                // Rejection against signal direction = market is disagreeing
                if(isBuySignal  && _ca.isBearishRejection) anatomyMod -= 0.15;
                if(!isBuySignal && _ca.isBullishRejection)  anatomyMod -= 0.15;

                // 5-bar momentum bias aligned with signal
                if((isBuySignal && _ca.momentumBias5 > 0.3) ||
                   (!isBuySignal && _ca.momentumBias5 < -0.3))
                    anatomyMod += 0.05;

                // Clamp modifier
                anatomyMod = MathMax(0.5, MathMin(1.5, anatomyMod));

                // Apply to signal confidence -- anatomy is a cross-validator, not a veto
                _anatomyModCaptured = anatomyMod;  // SLS23 FIX: applied at Step 11 now

                break;
            }
        }
    }
    
    signal.probabilityWR = prob.winRate;
    signal.expectedValue = prob.expectedValue;
    
    // Step 10: Determine direction
    signal.direction = (score > 0) ? 1 : -1;
    
    // Step 11: Calculate overall confidence
    double regimeConf = (g_CorrelationsLearned && regime >= 0 && regime < 9) ? 
                       g_RegimeCorrelations[regime].overallAccuracy : 0.75;
    double scoreConf = (MathAbs(score) - regimeThreshold) / 30.0;  // Excess above threshold
    scoreConf = MathMax(0, MathMin(1.0, scoreConf));
    
    signal.confidence = (regimeConf * 0.35) +        // Regime classification confidence
                       (prob.confidence * 0.30) +     // Statistical confidence
                       (pattern.confidence * 0.20) +  // Pattern confidence
                       (scoreConf * 0.15);            // Score excess confidence

    // SLS23 FIX: apply the CEO-alignment and candle-anatomy modifiers (captured earlier -- they
    // used to be applied to the still-zero pre-Step-11 confidence and get overwritten right here)
    signal.confidence *= _alignMultCaptured;
    signal.confidence *= _anatomyModCaptured;
    signal.confidence = MathMax(0.50, MathMin(1.0, signal.confidence));
    // Post-spike guard cap overrides the floor above -- it exists specifically to force confidence
    // down during a known-risky emotional window, same as it always intended to.
    if(_postSpikeConfCap >= 0.0) signal.confidence = MathMin(signal.confidence, _postSpikeConfCap);
    
    // Step 12: All checks passed!
    signal.valid = true;
    signal.reasonCode = 0;  // was string reasoning
    
    return signal;
}

// [SLS13 C3] retired dead function CalculateConfidenceBasedPositionSize (97 lines, zero refs)

// PHASE 3: CONTINUOUS LEARNING FUNCTIONS
// Track and learn from live trades

void TrackLiveTrade(int ticket, IntelligentSignal &signal) {
    // Store trade context for later learning
    if(g_LiveTradeCount >= 100) {
        // Shift array to make room
        for(int i = 0; i < 99; i++) {
            g_LiveTrades[i] = g_LiveTrades[i + 1];
        }
        g_LiveTradeCount = 99;
    }
    
    LiveTradeContext ctx;
    ctx.ticket = ticket;
    ctx.regime = signal.regime;
    // Normalize CEUS (-100..+100) to 0-100 for probability DB decile lookup.
    // ProcessClosedTrades uses (score / 10.0) to get decile key 0-9.
    ctx.score = (signal.score + 100.0) / 2.0;
    
    // Detect and store actual pattern
    MicroPattern detectedPattern = DetectMicroPatternAt(0);
    ctx.pattern = detectedPattern.type;
    
    ctx.session = DetermineSession(TimeHour(TimeCurrent()));
    
    double atr = iATR(Symbol(), PERIOD_CURRENT, 14, 0);
    ctx.volatility = DetermineVolatility(atr);
    ctx.confidence = signal.confidence;
    ctx.openTime = TimeCurrent();
    ctx.tracked = true;
    // Component snapshot: capture CEUS component scores at entry
    // These are the "weights" that drove the signal — needed for post-close attribution
    { MarketStateFeatures _csf = CalculateMarketFeatures(0);
      ComponentWeights _cw;
      if(g_WeightsOptimized) _cw = g_RegimeOptimalWeights[MathMax(0,MathMin(8,ctx.regime))];
      else { _cw.mtf=1.0; _cw.momentum=1.0; _cw.volume=1.0; _cw.volatility=1.0; _cw.session=1.0; _cw.pattern=1.0; }
      // Recompute individual component contributions (lightweight versions)
      // MTF: based on intelligence.mtfConsensus
      ctx.compMTF        = intelligence.mtfConsensus * _cw.mtf * 20.0;
    // Wave angle DNA: adjust MTF component for angle sequence quality
    // Steepening sequence = waves confirming trend = MTF bonus
    // Parabolic or decelerating = warning = penalty
    if(_csf.waveAngleDNALen >= 3) {
        if(_csf.angleRecovery)      ctx.compMTF += 6.0;   // textbook pullback pattern
        else if(_csf.angleAccelerating && !_csf.angleParabolic) ctx.compMTF += 3.0;  // healthy steepening
        else if(_csf.angleParabolic) ctx.compMTF -= 8.0;  // blow-off risk
        else if(_csf.angleDecelerating) ctx.compMTF -= 4.0;  // degrading sequence
        // angleMomentum: continuous score based on direction of sequence
        ctx.compMTF += MathMax(-5.0, MathMin(5.0, _csf.angleMomentum * 2.0));
    }
      // Momentum: MACD + RSI direction
      double _momDir = (intelligence.macd > 0 ? 1 : -1) * (intelligence.rsi > 50 ? 1 : -1);
      ctx.compMomentum   = _momDir * _cw.momentum * 12.0;
      // Volume: ratio above/below average
      ctx.compVolume     = (intelligence.volumeRatio > 1.2 ? 8.0 : intelligence.volumeRatio < 0.8 ? -5.0 : 0.0) * _cw.volume;
      // Volatility: ATR position (trending vs compressed)
      ctx.compVolatility = (intelligence.atrVolatility > 1.15 ? 6.0 : intelligence.atrVolatility < 0.85 ? -4.0 : 0.0) * _cw.volatility;
      // Session: from g_SessionStats
      int _gH = (TimeHour(TimeCurrent())-g_ServerTimeOffsetHours+24)%24;
      ctx.compSession    = (g_HourlyCalibrated && g_HourlyObs[MathMin(23,MathMax(0,_gH))]>=15) ?
          (g_HourlyWR[MathMin(23,MathMax(0,_gH))] - 0.65) * 30.0 * _cw.session : 0.0;
      // Pattern: from signal pattern type
      ctx.compPattern    = (signal.confidence > 0.65 ? 8.0 : signal.confidence > 0.50 ? 3.0 : -2.0) * _cw.pattern;
      // Score margin: how far above threshold
      ctx.scoreMargin    = engine.unifiedScore > 0 ?
          engine.unifiedScore - engine.buyThreshold :
          (100.0 - engine.unifiedScore) - (100.0 - engine.sellThreshold);
    }
    
    if(OrderSelect(ticket, SELECT_BY_TICKET)) {
        ctx.entryPrice = OrderOpenPrice();
    }
    
    if(g_LiveTradeCount >= 100) {
        // Array full: shift oldest entry out to make room
        for(int _s = 0; _s < 99; _s++) g_LiveTrades[_s] = g_LiveTrades[MathMin(_s+1,99)];
        g_LiveTradeCount = 99;
    }
    g_LiveTrades[g_LiveTradeCount] = ctx;
    g_LiveTradeCount++;
    // LSM: record entry conditions for per-bar mid-trade monitoring
    LSM_RecordEntry(ctx.regime, ctx.score, g_seqMultLiveCache);
}

// Loss-cluster sentinel state (rolling outcome ring, newest at end)
int    g_SentinelOutcomes[12];     // 1=win 0=loss, last 12 live trades
int    g_SentinelCount      = 0;   // how many recorded (caps at 12)
double g_SentinelMult       = 1.0; // current stake multiplier from sentinel (1.0 = inactive)
int    g_SentinelCooldown   = 0;   // trades remaining in current response window
bool   g_SentinelDiagnose   = false; // request: current regime needs targeted re-check
int    g_SentinelTriggers   = 0;   // lifetime count (telemetry)

void SentinelRecordOutcome(bool won) {
    // shift ring left, append newest
    int n = (g_SentinelCount < 12) ? g_SentinelCount : 12;
    if(n >= 12) { for(int i=0;i<11;i++) g_SentinelOutcomes[i]=g_SentinelOutcomes[i+1]; g_SentinelOutcomes[11]=won?1:0; }
    else        { g_SentinelOutcomes[n]=won?1:0; g_SentinelCount++; }

    if(!UseLossSentinel) { g_SentinelMult=1.0; return; }

    // early recovery: two of last three are wins -> stand down immediately
    if(g_SentinelCooldown > 0) {
        int w3=0,c3=0;
        for(int i=g_SentinelCount-1;i>=0 && c3<3;i--){ if(g_SentinelOutcomes[i]==1)w3++; c3++; }
        if(w3>=2){ g_SentinelCooldown=0; g_SentinelMult=1.0; g_SentinelDiagnose=false;
                   Print("  sentinel   |   edge recovered   |   full sizing restored"); return; }
        g_SentinelCooldown--;
        if(g_SentinelCooldown==0){ g_SentinelMult=1.0; g_SentinelDiagnose=false; }
        return;
    }

    // count losses in trailing windows
    int loss10=0,have10=0,loss12=0,have12=0;
    for(int i=g_SentinelCount-1;i>=0;i--){
        int age=g_SentinelCount-1-i;
        if(age<10){ have10++; if(g_SentinelOutcomes[i]==0)loss10++; }
        if(age<12){ have12++; if(g_SentinelOutcomes[i]==0)loss12++; }
    }
    // severe break: 9 of last 12 -> deep cut + diagnose
    if(have12>=12 && loss12>=9){
        g_SentinelMult=MathMax(0.05,MathMin(1.0,SentinelSevereMult));
        g_SentinelCooldown=12; g_SentinelDiagnose=true; g_SentinelTriggers++;
        PrintFormat("  sentinel   |   SEVERE break   |   %d/12 losses   |   stake x%.2f   |   regime diagnosis flagged",loss12,g_SentinelMult);
    }
    // break: 8 of last 10 -> hard cut + diagnose
    else if(have10>=10 && loss10>=8){
        g_SentinelMult=MathMax(0.05,MathMin(1.0,SentinelBreakMult));
        g_SentinelCooldown=10; g_SentinelDiagnose=true; g_SentinelTriggers++;
        PrintFormat("  sentinel   |   break detected   |   %d/10 losses   |   stake x%.2f   |   regime diagnosis flagged",loss10,g_SentinelMult);
    }
}
void ProcessClosedTrades() {
    // Check for closed trades and learn from them
    for(int i = g_LiveTradeCount - 1; i >= 0; i--) {
        if(!g_LiveTrades[i].tracked) continue;
        
        int ticket = g_LiveTrades[i].ticket;
        
        if(OrderSelect(ticket, SELECT_BY_TICKET)) {
            // Trade still open, skip
            if(OrderCloseTime() == 0) continue;
            
            // Trade closed - learn from it
            double profit = OrderProfit();
            bool won = (profit > 0);
            double profitPct = (OrderClosePrice() - OrderOpenPrice()) / OrderOpenPrice() * 100.0;
            if(OrderType() == OP_SELL) profitPct = -profitPct;
            
            // Update probability database
            if(g_ProbabilityDatabaseBuilt) {
                // SLS21 FIX: was bucketing by threshold-relative distance (0-19, +10 for
                // sell-side), but BuildMultiDimensionalProbabilityDatabase/GenerateIntelligentSignal
                // bucket by absolute score (0-9) -- these two encodings never matched, so live
                // outcomes were written under keys the live entry gate could never query back,
                // and every sell-side outcome (range 10-19) was permanently write-only/orphaned.
                // Use the same absolute-score formula as the build/query path.
                int scoreRange = MathMax(0, MathMin(9, (int)((g_LiveTrades[i].score + 100.0) / 20.0)));
                int index = FindOrCreateProbabilityEntry(
                    g_LiveTrades[i].regime,
                    scoreRange,
                    g_LiveTrades[i].pattern,
                    g_LiveTrades[i].session,
                    g_LiveTrades[i].volatility
                );
                
                if(index >= 0) {
                    UpdateProbabilityEntry(index, won, profitPct);
                }
            }
            
            // Update live performance tracking
            g_LiveTradesTotal++;
            if(won) g_LiveTradesWon++;
            g_LiveWinRate = (g_LiveTradesTotal > 0) ? ((double)g_LiveTradesWon / g_LiveTradesTotal) : 0.0;
            
            // Mark as processed
            g_LiveTrades[i].tracked = false;

            // ## FEED INTO UNIFIED LEARNING PIPELINE ##########################
            double _slEst = iATR(Symbol(), 0, 14, 0) * 1.5;  // atr not in LiveTradeContext, use current ATR
            double _rMult = (_slEst > 0 && profit != 0)
                ? profit / MathMax(AccountBalance() * (g_Risk.currentRisk / 100.0), 0.01)
                : (won ? FLOOR_RR_RATIO : -1.0);
            // RecordTradeResult feeds ring buffer, live adaptive, anatomy feedback
            RecordTradeResult((int)g_LiveTrades[i].ticket, won, profit, _rMult);
            SentinelRecordOutcome(won);  // loss-cluster sentinel: update rolling break-detector
            if(g_SentinelDiagnose) {
                // targeted, NON-BLOCKING diagnosis: ask the recalibration brain to check
                // whether the CURRENT regime's edge has genuinely broken. Light check;
                // only escalates to deep recalibration if it confirms. Cleared by recovery.
                CheckRecalibrationNeeded();
                g_SentinelDiagnose = false;  // consume the flag; sentinel re-raises if cluster persists
            }

            // DrawdownForensics is fed via RecordTradeResult -> UpdateLiveAdaptive
            // (UpdateDrawdownForensics takes TradeRecord& built internally)

            // Check if recalibration needed (every 100 trades)
            if(g_LiveTradesTotal % 100 == 0) {
                CheckRecalibrationNeeded();
            }
        }
    }
}

void CheckRecalibrationNeeded() {
    if(g_LiveTradesTotal < 50) return;

    // Use rolling 20-trade WR (g_Risk.recentWinRate) as the primary signal.
    // All-time WR (g_LiveWinRate) is too slow -- by the time it shows degradation,
    // the system may have been trading with a broken edge for hundreds of trades.
    // Rolling 20-trade WR detects regime shifts within 1-2 trading days.
    double rollingWR   = g_Risk.recentWinRate / 100.0;  // 0-1
    double allTimeWR   = g_LiveWinRate;                  // 0-1

    double calibratedWR = (g_WeightsOptimized && g_E99_Validation.expectedWinRate > 0.1)
                          ? g_E99_Validation.expectedWinRate / 100.0
                          : FLOOR_START_WR / 100.0;
    double floorWR = SpecLearnedWR() / 100.0;  // spec-relative: raw 72% strangled RR-2.7 systems

    // Primary signal: rolling deviation from calibrated expectation
    double rollingDev  = calibratedWR - rollingWR;
    // Secondary signal: all-time divergence (slower, catches persistent drift)
    double allTimeDev  = calibratedWR - allTimeWR;

    // Trigger thresholds:
    // Rolling 20-trade: 15+ point drop (fast-moving degradation)
    // All-time: 12+ point drop (persistent drift over many trades)
    // Floor breach: below FLOOR_LEARNED_WR by 6+ points on rolling basis
    bool rollingAlert  = (rollingDev  > 0.15);
    bool allTimeAlert  = (allTimeDev  > 0.12);
    bool floorBreach   = (rollingWR   < floorWR - 0.06);

    // CEO alignment override
    double _recalAlign = GetMarketAlignment();
    bool alignAlert = (_recalAlign < 0.25 && g_LiveAdaptive.totalLiveTrades >= 30);

    // Precision early warning: persistent RSI slope decline across sessions
    // If the last 3 sessions all show declining session WR trend, that's a
    // leading indicator -- WR hasn't fallen enough to trigger rollingAlert yet
    // but the direction is clear. Flag as early warning (not urgent).
    bool momentumAlert = false;
    if(g_LiveAdaptive.selfCalibrated && g_LiveAdaptive.totalLiveTrades >= 40) {
        int _declSessions = 0;
        for(int _si = 0; _si < 4; _si++) {
            if(g_LiveAdaptive.sessionTrades[_si] >= 10 &&
               g_LiveAdaptive.sessionLiveWR[_si] < calibratedWR - 0.08)
                _declSessions++;
        }
        momentumAlert = (_declSessions >= 2);  // 2+ sessions underperforming
    }

    // Spike environment filter: if current atrPercentile > 0.80 AND drawdown,
    // the recalibration signal may be temporary -- note it but don't escalate.
    MarketStateFeatures _rcf = CalculateMarketFeatures(0);
    bool spikeContext = (_rcf.atrPercentile > 0.80);

    if(rollingAlert || allTimeAlert || floorBreach || alignAlert || momentumAlert) {
        string urgency = alignAlert    ? "alignment critical" :
                         rollingAlert  ? "urgent" :
                         floorBreach   ? "floor breach" :
                         momentumAlert ? "early warning" : "drift";
        string spikeNote = spikeContext ? "   |   spike context (may resolve)" : "";
        PrintFormat("  CATREC|   recalibration   %s   |   WR %.1f%%   |   alignment %.2f%s   |   consider recalibrating",
                    urgency, rollingWR*100, _recalAlign, spikeNote);
        g_LastRecalibrationCheck = TimeCurrent();
    } else if(rollingWR > calibratedWR + 0.05) {
        static datetime lastPositiveLog = 0;
        if(TimeCurrent() - lastPositiveLog > 3600) {
            PrintFormat("  LIVE  |   performance   rolling WR %.1f%%   |   all-time %.1f%%   |   exceeds calibrated %.1f%%   |   edge confirmed",
                        rollingWR*100, allTimeWR*100, calibratedWR*100);
            lastPositiveLog = TimeCurrent();
        }
    }
}

// PHASE 4: COMPREHENSIVE GHOST VALIDATION
// Test complete integrated system on unseen data before live trading

struct GhostTradeResult {
    int barIndex;
    int direction;
    double entryPrice;
    double exitPrice;
    double profitPct;
    bool won;
    int regime;
    double score;
    double confidence;
};

// Global array for ghost validation (avoids MQL4 strict mode warnings with struct arrays)
GhostTradeResult g_GhostResults[1500];  // full OOS window coverage (was 300 — truncated to most recent 1.6 days)

// MULTI-CONTEXT VALIDATION HELPERS
// Each function runs a focused mini ghost-simulation and returns WR.

//| Validate on a specific bar range. Returns win rate (0.0 - 1.0).  |
double ValidateOnBars(int startBar, int endBar) {
    endBar = MathMin(endBar, MathMax(0, Bars - 30));
    if(startBar >= endBar) return 0.0;
    int wins = 0, total = 0;
    for(int bar = startBar; bar < endBar && total < 200; bar++) {
        double score = CalculateEnhancedUnifiedScore(bar);
        MarketStateFeatures f = CalculateMarketFeatures(bar);
        int rg = ClassifyBarToRegime(f, bar);

        // Use calibrated per-regime threshold, fall back to 52 minimum
        double rThr = (g_WeightsOptimized && rg >= 0 && rg < 9) ?
                      g_RegimeOptimalThresholds[MathMin(8,MathMax(0,rg))] : DEFAULT_REGIME_THRESHOLD;
        if(MathAbs(score) < rThr) continue;

        // ATR TP/SL exit matching live execution model
        double atrV = iATR(Symbol(), 0, 14, bar);
        if(atrV <= 0) continue;
        int exitH = (rg >= 0 && rg < 9 && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] >= 5) ?
                    g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] : 20;
        double slM = (rg >= 0 && rg < 9 && g_RegimeOptimalSLMult[MathMin(8,MathMax(0,rg))] > 0) ?
                     g_RegimeOptimalSLMult[MathMin(8,MathMax(0,rg))] : 1.5;
        double tpM = (rg >= 0 && rg < 9 && g_RegimeOptimalTPMult[MathMin(8,MathMax(0,rg))] > 0) ?
                     g_RegimeOptimalTPMult[MathMin(8,MathMax(0,rg))] : 2.5;

        bool isLong = (score > 0);
        // Execution model: signal fires at bar close, fills at next bar open
        double entry = (bar >= 1 && bar-1 < Bars) ? Open[bar-1] : Close[bar];
        double tp = isLong ? entry + atrV * tpM : entry - atrV * tpM;
        double sl = isLong ? entry - atrV * slM : entry + atrV * slM;
        bool hitTP = false, hitSL = false;
        for(int fb = bar - 1; fb >= MathMax(0, bar - exitH); fb--) {
            double hi = High[fb], lo = Low[fb];
            if(isLong) { if(hi >= tp) { hitTP = true; break; } if(lo <= sl) { hitSL = true; break; } }
            else       { if(lo <= tp) { hitTP = true; break; } if(hi >= sl) { hitSL = true; break; } }
        }
        // Count win on TP hit only (not time exit) -- stricter than P&L sign
        if(hitTP) wins++;
        else if(!hitSL) {
            // Time exit: use P&L sign
            double ex = Close[MathMax(0, bar - exitH)];
            double pnl = isLong ? (ex - entry) : (entry - ex);
            if(pnl > 0) wins++;
        }
        total++;
    }
    return (total > 0) ? ((double)wins / total) : 0.0;
}

//| Validate trades that occurred in a named trading session.        |
//| sessionName: "London" | "NY" | "Asian" | "Overlap"               |
double ValidateBySession(string sessionName) {
    int targetSession = 3; // default: Overlap
    if(sessionName == "Asian")  targetSession = 0;
    if(sessionName == "London") targetSession = 1;
    if(sessionName == "NY")     targetSession = 2;

    int wins = 0, total = 0;
    int endBar = MathMin(GetOOSWindowBars(), MathMax(0, Bars - 30));
    for(int bar = endBar - 1; bar >= 30 && total < 150; bar--) {
        if(DetermineSession(TimeHour(Time[bar])) != targetSession) continue;
        MarketStateFeatures f = CalculateMarketFeatures(bar);
        int rg = ClassifyBarToRegime(f, bar);
        double rThr = (g_WeightsOptimized && rg >= 0 && rg < 9) ?
                      g_RegimeOptimalThresholds[MathMin(8,MathMax(0,rg))] : DEFAULT_REGIME_THRESHOLD;
        double score = CalculateEnhancedUnifiedScore(bar);
        if(MathAbs(score) < rThr) continue;
        double atrV = iATR(Symbol(), 0, 14, bar); if(atrV <= 0) continue;
        double slM = (rg >= 0 && rg < 9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,rg))] : 1.5;
        double tpM = (rg >= 0 && rg < 9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,rg))] : 2.5;
        int exitH = (rg >= 0 && rg < 9 && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] >= 5) ?
                    g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] : 20;
        bool isLong = (score > 0);
        double entry = (bar >= 1 && bar-1 < Bars) ? Open[bar-1] : Close[bar];
        double tp = isLong ? entry + atrV*tpM - g_CalibratedAvgSpread*Point
                           : entry - atrV*tpM + g_CalibratedAvgSpread*Point;
        double sl = isLong ? entry - atrV*slM : entry + atrV*slM;
        bool hitTP = false, hitSL = false;
        for(int fb = bar-1; fb >= MathMax(0, bar-exitH); fb--) {
            if(isLong){ if(High[fb]>=tp){hitTP=true;break;} if(Low[fb]<=sl){hitSL=true;break;} }
            else      { if(Low[fb]<=tp){hitTP=true;break;} if(High[fb]>=sl){hitSL=true;break;} }
        }
        if(hitTP) wins++;
        else if(!hitSL) {
            int fb2 = MathMax(0, bar-exitH);
            double ex = Close[fb2];
            if((isLong && ex > entry) || (!isLong && ex < entry)) wins++;
        }
        total++;
    }
    return (total > 0) ? ((double)wins / total) : 0.0;
}

//| Validate trades in a named volatility regime.                    |
//| volName: "High" | "Normal" | "Low"                               |
double ValidateByVolatility(string volName) {
    int targetVol = 1; // default: Normal
    if(volName == "Low")  targetVol = 0;
    if(volName == "High") targetVol = 2;

    int wins = 0, total = 0;
    int endBar = MathMin(GetOOSWindowBars(), MathMax(0, Bars - 30));
    for(int bar = endBar - 1; bar >= 30 && total < 150; bar--) {
        double atrV = iATR(_Symbol, PERIOD_CURRENT, 14, bar); if(atrV <= 0) continue;
        if(DetermineVolatility(atrV) != targetVol) continue;
        MarketStateFeatures f = CalculateMarketFeatures(bar);
        int rg = ClassifyBarToRegime(f, bar);
        double rThr = (g_WeightsOptimized && rg >= 0 && rg < 9) ?
                      g_RegimeOptimalThresholds[MathMin(8,MathMax(0,rg))] : DEFAULT_REGIME_THRESHOLD;
        double score = CalculateEnhancedUnifiedScore(bar);
        if(MathAbs(score) < rThr) continue;
        double slM = (rg >= 0 && rg < 9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,rg))] : 1.5;
        double tpM = (rg >= 0 && rg < 9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,rg))] : 2.5;
        int exitH = (rg >= 0 && rg < 9 && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] >= 5) ?
                    g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] : 20;
        bool isLong = (score > 0);
        double entry = (bar >= 1 && bar-1 < Bars) ? Open[bar-1] : Close[bar];
        double tp = isLong ? entry + atrV*tpM - g_CalibratedAvgSpread*Point
                           : entry - atrV*tpM + g_CalibratedAvgSpread*Point;
        double sl = isLong ? entry - atrV*slM : entry + atrV*slM;
        bool hitTP = false, hitSL = false;
        for(int fb = bar-1; fb >= MathMax(0, bar-exitH); fb--) {
            if(isLong){ if(High[fb]>=tp){hitTP=true;break;} if(Low[fb]<=sl){hitSL=true;break;} }
            else      { if(Low[fb]<=tp){hitTP=true;break;} if(High[fb]>=sl){hitSL=true;break;} }
        }
        if(hitTP) wins++;
        else if(!hitSL) {
            int fb2 = MathMax(0, bar-exitH);
            if((isLong && Close[fb2] > entry) || (!isLong && Close[fb2] < entry)) wins++;
        }
        total++;
    }
    return (total > 0) ? ((double)wins / total) : 0.0;
}

//| Validate trades in a named regime type.                          |
//| regimeName: "Trend" | "Range"                                    |
double ValidateByRegimeType(string regimeName) {
    bool wantTrend = (regimeName == "Trend");
    int wins = 0, total = 0;
    int endBar = MathMin(GetOOSWindowBars(), MathMax(0, Bars - 30));
    for(int bar = endBar - 1; bar >= 30 && total < 150; bar--) {
        MarketStateFeatures feat = CalculateMarketFeatures(bar);
        int rg = ClassifyBarToRegime(feat, bar);
        bool isTrend = (rg == 0 || rg == 1 || rg == 2 || rg == 3 || rg == 7);
        if(isTrend != wantTrend) continue;
        double rThr = (g_WeightsOptimized && rg >= 0 && rg < 9) ?
                      g_RegimeOptimalThresholds[MathMin(8,MathMax(0,rg))] : DEFAULT_REGIME_THRESHOLD;
        double score = CalculateEnhancedUnifiedScore(bar);
        if(MathAbs(score) < rThr) continue;
        double atrV = iATR(Symbol(), 0, 14, bar); if(atrV <= 0) continue;
        double slM = (rg >= 0 && rg < 9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,rg))] : 1.5;
        double tpM = (rg >= 0 && rg < 9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,rg))] : 2.5;
        int exitH = (rg >= 0 && rg < 9 && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] >= 5) ?
                    g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] : 20;
        bool isLong = (score > 0);
        double entry = (bar >= 1 && bar-1 < Bars) ? Open[bar-1] : Close[bar];
        double tp = isLong ? entry + atrV*tpM - g_CalibratedAvgSpread*Point
                           : entry - atrV*tpM + g_CalibratedAvgSpread*Point;
        double sl = isLong ? entry - atrV*slM : entry + atrV*slM;
        bool hitTP = false, hitSL = false;
        for(int fb = bar-1; fb >= MathMax(0, bar-exitH); fb--) {
            if(isLong){ if(High[fb]>=tp){hitTP=true;break;} if(Low[fb]<=sl){hitSL=true;break;} }
            else      { if(Low[fb]<=tp){hitTP=true;break;} if(High[fb]>=sl){hitSL=true;break;} }
        }
        if(hitTP) wins++;
        else if(!hitSL) {
            int fb2 = MathMax(0, bar-exitH);
            if((isLong && Close[fb2] > entry) || (!isLong && Close[fb2] < entry)) wins++;
        }
        total++;
    }
    return (total > 0) ? ((double)wins / total) : 0.0;
}

//| Validate trades in a named market direction.                     |
//| dirName: "Bull" | "Bear" | "Sideways"                            |
double ValidateByMarketDirection(string dirName) {
    int wins = 0, total = 0;
    int endBar = MathMin(GetOOSWindowBars(), MathMax(0, Bars - 30));
    for(int bar = endBar - 1; bar >= 30 && total < 150; bar--) {
        MarketStateFeatures feat = CalculateMarketFeatures(bar);
        int rg = ClassifyBarToRegime(feat, bar);
        bool match = false;
        if(dirName == "Bull")     match = (rg == 0 || rg == 2);
        if(dirName == "Bear")     match = (rg == 1 || rg == 3);
        if(dirName == "Sideways") match = (rg == 4 || rg == 5 || rg == 6 || rg == 7);
        if(!match) continue;
        double rThr = (g_WeightsOptimized && rg >= 0 && rg < 9) ?
                      g_RegimeOptimalThresholds[MathMin(8,MathMax(0,rg))] : DEFAULT_REGIME_THRESHOLD;
        double score = CalculateEnhancedUnifiedScore(bar);
        if(MathAbs(score) < rThr) continue;
        double atrV = iATR(Symbol(), 0, 14, bar); if(atrV <= 0) continue;
        double slM = (rg >= 0 && rg < 9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,rg))] : 1.5;
        double tpM = (rg >= 0 && rg < 9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,rg))] : 2.5;
        int exitH = (rg >= 0 && rg < 9 && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] >= 5) ?
                    g_RegimeOptimalExitBars[MathMin(8,MathMax(0,rg))] : 20;
        bool isLong = (score > 0);
        double entry = (bar >= 1 && bar-1 < Bars) ? Open[bar-1] : Close[bar];
        double tp = isLong ? entry + atrV*tpM - g_CalibratedAvgSpread*Point
                           : entry - atrV*tpM + g_CalibratedAvgSpread*Point;
        double sl = isLong ? entry - atrV*slM : entry + atrV*slM;
        bool hitTP = false, hitSL = false;
        for(int fb = bar-1; fb >= MathMax(0, bar-exitH); fb--) {
            if(isLong){ if(High[fb]>=tp){hitTP=true;break;} if(Low[fb]<=sl){hitSL=true;break;} }
            else      { if(Low[fb]<=tp){hitTP=true;break;} if(High[fb]>=sl){hitSL=true;break;} }
        }
        if(hitTP) wins++;
        else if(!hitSL) {
            int fb2 = MathMax(0, bar-exitH);
            if((isLong && Close[fb2] > entry) || (!isLong && Close[fb2] < entry)) wins++;
        }
        total++;
    }
    return (total > 0) ? ((double)wins / total) : 0.0;
}


bool RunComprehensiveGhostValidation() {
    // -- RESET ALL PUBLISHED STATE ----------------------------------------
    // Clear globals published by this fn — prevent stale data from prior run
    // contaminating Retry 2 worst-regime selection and failure diagnostics.
    g_P6_WR=false; g_P6_PF=false; g_P6_EV=false;
    g_P6_CL=false; g_P6_SIG=false; g_P6_HIST=false;
    g_P6_Total=0;  g_P6_ResultCount=0;
    g_Ghost_EV=0.0; g_Ghost_MaxConsec=0; g_Ghost_PValue=1.0;
    g_Ghost_Total=0; g_Ghost_Wins=0;
    g_Ghost_StreamTotal=0; g_Ghost_StreamWins=0; g_Ghost_StreamPnL=0.0;
    ArrayInitialize(g_P6_RegimeObs, 0);
    ArrayInitialize(g_P6_RegimeWins, 0);
    ArrayInitialize(g_Ghost_RegObs, 0);
    ArrayInitialize(g_Ghost_RegWins, 0);

    // PHASE 4 ENHANCEMENT: MULTI-DIMENSIONAL VALIDATION
    // 2. REGIME-SPECIFIC VALIDATION (8 regimes ? 50 trades):
    // 3. SESSION-SPECIFIC VALIDATION (4 sessions ? 50 trades):

    // VALIDATION AGAINST BASELINE (Mathematical anchor)
    
    if(!g_CalibSilent) Print("  Simulating trades on unseen OOS data (bars 30-499, never used in training)...");
    if(!g_CalibSilent) Print("  Exit model: ATR TP/SL using regime-calibrated multipliers and horizons.");
    // GAP 3 FIX: Use ONLY the OOS hold-out window (bars 30-499).
    // GAP 4 FIX: Use ATR TP/SL exit matching RunGhostMode (ATR*1.5 SL, ATR*2.5 TP).
    // GAP 6 FIX: Deduct estimated spread from win threshold.
    int startBar = 30;
    // OOS window scales with timeframe — always ~7 equivalent trading days
    // Capped by available data (must leave 30 bars OOS buffer)
    int _oosTarget = GetOOSWindowBars();
    int endBar = MathMin(_oosTarget, MathMax(0, Bars - 30));  // scaled OOS
    
    // Use global array (avoids compiler warnings with struct arrays)
    // Clear previous data
    for(int clearIdx = 0; clearIdx < 1500; clearIdx++) {
        g_GhostResults[clearIdx].barIndex = 0;
        g_GhostResults[clearIdx].direction = 0;
        g_GhostResults[clearIdx].entryPrice = 0.0;
        g_GhostResults[clearIdx].exitPrice = 0.0;
        g_GhostResults[clearIdx].profitPct = 0.0;
        g_GhostResults[clearIdx].won = false;
        g_GhostResults[clearIdx].regime = 0;
        g_GhostResults[clearIdx].score = 0.0;
        g_GhostResults[clearIdx].confidence = 0.0;
    }
    
    // Initialize ALL elements explicitly - MQL4 requirement for structs
    // (second identical init loop removed — first loop above suffices)

    int resultCount = 0;

    if(!g_CalibSilent) PrintFormat("  %s - Ghost simulation starting (up to 300 trades)...", CalibProgressBar(5));
    int lastProgressPct = 0;

    // -- CHRONOLOGICAL SEQUENTIAL SIMULATION ----------------------------─
    // Iterate OLD→RECENT (bar=endBar-1 downto startBar).
    // This is the only direction that allows non-overlapping trade reveal:
    // after trade entry at bar N, skip all bars until after trade exit.
    // Each "future bar" checked for TP/SL is a bar with LOWER index = newer.
    int  _batchBase = 0;
    int  _batchWins = 0;
    double _batchProfit = 0.0;
    int    ghostStreamTotal = 0, ghostStreamWins = 0;
    double ghostStreamProfit = 0.0, ghostStreamLoss = 0.0;
    int    ghostStreamMaxConsec = 0, ghostStreamConsec = 0;
    int    ghostStreamRegimeObs[9];  ArrayInitialize(ghostStreamRegimeObs, 0);
    int    ghostStreamRegimeWins[9]; ArrayInitialize(ghostStreamRegimeWins, 0);
    // Non-overlapping: next trade can only start after previous trade exits
    // In chronological order: exit at bar=fb means next entry at bar=fb-1 or lower
    int _nextValidBar = endBar - 1;  // start from oldest OOS bar
    for(int bar = endBar - 1; bar >= startBar; bar--) {
        if(bar > _nextValidBar) continue;  // trade still in progress — skip
        int progress = (int)((endBar - 1 - bar) * 100.0 / MathMax(1, endBar - 1 - startBar));

        // Progress bar updates every 10%
        if(!g_CalibSilent && progress / 10 > lastProgressPct / 10 && progress > 0) {
            int runWins = 0;
            for(int _gi = 0; _gi < resultCount; _gi++) if(g_GhostResults[_gi].won) runWins++;
            double runWR = (resultCount > 0) ? (double)runWins / resultCount * 100 : 0;
            PrintFormat("  %s - Ghost trades: %d | Running WR: %.1f%%",
                        CalibProgressBar(progress), resultCount, runWR);
            lastProgressPct = progress;
        }
        
        // Generate signal
        MarketStateFeatures features = CalculateMarketFeatures(bar);
        int regime = ClassifyBarToRegime(features, bar);
        double score = CalculateEnhancedUnifiedScore(bar);
        
        double regimeThreshold = (g_WeightsOptimized && regime >= 0 && regime < 9) ?
                                g_RegimeOptimalThresholds[MathMin(8,MathMax(0,regime))] : DEFAULT_REGIME_THRESHOLD;
        // Compound threshold: ghost must clear the regime-specific threshold AND a floor derived
        // from the P1 baseline. Live execution applies adaptive overlays — ghost should not be
        // more permissive than live by using a regime threshold that is far below P1 baseline.
        double _ghostCompound = (g_BaseThreshold > 0) ?
            MathMax(regimeThreshold, g_BaseThreshold * 0.80) : regimeThreshold;

        if(MathAbs(score) < _ghostCompound) continue;

        // SLS18 CRITICAL2: invariant 5 — ghost counts only bars live would trade (spread ≤ 18% ATR)
        double _gsp = g_CalibratedAvgSpread * Point;
        if(_gsp <= 0) _gsp = iATR(Symbol(), 0, 14, bar) * 0.15;  // 9.27: ATR-based proxy; 5-point fallback was 0.5 pips — far too small for USDJPY
        double _gat = iATR(Symbol(), 0, 14, bar);
        if(_gat > 0 && _gsp > _gat * 0.18) continue;

        // Check probability database if built
        if(g_ProbabilityDatabaseBuilt) {
            // SLS21 FIX: was bucketing by threshold-relative distance (0-19, +10 for shorts),
            // but the matrix is built/queried elsewhere with the absolute-score formula (0-9) --
            // this query almost never matched, making the WR/EV probability filter silently
            // inert during ghost validation even though the live path enforces it.
            int scoreRange = MathMax(0, MathMin(9, (int)((score + 100.0) / 20.0)));
            int session = DetermineSession(TimeHour(Time[bar]));
            int vol = DetermineVolatility(features.atr);
            MicroPattern pattern = DetectMicroPatternAt(bar);
            
            ConditionalProbability prob = QueryProbabilityMatrix(regime, scoreRange, pattern.type, session, vol);
            
            // Skip patterns below 65% WR floor
    if(prob.observations >= 5 && (prob.winRate < 0.65 || prob.expectedValue < 0.3)) {
                continue;
            }
        }
        
        // Simulate trade with ATR-based TP/SL (matching RunGhostMode exit logic).
        // GAP 4 FIX: Previously used Close[SafeBar(bar-20)] exit, which is a completely different
        // exit mechanism from what the EA uses (ATR*1.5 SL, ATR*2.5 TP). Calibrating
        // for one exit and trading with another makes all results structurally wrong.
        GhostTradeResult trade;
        trade.barIndex = bar;
        trade.direction = (score > 0) ? 1 : -1;
        trade.entryPrice = (bar>=1&&bar-1<Bars)?Open[bar-1]:Close[bar];  // next bar open: no look-ahead
        trade.regime = regime;
        trade.score = score;
        
        double atrG = iATR(Symbol(), 0, 14, bar);
        if(atrG <= 0) continue;

        bool isLong = (trade.direction == 1);
        double entry = trade.entryPrice;

        // Use regime-specific TP/SL multipliers calibrated in Phase 3C.
        // Default 1.5/2.5 applies if regime is unknown or Phase 3C was skipped.
        double slMult = (regime >= 0 && regime < 9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,regime))] : 1.5;
        double tpMult = (regime >= 0 && regime < 9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,regime))] : 2.5;

        double sl = isLong ? (entry - atrG * slMult) : (entry + atrG * slMult);
        double tp = isLong ? (entry + atrG * tpMult) : (entry - atrG * tpMult);
        
        // Spread cost deduction (GAP 6 FIX): use g_CalibratedAvgSpread stored by Phase 1.
        // avgSpread is a local in RunE8_CompleteCalibration and not in scope here.
        double spreadCost = g_CalibratedAvgSpread * Point;  // spread in price units
        if(isLong) tp -= spreadCost; else tp += spreadCost;  // reduce net TP by spread
        
        // Use regime-optimal exit horizon as time-based fallback (GAP 7 FIX).
        // If neither TP nor SL is hit within maxBars, close at Close[SafeBar(bar-maxBars)].
        int maxBars = (regime >= 0 && regime < 9) ? g_RegimeOptimalExitBars[MathMin(8,MathMax(0,regime))] : 20;
        if(maxBars < 5) maxBars = 20;  // safety: never below 5
        
        bool hitTP = false, hitSL = false;
        int barsToResult = maxBars;
        
        int fb = bar - 1;  // hoisted — scope persists for _nextValidBar below
        for(; fb >= MathMax(0, bar - maxBars); fb--) {
            double hi = High[fb], lo = Low[fb];
            if(isLong) {
                if(hi >= tp) { hitTP = true; barsToResult = bar - fb; break; }
                if(lo <= sl) { hitSL = true; barsToResult = bar - fb; break; }
            } else {
                if(lo <= tp) { hitTP = true; barsToResult = bar - fb; break; }
                if(hi >= sl) { hitSL = true; barsToResult = bar - fb; break; }
            }
        }
        
        // Determine P&L
        double exitPrice;
        if(hitTP)      exitPrice = tp;
        else if(hitSL) exitPrice = sl;
        else {
            fb = MathMax(0, bar - maxBars);  // reassign hoisted fb (no re-decl)
            if(fb >= 0 && fb < Bars) exitPrice = Close[SafeBar(fb)]; else exitPrice = sl;  // SL as fallback: unresolved trade exits at stop
        }
        
        trade.exitPrice = exitPrice;
        trade.profitPct = isLong ? 
            (entry > 0 ? (exitPrice - entry) / entry * 100.0 : 0.0) :
            (entry > 0 ? (entry - exitPrice) / entry * 100.0 : 0.0);
        trade.won = (trade.profitPct > 0);

        // -- STREAMING STATS: every trade, unlimited ----------------------
        ghostStreamTotal++;
        if(trade.won) {
            ghostStreamWins++;
            ghostStreamProfit += trade.profitPct;
            ghostStreamConsec  = 0;
            _batchWins++;  _batchProfit += trade.profitPct;
        } else {
            ghostStreamLoss   += MathAbs(trade.profitPct);
            ghostStreamConsec++;
            _batchProfit -= MathAbs(trade.profitPct);
            if(ghostStreamConsec > ghostStreamMaxConsec)
                ghostStreamMaxConsec = ghostStreamConsec;
        }
        if(regime >= 0 && regime < 9) {
            ghostStreamRegimeObs[MathMin(8,MathMax(0,regime))]++;
            if(trade.won) ghostStreamRegimeWins[MathMin(8,MathMax(0,regime))]++;
        }

        // -- DETAIL STORE: first 299 trades only (per-trade analysis) ------
        if(resultCount < 1499) { g_GhostResults[resultCount++] = trade; }
        // -- SEQUENTIAL REVEAL: advance cursor past this trade's exit ------─
        // Next trade can only start after this one exits — no overlap
        _nextValidBar = MathMax(startBar - 1, (hitTP || hitSL) ? fb - 1 : MathMax(0, SafeBar(bar) - maxBars - 1));

        // -- BATCH REPORT: every 50 trades --------------------------------
        if(!g_CalibSilent && ghostStreamTotal > 0 && ghostStreamTotal % 50 == 0) {
            int  _bSize = ghostStreamTotal - _batchBase;
            double _bWR = (_bSize > 0) ? (double)_batchWins / _bSize * 100.0 : 0.0;
            double _rWR = (ghostStreamTotal > 0) ? (double)ghostStreamWins / ghostStreamTotal * 100.0 : 0.0;  // FIX59c: guard /0
        PrintFormat("  ghost  batch %d  |  trades %d-%d  |  batch WR %.0f%%  |  running WR %.0f%%  |  cumulative P&L %+.3f%%",
                ghostStreamTotal / 50, _batchBase + 1, ghostStreamTotal,
                _bWR, _rWR, _batchProfit);
            _batchBase   = ghostStreamTotal;
            _batchWins   = 0;
            _batchProfit = 0.0;
        }
    }
    // Validate we have results before calculating metrics
    // Use streaming total (all OOS bars processed) for quality gates
    // resultCount caps at 299 for detail storage; ghostStreamTotal is uncapped
    int ghostFinalTotal = (ghostStreamTotal > resultCount) ? ghostStreamTotal : resultCount;
    if(ghostFinalTotal < 20) {
        TLog(StringFormat("  ghost  ·  only %d qualifying trades in OOS window  ·  minimum 20  ·  threshold too high or OOS too quiet",
            ghostFinalTotal));
        // FIX(30): P1-BASELINE RESCUE SCAN
        // When per-regime thresholds kill all OOS signals, test the P1 baseline threshold.
        // Per-regime thresholds can be 28-55 (from P2 IC calibration), but these yield 30-40%
        // OOS WR. P1 baseline (g_BaseThreshold ~70) showed 59%+ training WR and is the only
        // proven edge. If P1 scan finds ≥15 OOS trades, update all regime thresholds to P1
        // so the next ghost retry operates at a threshold that actually has edge.
        // WARRANT#15 (forge pass 5): was a SINGLE fixed-threshold check (g_BaseThreshold only) --
        // real live calibration observed 2026-07-10 showed every regime landing on "no edge found,
        // equal weights, thr 70" from Phase 3B's own search, then this rescue scan re-checking the
        // exact same threshold (70) it just failed at. Widened to a small, bounded sweep across the
        // gap between typical per-regime-tuned values (28-55) and the baseline (70), scoring each
        // by WR*sqrt(n) and keeping the best that clears the SAME acceptance bar as before (>=15
        // trades, >=42% WR) -- the bar itself is unchanged, only the search breadth widened. This
        // does reopen a modest multiple-testing exposure (5 looks instead of 1) that is NOT formally
        // corrected here (the 42% bar was already a fixed engineering heuristic, not a powered test);
        // flagged honestly in the ledger, not hidden.
        // WARRANT#16 (forge pass 6): WARRANT#15 as first shipped reran the ENTIRE OOS bar scan once
        // per candidate (5x the original cost), and this function sits inside a
        // while(ghostRetry<=MAX_GHOST_RETRY) loop (up to 9 iterations, 3 call sites) -- the 5x-per-
        // call cost compounded across retries into a real, observed stall on Manuel's live SLS(33)
        // session (reported live 2026-07-10, confirmed as a genuine performance regression, not a
        // hang: bounded by MAX_GHOST_RETRY, but slow enough to read as stuck). Fixed by restructuring
        // to a SINGLE pass over the OOS bars: the entry/TP/SL simulation for a given bar is identical
        // regardless of which candidate threshold admits it (only |score| vs threshold differs), so
        // compute the score and win/loss once per bar (gated at the lowest candidate, 50) and bucket
        // the result into every candidate whose threshold that bar's |score| actually clears. Same
        // exact result as WARRANT#15, restored to ~O(n) cost instead of O(5n).
        {
            double _p1Cands[5] = {50.0, 55.0, 60.0, 65.0, 70.0};
            int _p1TArr[5]; ArrayInitialize(_p1TArr, 0);
            int _p1WArr[5]; ArrayInitialize(_p1WArr, 0);
            double _p1MinThr = _p1Cands[0];  // lowest candidate -- single-pass admission gate
            int _oosEnd=MathMin(GetOOSWindowBars(), MathMax(0, Bars-30));
            for(int _p1b=_oosEnd-1; _p1b>=30 && _p1b<Bars-30; _p1b--) {
                double _p1sc=CalculateEnhancedUnifiedScore(_p1b);
                double _p1abs=MathAbs(_p1sc);
                if(_p1abs<_p1MinThr) continue;
                double _p1atr=iATR(Symbol(),0,14,_p1b); if(_p1atr<=0||_p1b<2) continue;
                // Spread filter — same as live gate
                double _p1sp=g_CalibratedAvgSpread*Point; if(_p1sp<=0) _p1sp=MarketInfo(Symbol(),MODE_POINT)*5;
                if(_p1sp>_p1atr*0.18) continue;
                bool _p1lng=(_p1sc>0);
                double _p1e=(_p1b>=1)?Open[_p1b-1]:Close[_p1b];
                double _p1tp=_p1lng?_p1e+_p1atr*2.5:_p1e-_p1atr*2.5;
                double _p1sl=_p1lng?_p1e-_p1atr*1.5:_p1e+_p1atr*1.5;
                bool _p1won=false;
                for(int _p1f=_p1b-1;_p1f>=MathMax(0,_p1b-20);_p1f--) {
                    if(_p1lng){if(High[_p1f]>=_p1tp){_p1won=true;break;}if(Low[_p1f]<=_p1sl)break;}
                    else{if(Low[_p1f]<=_p1tp){_p1won=true;break;}if(High[_p1f]>=_p1sl)break;}
                }
                for(int _p1c=0; _p1c<5; _p1c++) {
                    if(_p1abs<_p1Cands[_p1c]) continue;
                    _p1TArr[_p1c]++; if(_p1won) _p1WArr[_p1c]++;
                }
            }
            double _bestThr=g_BaseThreshold; int _bestT=0, _bestW=0; double _bestOosWR=0.0, _bestComp=-1.0;
            for(int _p1c=0; _p1c<5; _p1c++) {
                int _p1T=_p1TArr[_p1c]; int _p1W=_p1WArr[_p1c];
                double _p1OosWR=(_p1T>0)?(double)_p1W/_p1T:0.0;
                double _p1Comp=(_p1T>=15)?_p1OosWR*MathSqrt((double)_p1T):-1.0;
                TLog(StringFormat("  ghost  ·  baseline-rescue scan  ·  thr %.0f  ·  %dt  ·  %.1f%% WR  ·  comp %.2f",
                    _p1Cands[_p1c], _p1T, _p1OosWR*100, _p1Comp));
                if(_p1Comp > _bestComp) { _bestComp=_p1Comp; _bestThr=_p1Cands[_p1c]; _bestT=_p1T; _bestW=_p1W; _bestOosWR=_p1OosWR; }
            }
            TLog(StringFormat("  ghost  ·  baseline-rescue best  ·  thr %.0f  ·  %dt  ·  %.1f%% WR  ·  (per-regime scan: %dt)",
                _bestThr, _bestT, _bestOosWR*100, ghostFinalTotal));
            if(_bestT >= 15 && _bestOosWR >= 0.42) {
                TLog(StringFormat("  ghost  ·  baseline-rescue viable (%.1f%% WR, %dt, thr %.0f)  ->  resetting all thresholds to %.0f for retry",
                    _bestOosWR*100, _bestT, _bestThr, _bestThr));
                for(int _p1r=0;_p1r<9;_p1r++)
                    g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_p1r))]=_bestThr;
            }
        }
        return false;
    }
    // Print final ghost simulation summary
    if(!g_CalibSilent) {
        double _finalWR = (ghostStreamTotal > 0) ? (double)ghostStreamWins / ghostStreamTotal * 100.0 : 0.0;
        PrintFormat("  ghost complete  |  %d total trades  |  %d stored for detail  |  final WR %.1f%%  |  P&L %+.3f%%",
            ghostStreamTotal, resultCount, _finalWR,
            (ghostStreamProfit - ghostStreamLoss));
        for(int _gs = 0; _gs < 9; _gs++) {
            if(ghostStreamRegimeObs[_gs] < 2) continue;
            double _rwr = (double)ghostStreamRegimeWins[_gs] / ghostStreamRegimeObs[_gs] * 100.0;
            PrintFormat("    regime %-22s  %3d trades  WR %.0f%%",
                GetRegimeName(_gs), ghostStreamRegimeObs[_gs], _rwr);
        }
    }
    
    // Publish streaming stats for Phase 6 to read
    g_Ghost_StreamTotal = ghostStreamTotal;
    g_Ghost_StreamWins  = ghostStreamWins;
    g_Ghost_StreamPnL   = ghostStreamProfit - ghostStreamLoss;

    // ===== SLS12: DENSE PER-REGIME STATISTICAL PASS =====
    // The sequential stream above is the honest equity curve (non-overlapping, ~300 trades).
    // But it leaves tiny per-regime samples (8-20 trades) that can't support a trustworthy
    // quarantine decision. This pass scans EVERY qualifying OOS bar independently — overlapping
    // allowed, because here we measure each regime's TP-before-SL HIT RATE, not a single
    // account's path. Thousands of resolved outcomes -> statistically sound per-regime WR.
    // No look-ahead (entry at next-bar open, resolve forward only); OOS-only (never training).
    {
        int _denseObs[9];  ArrayInitialize(_denseObs, 0);
        int _denseWins[9]; ArrayInitialize(_denseWins, 0);
        int _dStart = 30;
        int _dEnd   = MathMin(GetOOSWindowBars(), MathMax(0, Bars - 30));
        for(int db = _dEnd - 1; db >= _dStart; db--) {
            MarketStateFeatures df = CalculateMarketFeatures(db);
            int dreg = ClassifyBarToRegime(df, db);
            if(dreg < 0 || dreg > 8) continue;
            double dscore = CalculateEnhancedUnifiedScore(db);
            double dthr = (g_WeightsOptimized) ? g_RegimeOptimalThresholds[MathMin(8,MathMax(0,dreg))] : DEFAULT_REGIME_THRESHOLD;
            if(MathAbs(dscore) < dthr) continue;
            double datr = iATR(Symbol(), 0, 14, db);
            if(datr <= 0) continue;
            // SLS12: apply the SAME spread filter the live system uses (skip bars where spread
            // exceeds 18% of ATR). Calibration must measure edge on the bars live will ACTUALLY
            // trade — not on the blended average that includes wide-spread dead hours the live
            // gate refuses. This aligns the ghost's universe with live execution's universe.
            {
                double _dsp = g_CalibratedAvgSpread * Point;
                if(_dsp <= 0) _dsp = MarketInfo(Symbol(), MODE_POINT) * 5;
                if(_dsp > datr * 0.18) continue;   // live gate would refuse this bar
            }
            bool dLong = (dscore > 0);
            double dentry = (db>=1 && db-1<Bars) ? Open[db-1] : Close[db];
            double dsl = (g_RegimeOptimalSLMult[MathMin(8,MathMax(0,dreg))]>0.1)?g_RegimeOptimalSLMult[MathMin(8,MathMax(0,dreg))]:1.5;
            double dtp = (g_RegimeOptimalTPMult[MathMin(8,MathMax(0,dreg))]>0.1)?g_RegimeOptimalTPMult[MathMin(8,MathMax(0,dreg))]:2.5;
            double slP = dLong ? dentry - datr*dsl : dentry + datr*dsl;
            double tpP = dLong ? dentry + datr*dtp : dentry - datr*dtp;
            double spC = g_CalibratedAvgSpread * Point;
            if(dLong) tpP -= spC; else tpP += spC;
            int dMax = (g_RegimeOptimalExitBars[MathMin(8,MathMax(0,dreg))]>5)?g_RegimeOptimalExitBars[MathMin(8,MathMax(0,dreg))]:20;
            bool dWon = false; bool dResolved = false;
            for(int fb2 = db-1; fb2 >= MathMax(0, db-dMax); fb2--) {
                double hi2 = High[fb2], lo2 = Low[fb2];
                if(dLong) {
                    if(hi2 >= tpP) { dWon=true; dResolved=true; break; }
                    if(lo2 <= slP) { dWon=false; dResolved=true; break; }
                } else {
                    if(lo2 <= tpP) { dWon=true; dResolved=true; break; }
                    if(hi2 >= slP) { dWon=false; dResolved=true; break; }
                }
            }
            if(!dResolved) continue;
            _denseObs[dreg]++;
            if(dWon) _denseWins[dreg]++;
        }
        // Publish the DENSE per-regime reads as the authoritative quarantine statistics
        // whenever they have materially more samples than the sequential pass.
        int _denseTotal=0; for(int _dq=0;_dq<9;_dq++) _denseTotal+=_denseObs[_dq];
        if(_denseTotal >= ghostStreamTotal) {
            for(int _pg2=0;_pg2<9;_pg2++) {
                g_Ghost_RegObs[_pg2]  = _denseObs[_pg2];
                g_Ghost_RegWins[_pg2] = _denseWins[_pg2];
                g_P6_RegimeObs[_pg2]  = _denseObs[_pg2];
                g_P6_RegimeWins[_pg2] = _denseWins[_pg2];
            }
            if(!g_CalibSilent) {
                PrintFormat("  GHOST dense  |   %d resolved per-regime outcomes (vs %d sequential)   |   robust statistics", _denseTotal, ghostStreamTotal);
                for(int _ds=0;_ds<9;_ds++) if(_denseObs[_ds] >= 20) {
                    double _dwr = (double)_denseWins[_ds]/_denseObs[_ds]*100.0;
                    PrintFormat("    %-22s  %4d samples  WR %.1f%%%s",
                        GetRegimeName(_ds), _denseObs[_ds], _dwr,
                        _denseObs[_ds] >= 100 ? "   (high confidence)" : "   (moderate)");
                }
            }
        } else {
            // dense pass didn't beat sequential (rare) — keep sequential reads
            for(int _pg3=0;_pg3<9;_pg3++) {
                g_Ghost_RegObs[_pg3]  = ghostStreamRegimeObs[_pg3];
                g_Ghost_RegWins[_pg3] = ghostStreamRegimeWins[_pg3];
                g_P6_RegimeObs[_pg3]  = ghostStreamRegimeObs[_pg3];
                g_P6_RegimeWins[_pg3] = ghostStreamRegimeWins[_pg3];
            }
        }
    }
    g_P6_ResultCount = resultCount;
    // Ensure resultCount is within bounds (defensive programming)
    if(resultCount > 300) resultCount = 300;
    
    // Calculate metrics from ghost validation results
    int wins = 0;
    double totalProfit = 0, totalLoss = 0;
    int maxConsecLosses = 0, consecLosses = 0;
    
    // Direct array access - global array, no compiler warnings
    for(int i = 0; i < resultCount; i++) {
        if(g_GhostResults[i].won) {
            wins++;
            totalProfit += g_GhostResults[i].profitPct;
            consecLosses = 0;
        } else {
            totalLoss += MathAbs(g_GhostResults[i].profitPct);
            consecLosses++;
            if(consecLosses > maxConsecLosses) maxConsecLosses = consecLosses;
        }
    }
    
    double wr = (resultCount > 0) ? ((double)wins / resultCount) : 0.0;
    // Use streaming WR when it has materially more trades than the stored 300 —
    // the stream is uncapped and statistically more complete for the WR gate.
    if(ghostStreamTotal > resultCount * 2 && ghostStreamTotal >= 40)
        wr = (double)ghostStreamWins / ghostStreamTotal;
    double pf = (totalLoss > 0) ? totalProfit / totalLoss : 0;
    // Supplement PF from streaming stats if stream beats stored count
    if(ghostStreamTotal > resultCount * 2 && ghostStreamTotal >= 40 && ghostStreamLoss > 0)
        pf = ghostStreamProfit / ghostStreamLoss;
    double avgWin = (wins > 0) ? (totalProfit / wins) : 0.0;
    double avgLoss = (resultCount > wins) ? (totalLoss / (resultCount - wins)) : 0.0;
    double ev = wr * avgWin - (1 - wr) * avgLoss;
    
    if(!g_CalibSilent) PrintFormat("  Ghost OOS: %d trades | WR: %.1f%% | PF: %.2f | EV: %.2f%% | MaxDD %d consec",
               resultCount, wr * 100, pf, ev, maxConsecLosses);

    // Vol-adaptive gates: volatile OOS periods naturally produce harder outcomes
    // Measure current market volatility vs calibration-period median
    double _oosATRs[500]; int _aNc=0;
    for(int _ai=startBar; _ai<endBar && _ai<Bars && _aNc<500; _ai++) {
        double _at=iATR(Symbol(),0,14,_ai);
        if(_at>0) _oosATRs[_aNc++]=_at;
    }
    double _medATR=0;
    if(_aNc>0) { ArraySort(_oosATRs); _medATR=_oosATRs[_aNc/2]; }
    // Compute recent 50-bar ATR vs OOS median: volatility percentile
    double _recentATR = iATR(Symbol(),0,14,startBar);
    double _volPerc = (_medATR > 0) ? _recentATR / _medATR : 1.0;
    bool   _highVol = (_volPerc > 1.40);  // 40% above OOS median = high-vol environment
    // Adaptive gate thresholds
    // Catastrophic mode: Phase 6 gate raised — new calibration must prove itself
    double _baseWRGate = g_Calibration.catastrophicMode ? 0.68 : 0.65;
    double _wrGate  = _highVol ? (_baseWRGate - 0.03) : _baseWRGate;  // vol-adaptive on top
    // CATREC: stricter PF gate — new calibration must exceed failed one
    double _pfBase  = g_Calibration.catastrophicMode ? 1.95 : 1.80;
    double _pfGate  = _highVol ? MathMax(1.60, _pfBase - 0.20) : _pfBase;  // vol-adaptive
    if(g_Calibration.catastrophicMode && !g_CalibSilent)
        if(!g_CalibSilent) PrintFormat("  CATREC  |   P6 gate PF raised to 1.95 raised to 1.95 — must exceed failed calibration");
    double _evGate  = _highVol ? 0.40  : 0.60;   // EV harder to achieve in volatile spreads
    int    _ddGate  = _highVol ? 11    : 8;       // longer streak tolerance in volatile conditions
    if(!g_CalibSilent && _highVol)
        PrintFormat("  Vol-adaptive: %.1f%% above median ATR — gate thresholds relaxed",
                    (_volPerc-1.0)*100);
    bool passed = (wr >= _wrGate && pf >= _pfGate && ev >= _evGate && maxConsecLosses <= _ddGate);

    // FIX6 Gate 5: Signal frequency (≥5 wins/day avg)
    double barsPerDay = (Period()==PERIOD_M5)?288.0:(Period()==PERIOD_M15)?96.0:
                        (Period()==PERIOD_H1)?24.0:6.0;
    double tradingDays = MathMax(1.0, (double)(endBar-startBar)/barsPerDay);
    bool gate5_freq = (((double)wins/tradingDays) >= 5.0 || wins >= 20);
    if(!gate5_freq) passed = false;

    // FIX6 Gate 6: Statistical significance z>1.645 = p<0.05
    bool gate6_sig = false; double gate6_z = 0;
    if(resultCount >= 10) {
        double _exp = resultCount * 0.65;
        double _std = MathSqrt(resultCount * 0.65 * 0.35);
        gate6_z = (_std > 0) ? (wins - _exp) / _std : 0;
        gate6_sig = (gate6_z > 1.645);
    }
    if(!gate6_sig) passed = false;

    // FIX6 Gate 7: Walk-forward stability (4 of 5 windows ≥55%)
    // Phase 6: 8 walk-forward windows — 5 equal-spaced + 3 targeting volatile periods
    // This ensures robustness in calm AND volatile conditions
    int wfSize = MathMax(10, (endBar-startBar)/8);
    int wfPassed = 0;
    // Build 8 window start points: 5 equal + 3 overlapping the high-vol period
    // Pre-compute high-volatility region BEFORE WF window construction
    int _bestVolStart = startBar; double _bestVolSum = 0;
    for(int _vs=startBar;_vs<endBar-30;_vs++) {
        double _vS2=0;
        for(int _vi=_vs;_vi<_vs+30&&_vi<Bars;_vi++) _vS2+=iATR(Symbol(),0,14,_vi);
        if(_vS2>_bestVolSum){_bestVolSum=_vS2;_bestVolStart=_vs;}
    }
    int _wfStarts[8]; int _wfNW=8;
    for(int _ws=0;_ws<5;_ws++) _wfStarts[_ws] = startBar + _ws*((endBar-startBar)/5);
    // 3 additional windows targeting the confirmed high-ATR region
    _wfStarts[5] = MathMax(startBar, _bestVolStart - wfSize/2);
    _wfStarts[6] = _bestVolStart;
    _wfStarts[7] = MathMin(endBar - wfSize, _bestVolStart + wfSize/2);
    for(int _wf = 0; _wf < _wfNW; _wf++) {
        int _wfS = _wfStarts[_wf], _wfE = MathMin(_wfS+wfSize, endBar);
        int _wfW = 0, _wfT = 0;
        for(int _wi = 0; _wi < resultCount; _wi++) {
            if(g_GhostResults[_wi].barIndex >= _wfS && g_GhostResults[_wi].barIndex < _wfE)
                { _wfT++; if(g_GhostResults[_wi].won) _wfW++; }
        }
        double _wfBar = _highVol ? 0.50 : 0.55;  // lower bar in volatile conditions
        // Always-on: error memory tightens WF gate for chronically failing regimes
        double _wfFloor = _wfBar;
        { int _wfR=g_RegimeState.currentRegime, _rFl=0;
          for(int _wfM=0;_wfM<g_ErrorMemoryCount;_wfM++)
              if(g_ErrorMemory[_wfM].regime==_wfR) _rFl++;
          if(_rFl>=2) _wfFloor=MathMin(0.72,_wfFloor+0.03); }
        if(_wfT >= 5 && (double)_wfW/_wfT >= _wfFloor) wfPassed++;
    }
    bool gate7_wf = (wfPassed >= 6);  // 6/8 windows — stricter than 4/5 but with more windows
    if(!gate7_wf) { passed = false; g_Calibration.fragileFlag = true; }

    // -- UPGRADE 3: Weight Stability Gate ------------------------------------─
    // Audit all 9 regimes for extreme weight deviation (high L2 from neutral).
    // L2 > 8.0 = some dimension at ~3.8x or multiple at ~2.5x — indicates
    // overfitting to a specific training window slice. Blend 30% toward neutral.
    // This mirrors the "stability penalty" in academic WF optimization literature.
    {
        int _wExtremeRegs = 0;
        double _wMaxL2 = 0;
        for(int _re = 0; _re < 9; _re++) {
            if(!g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].validated) continue;
            double _wArr[6];
            _wArr[0]=g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].mtf;
            _wArr[1]=g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].momentum;
            _wArr[2]=g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].volume;
            _wArr[3]=g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].volatility;
            _wArr[4]=g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].session;
            _wArr[5]=g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].pattern;
            double _l2 = 0;
            for(int _lw = 0; _lw < 6; _lw++) _l2 += MathPow(_wArr[_lw] - 1.0, 2.0);
            if(_l2 > _wMaxL2) _wMaxL2 = _l2;
            if(_l2 > 8.0) {
                // Blend: 30% toward neutral 1.0, preserving direction of learned edge
                double _bf = 0.30;
                g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].mtf        = g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].mtf        * (1.0-_bf) + 1.0*_bf;
                g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].momentum   = g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].momentum   * (1.0-_bf) + 1.0*_bf;
                g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].volume     = g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].volume     * (1.0-_bf) + 1.0*_bf;
                g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].volatility = g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].volatility * (1.0-_bf) + 1.0*_bf;
                g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].session    = g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].session    * (1.0-_bf) + 1.0*_bf;
                g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].pattern    = g_RegimeOptimalWeights[MathMin(8,MathMax(0,_re))].pattern    * (1.0-_bf) + 1.0*_bf;
                _wExtremeRegs++;
            }
        }
        if(_wExtremeRegs > 0 && !g_CalibSilent)
            PrintFormat("  weight stability  |  %d/%d regimes blended toward neutral (max L2=%.1f > 8.0)",
                _wExtremeRegs, 9, _wMaxL2);
        else if(!g_CalibSilent)
            PrintFormat("  weight stability  |  all regimes within bounds (max L2=%.1f)  ✓", _wMaxL2);
    }
    // THESIS CRITICAL FLAG 3: fragileFlag must be logged with maximum clarity
    // Gate 8: Volatile stress window test — arm only if edge survives worst vol period
    // Identify highest-ATR 30-bar window in OOS; require ≥50% WR there
    // _bestVolStart already computed above (before WF window construction)
    int _svW=0, _svT=0;
    for(int _si=0; _si<resultCount; _si++)
        if(g_GhostResults[_si].barIndex>=_bestVolStart && g_GhostResults[_si].barIndex<_bestVolStart+30)
            { _svT++; if(g_GhostResults[_si].won) _svW++; }
    bool gate8_stress = (_svT < 5) || ((double)_svW/_svT >= 0.50);
    if(!gate8_stress) { passed=false; g_Calibration.fragileFlag=true; }
    if(!g_CalibSilent)
        PrintFormat("  gate8 stress  |  vol window bars %d-%d  |  WR %.1f%%  |  %s",
                    _bestVolStart, _bestVolStart+30,
                    _svT>0?(double)_svW/_svT*100:0, gate8_stress?"✓":"✗");

    if(g_Calibration.fragileFlag && !g_CalibSilent)
        Print("  ⚠ note   |   walk-forward instability detected — system arms but monitor performance closely");

    if(!g_CalibSilent)
        PrintFormat("  P6    |   gates  WR %s  |  PF %s  |  EV %s  |  DD %s  |  Freq %s  |  z=%.2f %s  |  WF %d/%d %s",  // SLS23 FIX: was hardcoded /5, denominator is _wfNW=8
            wr>=_wrGate?"✓":"✗", pf>=_pfGate?"✓":"✗", ev>=_evGate?"✓":"✗", maxConsecLosses<=_ddGate?"✓":"✗",
            gate5_freq?"✓":"✗", gate6_z, gate6_sig?"✓":"✗", wfPassed, _wfNW, gate7_wf?"✓":"✗");

    if(!g_CalibSilent) {
        if(passed) Print("  Ghost: PASS");
        else       PrintFormat("  Ghost: FAIL  WR %.1f%%  PF %.2f  EV %.2f%%  MaxDD %d",
                               wr*100, pf, ev, maxConsecLosses);
        if(!g_CalibSilent) Print("  Multi-context validation...");
    }

    // Context 1: Time-based cross-validation (within OOS window 30-499)
    double recentWR     = ValidateOnBars(30, 249);
    double historicalWR = ValidateOnBars(250, 499);
    if(!g_CalibSilent) {
        PrintFormat("  OOS   |   recent %.1f%%   |   older %.1f%%   |   %s",
                    recentWR*100, historicalWR*100,
                    MathAbs(recentWR-historicalWR) < 0.05 ? "consistent" : "variance noted");
        
    }
    if(MathAbs(recentWR - historicalWR) > 0.12 && !_highVol) {
        g_Calibration.fragileFlag = true;
        if(!g_CalibSilent) Print("  OOS variance >12pct — calibration fragile (not generalising well)");
    }

    // Context 2: Session-based validation
    double londonWR = ValidateBySession("London");
    double nyWR     = ValidateBySession("NY");
    double asianWR  = ValidateBySession("Asian");
    if(!g_CalibSilent)
        PrintFormat("  session  |  London %.1f%%  |  NY %.1f%%  |  Asian %.1f%%  |  %s",
            londonWR*100, nyWR*100, asianWR*100,
            (londonWR >= 0.50 && nyWR >= 0.50) ? "primary sessions OK" : "session gap detected");
    bool _ctxFailed = false;
    // Flag as fragile if either major session is below 50% (Asian alone is secondary)
    if((londonWR > 0 && londonWR < 0.50) || (nyWR > 0 && nyWR < 0.50)) {
        g_Calibration.fragileFlag = true; _ctxFailed = true;
        if(!g_CalibSilent)
            PrintFormat("  ⚠ session  |  London %.1f%%  NY %.1f%%  — primary session edge weak",
                londonWR*100, nyWR*100);
    }
    if(asianWR > 0 && asianWR < 0.45 && !g_CalibSilent)
        PrintFormat("  note  |  Asian WR %.1f%% (low-volume session, non-critical)", asianWR*100);

    // Context 3: Volatility-based validation
    double highVolWR   = ValidateByVolatility("High");
    double normalVolWR = ValidateByVolatility("Normal");
    double lowVolWR    = ValidateByVolatility("Low");
    if(!g_CalibSilent)
        PrintFormat("  volatility  |  High %.1f%%  |  Normal %.1f%%  |  Low %.1f%%",
            highVolWR*100, normalVolWR*100, lowVolWR*100);
    if(highVolWR > 0 && highVolWR < 0.45) {
        g_Calibration.fragileFlag = true; _ctxFailed = true;
        if(!g_CalibSilent)
            PrintFormat("  ⚠ vol  |  High-vol WR %.1f%% < 45%% — edge fails in volatile conditions", highVolWR*100);
    }
    if(normalVolWR > 0 && normalVolWR < 0.50) {
        g_Calibration.fragileFlag = true; _ctxFailed = true;
        if(!g_CalibSilent)
            PrintFormat("  ⚠ vol  |  Normal-vol WR %.1f%% < 50%% — core environment edge insufficient", normalVolWR*100);
    }

    // Context 4: Regime-based validation
    double trendWR = ValidateByRegimeType("Trend");
    double rangeWR = ValidateByRegimeType("Range");
    if(!g_CalibSilent)
        PrintFormat("  regime type  |  Trend %.1f%%  |  Range %.1f%%  |  %s",
            trendWR*100, rangeWR*100,
            (trendWR >= 0.52 && rangeWR >= 0.50) ? "regime coverage OK" : "regime gap detected");
    if((trendWR > 0 && trendWR < 0.52) || (rangeWR > 0 && rangeWR < 0.50)) {
        g_Calibration.fragileFlag = true; _ctxFailed = true;
        if(!g_CalibSilent)
            PrintFormat("  ⚠ regime type  |  Trend %.1f%%  Range %.1f%%  — regime coverage fragile",
                trendWR*100, rangeWR*100);
    }

    // Context 5: Market direction validation
    double bullWR     = ValidateByMarketDirection("Bull");
    double bearWR     = ValidateByMarketDirection("Bear");
    double sidewaysWR = ValidateByMarketDirection("Sideways");
    if(!g_CalibSilent)
        PrintFormat("  direction  |  Bull %.1f%%  |  Bear %.1f%%  |  Sideways %.1f%%  |  %s",
            bullWR*100, bearWR*100, sidewaysWR*100,
            (bullWR >= 0.50 && bearWR >= 0.50) ? "directional balance OK" : "directional bias detected");
    bool _dirImbalance = (bullWR > 0 && bearWR > 0) &&
                         ((bullWR < 0.45 && bearWR > 0.60) || (bearWR < 0.45 && bullWR > 0.60));
    bool _dirWeakBoth  = (bullWR > 0 && bullWR < 0.50) && (bearWR > 0 && bearWR < 0.50);
    if(_dirImbalance || _dirWeakBoth) {
        g_Calibration.fragileFlag = true; _ctxFailed = true;
        if(!g_CalibSilent) {
            if(_dirImbalance)
                PrintFormat("  ⚠ direction  |  Bull %.1f%%  Bear %.1f%%  — one-sided directional bias risk",
                    bullWR*100, bearWR*100);
            if(_dirWeakBoth)
                PrintFormat("  ⚠ direction  |  Bull %.1f%%  Bear %.1f%%  — edge weak on both directions",
                    bullWR*100, bearWR*100);
        }
    }
    if(!g_CalibSilent) {
        if(_ctxFailed)
            Print("  ⚠ multi-context  |  context gate(s) flagged fragile — system arms but monitor closely");
        else
            Print("  multi-context  |  all context gates passed  ✓");
    }

    // WARRANT#53: wire this function's own real gate variables into a ForgeScorecard + S1-S5 +
    // the ratchet, read-only w.r.t. everything above -- see the WARRANT#53 block for full detail.
    Forge_ReportGhostValidation(wr, pf, ev, maxConsecLosses, gate6_sig, wfPassed, _wfNW, gate8_stress,
                                 MathMax(resultCount, ghostStreamTotal), passed, resultCount);

    return passed;
}

// Note: Function returns bool on all code paths
// Early exit: return false (if insufficient trades)
// Normal exit: return passed (after validation)

struct PatternMatch {
    PatternType type;
    double      matchStrength;
    int         regime;
    int         patternId;   // pattern enum id (was string name)
    bool        isBullish;
    int         barsSpanned;
};

// Scans recent bars and scores match against each template.
// Returns best match. Match is probabilistic, not binary.
PatternMatch ScanForPattern(int bar, int currentRegime, bool nearSup, bool nearRes, double adx) {
    PatternMatch best;
    best.type = PATTERN_NONE;
    best.matchStrength = 0;
    best.regime = currentRegime;
    best.patternId = (int)PATTERN_NONE;  // was best.name = "None"
    best.isBullish = true;
    best.barsSpanned = 0;

    if(bar < 3 || bar >= Bars - 60) return best;

    // Gather candle data for scanning window
    double body0 = MathAbs(Close[bar] - Open[bar]);
    double range0 = High[bar] - Low[bar];
    double lwick0 = MathMin(Open[bar], Close[bar]) - Low[bar];
    double uwick0 = High[bar] - MathMax(Open[bar], Close[bar]);
    double bodyRatio0 = range0 > 0 ? body0 / range0 : 0;
    double wickRatio0 = range0 > 0 ? MathMax(lwick0, uwick0) / range0 : 0;
    bool isBull0 = (Close[bar] > Open[bar]);

    double body1 = MathAbs(Close[bar+1] - Open[bar+1]);
    double range1 = High[bar+1] - Low[bar+1];
    double bodyRatio1 = range1 > 0 ? body1 / range1 : 0;
    bool isBull1 = (Close[bar+1] > Open[bar+1]);

    double body2 = MathAbs(Close[bar+2] - Open[bar+2]);
    double range2 = High[bar+2] - Low[bar+2];
    double bodyRatio2 = range2 > 0 ? body2 / range2 : 0;
    bool isBull2 = (Close[bar+2] > Open[bar+2]);

    // Compute 10-bar and 20-bar ATR for context
    double atr10 = iATR(Symbol(), 0, 10, bar);

    for(int p = 0; p < g_PatternLibraryCount; p++) {
        PatternTemplate tmpl = g_PatternLibrary[p];

        // Skip patterns not applicable to current regime vicinity
        // Allow 1 regime of lookahead (transition detection)
        if(MathAbs(tmpl.regime - currentRegime) > 1 &&
           !(currentRegime == 7) && !(tmpl.regime == 7)) continue;

        // Context gates: ADX range
        if(adx < tmpl.minADXContext || adx > tmpl.maxADXContext) continue;

        // Context gates: S/R requirements
        if(tmpl.requiresSupport && !nearSup) continue;
        if(tmpl.requiresResistance && !nearRes) continue;

        double score = 0;

        // BODY RATIO SCORE (0-40 points)
        // Does the candle body match expected size for this pattern?
        if(bodyRatio0 >= tmpl.minBodyRatio && bodyRatio0 <= tmpl.maxBodyRatio) {
            // Exact match within range: full points
            double rangeMid = (tmpl.minBodyRatio + tmpl.maxBodyRatio) / 2.0;
            double rangeSpan = tmpl.maxBodyRatio - tmpl.minBodyRatio + 0.001;
            double closeness = 1.0 - (MathAbs(bodyRatio0 - rangeMid) / (rangeSpan / 2.0));
            score += 40.0 * MathMax(0.5, closeness);
        } else {
            // Outside range: partial credit for proximity
            double distOver = MathMax(0.0, bodyRatio0 - tmpl.maxBodyRatio);
            double distUnder = MathMax(0.0, tmpl.minBodyRatio - bodyRatio0);
            double dist = MathMax(distOver, distUnder);
            if(dist < 0.15) score += 20.0 * (1.0 - dist / 0.15);
        }

        // WICK RATIO SCORE (0-30 points)
        if(tmpl.minWickRatio > 0) {
            if(wickRatio0 >= tmpl.minWickRatio) {
                score += 30.0 * MathMin(1.0, wickRatio0 / (tmpl.minWickRatio * 1.5));
            } else {
                // Partial credit
                score += 15.0 * (wickRatio0 / tmpl.minWickRatio);
            }
        } else {
            score += 20; // No wick requirement = neutral score
        }

        // DIRECTION CONSISTENCY (0-20 points)
        // For bullish patterns: current bar should be bullish or prior bar bearish
        if(tmpl.isBullish) {
            if(isBull0) score += 20;
            else if(!isBull1) score += 10; // Prior was bear, setup for reversal
        } else {
            if(!isBull0) score += 20;
            else if(isBull1) score += 10;
        }

        // PATTERN-SPECIFIC SEQUENCE CHECKS (0-10 bonus points)
        // These distinguish pattern types from each other
        switch(tmpl.type) {
            case PATTERN_MORNING_STAR:
                // Three specific candles: bear, small, bull
                if(!isBull2 && bodyRatio1 < 0.30 && isBull0 &&
                   body2 > 0 && body0 > body2 * 0.5) score += 10;
                break;
            case PATTERN_EVENING_STAR:
                // Three specific candles: bull, small, bear
                if(isBull2 && bodyRatio1 < 0.30 && !isBull0 &&
                   body2 > 0 && body0 > body2 * 0.5) score += 10;
                break;
            case PATTERN_BULLISH_ENGULFING:
                // Current bull body > prior bear body
                if(isBull0 && !isBull1 && body0 > body1 * 1.1) score += 10;
                break;
            case PATTERN_BEARISH_ENGULFING:
                // Current bear body > prior bull body
                if(!isBull0 && isBull1 && body0 > body1 * 1.1) score += 10;
                break;
            case PATTERN_HAMMER_AT_SUPPORT:
            case PATTERN_SHOOTING_STAR_AT_RES:
                // Strong wick dominance
                if(lwick0 > body0 * 2.0 || uwick0 > body0 * 2.0) score += 10;
                break;
            case PATTERN_FAILED_BREAKOUT:
            case PATTERN_RANGE_FAKEOUT:
                // Reversal after break: current candle closes back inside
                if(isBull0 != isBull1 && body0 > body1 * 0.6) score += 10;
                break;
            default:
                score += 5; // Small generic bonus
                break;
        }

        // Store best match
        if(score > best.matchStrength) {
            best.matchStrength = score;
            best.type = tmpl.type;
            best.regime = tmpl.regime;
            best.patternId = (int)tmpl.type;  // PatternMatch.name replaced with patternId
            best.isBullish = tmpl.isBullish;
            best.barsSpanned = (int)tmpl.minBarsSpan;
        }
    }

    // Normalize to 0-100
    best.matchStrength = MathMin(100.0, best.matchStrength);
    return best;
}
