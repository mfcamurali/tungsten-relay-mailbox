    int signalBar;              // Bar index where signal occurred (for historical backtest)
    int closeBar;               // Bar index where trade closed (for historical backtest)
    double threshold;           // Threshold used for this ghost
    double unifiedScore;        // Score at entry
    double momentumWeight;      // Component weights being tested
    double reversalWeight;
    double volatilityWeight;
    double directionalWeight;
    double patternWeight;
    double predictiveWeight;
    bool closed;               // Has outcome been determined?
    bool wonTrade;             // Would it have won?
    double rMultiple;          // R-multiple achieved
    datetime closeTime;
    string closeReason;        // "TP", "SL", "Timeout"
    int ticksOpen;             // How many ticks monitored
};

struct DiscoveryMode {
    bool active;                    // Is discovery mode running?
    datetime startTime;             // When discovery started
    datetime endTime;               // When discovery should end
    int durationMinutes;            // Duration (15-20 min configurable)
    
    GhostTrade ghostTrades[1000];   // Array of ghost trades (max 1000)
    int ghostTradeCount;            // How many ghosts created
    int ghostTradesWon;             // Ghosts that would have won
    int ghostTradesLost;            // Ghosts that would have lost
    int ghostTradesTimeout;         // Ghosts that timed out (no TP/SL hit)
    
    // Best parameters discovered
    double bestThreshold;
    double bestMomentumWeight;
    double bestReversalWeight;
    double bestVolatilityWeight;
    double bestDirectionalWeight;
    double bestPatternWeight;
    double bestPredictiveWeight;
    double bestWinRate;
    string bestConfig;              // Description of best config
    
    // Testing ranges
