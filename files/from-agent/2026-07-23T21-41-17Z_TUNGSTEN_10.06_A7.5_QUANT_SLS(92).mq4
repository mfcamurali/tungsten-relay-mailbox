// Regime transition probability matrix -- 8x8.
// g_RegimeTransitionProb[from][to] = probability of transitioning from 'from' to 'to'.
// Built from 10k bars in Phase 2. If "Building Momentum" -> "Strong Bull" = 74%,
// buy signals in regime 7 get elevated conviction for the next bar.
double g_RegimeTransitionProb[9][9];
int    g_RegimeTransitionCount[9];  // Total transitions observed from each regime
bool   g_TransitionMatrixBuilt = false;
// 9.42: regime duration statistics, captured in the SAME calibration scan that builds
// the transition matrix (the loop already tracks currentAgeT -- it was measuring
// durations and throwing them away). Powers the geometric-hazard continuation model:
// the old continuationProb = 1 - maxTransitionProb misread a distribution that is
// CONDITIONAL on a transition occurring as if it were marginal -- the matrix only
// records regime CHANGES (prevRegimeT != rT), so P(stay) was never in it at all.
double g_RegimeAvgDuration[9];      // mean bars a regime persists once entered
int    g_RegimeDurationSamples[9];  // completed spells observed per regime
bool   g_RegimeDurationCalibrated = false;

// Regime age threshold adjustments -- derived from per-regime WR vs age analysis.
// Young regimes (1-3 bars): unproven, +threshold. Mature (8-15 bars): sweet spot, -threshold.
// Old regimes (20+ bars): overextended, +threshold.
double g_RegimeAgeThreshAdj[9][3]; // [regime][0=young 1=mature 2=old]
bool   g_RegimeAgeCalibrated = false;

// PHASE 1B: MULTI-DIMENSIONAL PROBABILITY DATABASE
// Learn conditional probabilities: Regime ? Score ? Pattern ? Session ? Vol
// Not just "Score 60 wins 52%" but "Score 60 + Regime 2 + Bull Flag + London = 78%"

struct ConditionalProbability {
    // Keys for lookup (multi-dimensional)
    int regime;              // 0-7
    int scoreRange;          // 0-9 (represents 0-10, 10-20, ..., 90-100)
    PatternType pattern;     // Detected pattern type
    int session;             // 0=Asian, 1=London, 2=NY, 3=Overlap
    int volatility;          // 0=Low, 1=Normal, 2=High
    
    // Outcome statistics
    int observations;        // How many times this combination appeared
    int wins;                // How many won
    double winRate;          // wins / observations
    double avgProfit;        // Average profit when won (%)
    double avgLoss;          // Average loss when lost (%)
    double expectedValue;    // (WR ? avgProfit) - ((1-WR) ? avgLoss)
    double confidence;       // Statistical confidence (based on sample size)
    
    // Meta
    datetime lastSeen;
    bool validated;          // Passed validation checks
    
    // Cumulative tracking (added to fix compilation)
    double totalProfit;      // Sum of all winning trades
    double totalLoss;        // Sum of all losing trades
    };

// Large probability matrix - stores discovered combinations
// Theoretical max: 8 regimes ? 10 score ranges ? 20 patterns ? 4 sessions ? 3 volatility = 19,200
// Practical capacity: 25000 most common combinations (upgraded from 5000 — avoids early cap in long calibrations)
ConditionalProbability g_ProbabilityMatrix[25000];
int g_ProbabilityCount = 0;
bool g_ProbabilityDatabaseBuilt = false;
bool g_CalibSilent = false;
// ===== SLS13 R1: CALIBRATION NARRATION VOICE =====
// The retry layer speaks ONLY through this helper — never per-attempt Prints. It emits a
// beat at meaningful turns (a phase opening, a strategy that changed the outcome, a phase
// closing) so calibration reads like a mind working a problem, not a status register. The
// per-attempt grind stays silent by construction. g_CalibVerbose (default OFF) exposes the
// raw per-attempt numbers for engineering only, keeping the elegant stream clean.
bool g_CalibVerbose = false;   // ON only for deep engineering inspection
void Narrate(string phase, string region, string beat) {
    if(g_CalibSilent) return;
    if(region == "") PrintFormat("  %s · %s", phase, beat);
    else             PrintFormat("  %s · %s · %s", phase, region, beat);
}
bool g_CATREC_ForceActivate  = false;  // triggers CATREC recalibration      // When true all sub-function Print output is suppressed
string g_CalibFailReason = "";   // Set by failing sub-functions for orchestrator [fail] block

// PHASE 3: CONTINUOUS LEARNING (FEEDBACK LOOP)
// Track live trades and update probability database

struct LiveTradeContext {
    int ticket;
    int regime;
    double score;
    PatternType pattern;
    int session;
    int volatility;
    double entryPrice;
    double confidence;
    datetime openTime;
    bool tracked;
    // Component snapshot at entry — enables post-close error attribution
    double compMTF, compMomentum, compVolume, compVolatility, compSession, compPattern;
    double scoreMargin;  // how far above threshold the signal was
};

// Track recent trades for learning
LiveTradeContext g_LiveTrades[100];
int g_LiveTradeCount = 0;

// Performance tracking for adaptation
int g_LiveTradesTotal = 0;
int g_LiveTradesWon = 0;
double g_LiveWinRate = 0;
// Live SR cache -- updated each tick by BuildSwingDNA via CalculateMarketFeatures(0)
double g_LiveKeyResistance  = 0.0;
double g_LiveKeySupport     = 0.0;
double g_LiveDistToResATR   = 99.0;
double g_LiveDistToSupATR   = 99.0;
int    g_LiveResTouchCount  = 0;
int    g_LiveSupTouchCount  = 0;
datetime g_LastRecalibrationCheck = 0;

// Session determination helper
int DetermineSession(int hour) {
    if(hour >= 0 && hour < 7) return 0;      // Asian (0-7 UTC)
    if(hour >= 7 && hour < 12) return 1;     // London (7-12 UTC)
    if(hour >= 12 && hour < 17) return 2;    // NY (12-17 UTC)
    return 3;                                 // Overlap/Other
}

// Volatility determination helper
int DetermineVolatility(double atr) {
    // Uses calibrated ATR-ratio percentile thresholds set in Phase 3B.6.
    // Instrument-agnostic: compares current ATR to its own 20-bar rolling average.
    // Falls back to reasonable defaults pre-calibration.
    double atr20 = 0.0;
    for(int _i = 0; _i < 20; _i++) atr20 += iATR(NULL, PERIOD_CURRENT, 14, _i);
    atr20 /= 20.0;
    if(atr20 <= 0) return 1;  // guard
    double ratio = atr / atr20;
    if(ratio < g_CalibratedVolLowThresh)  return 0;  // Low-vol
    if(ratio > g_CalibratedVolHighThresh) return 2;  // High-vol
    return 1;                                         // Normal
}

// Calculate statistical confidence based on sample size
double CalculateStatisticalConfidence(int sampleSize) {
    if(sampleSize >= 30) return 0.95;
    if(sampleSize >= 20) return 0.90;
    if(sampleSize >= 15) return 0.85;
    if(sampleSize >= 10) return 0.75;
    if(sampleSize >= 5) return 0.60;
    return 0.40;
}

// SLS22-ERM: enum + state global moved here (ahead of both SEG and ERM's own
// implementation block) because SEG's post-event interlock needs to reference
// g_ERM_State/ERM_STATE_* before ERM's block is textually defined -- MQL4
// requires enum types fully declared before use, unlike plain function calls.
