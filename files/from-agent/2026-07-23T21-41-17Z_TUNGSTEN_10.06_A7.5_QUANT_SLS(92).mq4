//| NEW: Initialize Intelligent TP/SL System                         |
void InitializeIntelligentTPSL() {
    double stopLevel = MarketInfo(Symbol(), MODE_STOPLEVEL);
    double point = MarketInfo(Symbol(), MODE_POINT);
    
    tpslSystem.minStopLevel = stopLevel;
    tpslSystem.minStopDistance = stopLevel * point * MIN_STOP_LEVEL_MULTIPLIER;
    tpslSystem.brokerLimitsChecked = true;
    
    tpslSystem.baseTPMultiplier = DYNAMIC_TP_BASE;
    tpslSystem.baseSLMultiplier = 1.0;
    tpslSystem.currentTPMultiplier = DYNAMIC_TP_BASE;
    tpslSystem.currentSLMultiplier = 1.0;
    
    tpslSystem.consecutiveWins = 0;
    tpslSystem.consecutiveLosses = 0;
    tpslSystem.recentWinRate = 0.5;
    tpslSystem.recentRR = TARGET_RISK_REWARD_RATIO;
    tpslSystem.averageWinSize = 0.0;
    tpslSystem.averageLossSize = 0.0;
    
    tpslSystem.volatilityAdjustment = 1.0;
    tpslSystem.trendStrengthAdjustment = 1.0;
    tpslSystem.momentumAdjustment = 1.0;
    tpslSystem.confidenceAdjustment = 1.0;
    
    tpslSystem.optimalTPDistance = 0.0;
    tpslSystem.optimalSLDistance = 0.0;
    tpslSystem.riskRewardScore = 0.5;
    tpslSystem.profitConsistencyScore = 0.5;
    
    tpslSystem.tightenSLMode = false;
    tpslSystem.expandTPMode = false;
    tpslSystem.lastAdjustment = 0;
    tpslSystem.adjustmentCycles = 0;
    
    for(int i = 0; i < 20; i++) {
        tpslSystem.tpHistory[i] = DYNAMIC_TP_BASE;
        tpslSystem.slHistory[i] = 1.0;
        tpslSystem.rrHistory[i] = TARGET_RISK_REWARD_RATIO;
    }
    tpslSystem.historyIndex = 0;
    tpslSystem.systemCalibrated = false;
    
    // TP/SL system initialized silently
}

// Helper to avoid divide-by-zero: returns a safe non-zero denominator
// Clamp bar index to valid price array range — prevents array-out-of-range crashes
// Use in all price[] accesses with calculated bar indices
int SafeBar(int bar) {
    if(bar < 0)       return 0;
    if(bar >= Bars-1) return MathMax(0, Bars-2);
    return bar;
}
int SafeHL(int idx) { return (idx < 0 || idx >= Bars) ? 0 : idx; }
double SafeLog(double x) { return MathLog(MathMax(1e-10, x)); }
double SafeSqrt(double x) { return MathSqrt(MathMax(0.0, x)); }

double NonZero(double v) {
    if(v == 0.0) return 1e-9;
    if(MathAbs(v) < 1e-9) return (v < 0) ? -1e-9 : 1e-9;
    return v;
}

//| NEW: Update Intelligent TP/SL System                             |
void UpdateIntelligentTPSL() {
    static datetime lastUpdate = 0;
    if((TimeCurrent() - lastUpdate) < 60) return;
    lastUpdate = TimeCurrent();
    
    UpdateTPSLPerformanceMetrics();
    AdjustTPSLFromConsecutiveResults();
    AdjustTPSLFromMarketConditions();
    OptimizeTPSLForWinRate();
    CalculateOptimalTPSLDistances();
    UpdateTPSLSafetyModes();
    
    tpslSystem.tpHistory[tpslSystem.historyIndex] = tpslSystem.currentTPMultiplier;
    tpslSystem.slHistory[tpslSystem.historyIndex] = tpslSystem.currentSLMultiplier;
    tpslSystem.rrHistory[tpslSystem.historyIndex] = tpslSystem.currentTPMultiplier / NonZero(tpslSystem.currentSLMultiplier);
    tpslSystem.historyIndex = (tpslSystem.historyIndex + 1) % 20;
    
    if(tpslSystem.adjustmentCycles >= 20) {
        tpslSystem.systemCalibrated = true;
    }
    tpslSystem.adjustmentCycles++;
}

//| NEW: Update TP/SL Performance Metrics                            |
void UpdateTPSLPerformanceMetrics() {
    tpslSystem.recentWinRate = CalculateRecentWinRate() / 100.0;
    
    int wins = 0, losses = 0;
    bool counting = true;
    
    for(int i = OrdersHistoryTotal() - 1; i >= 0 && counting; i--) {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
        if(OrderSymbol() != Symbol() || OrderMagicNumber() != MagicNumber) continue;
        
        double profit = OrderProfit() + OrderSwap() + OrderCommission();
        
        if(profit > 0) {
            if(losses == 0) wins++;
            else counting = false;
        } else if(profit < 0) {
            if(wins == 0) losses++;
            else counting = false;
        }
        
        if(wins > 0 || losses > 0) break;
    }
    
    tpslSystem.consecutiveWins = wins;
    tpslSystem.consecutiveLosses = losses;
    
    double totalWins = 0, totalLosses = 0;
    int winCount = 0, lossCount = 0;
    int lookback = MathMin(20, OrdersHistoryTotal());
    
    for(int i = OrdersHistoryTotal() - 1; i >= OrdersHistoryTotal() - lookback && i >= 0; i--) {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
        if(OrderSymbol() != Symbol() || OrderMagicNumber() != MagicNumber) continue;
        
        double profit = OrderProfit() + OrderSwap() + OrderCommission();
        
        if(profit > 0) {
            totalWins += profit;
            winCount++;
        } else if(profit < 0) {
            totalLosses += MathAbs(profit);
            lossCount++;
        }
    }
    
    tpslSystem.averageWinSize = winCount > 0 ? totalWins / NonZero(winCount) : 0;
    tpslSystem.averageLossSize = lossCount > 0 ? totalLosses / NonZero(lossCount) : 0;
    
    if(tpslSystem.averageLossSize > 0) {
        tpslSystem.recentRR = tpslSystem.averageWinSize / NonZero(tpslSystem.averageLossSize);
    }
}

//| SMART: Adjust TP/SL from Consecutive Results (R-multiple aware)  |
void AdjustTPSLFromConsecutiveResults() {
    // BOOST TP on win streaks (unchanged - this works well)
    if(tpslSystem.consecutiveWins >= 3) {
        double boost = tpslSystem.consecutiveWins * CONSECUTIVE_WIN_TP_BOOST;
        boost = MathMin(boost, 1.0);
        tpslSystem.currentTPMultiplier = tpslSystem.baseTPMultiplier * (1.0 + boost);
        tpslSystem.expandTPMode = true;

        // -- CEO: ANTI-OVERCONFIDENCE SKEPTICISM ----------------------------─
        //   Evidence of real edge: high IC (score predicts outcomes) + proven signalWR
        //   Evidence of variance: low IC (score-outcome correlation near noise floor)
        if(tpslSystem.consecutiveWins >= 5) {
            int _curReg = g_RegimeState.currentRegime;
            bool _highIC = false;
            bool _provenWR = false;
            if(g_ICMeasured && _curReg >= 0 && _curReg < 9) {
                double _avgIC2 = 0.0;
                for(int _ci3=0;_ci3<6;_ci3++) _avgIC2 += MathAbs(g_RegimeIC[_curReg][_ci3]);
                _avgIC2 /= 6.0;
                _highIC = (_avgIC2 >= 0.025);  // above signal-quality threshold
            }
            if(g_CorrelationsLearned && _curReg >= 0 && _curReg < 9 &&
               g_RegimeCorrelations[_curReg].signalTotal >= 10) {
                _provenWR = (g_RegimeCorrelations[_curReg].signalWR >= 0.68);
            }
            // Skepticism applies when streak isn't backed by signal quality evidence
            if(!_highIC || !_provenWR) {
                // Dampen the TP expansion — streak may be favorable variance, not edge
                double _skepticismDamp = (tpslSystem.consecutiveWins >= 8) ? 0.60 : 0.75;
                tpslSystem.currentTPMultiplier = tpslSystem.baseTPMultiplier *
                    (1.0 + boost * _skepticismDamp);  // reduced expansion
                if(EnableFriendlyLogs && !g_CalibSilent) {
                    static datetime _lastSkLog = 0;
                    if(TimeCurrent() - _lastSkLog > 600) {
                        PrintFormat("  win skepticism   |   %d consec wins   |   IC %s   |   WR %s   |   TP expansion %.2fx (dampened)",
                                    tpslSystem.consecutiveWins,
                                    _highIC?"ok":"low", _provenWR?"proven":"unproven",
                                    tpslSystem.currentTPMultiplier);
                        _lastSkLog = TimeCurrent();
                    }
                }
            }
        }
    }
    
    // SMART: Tighten SL based on CUMULATIVE R-MULTIPLE, not just loss count
    // 3 small losses (-0.5R each) = -1.5R total = normal variance = NO ACTION
    // 3 big losses (-1.5R each) = -4.5R total = something wrong = TIGHTEN
    
    if(tpslSystem.consecutiveLosses >= 2) { // Changed from 3 to 2 (faster detection)
        // Calculate cumulative R-multiple for recent consecutive losses
        double cumulativeR = 0.0;
        int lossCount = 0;
        bool stillCounting = true;
        
        for(int i = OrdersHistoryTotal() - 1; i >= 0 && stillCounting && lossCount < 5; i--) {
            if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
            if(OrderSymbol() != Symbol() || OrderMagicNumber() != MagicNumber) continue;
            
            double profit = OrderProfit() + OrderSwap() + OrderCommission();

            if(profit < 0) {
                // Calculate R-multiple: (actual loss / initial risk)
                // Approximate initial risk as order lots x SL distance x pip value
                double lotSize = OrderLots();
                double slDistance = MathAbs(OrderOpenPrice() - OrderStopLoss());
                double pointValue = MarketInfo(Symbol(), MODE_TICKVALUE);
                double estimatedRisk = lotSize * (slDistance / NonZero(Point)) * pointValue;
                
                double rMultiple = 0.0;
                if(estimatedRisk > 0) {
                    rMultiple = MathAbs(profit) / estimatedRisk; // How many R we lost
                }
                else {
                    rMultiple = 1.0; // Default to 1R if we can't calculate
                }
                
                cumulativeR += rMultiple;
                lossCount++;
            }
            else if(profit > 0) {
                stillCounting = false; // Hit a win, stop counting
            }
        }
        
        // SMART ASSESSMENT: Only tighten if cumulative R-multiple is severe
        if(cumulativeR >= 3.0) {
            // Cumulative loss >= 3R: Something is wrong, tighten
            double tightenAmount = (cumulativeR - 2.0) * 0.15; // Progressive tightening
            tightenAmount = MathMin(tightenAmount, 0.4); // Cap at 40% tightening
            
            tpslSystem.currentSLMultiplier = tpslSystem.baseSLMultiplier * (1.0 - tightenAmount);
            tpslSystem.tightenSLMode = true;
            
            if(EnableFriendlyLogs) {
                PrintFormat("  stop tightened   |   %d losses   |   -%.2fR cumulative", lossCount, cumulativeR);
            }
        }
        else if(cumulativeR < 3.0 && lossCount >= 2) {
            // Small consecutive losses = normal variance, NO tightening
            if(EnableFriendlyLogs && lossCount >= 3) {
                PrintFormat("  %d losses   |   -%.2fR   |   normal variance", lossCount, cumulativeR);
            }
        }
    }
    
    // Reset when streak breaks
    if(tpslSystem.consecutiveWins <= 1 && tpslSystem.consecutiveLosses <= 1) {
        tpslSystem.currentTPMultiplier = tpslSystem.baseTPMultiplier;
        tpslSystem.currentSLMultiplier = tpslSystem.baseSLMultiplier;
        tpslSystem.tightenSLMode = false;
        tpslSystem.expandTPMode = false;
    }
    
    tpslSystem.currentTPMultiplier = MathMin(tpslSystem.currentTPMultiplier, DYNAMIC_TP_MAX);
    tpslSystem.currentTPMultiplier = MathMax(tpslSystem.currentTPMultiplier, 1.5);
    tpslSystem.currentSLMultiplier = MathMax(tpslSystem.currentSLMultiplier, 0.7);
    tpslSystem.currentSLMultiplier = MathMin(tpslSystem.currentSLMultiplier, 1.3);
}

//| NEW: Adjust TP/SL from Market Conditions                         |
void AdjustTPSLFromMarketConditions() {
    double atrNormalized = intelligence.atr /NonZero(iClose(Symbol(), 0, 0));
    double avgAtrNormalized = intelligence.atrAvg /NonZero(iClose(Symbol(), 0, 0));
    
    if(avgAtrNormalized > 0) {
        tpslSystem.volatilityAdjustment = atrNormalized / NonZero(avgAtrNormalized);
        
        if(tpslSystem.volatilityAdjustment > 1.3) {
            tpslSystem.currentTPMultiplier *= (1.0 + VOLATILITY_TP_ADJUSTMENT);
        }
        else if(tpslSystem.volatilityAdjustment < 0.7) {
            tpslSystem.currentSLMultiplier *= 0.9;
        }
    }
    
    double trendStrength = MathAbs(intelligence.mtfConsensus);
    tpslSystem.trendStrengthAdjustment = trendStrength;
    
    if ((double)trendStrength > 0.7) {
        tpslSystem.currentTPMultiplier *= 1.2;
    }
    
    double momentum = MathAbs(intelligence.priceVelocity);
    tpslSystem.momentumAdjustment = momentum;
    
    if(momentum > intelligence.atr * 0.5) {
        tpslSystem.currentTPMultiplier *= 1.15;
    }
    
    if(predictiveSystem.predictionsValid) {
        double confidence = predictiveSystem.predictionReliability;
        tpslSystem.confidenceAdjustment = confidence;
        
        if ((double)confidence > 0.75) {
            tpslSystem.currentSLMultiplier *= 0.95;
            tpslSystem.currentTPMultiplier *= 1.1;
        }
    }
}

//| NEW: Optimize TP/SL for Target Win Rate                          |
void OptimizeTPSLForWinRate() {
    if(tpslSystem.recentWinRate < OPTIMAL_WIN_RATE_TARGET - 0.1) {
        tpslSystem.currentTPMultiplier *= 0.95;
        tpslSystem.currentSLMultiplier *= 1.05;
    }
    else if(tpslSystem.recentWinRate > OPTIMAL_WIN_RATE_TARGET + 0.1) {
        tpslSystem.currentTPMultiplier *= 1.05;
        tpslSystem.currentSLMultiplier *= 0.95;
    }
    
    double impliedRR = tpslSystem.currentTPMultiplier / NonZero(tpslSystem.currentSLMultiplier);
    double requiredWinRate = 1.0 / (1.0 + impliedRR);
    
    if(tpslSystem.recentWinRate < requiredWinRate * 1.1) {
        double targetRR = (1.0 / NonZero(tpslSystem.recentWinRate)) - 1.0;
        targetRR = MathMax(targetRR, MIN_RISK_REWARD_RATIO);
        targetRR = MathMin(targetRR, MAX_RISK_REWARD_RATIO);
        
        tpslSystem.currentTPMultiplier = targetRR * tpslSystem.currentSLMultiplier;
    }
}

//| NEW: Calculate Optimal TP/SL Distances                           |
void CalculateOptimalTPSLDistances() {
    double atr = intelligence.atr;
    double slMultiplier = tpslSystem.currentSLMultiplier;
    
    if(tpslSystem.consecutiveLosses >= 3) {
        slMultiplier *= (1.0 - (tpslSystem.consecutiveLosses * 0.1));
    }
    
    slMultiplier = MathMax(MIN_SL_DISTANCE_ATR, MathMin(MAX_SL_DISTANCE_ATR, slMultiplier));
    
    tpslSystem.optimalSLDistance = atr * slMultiplier * SAFE_STOP_BUFFER;
    tpslSystem.optimalSLDistance = MathMax(tpslSystem.optimalSLDistance, 
                                           tpslSystem.minStopDistance * SAFE_STOP_BUFFER);
    
    tpslSystem.optimalTPDistance = tpslSystem.optimalSLDistance * tpslSystem.currentTPMultiplier;
    
    if(tpslSystem.averageLossSize > 0) {
        tpslSystem.riskRewardScore = tpslSystem.averageWinSize / NonZero(tpslSystem.averageLossSize);
    }
    
    double actualRR = tpslSystem.currentTPMultiplier / NonZero(tpslSystem.currentSLMultiplier);
    double expectedProfit = (tpslSystem.recentWinRate * actualRR) - (1.0 - tpslSystem.recentWinRate);
    tpslSystem.profitConsistencyScore = MathMax(0, MathMin(1.0, expectedProfit));
}

//| NEW: Update TP/SL Safety Modes                                   |
void UpdateTPSLSafetyModes() {
    if(tpslSystem.consecutiveLosses >= 5) {
        tpslSystem.tightenSLMode = true;
        tpslSystem.currentSLMultiplier = 0.7;
        tpslSystem.currentTPMultiplier = 1.5;
    }
    
    if(tpslSystem.consecutiveWins >= 5 && tpslSystem.recentWinRate > 0.65) {
        tpslSystem.expandTPMode = true;
        tpslSystem.currentTPMultiplier = MathMin(DYNAMIC_TP_MAX, tpslSystem.currentTPMultiplier * 1.3);
    }
    
    if((TimeCurrent() - tpslSystem.lastAdjustment) > 3600) {
        double profitFactor = CalculateProfitFactor();
        
        if((double)profitFactor < 1.2) {
            tpslSystem.currentTPMultiplier = DYNAMIC_TP_BASE * 0.9;
            tpslSystem.currentSLMultiplier = 1.0;
            tpslSystem.tightenSLMode = true;
        }
        
        tpslSystem.lastAdjustment = TimeCurrent();
    }
}

//| NEW: Calculate Smart TP/SL for Trade Execution                   |
bool CalculateSmartTPSL(bool isBuy, double entryPrice, double &stopLevel, double &targetLevel, double strength) {
    // Always recalculate from calibrated data when available.
    // DetermineOptimalTPSL() pre-fills tpslSystem from the static regimeStrategies table
    // (uncalibrated). When g_WeightsOptimized=true we override unconditionally with the
    // values Phase 3C actually measured for this regime and session.
    {
        double atr = intelligence.atr;
        int liveRegime = (g_LiveTradeEntryRegime >= 0 && g_LiveTradeEntryRegime < 9)
                         ? g_LiveTradeEntryRegime : DetectCurrentRegime();
        double slM = (g_WeightsOptimized && liveRegime >= 0 && liveRegime < 9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,liveRegime))] : 1.5;
        double tpM = (g_WeightsOptimized && liveRegime >= 0 && liveRegime < 9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,liveRegime))] : 2.5;
        // Session-specific TP/SL override (calibrated in Phase 3C.5)
        int _gmtHTsl = (TimeHour(TimeCurrent()) - g_ServerTimeOffsetHours + 24) % 24;
        int sesTsl = (_gmtHTsl>=7&&_gmtHTsl<16)?0:(_gmtHTsl>=16&&_gmtHTsl<21)?1:(_gmtHTsl>=21||_gmtHTsl<6)?3:2;
        if(g_WeightsOptimized && liveRegime >= 0 && liveRegime < 9
           && g_SessionSLMult[sesTsl][liveRegime] > 0.1) {
            slM = g_SessionSLMult[sesTsl][liveRegime];
            tpM = g_SessionTPMult[sesTsl][liveRegime];
        }
        double minDist = (tpslSystem.minStopDistance > 0) ? tpslSystem.minStopDistance * 1.5 : atr * 0.5;
        // -- UPGRADE 5: Transition-aware TP/SL pre-adjustment ----------------─
        // Uses empirical g_RegimeTransitions matrix built from live regime commits.
        // Only activates after ≥20 observed transitions from this regime (prevents noise).
        if(liveRegime >= 0 && liveRegime < 9) {
            int _totFrom = 0;
            for(int _tr = 0; _tr < 9; _tr++) _totFrom += g_RegimeTransitions[liveRegime][_tr];
            if(_totFrom >= 20) {
                // P(R6 volatile | current) — blow-off risk - tighten SL
                double _volRisk = (double)g_RegimeTransitions[liveRegime][6] / _totFrom;
                if(_volRisk > 0.20)
                    slM *= MathMax(0.75, 1.0 - _volRisk * 0.40);  // up to 25% tighter

                // P(R8 pullback | current) — controlled continuation - allow wider TP
                double _pbProb = (double)g_RegimeTransitions[liveRegime][8] / _totFrom;
                if(_pbProb > 0.30)
                    tpM = MathMin(tpM * 1.15, tpM + 0.50);  // up to 15% wider TP

                // P(R7 exhaustion | current) — momentum fading - tighten TP to capture sooner
                double _exhProb = (double)g_RegimeTransitions[liveRegime][7] / _totFrom;
                if(_exhProb > 0.25)
                    tpM *= MathMax(0.80, 1.0 - _exhProb * 0.50);  // exit earlier before exhaustion
            }
        }
        // Hurst-aware TP extension: trending regimes can sustain longer moves.
        // High Hurst (>0.60) = persistent - extend TP by up to 20%.
        // Low Hurst (<0.43) = mean-reverting - shorten TP by up to 20%.
        // Only fires with sufficient calibration data (5+ signals in regime).
        double _hrstMult = 1.0;
        if(g_CorrelationsLearned && liveRegime >= 0 && liveRegime < 9
           && g_RegimeCorrelations[liveRegime].signalTotal >= 5) {
            double _h = g_RegimeCorrelations[liveRegime].avgHurst;
            if(_h > 0.60)       _hrstMult = 1.0 + MathMin(0.20, (_h - 0.60) * 1.0);  // up to 1.20x
            else if(_h < 0.43 && _h > 0) _hrstMult = 1.0 - MathMin(0.20, (0.43 - _h) * 1.0);  // down to 0.80x
        }
        // Conviction-adjusted SL: strong signals get more room, weak signals less
        double _scoreMgn = (MathAbs(engine.unifiedScore) > 0 && engine.buyThreshold > 0) ?
            MathAbs(engine.unifiedScore) - (isBuy ? engine.buyThreshold : (100.0-engine.sellThreshold)) : 0;
        // Smooth SL gradient: conviction quality earns more room, marginal signals less
        // 0pt margin=0.85x · 10pt=1.02x · 20pt=1.17x · 25pt+=1.20x ceiling
        double _convMult = MathMax(0.85, MathMin(1.20, 0.85 + MathMax(0.0,_scoreMgn)*0.014));
        // R8: SL at pullback extreme (tightest defensible institutional SL)
        bool _r8SLSet = false;  // SLS21 FIX: tracks whether the R8 override below actually fired,
                                  // so the generic ATR-based assignment further down can't silently stomp it
        if(liveRegime == 8) {
            double _pbEx=entryPrice; bool _r8B=isBuy;
            for(int _pb=1;_pb<=8&&_pb<Bars;_pb++) {
                if(_r8B&&Low[_pb]<_pbEx) _pbEx=Low[_pb];
                else if(!_r8B&&High[_pb]>_pbEx) _pbEx=High[_pb];}
            double _r8SL=MathAbs(entryPrice-_pbEx)+intelligence.atr*0.30;
            if(_r8SL>0&&_r8SL<intelligence.atr*slM*1.1) {
                tpslSystem.optimalSLDistance=MathMax(_r8SL,intelligence.atr*0.5);
                _r8SLSet = true;
            }
        }
        // Wave phase TP: impulse start = more room, exhaustion = exit earlier
        double _waveMult = 1.0;
        if(!g_Calibration.isCalibrating) {
            MarketStateFeatures _wvF = CalculateMarketFeatures(0);
            if(_wvF.optimalEntryWindow)      _waveMult = 1.20;
            else if(_wvF.exhaustionWarning)  _waveMult = 0.80;
            else if(_wvF.wavePhase == 3)     _waveMult = 0.92;
        }
        // Smooth score-margin SL gradient: stronger conviction = tighter SL (better entry)
        double _smGradTP = MathMax(0.0, _scoreMgn);
        double _convMult2 = MathMax(0.85, MathMin(1.20, 0.85 + _smGradTP * 0.014));
        // SLS21 FIX: was unconditionally overwriting the R8 pullback-extreme SL set above
        if(!_r8SLSet) tpslSystem.optimalSLDistance = MathMax(atr * slM * _convMult2, minDist);
        tpslSystem.optimalTPDistance = MathMax(atr * tpM * _hrstMult * _waveMult, minDist);

        // -- Awareness-aware TP/SL adjustment ------------------------------
        // reversalRisk high - tighten TP (take profit before stall)
        // breakoutPotential high - widen TP (let the extension run)
        if(g_Awareness.isValid) {
            double _rvR = g_Awareness.reversalRisk;
            double _boP = g_Awareness.breakoutPotential;
            double _tpAdj = 1.0;
            if(_rvR >= 0.60) _tpAdj *= MathMax(0.80, 1.0 - (_rvR - 0.60) * 0.50);
            if(_boP >= 0.55) _tpAdj *= MathMin(1.30, 1.0 + (_boP - 0.55) * 0.60);
            if(_rvR >= 0.75 && !g_Awareness.signalLegitimate)
                tpslSystem.optimalSLDistance *= MathMax(0.85, 1.0-(_rvR-0.75)*0.40);
            tpslSystem.optimalTPDistance = MathMax(tpslSystem.optimalTPDistance * _tpAdj, minDist);
        }
        // PPS momentum sequence - further TP extension or tightening
        {
            MarketStateFeatures _tpf = CalculateMarketFeatures(0);
            if(_tpf.seqContinuationScore >= 0.60)
                tpslSystem.optimalTPDistance *= MathMin(1.15, 1.0+(_tpf.seqContinuationScore-0.60)*0.375);
            else if(_tpf.seqReversalScore >= 0.60)
                tpslSystem.optimalTPDistance *= MathMax(0.85, 1.0-(_tpf.seqReversalScore-0.60)*0.375);
        }
        // Calibrated time-exit horizon -- shortened for overextended (old) regimes
        if(g_WeightsOptimized && liveRegime >= 0 && liveRegime < 9) {
            int baseExit = g_RegimeOptimalExitBars[MathMin(8,MathMax(0,liveRegime))];
            // Regime age adjustment: old regime = less time left in trend
            if(g_RegimeAgeCalibrated) {
                int _barsInR = g_RegimeState.confirmedBars;
                if(_barsInR > 20) {
                    baseExit = MathMax(5, (int)(baseExit * 0.75));  // Trim 25% -- exit earlier
                    tpslSystem.optimalTPDistance *= 0.85;  // Tighter TP -- take profit before reversal
                }
            }
            tpslSystem.maxBarsToHold = baseExit;
        }
    }
    
    // [FIX-I] strengthAdjustment is now = strength (0..1), not (2.0 - strength).
    double strengthAdjustment = strength;
    // SL is calibrated to regime noise floor — constant regardless of signal strength
    // Signal strength belongs in lot sizing (Kelly), not SL distance
    // Wide SLs on weak signals compound loss; Kelly already reduces position size
    double slDistance = tpslSystem.optimalSLDistance;
    // TP widens slightly on stronger signals — more conviction - let it run
    double tpDistance = tpslSystem.optimalTPDistance * (1.0 + MathMax(0.0, strengthAdjustment - 0.5) * 0.4);
    
    double point = MarketInfo(Symbol(), MODE_POINT);
    double minDistance = tpslSystem.minStopLevel * point * MIN_STOP_LEVEL_MULTIPLIER;
    
    slDistance = MathMax(slDistance, minDistance);
    tpDistance = MathMax(tpDistance, minDistance);
    
    if(intelligence.atrVolatility > 1.5) {
        slDistance *= 1.2;
        tpDistance *= 1.3;
    }
    
    if(enhancedBias.directionalBiasValid && enhancedBias.biasConfidence > 0.7) {
        bool biasAligned = (isBuy && enhancedBias.bullishTimeframes > enhancedBias.bearishTimeframes) ||
                          (!isBuy && enhancedBias.bearishTimeframes > enhancedBias.bullishTimeframes);
        
        if(biasAligned) {
            tpDistance *= 1.2;
        }
    }
    
    // S/R-anchored TP: snap to nearest structural level when within 3 ATR
    // Natural S/R targets dramatically improve PF vs pure ATR multiples
    // Regime RR floor: never accept below minimum risk:reward
    // -- HARD PRESERVATION ENFORCEMENT ------------------------------------─
    // After ALL multipliers applied: TP must beat SL by the regime minimum.
    // SL can NEVER exceed TP — the fundamental preservation rule.
    { double _rrF = (g_RegimeState.currentRegime==0||g_RegimeState.currentRegime==1) ? 1.8 :
                    (g_RegimeState.currentRegime==8) ? 1.5 : 1.5;  // min 1.5 everywhere
      if(slDistance > 0 && tpDistance / slDistance < _rrF)
          tpDistance = slDistance * _rrF;
      // Absolute: SL can never match or exceed TP (you must always stand to gain more)
      if(slDistance >= tpDistance)
          slDistance = tpDistance * 0.60;  // SL capped at 60% of TP distance
    }
    if(isBuy) {
        stopLevel = entryPrice - slDistance;
        double _srTP = g_LiveKeyResistance;
        double _srDist = (_srTP > entryPrice) ? (_srTP - entryPrice) : 0;
        double _atrTPchk = (intelligence.atr > 0) ? intelligence.atr : slDistance;
        // Use S/R level as TP if it's between 1.5 and 3 ATR away (realistic target, not too near/far)
        // Minimum RR 1:1.2 required — SL must not be larger than 83% of the TP distance
        if(_srDist >= _atrTPchk * 1.5 && _srDist <= _atrTPchk * 3.5 &&
           _srDist >= slDistance * 1.2)
            targetLevel = _srTP - MarketInfo(Symbol(), MODE_POINT) * 5;  // 5pt buffer below resistance
        else
        // FVG TP: fair value gap within 2 ATR used as target
        { MarketStateFeatures _fvgF=CalculateMarketFeatures(0);
          double _fd=_fvgF.fvgDistancePips*MarketInfo(Symbol(),MODE_POINT);
          if(_fd>intelligence.atr*0.5&&_fd<intelligence.atr*2.5)
              targetLevel = isBuy?entryPrice+_fd:entryPrice-_fd;
          else
              targetLevel = entryPrice + tpDistance;
        }
    } else {
        stopLevel = entryPrice + slDistance;
        double _srTP = g_LiveKeySupport;
        double _srDist = (_srTP > 0 && _srTP < entryPrice) ? (entryPrice - _srTP) : 0;
        double _atrTPchk = (intelligence.atr > 0) ? intelligence.atr : slDistance;
        if(_srDist >= _atrTPchk * 1.5 && _srDist <= _atrTPchk * 3.5 &&
           _srDist >= slDistance * 1.2)
            targetLevel = _srTP + MarketInfo(Symbol(), MODE_POINT) * 5;  // 5pt buffer above support
        else
            targetLevel = entryPrice - tpDistance;
    }
    
    int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
    stopLevel = NormalizeDouble(stopLevel, digits);
    targetLevel = NormalizeDouble(targetLevel, digits);
    
    double actualSLDistance = MathAbs(entryPrice - stopLevel);
    double actualTPDistance = MathAbs(targetLevel - entryPrice);
    
    if(actualSLDistance < minDistance || actualTPDistance < minDistance) {
        if(isBuy) {
            stopLevel = entryPrice - minDistance;
            targetLevel = entryPrice + (minDistance * tpslSystem.currentTPMultiplier);
        } else {
            stopLevel = entryPrice + minDistance;
            targetLevel = entryPrice - (minDistance * tpslSystem.currentTPMultiplier);
        }
        
        stopLevel = NormalizeDouble(stopLevel, digits);
        targetLevel = NormalizeDouble(targetLevel, digits);
    }
    
    return true;
}

