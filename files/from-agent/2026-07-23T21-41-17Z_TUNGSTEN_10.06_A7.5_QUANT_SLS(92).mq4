struct ComprehensiveSignalRecord {
    // Basic info
    datetime timestamp;
    int direction;
    double score;
    double edgeValue;
    double entryPrice;
    double slPrice;
    double tpPrice;
    bool wasExecuted;
    string rejectReason;
    
    // Time context (Priority 1-2)
    int dayOfWeek;
    int hourOfDay;
    string session;
    
    // Spread context (Priority 3)
    double spreadPips;
    double spreadPercentile;
    
    // Volatility context (Priority 4-5)
    double atrValue;
    double atrPercentile;
    string volRegime;
    
    // Component scores (Priority 9)
    double momentum;
    double reversal;
    double volatility;
    double directional;
    double pattern;
    double predictive;
    int componentsAligned;
    
    // Intelligence metrics
    double adx;
    double volume;
    double rsi;
    
    // Price context (Priority 6-7)
    double distanceToSupport;
    double distanceToResistance;
    double distanceToRoundNumber;
    double priceInRange;
    
    // Multi-timeframe (Priority 8)
    int trendM15;
    int trendH1;
    int trendH4;
    int trendD1;
    int mtfAlignment;
    bool tradingAgainstHTF;
    
    // Regime context
    int regime;
    string candlePattern;
    
    // Edge breakdown
    double edgeAlignment;
    double edgePosition;
    double edgeMomentum;
    double edgeVolatility;
    double edgeConfirmation;
    
    // Risk metrics
    double riskReward;
    double stopPips;
    double targetPips;
    
    // Recent performance
    int recentWinStreak;
    double recent5TradeWinRate;
    
    // Outcome
    bool outcomeChecked;
    int outcome;
    double maxFavorableMove;
    double maxAdverseMove;
    int barsToOutcome;
    datetime outcomeTime;
};

struct TimePerformance {
    double winRateByDay[7];
    int tradesByDay[7];
    double winRateByHour[24];
    int tradesByHour[24];
    double minEdgeByDay[7];
    double minEdgeByHour[24];
    bool disabledDays[7];
    bool disabledHours[24];
    int goldenHours[5];
    int deathHours[5];
