// TUNGSTEN E9.5 - MULTI-SCALE PATTERN RECOGNITION & DYNAMIC RISK


// Swing point types
// enum SwingType moved to top

// Swing point structure
// struct SwingPoint moved to top of file

// Micro pattern (5-20 bars)
// struct MicroPattern moved to top of file

// Macro pattern (50-200 bars)
// struct MacroPattern moved to top of file

// Pattern sequence learning (micro - macro prediction)
struct PatternSequence {
    PatternType microSequence[5];  // Last 5 micro patterns
    int microCount;
    PatternType predictedMacro;    // What macro pattern this sequence predicts
    int timesObserved;
    int timesCorrect;
    double accuracy;
    double confidence;
};

// Pattern state tracker
struct PatternState {
    // Current patterns
    MicroPattern currentMicro;
    MacroPattern currentMacro;
    PatternType currentMicroPattern;  // Shortcut to currentMicro.type
    PatternType currentMacroPattern;  // Shortcut to currentMacro.type
    double microConfidence;           // Shortcut to currentMicro.confidence
    double macroConfidence;           // Shortcut to currentMacro.confidence
    
    // Recent micro history
    MicroPattern microHistory[20];
    int microHistoryCount;
    
    // Pattern sequence database
    PatternSequence sequences[100];
    int sequenceCount;
    
    // State flags
    bool microActive;
    bool macroActive;
    datetime lastBarTime;
    int consecutiveBars;
    
    // Pattern-based signals
    bool patternBuySignal;
    bool patternSellSignal;
    double patternConfidence;
    string patternReasoning;
};

// Dynamic risk configuration
struct DynamicRiskConfig {
    double baseRisk;           // Base risk percentage (1.0-2.0)
    double currentRisk;        // Calculated risk for next trade
    double maxRisk;            // Maximum allowed risk (7.5)
    
    // Risk multipliers
    double confidenceBonus;    // 0.0-2.0 based on pattern confidence
    double streakBonus;        // 0.0-1.5 based on win streak
    double alignmentBonus;     // 0.0-1.0 based on pattern alignment
    
    // Recent performance
    int recentWins;
    int recentLosses;
    int consecutiveWins;
    datetime lastRiskUpdate;
};

// Global pattern state
PatternState g_PatternState;
DynamicRiskConfig g_DynamicRisk;


// Detect swing high at bar index
bool IsSwingHigh(int bar, int leftBars = 5, int rightBars = 5) {
    if(bar - rightBars < 0 || bar + leftBars >= Bars) return false;  // bounds: not classifiable

    if(bar < rightBars || bar > Bars - leftBars - 1) return false;
    
    double centerHigh = High[bar];
    
    // Check left side
    for(int i = 1; i <= leftBars; i++) {
        if(High[bar + i] >= centerHigh) return false;
    }
    
    // Check right side
    for(int i = 1; i <= rightBars; i++) {
        if(High[bar - i] >= centerHigh) return false;
    }
    
    return true;
}

// Detect swing low at bar index
bool IsSwingLow(int bar, int leftBars = 5, int rightBars = 5) {
    if(bar - rightBars < 0 || bar + leftBars >= Bars) return false;  // bounds: not classifiable

    if(bar < rightBars || bar > Bars - leftBars - 1) return false;
    
    double centerLow = Low[bar];
    
    // Check left side
    for(int i = 1; i <= leftBars; i++) {
        if(Low[bar + i] <= centerLow) return false;
    }
    
    // Check right side
    for(int i = 1; i <= rightBars; i++) {
        if(Low[bar - i] <= centerLow) return false;
    }
    
    return true;
}

// Find most recent swing high
SwingPoint FindLastSwingHigh(int lookback = 50) {
    SwingPoint point;
    point.type = SWING_NONE;
    
    for(int bar = 5; bar < lookback; bar++) {
        if(IsSwingHigh(bar, 5, 5)) {
            point.barIndex = bar;
            point.price = High[bar];
            point.type = SWING_HIGH;
            point.time = Time[bar];
            point.confirmed = true;
            return point;
        }
    }
    
    return point;
}

// Find most recent swing low
SwingPoint FindLastSwingLow(int lookback = 50) {
    SwingPoint point;
    point.type = SWING_NONE;
    
    for(int bar = 5; bar < lookback; bar++) {
        if(IsSwingLow(bar, 5, 5)) {
            point.barIndex = bar;
            point.price = Low[bar];
            point.type = SWING_LOW;
            point.time = Time[bar];
            point.confirmed = true;
            return point;
        }
    }
    
    return point;
}

// MICRO PATTERN DETECTION (5-20 bars)

MicroPattern DetectMicroPattern() {
    return DetectMicroPatternAt(0);  // Live detection from current bar
}

// HISTORICAL BAR VERSION - For calibration
// Detects pattern at any historical bar using marker-aware logic
MicroPattern DetectMicroPatternAt(int startBar) {
    MicroPattern pattern;
    pattern.type = PATTERN_UNKNOWN;
    pattern.confidence = 0.0;
    pattern.active = false;
    pattern.pointCount = 0;
    
    if(Bars < startBar + 60) return pattern;
    if(g_FormationParamsCount == 0) InitializeFormationParameters();

    double atr = iATR(_Symbol, PERIOD_CURRENT, 14, startBar);
    
    // STEP 1: Collect swing points adaptively with NO FIXED LIMIT
    // Scan continues until formation completes OR times out
    SwingPoint swings[20];
    ZeroMemory(swings);
    int swingCount = 0;
    bool lookingForHigh = true;

    // Adaptive swing parameters based on market state
    int leftBars  = (atr < 0.0005) ? 3 : 5;
    int rightBars = leftBars;
    int scanStep  = (atr < 0.0005) ? 1 : 2;
    int maxScan   = 200;

    for(int bar = startBar + rightBars; bar < startBar + maxScan && swingCount < 20; bar += scanStep) {
        if(bar >= Bars) break;
        
        if(lookingForHigh && IsSwingHigh(bar, leftBars, rightBars)) {
            swings[swingCount].barIndex = bar;
            swings[swingCount].price    = High[bar];
            swings[swingCount].type     = SWING_HIGH;
            swings[swingCount].time     = Time[bar];
            swings[swingCount].confirmed = true;
            swingCount++;
            lookingForHigh = false;
        } else if(!lookingForHigh && IsSwingLow(bar, leftBars, rightBars)) {
            swings[swingCount].barIndex = bar;
            swings[swingCount].price    = Low[bar];
            swings[swingCount].type     = SWING_LOW;
            swings[swingCount].time     = Time[bar];
            swings[swingCount].confirmed = true;
            swingCount++;
            lookingForHigh = true;
        }
    }

    if(swingCount < 4) return pattern;

    int barSpan = swings[0].barIndex - swings[swingCount-1].barIndex;

    // STEP 2: Extract geometry arrays (chronological: oldest first)
    double highs[20], lows[20];
    int hCount = 0, lCount = 0;
    ArrayInitialize(highs, 0);
    ArrayInitialize(lows, 0);

    for(int i = swingCount-1; i >= 0; i--) {
        if(swings[i].type == SWING_HIGH && hCount < 20) highs[hCount++] = swings[i].price;
        if(swings[i].type == SWING_LOW  && lCount < 20) lows[lCount++]  = swings[i].price;
    }

    // Structural flags
    bool hhPattern = (hCount >= 2 && highs[hCount-1] > highs[0]);
    bool hlPattern = (lCount >= 2 && lows[lCount-1]  > lows[0]);
    bool llPattern = (lCount >= 2 && lows[lCount-1]  < lows[0]);
    bool lhPattern = (hCount >= 2 && highs[hCount-1] < highs[0]);

    double tolerance = atr * 0.6;
    bool twoHighsEqual = (hCount >= 2 && MathAbs(highs[hCount-1] - highs[0]) <= tolerance);
    bool twoLowsEqual  = (lCount >= 2 && MathAbs(lows[lCount-1]  - lows[0])  <= tolerance);

    // Flat boundary detection
    double highVar = 0, lowVar = 0;
    for(int i = 0; i < hCount; i++) highVar += MathAbs(highs[i] - highs[0]);
    for(int i = 0; i < lCount; i++) lowVar  += MathAbs(lows[i]  - lows[0]);
    highVar = (hCount > 1) ? highVar / hCount / MathMax(atr, 0.00001) : 99;
    lowVar  = (lCount > 1) ? lowVar  / lCount / MathMax(atr, 0.00001) : 99;
    bool flatRes = (highVar < 0.4);
    bool flatSup = (lowVar  < 0.4);

    // Convergence
    bool highsConv = (hCount >= 3 && highs[hCount-1] < highs[hCount-2]);
    bool lowsConv  = (lCount >= 3 && lows[lCount-1]  > lows[lCount-2]);

    double adx = iADX(_Symbol, PERIOD_CURRENT, 14, PRICE_CLOSE, MODE_MAIN, startBar);

    // STEP 3: Marker-aware pattern classification
    // Each formation tested against its natural span and structural DNA
    // Priority order: most specific patterns first, fallback last

    bool patternFound = false;  // Prevents pattern overwrites

    // ---- HEAD & SHOULDERS (30-120 bars, 6+ swings) ----
    if(!patternFound && barSpan >= 30 && barSpan <= 120 && swingCount >= 6) {
        if(lCount >= 3 && hCount >= 2) {
            bool headDeeper  = (lows[1] < lows[0] - atr*0.05 && lows[1] < lows[2] - atr*0.05);
            bool shoulders   = (MathAbs(lows[0] - lows[2]) < atr*0.8);
            bool neckFlat    = (MathAbs(highs[0] - highs[1]) < atr);
            int volIdx = swings[swingCount/2].barIndex;
            double volHead   = (volIdx < Bars) ? (double)iVolume(_Symbol, PERIOD_CURRENT, volIdx) : 0;
            double volRight  = (double)iVolume(_Symbol, PERIOD_CURRENT, swings[0].barIndex);
            bool volDecline  = (volRight < volHead * 1.2);
            
            if(headDeeper && shoulders && neckFlat) {
                pattern.type = PATTERN_INV_HEAD_SHOULDERS;
                pattern.confidence = volDecline ? 0.87 : 0.82;
                patternFound = true;
            }
        }
        if(!patternFound && hCount >= 3 && lCount >= 2) {
            bool headHigher = (highs[1] > highs[0] + atr*0.05 && highs[1] > highs[2] + atr*0.05);
            bool shoulders  = (MathAbs(highs[0] - highs[2]) < atr*0.8);
            bool neckFlat   = (MathAbs(lows[0] - lows[1]) < atr);
            int volIdx = swings[swingCount/2].barIndex;
            double volHead  = (volIdx < Bars) ? (double)iVolume(_Symbol, PERIOD_CURRENT, volIdx) : 0;
            double volRight = (double)iVolume(_Symbol, PERIOD_CURRENT, swings[0].barIndex);
            bool volDecline = (volRight < volHead * 1.2);
            
            if(headHigher && shoulders && neckFlat) {
                pattern.type = PATTERN_HEAD_SHOULDERS;
                pattern.confidence = volDecline ? 0.87 : 0.82;
                patternFound = true;
            }
        }
    }

    // ---- DOUBLE BOTTOM/TOP (15-60 bars, volume confirmation) ----
    if(!patternFound && barSpan >= 15 && barSpan <= 60 && swingCount >= 4) {
        if(twoLowsEqual && hCount >= 1) {
            double rallyHeight = (hCount >= 1) ? highs[0] - MathMin(lows[0], lows[lCount-1]) : 0;
            double totalRange  = highs[0] - lows[0];
            bool rallySignificant = (totalRange > 0 && rallyHeight > totalRange * 0.3);
            
            int vol1Idx = swings[swingCount-1].barIndex;
            int vol2Idx = swings[0].barIndex;
            double vol1 = (vol1Idx < Bars) ? (double)iVolume(_Symbol, PERIOD_CURRENT, vol1Idx) : 0;
            double vol2 = (vol2Idx < Bars) ? (double)iVolume(_Symbol, PERIOD_CURRENT, vol2Idx) : 0;
            bool volExhaustion = (vol2 < vol1 * 1.1);
            
            if(rallySignificant) {
                pattern.type = PATTERN_DOUBLE_BOTTOM;
                pattern.confidence = volExhaustion ? 0.85 : 0.78;
                patternFound = true;
            }
        }
        if(!patternFound && twoHighsEqual && lCount >= 1) {
            double declineDepth = highs[0] - MathMax(lows[0], lows[lCount-1]);
            double totalRange   = highs[0] - lows[0];
            bool declineSignificant = (totalRange > 0 && declineDepth > totalRange * 0.3);
            
            int vol1Idx = swings[swingCount-1].barIndex;
            int vol2Idx = swings[0].barIndex;
            double vol1 = (vol1Idx < Bars) ? (double)iVolume(_Symbol, PERIOD_CURRENT, vol1Idx) : 0;
            double vol2 = (vol2Idx < Bars) ? (double)iVolume(_Symbol, PERIOD_CURRENT, vol2Idx) : 0;
            bool volExhaustion = (vol2 < vol1 * 1.1);
            
            if(declineSignificant) {
                pattern.type = PATTERN_DOUBLE_TOP;
                pattern.confidence = volExhaustion ? 0.85 : 0.78;
                patternFound = true;
            }
        }
    }

    // ---- TRIANGLES (10-50 bars, boundary tests) ----
    if(!patternFound && barSpan >= 10 && barSpan <= 50 && swingCount >= 6) {
        int resTests = 0;
        for(int i = 0; i < hCount; i++) {
            if(MathAbs(highs[i] - highs[0]) < atr * 0.3) resTests++;
        }
        int supTests = 0;
        for(int i = 0; i < lCount; i++) {
            if(MathAbs(lows[i] - lows[0]) < atr * 0.3) supTests++;
        }
        
        if(flatRes && hlPattern && resTests >= 3) {
            pattern.type = PATTERN_ASCENDING_TRIANGLE;
            pattern.confidence = 0.80;
            patternFound = true;
        }
        if(flatSup && lhPattern && supTests >= 3) {
            pattern.type = PATTERN_DESCENDING_TRIANGLE;
            pattern.confidence = 0.80;
            patternFound = true;
        }
    }

    // ---- PENNANTS (5-15 bars, convergence) ----
    if(!patternFound && barSpan >= 5 && barSpan <= 15 && swingCount >= 5 && highsConv && lowsConv) {
        double rangeFirst = highs[0] - lows[0];
        double rangeLast  = highs[hCount-1] - lows[lCount-1];
        bool converging   = (rangeFirst > 0 && rangeLast < rangeFirst * 0.5);
        
        if(converging) {
            int biasBar = startBar + MathMin(50, Bars - startBar - 1);
            double bias50 = iClose(_Symbol, PERIOD_CURRENT, startBar) - 
                           iClose(_Symbol, PERIOD_CURRENT, biasBar);
            pattern.type = (bias50 > 0) ? PATTERN_BULLISH_PENNANT : PATTERN_BEARISH_PENNANT;
            pattern.confidence = 0.76;
            patternFound = true;
        }
    }

    // ---- FLAGS (5-21 bars, channel containment) ----
    if(!patternFound && barSpan >= 5 && barSpan <= 21 && swingCount >= 4) {
        if(hhPattern && hlPattern && swings[0].type == SWING_LOW) {
            double impulse  = (hCount >= 2) ? highs[hCount-1] - lows[lCount > 1 ? lCount-2 : 0] : 1;
            double pullback = (hCount >= 1 && lCount >= 1) ? highs[hCount-1] - lows[lCount-1] : 0;
            bool contained  = (impulse > 0 && pullback < impulse * 0.65);
            
            // Volume during flag
            int flagStart = swings[swingCount-1].barIndex;
            double volImpulse = 0, volFlag = 0;
            int impCount = 0, flagCount = 0;
            for(int b = flagStart-5; b < flagStart && b < Bars; b++) {
                volImpulse += (double)iVolume(_Symbol, PERIOD_CURRENT, b);
                impCount++;
            }
            for(int b = swings[0].barIndex; b < flagStart && b < Bars; b++) {
                volFlag += (double)iVolume(_Symbol, PERIOD_CURRENT, b);
                flagCount++;
            }
            volImpulse = (impCount > 0) ? volImpulse / impCount : 1;
            volFlag = (flagCount > 0) ? volFlag / flagCount : 1;
            bool volDecline = (volFlag < volImpulse * 0.9);
            
            pattern.type = contained ? PATTERN_BULL_FLAG : PATTERN_MOMENTUM_CONTINUATION;
            pattern.confidence = (contained && volDecline) ? 0.82 : 0.74;
            patternFound = true;
        }
        if(llPattern && lhPattern && swings[0].type == SWING_HIGH) {
            double impulse  = (lCount >= 2) ? lows[0] - highs[hCount > 1 ? hCount-2 : 0] : -1;
            double bounce   = (lCount >= 1 && hCount >= 1) ? highs[hCount-1] - lows[lCount-1] : 0;
            bool contained  = (impulse < 0 && bounce < MathAbs(impulse) * 0.65);
            
            pattern.type = PATTERN_BEAR_FLAG;
            pattern.confidence = contained ? 0.82 : 0.74;
            patternFound = true;
        }
    }

    // ---- CHoCH (20+ bars prior structure) ----
    if(!patternFound && barSpan >= 20) {
        if(hhPattern && lhPattern && !hlPattern) {
            pattern.type = PATTERN_BULLISH_CHOCH;
            pattern.confidence = 0.78;
            patternFound = true;
        }
        if(llPattern && hlPattern && !lhPattern) {
            pattern.type = PATTERN_BEARISH_CHOCH;
            pattern.confidence = 0.78;
            patternFound = true;
        }
    }

    // ---- RANGE PATTERNS (10+ bars, flat boundaries) ----
    if(!patternFound && barSpan >= 10 && flatRes && flatSup && swingCount >= 6) {
        double width = (hCount >= 1 && lCount >= 1) ? highs[hCount-1] - lows[lCount-1] : 0;
        bool tradeable = (width > atr * 1.5);
        pattern.type = tradeable ? PATTERN_WIDE_SR_RESPECT : PATTERN_CONSOLIDATION;
        pattern.confidence = 0.72;
        patternFound = true;
    }

    // ---- BASIC STRUCTURAL (fallback) ----
    if(!patternFound) {
        if(hhPattern && hlPattern) {
            pattern.type = PATTERN_HH;
            pattern.confidence = 0.65;
        } else if(llPattern && lhPattern) {
            pattern.type = PATTERN_LL;
            pattern.confidence = 0.65;
        } else {
            pattern.type = PATTERN_CONSOLIDATION;
            pattern.confidence = 0.55;
        }
    }

    for(int i = 0; i < swingCount && i < 5; i++)
        pattern.points[i] = swings[i];
    pattern.pointCount = MathMin(swingCount, 5);
    pattern.startBar   = swings[swingCount-1].barIndex;
    pattern.endBar     = swings[0].barIndex;
    pattern.detectedAt = TimeCurrent();
    pattern.active     = true;

    return pattern;
}
MacroPattern DetectMacroPattern() {
    MacroPattern pattern;
    pattern.type       = PATTERN_UNKNOWN;
    pattern.confidence = 0.0;
    pattern.active     = false;
    pattern.pointCount = 0;
    pattern.microCount = 0;

    if(Bars < 200) return pattern;
    if(g_FormationParamsCount == 0) InitializeFormationParameters();

    double atr = iATR(_Symbol, PERIOD_CURRENT, 14, 0);

    // STEP 1: Collect macro swing points (longer timeframe)
    // Macro uses wider swing detection and longer scan (up to 500 bars)
    SwingPoint swings[20];
    ZeroMemory(swings);
    int swingCount   = 0;
    bool lookingForHigh = true;

    int leftBars  = 20;   // Wider swings for macro
    int rightBars = 20;
    int scanStep  = 8;    // Coarser step for efficiency

    for(int bar = rightBars; bar < 500 && swingCount < 20; bar += scanStep) {
        if(lookingForHigh && IsSwingHigh(bar, leftBars, rightBars)) {
            swings[swingCount].barIndex  = bar;
            swings[swingCount].price     = High[bar];
            swings[swingCount].type      = SWING_HIGH;
            swings[swingCount].time      = Time[bar];
            swings[swingCount].confirmed = true;
            swingCount++;
            lookingForHigh = false;
        } else if(!lookingForHigh && IsSwingLow(bar, leftBars, rightBars)) {
            swings[swingCount].barIndex  = bar;
            swings[swingCount].price     = Low[bar];
            swings[swingCount].type      = SWING_LOW;
            swings[swingCount].time      = Time[bar];
            swings[swingCount].confirmed = true;
            swingCount++;
            lookingForHigh = true;
        }
    }

    if(swingCount < 3) return pattern;

    int barSpan = swings[0].barIndex - swings[swingCount-1].barIndex;

    // STEP 2: Extract geometry (chronological)
    double highs[20], lows[20];
    int hCount = 0, lCount = 0;
    ArrayInitialize(highs, 0);
    ArrayInitialize(lows,  0);

    for(int i = swingCount-1; i >= 0; i--) {
        if(swings[i].type == SWING_HIGH && hCount < 20) highs[hCount++] = swings[i].price;
        if(swings[i].type == SWING_LOW  && lCount < 20) lows[lCount++]  = swings[i].price;
    }

    bool hhPattern = (hCount >= 2 && highs[hCount-1] > highs[0]);
    bool hlPattern = (lCount >= 2 && lows[lCount-1]  > lows[0]);
    bool llPattern = (lCount >= 2 && lows[lCount-1]  < lows[0]);
    bool lhPattern = (hCount >= 2 && highs[hCount-1] < highs[0]);

    double tolerance = atr * 1.2;  // Wider tolerance for macro
    bool twoHighsEqual = (hCount >= 2 && MathAbs(highs[hCount-1] - highs[0]) <= tolerance);
    bool twoLowsEqual  = (lCount >= 2 && MathAbs(lows[lCount-1]  - lows[0])  <= tolerance);

    double highVar = 0, lowVar = 0;
    for(int i = 0; i < hCount; i++) highVar += MathAbs(highs[i] - highs[0]);
    for(int i = 0; i < lCount; i++) lowVar  += MathAbs(lows[i]  - lows[0]);
    highVar = (hCount > 1) ? highVar / hCount / MathMax(atr, 0.00001) : 99;
    lowVar  = (lCount > 1) ? lowVar  / lCount / MathMax(atr, 0.00001) : 99;
    bool flatRes = (highVar < 0.8);
    bool flatSup = (lowVar  < 0.8);

    bool highsConv = (hCount >= 3 && highs[hCount-1] < highs[hCount-2]);
    bool lowsConv  = (lCount >= 3 && lows[lCount-1]  > lows[lCount-2]);

    double adx = iADX(_Symbol, PERIOD_CURRENT, 14, PRICE_CLOSE, MODE_MAIN, 0);

    // STEP 3: MACRO MARKER-AWARE CLASSIFICATION
    // Same patterns as micro but with macro span thresholds

    bool patternFound = false;  // Prevents pattern overwrites

    // ---- H&S / INV H&S (60-150 bars macro) ----
    // SLS23 FIX: none of the blocks below actually checked !patternFound (unlike the sibling
    // DetectMicroPattern(), which does), and the terminal fallback had no guard at all -- so this
    // function could structurally never return anything but the 3 fallback types. All the
    // pattern-specific detection work below (H&S, Double Top/Bottom, Triangles, Pennants, Flags,
    // CHoCH, Range, Cup&Handle, Parabolic Stall) was computed and silently discarded every call.
    if(!patternFound && barSpan >= 60 && barSpan <= 150 && swingCount >= 6) {
        if(lCount >= 3 && hCount >= 2) {
            bool headDeeper = (lows[1] < lows[0] - atr*0.08 && lows[1] < lows[2] - atr*0.08);
            bool shouldersSym = (MathAbs(lows[0] - lows[2]) < atr*1.5);
            bool neckFlat = (MathAbs(highs[0] - highs[1]) < atr*1.5);
            if(headDeeper && shouldersSym && neckFlat) {
                pattern.type = PATTERN_INV_HEAD_SHOULDERS;
                pattern.confidence = 0.88;
                patternFound = true;
            }
        }
        if(hCount >= 3 && lCount >= 2) {
            bool headHigher = (highs[1] > highs[0] + atr*0.08 && highs[1] > highs[2] + atr*0.08);
            bool shouldersSym = (MathAbs(highs[0] - highs[2]) < atr*1.5);
            bool neckFlat = (MathAbs(lows[0] - lows[1]) < atr*1.5);
            if(headHigher && shouldersSym && neckFlat) {
                pattern.type = PATTERN_HEAD_SHOULDERS;
                pattern.confidence = 0.88;
                patternFound = true;
            }
        }
    }

    // ---- DOUBLE BOTTOM / TOP (30-120 bars macro) ----
    if(!patternFound && barSpan >= 30 && barSpan <= 120 && swingCount >= 4) {
        if(twoLowsEqual && hCount >= 1) {
            pattern.type = PATTERN_DOUBLE_BOTTOM;
            pattern.confidence = 0.86;
            patternFound = true;
        }
        if(twoHighsEqual && lCount >= 1) {
            pattern.type = PATTERN_DOUBLE_TOP;
            pattern.confidence = 0.86;
            patternFound = true;
        }
    }

    // ---- TRIANGLES (20-100 bars macro) ----
    if(!patternFound && barSpan >= 20 && barSpan <= 100 && swingCount >= 6) {
        if(flatRes && hlPattern && hCount >= 3) {
            pattern.type = PATTERN_ASCENDING_TRIANGLE;
            pattern.confidence = 0.82;
            patternFound = true;
        }
        if(flatSup && lhPattern && lCount >= 3) {
            pattern.type = PATTERN_DESCENDING_TRIANGLE;
            pattern.confidence = 0.82;
            patternFound = true;
        }
    }

    // ---- PENNANTS (10-30 bars macro) ----
    if(!patternFound && barSpan >= 10 && barSpan <= 30 && swingCount >= 5 && highsConv && lowsConv) {
        double bias100 = iClose(_Symbol, PERIOD_CURRENT, 0) - iClose(_Symbol, PERIOD_CURRENT, MathMin(100, MathMax(0, Bars - 1)));
        pattern.type = (bias100 > 0) ? PATTERN_BULLISH_PENNANT : PATTERN_BEARISH_PENNANT;
        pattern.confidence = 0.78;
        patternFound = true;
    }

    // ---- FLAGS (10-40 bars macro) ----
    if(!patternFound && barSpan >= 10 && barSpan <= 40 && swingCount >= 4) {
        if(hhPattern && hlPattern && swings[0].type == SWING_LOW) {
            pattern.type = PATTERN_BULL_FLAG;
            pattern.confidence = 0.84;
            patternFound = true;
        }
        if(llPattern && lhPattern && swings[0].type == SWING_HIGH) {
            pattern.type = PATTERN_BEAR_FLAG;
            pattern.confidence = 0.84;
            patternFound = true;
        }
    }

    // ---- CHoCH (40+ bars macro context) ----
    if(!patternFound && barSpan >= 40) {
        if(hhPattern && lhPattern && !hlPattern) {
            pattern.type = PATTERN_BULLISH_CHOCH;
            pattern.confidence = 0.80;
            patternFound = true;
        }
        if(llPattern && hlPattern && !lhPattern) {
            pattern.type = PATTERN_BEARISH_CHOCH;
            pattern.confidence = 0.80;
            patternFound = true;
        }
    }

    // ---- RANGE PATTERNS (20-150 bars macro) ----
    if(!patternFound && barSpan >= 20 && flatRes && flatSup && swingCount >= 6) {
        double width = (hCount >= 1 && lCount >= 1) ? highs[hCount-1] - lows[lCount-1] : 0;
        bool wide = (width > atr * 8);  // Wide macro range (like IBM example)
        pattern.type = wide ? PATTERN_WIDE_SR_RESPECT : PATTERN_CONSOLIDATION;
        pattern.confidence = 0.80;
        patternFound = true;
    }

    // ---- CUP AND HANDLE (60+ bars macro) ----
    if(!patternFound && barSpan >= 60 && lCount >= 5 && flatSup) {
        bool rounded = (lCount >= 5 && lows[2] < lows[1] && lows[2] < lows[3]);
        if(rounded && hhPattern) {
            pattern.type = PATTERN_CUP_AND_HANDLE;
            pattern.confidence = 0.75;
            patternFound = true;
        }
    }

    // ---- PARABOLIC STALL (macro exhaustion) ----
    if(!patternFound && swingCount >= 6 && adx > 35) {
        double amp0 = MathAbs(swings[0].price - swings[1].price);
        double amp2 = MathAbs(swings[2].price - swings[3].price);
        double amp4 = MathAbs(swings[4].price - swings[5].price);
        if(amp0 < amp2 * 0.7 && amp2 < amp4 * 0.7) {
            pattern.type = PATTERN_PARABOLIC_STALL;
            pattern.confidence = 0.82;
            patternFound = true;
        }
    }

    // ---- FALLBACK ----
    if(!patternFound) {
        if(hhPattern && hlPattern) {
            pattern.type = PATTERN_HH;
            pattern.confidence = 0.68;
        } else if(llPattern && lhPattern) {
            pattern.type = PATTERN_LL;
            pattern.confidence = 0.68;
        } else {
            pattern.type = PATTERN_CONSOLIDATION;
            pattern.confidence = 0.58;
        }
    }

    for(int i = 0; i < swingCount && i < 10; i++)
        pattern.points[i] = swings[i];
    pattern.pointCount = MathMin(swingCount, 10);
    pattern.startBar   = swings[swingCount-1].barIndex;
    pattern.endBar     = swings[0].barIndex;
    pattern.detectedAt = TimeCurrent();
    pattern.active     = true;

    // Attach micro patterns that contributed
    for(int i = 0; i < g_PatternState.microHistoryCount && pattern.microCount < 10; i++) {
        pattern.microSequence[pattern.microCount] = g_PatternState.microHistory[i];
        pattern.microCount++;
    }

    return pattern;
}


// Learn which micro pattern sequences predict macro patterns
void LearnPatternSequence(const PatternType &microSequence[], int microCount, PatternType actualMacro) {
    if(microCount < 2) return;  // Need at least 2 micro patterns
    
    // Look for existing sequence
    int matchIdx = -1;
    for(int i = 0; i < g_PatternState.sequenceCount; i++) {
        PatternSequence seq = g_PatternState.sequences[i];
        
        // Check if sequence matches
        if(seq.microCount == microCount) {
            bool matches = true;
            for(int j = 0; j < microCount; j++) {
                if(seq.microSequence[j] != microSequence[j]) {
                    matches = false;
                    break;
                }
            }
            
            if(matches) {
                matchIdx = i;
                break;
            }
        }
    }
    
    if(matchIdx >= 0) {
        // Update existing sequence
        g_PatternState.sequences[matchIdx].timesObserved++;
        
        if(g_PatternState.sequences[matchIdx].predictedMacro == actualMacro) {
            g_PatternState.sequences[matchIdx].timesCorrect++;
        }
        
        // Recalculate accuracy
        g_PatternState.sequences[matchIdx].accuracy = 
            (double)g_PatternState.sequences[matchIdx].timesCorrect / 
            g_PatternState.sequences[matchIdx].timesObserved;
        
        // Update confidence based on sample size
        int observed = g_PatternState.sequences[matchIdx].timesObserved;
        if(observed >= 20) {
            g_PatternState.sequences[matchIdx].confidence = 0.90;
        } else if(observed >= 10) {
            g_PatternState.sequences[matchIdx].confidence = 0.75;
        } else if(observed >= 5) {
            g_PatternState.sequences[matchIdx].confidence = 0.60;
        } else {
            g_PatternState.sequences[matchIdx].confidence = 0.40;
        }
        
    } else if(g_PatternState.sequenceCount < 100) {
        // Create new sequence
        PatternSequence newSeq;
        for(int i = 0; i < microCount; i++) {
            newSeq.microSequence[i] = microSequence[i];
        }
        newSeq.microCount = microCount;
        newSeq.predictedMacro = actualMacro;
        newSeq.timesObserved = 1;
        newSeq.timesCorrect = 1;
        newSeq.accuracy = 1.0;
        newSeq.confidence = 0.40;  // Low confidence initially
        
        g_PatternState.sequences[g_PatternState.sequenceCount] = newSeq;
        g_PatternState.sequenceCount++;
    }
}

// Query pattern sequence database for prediction
PatternType PredictMacroFromMicroSequence(const PatternType &microSequence[], int microCount, 
                                          double &confidence) {
    confidence = 0.0;
    
    if(microCount < 2) return PATTERN_UNKNOWN;
    
    // Find best matching sequence
    int bestMatch = -1;
    double bestConfidence = 0.0;
    
    for(int i = 0; i < g_PatternState.sequenceCount; i++) {
        PatternSequence seq = g_PatternState.sequences[i];
        
        // Check if sequence matches recent micro patterns
        if(seq.microCount == microCount) {
            bool matches = true;
            for(int j = 0; j < microCount; j++) {
                if(seq.microSequence[j] != microSequence[j]) {
                    matches = false;
                    break;
                }
            }
            
            if(matches && seq.confidence > bestConfidence && seq.accuracy > 0.60) {
                bestMatch = i;
                bestConfidence = seq.confidence;
            }
        }
    }
    
    if(bestMatch >= 0) {
        confidence = bestConfidence * g_PatternState.sequences[bestMatch].accuracy;
        return g_PatternState.sequences[bestMatch].predictedMacro;
    }
    
    return PATTERN_UNKNOWN;
}

// PATTERN STATE UPDATE (Called on every bar close)

void UpdatePatternState() {
    // Check if new bar formed
    if(Time[0] == g_PatternState.lastBarTime) return;
    
    datetime prevBarTime = g_PatternState.lastBarTime;
    g_PatternState.lastBarTime = Time[0];
    g_PatternState.consecutiveBars++;
    
    // Detect current micro pattern
    MicroPattern newMicro = DetectMicroPattern();
    
    // Check if micro pattern changed
    bool microChanged = false;
    if(newMicro.active) {
        if(!g_PatternState.microActive || 
           g_PatternState.currentMicro.type != newMicro.type) {
            microChanged = true;
            
            // Store previous micro in history
            if(g_PatternState.microActive) {
                // Shift history
                for(int i = 19; i > 0; i--) {
                    g_PatternState.microHistory[i] = g_PatternState.microHistory[i-1];
                }
                g_PatternState.microHistory[0] = g_PatternState.currentMicro;
                if(g_PatternState.microHistoryCount < 20) g_PatternState.microHistoryCount++;
            }
            
            // Update current
            g_PatternState.currentMicro = newMicro;
            g_PatternState.microActive = true;
            
            // LOG EVENT: Micro pattern change
            string microName = "";
            if(newMicro.type == PATTERN_HH) microName = "HH";
            else if(newMicro.type == PATTERN_HL) microName = "HL";
            else if(newMicro.type == PATTERN_LH) microName = "LH";
            else if(newMicro.type == PATTERN_LL) microName = "LL";
            else if(newMicro.type == PATTERN_CONSOLIDATION) microName = "CONSOL";
            
            PrintFormat("  micro pattern   |   %s", microName);
        }
    }
    
    // Detect macro pattern every 10 bars
    if(g_PatternState.consecutiveBars % 10 == 0) {
        MacroPattern newMacro = DetectMacroPattern();
        
        if(newMacro.active) {
            bool macroChanged = false;
            if(!g_PatternState.macroActive || 
               g_PatternState.currentMacro.type != newMacro.type) {
                macroChanged = true;
                
                // Learn sequence if we have enough micro history
                if(g_PatternState.microHistoryCount >= 3) {
                    PatternType microSeq[5];
                    int seqCount = MathMin(5, g_PatternState.microHistoryCount);
                    for(int i = 0; i < seqCount; i++) {
                        microSeq[i] = g_PatternState.microHistory[i].type;
                    }
                    LearnPatternSequence(microSeq, seqCount, newMacro.type);
                }
                
                g_PatternState.currentMacro = newMacro;
                g_PatternState.macroActive = true;
                
                // LOG EVENT: Macro pattern change
                string macroName = "";
                if(newMacro.type == PATTERN_HH) macroName = "UPTREND";
                else if(newMacro.type == PATTERN_LL) macroName = "DOWNTREND";
                else if(newMacro.type == PATTERN_CONSOLIDATION) macroName = "RANGE";
                
                PrintFormat("  macro pattern   |   %s", macroName);
            }
        }
    }
    
    // Generate pattern-based signals
    GeneratePatternSignals();
}

// PATTERN-BASED TRADING SIGNALS

void GeneratePatternSignals() {
    g_PatternState.patternBuySignal = false;
    g_PatternState.patternSellSignal = false;
    g_PatternState.patternConfidence = 0.0;
    g_PatternState.patternReasoning = "";
    
    // Need both micro and macro patterns active
    if(!g_PatternState.microActive || !g_PatternState.macroActive) return;
    
    MicroPattern micro = g_PatternState.currentMicro;
    MacroPattern macro = g_PatternState.currentMacro;
    
    // Predict macro from recent micro sequence
    PatternType microSeq[5];
    int seqCount = MathMin(5, g_PatternState.microHistoryCount);
    for(int i = 0; i < seqCount; i++) {
        microSeq[i] = g_PatternState.microHistory[i].type;
    }
    double predictionConf = 0.0;
    PatternType predictedMacro = PredictMacroFromMicroSequence(microSeq, seqCount, predictionConf);
    
    // 1. Macro uptrend + Micro HH/HL
    if(macro.type == PATTERN_HH && (micro.type == PATTERN_HH || micro.type == PATTERN_HL)) {
        g_PatternState.patternBuySignal = true;
        g_PatternState.patternConfidence = (macro.confidence + micro.confidence) / 2.0;
        g_PatternState.patternReasoning = "Uptrend + Higher highs forming";
    }
    // 2. Predicted macro uptrend with high confidence
    else if(predictedMacro == PATTERN_HH && predictionConf > 0.70) {
        g_PatternState.patternBuySignal = true;
        g_PatternState.patternConfidence = predictionConf;
        g_PatternState.patternReasoning = "Learned sequence predicts uptrend";
    }
    // 3. Consolidation breakout up (micro HH in range)
    else if(macro.type == PATTERN_CONSOLIDATION && micro.type == PATTERN_HH) {
        g_PatternState.patternBuySignal = true;
        g_PatternState.patternConfidence = 0.70;
        g_PatternState.patternReasoning = "Range breakout bullish";
    }
    
    // 1. Macro downtrend + Micro LL/LH
    if(macro.type == PATTERN_LL && (micro.type == PATTERN_LL || micro.type == PATTERN_LH)) {
        g_PatternState.patternSellSignal = true;
        g_PatternState.patternConfidence = (macro.confidence + micro.confidence) / 2.0;
        g_PatternState.patternReasoning = "Downtrend + Lower lows forming";
    }
    // 2. Predicted macro downtrend with high confidence
    else if(predictedMacro == PATTERN_LL && predictionConf > 0.70) {
        g_PatternState.patternSellSignal = true;
        g_PatternState.patternConfidence = predictionConf;
        g_PatternState.patternReasoning = "Learned sequence predicts downtrend";
    }
    // 3. Consolidation breakout down (micro LL in range)
    else if(macro.type == PATTERN_CONSOLIDATION && micro.type == PATTERN_LL) {
        g_PatternState.patternSellSignal = true;
        g_PatternState.patternConfidence = 0.70;
        g_PatternState.patternReasoning = "Range breakout bearish";
    }
}


void InitializeDynamicRisk() {
    g_DynamicRisk.baseRisk = RiskPercentPerTrade;  // User's input
    g_DynamicRisk.currentRisk = g_DynamicRisk.baseRisk;
    g_DynamicRisk.maxRisk = 15.0; // Removed hard cap — CEO competence governs
    
    g_DynamicRisk.confidenceBonus = 0.0;
    g_DynamicRisk.streakBonus = 0.0;
    g_DynamicRisk.alignmentBonus = 0.0;
    
    g_DynamicRisk.recentWins = 0;
    g_DynamicRisk.recentLosses = 0;
    g_DynamicRisk.consecutiveWins = 0;
    g_DynamicRisk.lastRiskUpdate = 0;
}

// EVENT-DRIVEN LOGGING

// Hourly summary instead of constant spam

// Log only significant score changes
void LogSignificantScoreChange(double oldScore, double newScore, string reason) {
    double change = MathAbs(newScore - oldScore);
    
    // Only log if change is significant (>10 points)
    if(change > 10.0) {
        PrintFormat("  pattern score change   |   %+.1f points", change);
    }
}

// Log trade decisions with clear reasoning

// INTEGRATION HELPER - Get pattern-adjusted score

double GetPatternAdjustedScore(double baseScore) {
    double adjustedScore = baseScore;
    
    // Apply pattern confidence boost/dampen
    if(g_PatternState.patternBuySignal && baseScore > 0) {
        // Boost buy score
        double boost = 10.0 * g_PatternState.patternConfidence;
        adjustedScore += boost;
        
        LogSignificantScoreChange(baseScore, adjustedScore, g_PatternState.patternReasoning);
    } else if(g_PatternState.patternSellSignal && baseScore < 0) {
        // Boost sell score
        double boost = 10.0 * g_PatternState.patternConfidence;
        adjustedScore -= boost;
        
        LogSignificantScoreChange(baseScore, adjustedScore, g_PatternState.patternReasoning);
    }
    
    // Cap at limits
    if(adjustedScore > 100.0) adjustedScore = 100.0;
    if(adjustedScore < -100.0) adjustedScore = -100.0;
    
    return adjustedScore;
}

// EOF - E9.5 PATTERN SYSTEM
// Enhanced decision functions
// ========================================================================
// L4  SIGNAL ENGINE — CEUS  (6-component IC-weighted scoring engine)
// ========================================================================

// ============================================================================
// SIGNAL TYPE CLASSIFIER
// Classifies a signal bar into one of three archetypes based on its component
// pattern. This is NOT about whether the signal is strong — it is about WHAT
// TYPE of market move is being proposed.
//
// CONTINUATION: Trend is intact, components align — enter WITH the trend.
//   Agreement pattern confirms the signal. Penalise conflict here.
//
// REVERSAL: Prior trend is exhausted, turning. SPECIFIC CONFLICT is the signal.
//   MTF shows old trend, but RSI/momentum already turned. The conflict between
//   these IS the reversal confirmation. Do NOT penalise this conflict.
//
// BREAKOUT: Price leaving compression. Volatility/volume lead — MTF may lag.
//   Count volume+ATR agreement specifically. MTF lag is normal here.
// ============================================================================
int ClassifySignalType(int shift, bool isLong) {
    if(shift < 2 || shift >= Bars - 10) return SIGTYPE_CONTINUATION;  // safe default

    // -- Key component readings ----------------------------------------------
    bool mtfAgrees = (iMA(NULL,PERIOD_M15,20,0,MODE_EMA,PRICE_CLOSE,shift) >
                      iMA(NULL,PERIOD_M15,50,0,MODE_EMA,PRICE_CLOSE,shift)) == isLong;
    double rsi     = iRSI(NULL,PERIOD_CURRENT,14,PRICE_CLOSE,shift);
    double macdH   = iMACD(NULL,PERIOD_CURRENT,12,26,9,PRICE_CLOSE,MODE_MAIN,shift)
                   - iMACD(NULL,PERIOD_CURRENT,12,26,9,PRICE_CLOSE,MODE_SIGNAL,shift);
    bool macdAgrees= (macdH > 0) == isLong;
    double atr0    = iATR(NULL,PERIOD_CURRENT,14,shift);
    double atr10   = 0; for(int k=0;k<10;k++) if(shift+k<Bars) atr10+=iATR(NULL,0,14,shift+k);
    atr10 = (atr10 > 0) ? atr10/10.0 : atr0;
    bool atrExpanding = (atr0 > atr10 * 1.05);  // volatility expanding

    // -- Volume check (approximated by candle range vs ATR) ------------------
    double candleRange = (shift < Bars) ? (High[shift] - Low[shift]) : atr0;
    bool volumeSpike   = (candleRange > atr0 * 1.3);  // larger-than-usual bar

    // -- RSI extremes --------------------------------------------------------
    bool rsiExtreme = isLong ? (rsi < 35.0) : (rsi > 65.0);  // potential exhaustion reversal
    bool rsiOverbought = (rsi > 68.0);
    bool rsiOversold   = (rsi < 32.0);

    // -- Classification logic ------------------------------------------------─

    // BREAKOUT: volatility expanding + large candle confirms compression break
    // MTF lag is expected — breakouts often precede MTF confirmation
    if(atrExpanding && volumeSpike) {
        return SIGTYPE_BREAKOUT;
    }

    // REVERSAL: MTF disagrees (prior trend) but RSI/momentum have already turned
    // This is the key divergence pattern — MTF still shows old direction but
    // the intrabar signals say reversal is underway
    if(!mtfAgrees && (rsiExtreme || !macdAgrees)) {
        return SIGTYPE_REVERSAL;
    }
    // Also reversal if RSI at extreme regardless of MTF (exhaustion setup)
    if(isLong && rsiOversold) return SIGTYPE_REVERSAL;
    if(!isLong && rsiOverbought) return SIGTYPE_REVERSAL;

    // CONTINUATION: trend intact, components broadly aligned
    // Default for trend-following signals with component consensus
    return SIGTYPE_CONTINUATION;
}

double CalculateEnhancedUnifiedScore(int shift = 0) {
    // 9.15 UNIFIED SCORING: -100 to +100 (Bidirectional)
    
    double totalScore = 0.0;
    
    // CONTEXT-AWARE WEIGHT SELECTION
    ComponentWeights weights;
    int regime = -1;
    // f declared at function scope so it is accessible to all code paths below
    MarketStateFeatures f = CalculateMarketFeatures(shift);
    if(g_WeightsOptimized) {
        regime = ClassifyBarToRegime(f, shift);
        if(regime < 0 || regime >= 9) regime = 0;  // R8 = 9th regime, valid index

        ComponentWeights rw = g_RegimeOptimalWeights[MathMin(8,MathMax(0,regime))];  // regime weights

        // ## Detect current session (0=London 1=NY 2=Asia 3=Sydney) ##########
        int _gmtH = (TimeHour(Time[shift]) - g_ServerTimeOffsetHours + 24) % 24;
        int ses = 2;  // default Asia (conservative)
        if(_gmtH >= 7  && _gmtH < 12) ses = 0;   // London open
        else if(_gmtH >= 12 && _gmtH < 16) ses = 0; // London+NY overlap -> London weights (best)
        else if(_gmtH >= 16 && _gmtH < 21) ses = 1; // NY
        else if(_gmtH >= 21 || _gmtH < 6)  ses = 3; // Sydney

        // ## Detect current volatility state using calibrated ATR-ratio #######
        double _atr0 = iATR(NULL, PERIOD_CURRENT, 14, shift);
        double _atr20=0; int _aCnt_cs=0; for(int _k=0;_k<20;_k++){if(shift+_k>=Bars)break;_atr20+=iATR(NULL,PERIOD_CURRENT,14,shift+_k);_aCnt_cs++;}
        if(_aCnt_cs>0)_atr20/=_aCnt_cs; else _atr20=_atr0;
        double _atrRatio = (_atr20 > 0) ? _atr0 / _atr20 : 1.0;
        int vs = 1;  // default Normal
        if(_atrRatio < g_CalibratedVolLowThresh)  vs = 0;  // Low-vol
        else if(_atrRatio > g_CalibratedVolHighThresh) vs = 2;  // High-vol

        // ## Pull session and vol weight sets (fall back to regime if invalid) #
        ComponentWeights sw = g_SessionWeightsValid[ses][regime]     ? g_SessionRegimeWeights[ses][regime]     : rw;
        ComponentWeights vw = g_VolatilityWeightsValid[vs][regime]   ? g_VolatilityRegimeWeights[vs][regime]   : rw;

        // ## Weighted blend using calibrated ratios (Phase 3B.7) ############
        // Defaults 50/30/20 hold until calibration sets g_BlendCalibrated=true.
        double _ar = g_BlendAlphaRegime, _as = g_BlendAlphaSession, _av = g_BlendAlphaVol;
        weights.mtf        = rw.mtf        * _ar + sw.mtf        * _as + vw.mtf        * _av;
        weights.momentum   = rw.momentum   * _ar + sw.momentum   * _as + vw.momentum   * _av;
        weights.volume     = rw.volume     * _ar + sw.volume     * _as + vw.volume     * _av;
        weights.volatility = rw.volatility * _ar + sw.volatility * _as + vw.volatility * _av;
        weights.session    = rw.session    * _ar + sw.session    * _as + vw.session    * _av;
        weights.pattern    = rw.pattern    * _ar + sw.pattern    * _as + vw.pattern    * _av;
        // 9.35-K: apply CATREC damping overlay without touching calibrated weights
        if(regime >= 0 && regime < 9 && g_CATREC_DampActive[regime]) {
            weights.mtf        *= g_CATREC_Damp[regime][0];
            weights.momentum   *= g_CATREC_Damp[regime][1];
            weights.volume     *= g_CATREC_Damp[regime][2];
            weights.volatility *= g_CATREC_Damp[regime][3];
            weights.session    *= g_CATREC_Damp[regime][4];
            weights.pattern    *= g_CATREC_Damp[regime][5];
        }
    } else {
        weights.mtf = 1.0; weights.momentum = 1.0; weights.volume = 1.0;
        weights.volatility = 1.0; weights.session = 1.0; weights.pattern = 1.0;
    }

    // IC-based soft noise gate: if a component showed near-zero predictive power
    // in calibration (IC < 0.015 = below noise floor), attenuate its LIVE weight by 30%.
    // Components with valid calibration data get a second check: IC encodes the signal-to-noise
    if(g_State.totalTrades >= 10) {  // only after meaningful live data
        // Dynamic cap: proven components (high IC x live WR) earn up to 1.50x.
        // Unproven components stay bounded at 1.30 — no free lunches.
        // IC acts as the quality credential that unlocks the expanded ceiling.
        double _gcw_cap_lo = 0.70;
        bool _hasIC = (g_ICMeasured && regime >= 0 && regime < 9);
        double _icMtf  = _hasIC ? MathAbs(g_RegimeIC[regime][0]) : 0.0;
        double _icMom  = _hasIC ? MathAbs(g_RegimeIC[regime][1]) : 0.0;
        double _icVol  = _hasIC ? MathAbs(g_RegimeIC[regime][2]) : 0.0;
        double _icAtR  = _hasIC ? MathAbs(g_RegimeIC[regime][3]) : 0.0;
        double _icSes  = _hasIC ? MathAbs(g_RegimeIC[regime][4]) : 0.0;
        double _icPat  = _hasIC ? MathAbs(g_RegimeIC[regime][5]) : 0.0;
        // Proven = IC above noise AND live g_ComponentWeights above neutral
        double _capMtf  = (_icMtf  > 0.025 && g_ComponentWeights.mtf       > 1.0) ? 1.50 : 1.30;
        double _capMom  = (_icMom  > 0.025 && g_ComponentWeights.momentum  > 1.0) ? 1.50 : 1.30;
        double _capVol  = 1.30;  // volume: no IC mapping — keep 1.30
        double _capAtR  = (_icAtR  > 0.025 && g_ComponentWeights.volatility > 1.0) ? 1.50 : 1.30;
        double _capSes  = 1.30;  // session: no IC mapping — keep 1.30
        double _capPat  = (_icPat  > 0.025 && g_ComponentWeights.pattern   > 1.0) ? 1.50 : 1.30;
        weights.mtf        *= MathMax(_gcw_cap_lo, MathMin(_capMtf,  g_ComponentWeights.mtf));
        weights.momentum   *= MathMax(_gcw_cap_lo, MathMin(_capMom,  g_ComponentWeights.momentum));
        weights.volume     *= MathMax(_gcw_cap_lo, MathMin(_capVol,  1.0));
        weights.volatility *= MathMax(_gcw_cap_lo, MathMin(_capAtR,  g_ComponentWeights.volatility));
        weights.session    *= MathMax(_gcw_cap_lo, MathMin(_capSes,  1.0));
        weights.pattern    *= MathMax(_gcw_cap_lo, MathMin(_capPat,  g_ComponentWeights.pattern));
    }

    if(g_ICMeasured && regime >= 0 && regime < 9) {
        // Regime-adaptive noise floor: trend regimes (0,1,2,3) show cleaner component
        // correlations so apply a tighter floor. Range regimes (4,5) are inherently
        // noisier -- lower floor prevents over-filtering legitimate but weaker signals.
        // Noise (6) and ultra-bull (7) use moderate values.
        double _noiseFloor;
        // CEO Building tier: blocked regimes — hard-zero the score
    if(g_CEO_CompetenceScore < 60 && g_WeightsOptimized) {
        if(regime >= 0 && regime < 9 && g_CEO_RegimeBlocked[regime]) {
            // SLS23 FIX: this early return used to skip the g_CEO_CCA_Active reset further down,
            // so a trade closed right after a regime-blocked scoring pass could be mis-attributed
            // to the CEO Conviction Amplifier, skewing its win-rate self-tuning.
            g_CEO_CCA_Active = false;
            return 0.0;  // regime blocked: score zeroed, signal will not fire
        }
    }

    // OP: Regime transition confidence discount — weights uncertain during hysteresis
        if(shift == 0 && g_RegimeState.inTransition && g_RegimeState.transitionConfirmBars > 0) {
            double _tw = MathMax(0.55, 1.0-(double)g_RegimeState.transitionConfirmBars/6.0);
            weights.mtf*=_tw;weights.momentum*=_tw;weights.volume*=_tw;
            weights.volatility*=_tw;weights.session*=_tw;weights.pattern*=_tw;
        }
        if(regime <= 3 || regime == 7) _noiseFloor = 0.020;  // trend+prebreak: higher IC required
        else if(regime <= 5)  _noiseFloor = 0.010;  // range: more lenient
        else                  _noiseFloor = 0.016;  // noise/ultra: raised from 0.014

        double ics[6]; ics[0]=g_RegimeIC[regime][0]; ics[1]=g_RegimeIC[regime][1];
                       ics[2]=g_RegimeIC[regime][2]; ics[3]=g_RegimeIC[regime][3];
                       ics[4]=g_RegimeIC[regime][4]; ics[5]=g_RegimeIC[regime][5];
        // Smooth gradient attenuation: IC=0 -> keep 40% weight, IC=floor -> 100%.
        // Preserves weak-but-real signals rather than binary-chopping them.
        // Smooth gradient attenuation: IC=0 keeps 40% weight, IC=noiseFloor keeps 100%
        { double _a0=MathAbs(ics[0]); if(_a0<_noiseFloor) weights.mtf        *= (0.40+0.60*SafeSqrt(_a0/_noiseFloor)); }
        { double _a1=MathAbs(ics[1]); if(_a1<_noiseFloor) weights.momentum   *= (0.40+0.60*SafeSqrt(_a1/_noiseFloor)); }
        { double _a2=MathAbs(ics[2]); if(_a2<_noiseFloor) weights.volume     *= (0.40+0.60*SafeSqrt(_a2/_noiseFloor)); }
        { double _a3=MathAbs(ics[3]); if(_a3<_noiseFloor) weights.volatility *= (0.40+0.60*SafeSqrt(_a3/_noiseFloor)); }
        { double _a4=MathAbs(ics[4]); if(_a4<_noiseFloor) weights.session    *= (0.40+0.60*SafeSqrt(_a4/_noiseFloor)); }
        { double _a5=MathAbs(ics[5]); if(_a5<_noiseFloor) weights.pattern    *= (0.40+0.60*SafeSqrt(_a5/_noiseFloor)); }

        // IC x Regime synergy amplifier: when IC is STRONG (above signal floor) AND the
        // current regime has proven signal quality (P2 signalWR > baseline), the score's
        // predictive power is real — amplify the weight, not just protect it from noise.
        // This is the multiplicative gap: good IC in a good regime should compound.
        if(g_CorrelationsLearned && regime >= 0 && regime < 9) {
            double _sigWR = SAFE_SIGNAL_WR(regime);
            double _sigFloor = 0.030;  // above this IC = genuinely predictive
            // CEO3: regime-quality adaptive amplification ceiling
            // High-quality regimes (IC>0.06, WR>0.72) earn up to 1.40x (empirical: IC is super-additive above 0.06)
            double _regQual = MathMax(0.0, MathMin(1.0, (_sigWR - 0.60) / 0.20));
            // CEO: IC amplifier ceiling scales with system competence
            // SVJ-G: Smooth IC amplifier ceiling — regime quality and CEO score earned proportionally
            // _regBonus: 0.0 at 65% WR - 0.15 at 80%+ WR, linear
            double _regBonus = MathMax(0.0, MathMin(0.15, (_sigWR - 0.65) / 0.15 * 0.15));
            // _ccsBonus: 0.0 at CEO=60 - 0.10 at CEO=100, linear
            double _ccsBonus = MathMax(0.0, MathMin(0.10, (g_CEO_CompetenceScore - 60.0) / 40.0 * 0.10));
            double _maxAmp = MathMin(1.50, 1.25 + _regBonus + _ccsBonus);  // up to 1.50x for elite
            // Regime quality factor: how much better than baseline 0.65 is this regime?
            // _regQual declared above
            if(_regQual > 0.0) {
                double _icA0 = ics[0]; if(_icA0 > _sigFloor) weights.mtf       *= MathMin(_maxAmp, 1.0 + (_icA0 - _sigFloor) * _regQual * 6.0);
                double _icA1 = ics[1]; if(_icA1 > _sigFloor) weights.momentum  *= MathMin(_maxAmp, 1.0 + (_icA1 - _sigFloor) * _regQual * 6.0);
                double _icA2 = ics[2]; if(_icA2 > _sigFloor) weights.volume    *= MathMin(_maxAmp, 1.0 + (_icA2 - _sigFloor) * _regQual * 6.0);
                double _icA3 = ics[3]; if(_icA3 > _sigFloor) weights.volatility*= MathMin(_maxAmp, 1.0 + (_icA3 - _sigFloor) * _regQual * 6.0);
                double _icA4 = ics[4]; if(_icA4 > _sigFloor) weights.session   *= MathMin(_maxAmp, 1.0 + (_icA4 - _sigFloor) * _regQual * 6.0);
                double _icA5 = ics[5]; if(_icA5 > _sigFloor) weights.pattern   *= MathMin(_maxAmp, 1.0 + (_icA5 - _sigFloor) * _regQual * 6.0);
            }
        }
    }

    // Component tracking for verification
    // -- CCA raw component capture (filled as each component is computed) ------
    // These track the unsigned conviction level of each component BEFORE weights.
    // Used by CEO Conviction Amplifier at end of function.
    double _ccaRaw[6]; ArrayInitialize(_ccaRaw, 0.0);  // [MTF,Mom,VolCtx,Volume,Session,Pattern]

    static bool componentCheck = false;
    if(!componentCheck) {
        componentCheck = true;
                // weights: regime(50%) + session(30%) + vol(20%) -- logged at startup
        if(g_ICMeasured)       Print("  IC noise gate   |   low-predictive components softened");
    }
    
    // COMPONENT 1: MTF ALIGNMENT (+/-30 points maximum) -- 5-timeframe
    // M15/H1/H4 are execution timeframes. H8/D1 are structural context.
    // Structural alignment earns a bonus; structural opposition applies a discount.
    double mtfScore = 0.0;
    int m15Trend = (iMA(NULL,PERIOD_M15,20,0,MODE_EMA,PRICE_CLOSE,shift) >
                    iMA(NULL,PERIOD_M15,50,0,MODE_EMA,PRICE_CLOSE,shift)) ? 1 : -1;
    int h1Trend  = (iMA(NULL,PERIOD_H1, 20,0,MODE_EMA,PRICE_CLOSE,shift) >
                    iMA(NULL,PERIOD_H1, 50,0,MODE_EMA,PRICE_CLOSE,shift)) ? 1 : -1;
    int h4Trend  = (iMA(NULL,PERIOD_H4, 20,0,MODE_EMA,PRICE_CLOSE,shift) >
                    iMA(NULL,PERIOD_H4, 50,0,MODE_EMA,PRICE_CLOSE,shift)) ? 1 : -1;
    // H8/D1: structural direction (single EMA relationship -- simple and robust)
    // H8 fallback: some brokers don't offer H8 charts -- use H4 in that case
    int h8Bars   = iBars(Symbol(), PERIOD_H8);
    int h8Trend  = (h8Bars >= 110)
        ? ((iMA(NULL,PERIOD_H8, 50,0,MODE_EMA,PRICE_CLOSE,shift) >
            iMA(NULL,PERIOD_H8,100,0,MODE_EMA,PRICE_CLOSE,shift)) ? 1 : -1)
        : h4Trend;  // fall back to H4 direction if H8 not available
    // D1 structural direction
    int d1Trend  = (iBars(Symbol(), PERIOD_D1) >= 55)
        ? ((iMA(NULL,PERIOD_D1,20,0,MODE_EMA,PRICE_CLOSE,shift) >
            iMA(NULL,PERIOD_D1,50,0,MODE_EMA,PRICE_CLOSE,shift)) ? 1 : -1)
        : h4Trend;  // fall back to H4 if insufficient D1 bars

    int execSum  = m15Trend + h1Trend + h4Trend;   // -3 to +3
    int structSum= h8Trend  + d1Trend;              // -2 to +2

    // Base score from execution TFs
    if(execSum == 3)        mtfScore = 30.0;
    else if(execSum == -3)  mtfScore = -30.0;
    else if(execSum >= 1)   mtfScore = 20.0;
    else if(execSum <= -1)  mtfScore = -20.0;

    // Structural alignment bonus/penalty (up to +/-6 pts)
    if(mtfScore != 0.0) {
        int signalDir1 = (mtfScore > 0) ? 1 : -1;
        if(structSum == signalDir1 * 2)      mtfScore += signalDir1 * 6.0;  // D1+H8 confirm
        else if(structSum == signalDir1 * 1) mtfScore += signalDir1 * 3.0;  // one confirms
        else if(structSum == -signalDir1 * 2) mtfScore *= 0.60;  // both oppose -- strong discount
        else if(structSum == -signalDir1 * 1) mtfScore *= 0.80;  // one opposes -- mild discount
    }
    _ccaRaw[0] = MathAbs(mtfScore);  // CCA: MTF raw conviction
    totalScore += mtfScore * weights.mtf;
    
    // ATR is used by both Component 2 (MACD normalization) and Component 3 (volatility ratio).
    // Declare it here once so both components can use it without re-querying the indicator.
    double atr = iATR(NULL, PERIOD_CURRENT, 14, shift);

    // COMPONENT 2: MOMENTUM/MACD (+/-25 points maximum) ? regime weight
    double macd = iMACD(NULL, PERIOD_CURRENT, 12, 26, 9, PRICE_CLOSE, MODE_MAIN, shift);
    double macdSignal = iMACD(NULL, PERIOD_CURRENT, 12, 26, 9, PRICE_CLOSE, MODE_SIGNAL, shift);
    double macdDiff = macd - macdSignal;

    double macdNormThreshStrong = (atr > 0) ? atr * 0.10 : 0.0010;
    double macdNormThreshMed    = (atr > 0) ? atr * 0.03 : 0.0003;
    double macdScore = 0.0;
    if(MathAbs(macdDiff) > macdNormThreshStrong) {
        macdScore = (macdDiff > 0) ? 25.0 : -25.0;
    } else if(MathAbs(macdDiff) > macdNormThreshMed) {
        macdScore = (macdDiff > 0) ? 15.0 : -15.0;
    } else if(macdDiff != 0) {
        macdScore = (macdDiff > 0) ? 5.0 : -5.0;
    }
    // Correlation discount: MTF and MACD both measure trend.
    if(MathAbs(mtfScore) >= 20.0 && MathSign(macdScore) == MathSign(mtfScore) && macdScore != 0.0) {
        macdScore *= 0.80;
    }
    // RSI slope confirmation: if rsiSlope aligns with MACD direction -> +15% bonus
    // If rsiSlope diverges (MACD bullish but RSI slope negative) -> ?20% penalty
    // This catches hidden divergence before price confirms it
    double _rsiSl = f.rsiSlope;  // pre-computed slope of RSI over 3 bars
    if(macdScore > 0 && _rsiSl > 0.10)       macdScore *= 1.15;  // RSI slope confirms bull
    else if(macdScore < 0 && _rsiSl < -0.10) macdScore *= 1.15;  // RSI slope confirms bear
    else if(macdScore > 0 && _rsiSl < -0.15) macdScore *= 0.80;  // RSI slope diverges bull
    else if(macdScore < 0 && _rsiSl > 0.15)  macdScore *= 0.80;  // RSI slope diverges bear
    // Price acceleration cross-check: if MACD bullish but price decelerating -> reduce
    if(macdScore > 0 && f.priceAcceleration < -0.20) macdScore *= 0.85;
    if(macdScore < 0 && f.priceAcceleration > 0.20)  macdScore *= 0.85;
    _ccaRaw[1] = MathAbs(macdScore);  // CCA: Momentum raw conviction
    totalScore += macdScore * weights.momentum;

    // -- FEATURE INTERACTION BONUS (neural-equivalent synergy) ----------
    // When MTF full-alignment AND strong momentum agree on same direction,
    // AND current volume confirms: grant a synergy multiplier.
    // This captures the non-linear interaction effect that a NN hidden layer
    // would learn from seeing all three fire simultaneously.
    if(!g_Calibration.isCalibrating) {
        bool _mtfStrong  = (MathAbs(mtfScore) >= 20.0);   // ≥2/3 MTF timeframes agree
        bool _momStrong  = (MathAbs(macdScore) >= 15.0);  // momentum above moderate level
        bool _sameDir    = (MathSign(mtfScore) == MathSign(macdScore) && mtfScore != 0 && macdScore != 0);
        double _vNow2    = (double)iVolume(NULL, PERIOD_CURRENT, shift);
        double _vAvg2    = 0.0; int _vc2 = 0;
        for(int _vi2=shift+1; _vi2<=shift+10 && _vi2<Bars; _vi2++) { _vAvg2+=(double)iVolume(NULL,PERIOD_CURRENT,_vi2); _vc2++; }
        bool _volConf    = (_vc2 > 0 && _vAvg2 > 0 && _vNow2 > (_vAvg2 / _vc2) * 1.15);
        if(_mtfStrong && _momStrong && _sameDir && _volConf) {
            // Synergy confirmed: add direction-aligned bonus capped at +8pt
            int _synDir = (mtfScore > 0) ? 1 : -1;
            double _synBonus = MathMin(8.0, 4.0 + (MathAbs(mtfScore) - 20.0) * 0.15
                                                  + (MathAbs(macdScore) - 15.0) * 0.10);
            totalScore += _synDir * _synBonus;
        }
    }
    
    // COMPONENT 3: VOLATILITY CONTEXT (+/-15 points) ? regime weight
    // ARCH-5 FIX: Was multiplied by currentDirection (raw bar sign) - circular: a bearish bar
    double atr20 = 0.0; int _aCnt_c=0;
    for(int i = 0; i < 20; i++) { if(shift+i >= Bars) break; atr20 += iATR(NULL, PERIOD_CURRENT, 14, shift + i); _aCnt_c++; }
    if(_aCnt_c > 0) atr20 /= _aCnt_c; else atr20 = atr;
    double atrRatio = (atr20 > 0) ? atr / atr20 : 1.0;
    
    // Signal direction from the MTF+Momentum components already accumulated
    int signalDir = (totalScore > 0) ? 1 : (totalScore < 0) ? -1 : 0;  // neutral=0: C3/C4/C5 contribute nothing when C1+C2 cancel
    // currentDirection still needed for volume/session candle-neutral backup
    int currentDirection = (Close[shift] > Open[shift]) ? 1 : -1;
    
    double volScore = 0.0;
    if     (atrRatio >= 0.8 && atrRatio <= 1.2) volScore =  15.0; // Normal -- ideal signal environment
    else if(atrRatio >  1.5)                     volScore = -10.0; // Spike -- noisy, reduce confidence
    else if(atrRatio >= 1.2 && atrRatio <= 1.5)  volScore =  -5.0; // Elevated -- mild caution
    else if(atrRatio >= 0.5 && atrRatio <  0.8)  volScore =  -5.0; // Low-vol -- thin liquidity
    else                                          volScore = -10.0; // Dead -- near-zero ATR, no edge
    // Apply in SIGNAL direction (not raw candle direction)
    _ccaRaw[2] = MathAbs(volScore);  // CCA: Volatility context raw conviction
    totalScore += (volScore * signalDir) * weights.volatility;  // ARCH-5 FIX
    
    // COMPONENT 4: VOLUME (+/-15 points) ? regime weight
    // Volume is tick-volume on forex (real volume unavailable). Relative tick volume still
    // has ~0.35-0.45 correlation with directional moves. Apply in signal direction.
    double currentVol = (double)iVolume(NULL, PERIOD_CURRENT, shift);
    double avgVol = 0.0; int _vCnt_c=0;
    for(int i = 1; i <= 20; i++) { if(shift+i >= Bars) break; avgVol += (double)iVolume(NULL, PERIOD_CURRENT, shift + i); _vCnt_c++; }
    if(_vCnt_c > 0) avgVol /= _vCnt_c; else avgVol = currentVol;
    double volRatio = (avgVol > 0) ? currentVol / avgVol : 1.0;
    // Cross-validate with pre-computed volumeDelta from features struct (uses 5-bar avg)
    // Blend: 70% from our 20-bar ratio (more stable), 30% from features 5-bar (more reactive)
    double _fvd = f.volumeDelta;  // 5-bar delta from CalculateMarketFeatures
    double blendedVolRatio = volRatio * 0.70 + _fvd * 0.30;

    // Conviction multiplier: volume spike means more when body closes in signal direction
    double _bodyConviction = (signalDir > 0)
        ? (f.closePosition > 0.65 ? 1.3 : f.closePosition < 0.35 ? 0.6 : 1.0)
        : (f.closePosition < 0.35 ? 1.3 : f.closePosition > 0.65 ? 0.6 : 1.0);
    // Wick-dominant on a vol spike = possible trap -- reduce contribution
    // Wick trap detection: directional wick opposing the signal = potential reversal trap
    // Upper wick on buy signal = bearish rejection; lower wick on sell = bullish support
    double _wickTrap = 1.0;
    if(signalDir > 0 && f.upperWickRatio > 0.50) _wickTrap = 0.75;  // bear rejection on buy
    if(signalDir < 0 && f.lowerWickRatio > 0.50) _wickTrap = 0.75;  // bull support on sell
    double _wickPenalty = ((blendedVolRatio > 1.5 && f.bodyRatio < 0.28) ? 0.45 : 1.0) * _wickTrap;

    double volumeScore = 0.0;
    if(blendedVolRatio > 2.0)      volumeScore = 15.0;
    else if(blendedVolRatio > 1.5) volumeScore = 10.0;
    else if(blendedVolRatio > 1.1) volumeScore =  5.0;
    else if(blendedVolRatio < 0.5) volumeScore = -10.0;
    volumeScore *= _bodyConviction * _wickPenalty;
    _ccaRaw[3] = MathAbs(volumeScore);  // CCA: Volume raw conviction
    totalScore += (volumeScore * signalDir) * weights.volume;  // ARCH-5 FIX (signal dir)
    
    // COMPONENT 5: SESSION QUALITY (+/-10 points) ? regime weight
    // Post-calibration: uses actual per-hour WR from 10,000 bars (400+ obs/hour).
    // Pre-calibration: uses static session buckets as fallback.
    int hour = TimeHour(Time[shift]);
    int gmtHour = (hour - g_ServerTimeOffsetHours + 24) % 24;
    double sessionScore = 0.0;
    if(g_HourlyCalibrated && g_HourlyObs[MathMin(23,MathMax(0,gmtHour))] >= 15) {
        // Map calibrated WR to session score: WR 0.72+ = +10, 0.65+ = +6, 0.55+ = +2,
        // 0.50+ = -2, below 0.50 = -8. Linear relationship between historical WR and score.
        double _hwr = g_HourlyWR[MathMin(23,MathMax(0,gmtHour))];
        if(_hwr >= 0.72)      sessionScore =  10.0;
        else if(_hwr >= 0.65) sessionScore =   6.0;
        else if(_hwr >= 0.58) sessionScore =   2.0;
        else if(_hwr >= 0.50) sessionScore =  -2.0;
        else                  sessionScore =  -8.0;
    } else {
        // Fallback: static session buckets (pre-calibration)
        if(gmtHour >= 7 && gmtHour < 16)       sessionScore =  10.0;
        else if(gmtHour >= 16 && gmtHour < 21) sessionScore =   5.0;
        else                                     sessionScore =  -5.0;
    }
    // Day-of-week layer: calibrated per-day WR adjusts session score
    if(g_DayOfWeekCalibrated) {
        int dow = TimeDayOfWeek(Time[shift]) - 1;  // Mon=0, Fri=4
        if(dow >= 0 && dow < 5 && g_DayOfWeekObs[MathMin(4,MathMax(0,dow))] >= 20) {
            double _dwr = g_DayOfWeekWR[MathMin(4,MathMax(0,dow))];
            // SVJ-G: smooth day-of-week WR gradient
            double _dowMult = MathMax(0.75, MathMin(1.20, 0.75 + (_dwr-0.55)/0.17*0.45));
            sessionScore = (double)(sessionScore * _dowMult);
        }
    }
    _ccaRaw[4] = MathAbs(sessionScore);  // CCA: Session raw conviction
    totalScore += (sessionScore * signalDir) * weights.session;
    { static int _lSs=-1; int _cSs=(TimeHour(TimeCurrent())-g_ServerTimeOffsetHours+24)%24;
      if(_cSs!=_lSs&&(_cSs==8||_cSs==13||_cSs==17)){g_SessionWins=0;g_SessionLosses=0;_lSs=_cSs;} }
    if(intelligence.vwap > 0.0) {  // vwap guard: skip when uncomputed

        if(intelligence.aboveVWAP && totalScore > 0)       totalScore += 5.0;

        else if(!intelligence.aboveVWAP && totalScore < 0) totalScore += 5.0;

        else                                                totalScore -= 3.0;

    }

    
    // COMPONENT 6: PATTERN RECOGNITION (+/-10 points)
    double patternScore = 0.0;
    if(!g_Calibration.isCalibrating) {
        PatternType micro  = g_PatternState.currentMicroPattern;
        double microConf   = g_PatternState.microConfidence;
        bool microBull     = (micro == PATTERN_BULL_FLAG      || micro == PATTERN_MOMENTUM_CONTINUATION ||
                              micro == PATTERN_DOUBLE_BOTTOM   || micro == PATTERN_INV_HEAD_SHOULDERS    ||
                              micro == PATTERN_MORNING_STAR    || micro == PATTERN_HAMMER_AT_SUPPORT     ||
                              micro == PATTERN_BULLISH_CHOCH   || micro == PATTERN_BULLISH_ENGULFING     ||
                              micro == PATTERN_HH              || micro == PATTERN_BULLISH_PENNANT        ||
                              micro == PATTERN_ASCENDING_TRIANGLE || micro == PATTERN_CUP_AND_HANDLE    ||
                              micro == PATTERN_SR_BOUNCE);
        bool microBeari    = (micro == PATTERN_BEAR_FLAG       || micro == PATTERN_BEARISH_CONTINUATION  ||
                              micro == PATTERN_DOUBLE_TOP       || micro == PATTERN_HEAD_SHOULDERS        ||
                              micro == PATTERN_EVENING_STAR     || micro == PATTERN_SHOOTING_STAR_AT_RES  ||
                              micro == PATTERN_BEARISH_CHOCH    || micro == PATTERN_BEARISH_ENGULFING     ||
                              micro == PATTERN_LL               || micro == PATTERN_BEARISH_PENNANT        ||
                              micro == PATTERN_DESCENDING_TRIANGLE || micro == PATTERN_PARABOLIC_STALL   ||
                              micro == PATTERN_CLIMAX_REVERSAL  || micro == PATTERN_INVERTED_CUP_HANDLE);

        if(microBull  && microConf > 0.55) patternScore =  10.0 * microConf;
        else if(microBeari && microConf > 0.55) patternScore = -10.0 * microConf;
        else {
            double bs = MathAbs(Close[shift] - Open[shift]);
            double ts = High[shift] - Low[shift];
            double bp = (ts > 0) ? bs / ts : 0;
            if(bp > 0.7)      patternScore =  5.0 * currentDirection;
            else if(bp < 0.3) patternScore = -3.0 * currentDirection;
        }
    } else {
        // Calibration: bar-local candle body ratio only (no live state contamination)
        double bs = MathAbs(Close[shift] - Open[shift]);
        double ts = High[shift] - Low[shift];
        double bp = (ts > 0) ? bs / ts : 0;
        if(bp > 0.7)      patternScore =  5.0 * currentDirection;
        else if(bp < 0.3) patternScore = -3.0 * currentDirection;
    }
    _ccaRaw[5] = MathAbs(patternScore);  // CCA: Pattern raw conviction
    totalScore += patternScore * weights.pattern;

    // COMPONENT 8: PROBABLE PATH SCORE (−20 to +20) -- sequence + divergence intelligence
    // tweezer patterns at S/R, range compression. Research-backed; IC-gated if measurable.
    if(!g_Calibration.isCalibrating) {
        double _pps = f.probablePathScore;  // −20 to +20, already computed and cached
        // IC quality gate: if IC is low, the score-to-outcome link is weak.
        // Dampen the PPS contribution proportionally so it cannot override calibrated edge.
        if(g_ICMeasured && regime >= 0 && regime < 9) {
            double _avgIC_pps = 0.0;
            for(int _ci_pps=0;_ci_pps<6;_ci_pps++) _avgIC_pps+=MathAbs(g_RegimeIC[regime][_ci_pps]);
            _avgIC_pps /= 6.0;
            // IC < 0.015 = noise floor — full dampening. IC 0.015-0.04 = partial. IC > 0.04 = full.
            double _icGate_pps = MathMax(0.0, MathMin(1.0, (_avgIC_pps - 0.015) / 0.025));
            _pps *= (0.40 + 0.60 * _icGate_pps);  // at min IC: 40% contribution
        }
        // S/R quality amplifier: PPS near high-quality levels is more reliable
        // Smooth S/R quality multiplier: 0.65x (quality=0) to 1.40x (quality=100)
        // Avoids binary step; quality is continuous signal

        double _srQMult = 0.65 + f.srZoneQuality / 100.0 * 0.75;  // 0.65 to 1.40

        _pps *= MathMax(0.65, MathMin(1.40, _srQMult));



        // Add to total score — no component weight (PPS already regime-aware internally)
        totalScore += MathMax(-20.0, MathMin(20.0, _pps));
        // High-quality S/R bonus: very strong levels add conviction directly to score
        if(f.srZoneQuality >= 70.0) {
            double _srBonus = (f.srZoneQuality - 70.0) / 30.0 * 5.0;  // 0 to +5pts
            double _srDir = (f.inDiscountZone && !g_Calibration.isCalibrating) ? 1.0 :
                            (f.inPremiumZone && !g_Calibration.isCalibrating) ? -1.0 : 0.0;
            totalScore += _srBonus * _srDir;  // direction-aware S/R conviction bonus
        }

    }

    // COMPONENT 9 (unweighted): ATR MOMENTUM (+/-8 points) -- is volatility expanding or contracting?
    {
        double _atr5 = 0.0; int _aC5 = 0;
        for(int _k = shift; _k < shift + 5 && _k < Bars; _k++) {
            _atr5 += iATR(NULL, PERIOD_CURRENT, 14, _k); _aC5++;
        }
        _atr5 = (_aC5 > 0) ? _atr5 / _aC5 : atr;
        double _atrSlope = (atr > 0 && _atr5 > 0) ? (atr - _atr5) / _atr5 : 0.0;
        double atrMomScore = 0.0;
        if(_atrSlope > 0.10)       atrMomScore =  8.0;   // ATR expanding 10%+ -- momentum building
        else if(_atrSlope > 0.04)  atrMomScore =  4.0;   // Expanding moderately
        else if(_atrSlope < -0.10) atrMomScore = -6.0;   // ATR contracting 10%+ -- exhaustion risk
        else if(_atrSlope < -0.04) atrMomScore = -3.0;   // Contracting moderately
        totalScore += atrMomScore * signalDir * weights.volatility;  // regime-weighted ATR momentumpenalises if fading
    }

    // COMPONENT 10 (unweighted): PRICE POSITION IN RANGE (+/-6 points) -- where in the 20-bar range is this close?
    // Score confirms signal direction: 80%+ in range for buy = strength. 20%- for sell = strength.
    // Score contradicts signal: bar at 20% range trying to buy = buying into weakness.
    {
        double _rHigh = High[shift], _rLow = Low[shift];
        for(int _k = shift + 1; _k < shift + 21 && _k < Bars; _k++) {
            if(High[_k] > _rHigh) _rHigh = High[_k];
            if(Low[_k]  < _rLow)  _rLow  = Low[_k];
        }
        double _rRange = _rHigh - _rLow;
        double _pricePos = (_rRange > 0) ? (Close[shift] - _rLow) / _rRange : 0.5;
        double ppScore = 0.0;
        if(signalDir > 0) {          // Buy signal
            if(_pricePos >= 0.75)      ppScore =  6.0;   // Price at top of range -- strong buy
            else if(_pricePos >= 0.55) ppScore =  3.0;   // Upper half -- confirming
            else if(_pricePos <= 0.30) ppScore = -5.0;   // Price at bottom -- buying weakness
        } else if(signalDir < 0) {   // Sell signal
            if(_pricePos <= 0.25)      ppScore =  6.0;   // Price at bottom of range -- strong sell
            else if(_pricePos <= 0.45) ppScore =  3.0;   // Lower half -- confirming
            else if(_pricePos >= 0.70) ppScore = -5.0;   // Price at top -- selling strength
        }
        totalScore += ppScore * weights.pattern;  // regime-weighted
    }

    // BONUSES: Breakout confirmation
    double bbUpper = iBands(NULL, PERIOD_CURRENT, 20, 2, 0, PRICE_CLOSE, MODE_UPPER, shift);
    double bbLower = iBands(NULL, PERIOD_CURRENT, 20, 2, 0, PRICE_CLOSE, MODE_LOWER, shift);
    {
        // BB breakout: amplify existing signal direction, don't override it
        double bbScore = 0.0;
        if(Close[shift] > bbUpper)      bbScore =  8.0 * signalDir;  // above upper: bullish
        else if(Close[shift] < bbLower) bbScore = -8.0 * signalDir;  // below lower: bearish
        // Only add when BB confirms signal direction (eliminates counter-signal noise)
        if(bbScore * totalScore > 0 || totalScore == 0) totalScore += bbScore;
    }
    
    // Win streak bonus (if we have it in context)
    // totalScore += g_CurrentWinStreak >= 5 ? 5.0 * currentDirection : 0.0;
    
    // E9.5: PATTERN-BASED SCORE ADJUSTMENT
    // BUG J FIX: Guard with isCalibrating - g_PatternState reflects the LIVE OnTick state,
    if(!g_Calibration.isCalibrating && (g_PatternState.patternBuySignal || g_PatternState.patternSellSignal)) {
        double prePatternScore = totalScore;
        totalScore = GetPatternAdjustedScore(totalScore);
    }
    
    // CAP AT +/-100
    if(totalScore > 100.0) totalScore = 100.0;
    if(totalScore < -100.0) totalScore = -100.0;
    
    // PROBABILITY INTELLIGENCE: Apply learned patterns to adjust score
    if(g_ProbDB.calibrated && g_ProbDB.patternCount > 0 && g_Calibration.isComplete) {
        // CRITICAL FIX: Only apply during live trading, not calibration
        // Get current market context
        MarketStateFeatures currentFeatures = f;  // reuse cached features from L11773
        int currentRegime = DetectCurrentRegime();
        double currentATR = iATR(NULL, 0, 14, shift);
        int currentHour = TimeHour(Time[shift]);
        
        // Adjust both long AND short signals using probability intelligence
        if(totalScore != 0) {
            double originalScore = totalScore;
            totalScore = ApplyProbabilityIntelligence(totalScore, currentRegime, currentATR, currentHour, false);
            static datetime lastProbLog = 0;
            if(MathAbs(totalScore - originalScore) > 5.0 && TimeCurrent() - lastProbLog > 300) {
                lastProbLog = TimeCurrent();
                ApplyProbabilityIntelligence(originalScore, currentRegime, currentATR, currentHour, true);
            }
        }
    }
    
    // Value area position: price above/below value area = directional conviction
    if(marketStructure.valueAreaHigh > 0 && marketStructure.valueAreaLow > 0) {
        double _curP = Close[shift];
        bool _aboveVA = (_curP > marketStructure.valueAreaHigh);
        bool _belowVA = (_curP < marketStructure.valueAreaLow);
        bool _insideVA = (!_aboveVA && !_belowVA);
        if(_insideVA)           totalScore *= 0.92;  // contested: dampen signal
        else if(_aboveVA && totalScore > 0) totalScore += 4.0;  // above VA: long confirmed
        else if(_belowVA && totalScore < 0) totalScore += 4.0;  // below VA: short confirmed
        else                    totalScore -= 3.0;  // fighting value area direction
    }

    // Market memory conviction: similar past setups voted on this signal
    if(MathAbs(g_MarketMemoryConviction) > 0.5 && g_CorrelationsLearned)
        totalScore += MathMax(-8.0, MathMin(8.0, g_MarketMemoryConviction));

    // Wave angle: applied after components are summed so direction is known.
    // Uses f (correct bar's features — not live bar). Amplifies recoveries, penalises
    // parabolic overextension. Direction-aware: always pushes WITH signal direction.
    if(totalScore != 0) {
        double _angBoost = 0;
        if(f.angleRecovery && f.waveAngleDNALen >= 3) _angBoost += 4.0;
        if(f.angleParabolic)                          _angBoost -= 6.0;
        if(f.angleAccelerating && !f.angleParabolic)  _angBoost += 2.0;
        if(f.angleDecelerating)                       _angBoost -= 3.0;
        if(_angBoost != 0) totalScore += MathSign(totalScore) * _angBoost;
    }

    // -- SEQUENTIAL PATTERN QUALITY (live trading, cached) --------------------
    // Patterns form over several bars. Discount isolated signals; amplify sustained ones.
    // Cache key = Time[shift]: prevents 12 repeated indicator calls per tick within
    // the same bar. Cache is valid only for the current bar — stale on new bar open.
    {
        double _seqMult;
        if(shift == 0 && g_seqMultLiveCacheBar == Time[0]) {
            _seqMult = g_seqMultLiveCache;  // free: same bar, already computed
        } else if(shift + 3 < Bars && MathAbs(totalScore) > 5.0) {
            int _seqAgree = 0;
            double _curDir = (totalScore > 0) ? 1.0 : -1.0;
            for(int _k = 1; _k <= 3; _k++) {
                if(shift + _k >= Bars) break;
                int _pm = (iMA(NULL,PERIOD_M15,20,0,MODE_EMA,PRICE_CLOSE,shift+_k) >
                           iMA(NULL,PERIOD_M15,50,0,MODE_EMA,PRICE_CLOSE,shift+_k)) ? 1 : -1;
                int _ph = (iMA(NULL,PERIOD_H1, 20,0,MODE_EMA,PRICE_CLOSE,shift+_k) >
                           iMA(NULL,PERIOD_H1, 50,0,MODE_EMA,PRICE_CLOSE,shift+_k)) ? 1 : -1;
                double _pmd = iMACD(NULL,PERIOD_CURRENT,12,26,9,PRICE_CLOSE,MODE_MAIN,  shift+_k)
                            - iMACD(NULL,PERIOD_CURRENT,12,26,9,PRICE_CLOSE,MODE_SIGNAL, shift+_k);
                double _prevDir = ((_pm + _ph + (_pmd > 0 ? 1 : -1)) >= 1) ? 1.0 : -1.0;
                if(_prevDir * _curDir > 0.0) _seqAgree++;
            }
            _seqMult = (_seqAgree >= 3) ? 1.25 :
                       (_seqAgree == 2) ? 1.10 :
                       (_seqAgree == 1) ? 1.00 : 0.82;
            // Update cache for this bar (shift==0 only — historical bars don't cache)
            if(shift == 0) { g_seqMultLiveCache = _seqMult; g_seqMultLiveCacheBar = Time[0]; }
        } else {
            _seqMult = 1.0;  // insufficient data or |score| too small to bother
        }
        totalScore *= _seqMult;
        if(totalScore >  100.0) totalScore =  100.0;
        if(totalScore < -100.0) totalScore = -100.0;
    }

    // -- INTELLIGENCE LAYERS 9/10/11: Order Flow + Trap + MTF ----------─
    // These three new layers add real predictive intelligence beyond CEUS
    // indicators. They run at bar-0 only (live trading path).
    if(!g_Calibration.isCalibrating && shift == 0) {
        MarketStateFeatures _lf = CalculateMarketFeatures(0);
        double _ceusDamp = 1.0;  // SLS18 MEDIUM3: collect Layer 10-11 dampings, apply single-strongest

        // Layer 9 — ORDER FLOW PROXY: pressure confirms signal direction?
        if(_lf.pressureConviction) {
            bool _pfBuy = (_lf.pressureDelta > 0.25);
            bool _pfSell = (_lf.pressureDelta < -0.25);
            int _pfDir = (totalScore > 0) ? 1 : -1;
            if((_pfDir > 0 && _pfBuy) || (_pfDir < 0 && _pfSell))
                totalScore += _pfDir * 4.5;  // Flow confirms direction: +4.5pt
            if(_lf.pressureDivergence)
                totalScore -= _pfDir * 3.0;  // Flow opposes direction: -3pt warning
        }
        // Liquidity sweep in signal direction = stop hunt complete, real move starting
        if(_lf.liquiditySweep && _lf.sweepStrength > 0.3) {
            int _sfDir = (totalScore > 0) ? 1 : -1;
            bool _sweepAligns = (_sfDir > 0 && _lf.pressureDelta > 0) ||
                                (_sfDir < 0 && _lf.pressureDelta < 0);
            if(_sweepAligns) totalScore += _sfDir * 3.5;  // Sweep in signal direction: confirming
        }
        // Spread absorption during high volume = institutional participant active
        if(_lf.spreadAbsorption > 0.5) {
            int _saDir = (totalScore > 0) ? 1 : -1;
            totalScore += _saDir * 2.0;
        }

        // Layer 10 — TRAP DETECTION: block or reverse if this is a trap setup
        if(_lf.bullTrap && totalScore > 0) {
            totalScore -= _lf.trapStrength * 12.0;  // Bull trap: strongly penalise long signals
        }
        if(_lf.bearTrap && totalScore < 0) {
            totalScore += _lf.trapStrength * 12.0;  // Bear trap: strongly penalise short signals
        }
        // Near trap level: be cautious even if trap hasn't confirmed yet
        if(_lf.nearTrapLevel && !_lf.bullTrap && !_lf.bearTrap) {
            _ceusDamp = MathMin(_ceusDamp, 0.85);  // 15% damping near trap levels
        }

        // Layer 11 — MTF MOMENTUM CONVERGENCE: full alignment = rare high-conviction setup
        if(_lf.mtfFullConvergence) {
            int _mcDir = (totalScore > 0) ? 1 : -1;
            bool _mcAligns = (_mcDir > 0 && _lf.mtfMomentumScore > 0) ||
                             (_mcDir < 0 && _lf.mtfMomentumScore < 0);
            if(_mcAligns)
                totalScore += _mcDir * _lf.mtfConvictionBonus;  // +6 to +8pt conviction bonus
        }
        if(_lf.mtfDivergence) {
            _ceusDamp = MathMin(_ceusDamp, 0.80);  // Higher TF opposing: 20% damping
        }
        totalScore *= _ceusDamp;  // SLS18 MEDIUM3: apply single-strongest Layer 10-11 damping
    }

    // -- INTELLIGENCE LAYERS 12/13/14: Bayesian + ILM + WavePhase --------
    if(!g_Calibration.isCalibrating && shift == 0) {
        MarketStateFeatures _xf = CalculateMarketFeatures(0);  // cached — no recalc
        double _bayesDamp = 1.0;  // SLS18 MEDIUM3: Layer 12 damping collected, applied once

        // Layer 12 — BAYESIAN REGIME BELIEF: conviction modulates risk tolerance
        // High conviction in current regime = full signal weight
        // Diffuse belief (confused market) = dampen the signal
        if(_xf.beliefConviction < 0.30) {
            _bayesDamp = MathMin(_bayesDamp, 0.65);  // Genuinely confused market: 35% damping
        } else if(_xf.beliefConviction < 0.45) {
            _bayesDamp = MathMin(_bayesDamp, 0.82);  // Uncertain market: 18% damping
        } else if(_xf.beliefConviction > 0.78) {
            int _bDir = (totalScore > 0) ? 1 : -1;
            // Belief strongly aligns with signal direction?
            int _bReg = _xf.dominantBeliefRegime;
            bool _beliefBull = (_bReg == 0 || _bReg == 1 || _bReg == 2 || _bReg == 4 || _bReg == 8);
            bool _beliefBear = (_bReg == 3 || _bReg == 5 || _bReg == 7);
            if((_bDir > 0 && _beliefBull) || (_bDir < 0 && _beliefBear)) {
                double _convBonus = (_xf.beliefConviction - 0.78) * 32.0;  // 0-7pt (earned at higher bar)
                totalScore += _bDir * MathMin(5.0, _convBonus);
            } else if((_bDir > 0 && _beliefBear) || (_bDir < 0 && _beliefBull)) {
                _bayesDamp = MathMin(_bayesDamp, 0.80);  // Belief opposes signal direction
            }
        }
        totalScore *= _bayesDamp;  // SLS18 MEDIUM3: apply single-strongest Layer 12 damping

        // Layer 13 — INSTITUTIONAL LEVEL MEMORY: calibrate by what this price has done before
        if(_xf.memoryLevelScore > 0) {
            int _mDir = (totalScore > 0) ? 1 : -1;
            // Memory bias aligns with signal: the market remembers this level favours this direction
            if((_mDir > 0 && _xf.memoryBias > 0.3) || (_mDir < 0 && _xf.memoryBias < -0.3)) {
                totalScore += _mDir * MathMin(5.0, MathAbs(_xf.memoryBias) * 8.0);
            }
            // Approaching strong resistance on a long signal: serious penalty
            if(_xf.approachingResistance && _mDir > 0 && _xf.memoryLevelScore > 50)
                totalScore -= 6.0;
            if(_xf.approachingSupport && _mDir < 0 && _xf.memoryLevelScore > 50)
                totalScore += 6.0;
            // At high-probability level (score≥80, within 0.3 ATR): high conviction confirmation
            if(_xf.atHighProbLevel) {
                double _lvlBonus = _xf.memoryLevelScore / 100.0 * 4.0;  // up to +4pt
                bool _lvlAligns = (_mDir > 0 && _xf.memoryBias > 0) || (_mDir < 0 && _xf.memoryBias < 0);
                if(_lvlAligns) totalScore += _mDir * _lvlBonus;
            }
        }

        // Layer 14 — WAVE PHASE: timing is everything
        if(_xf.wavePhase > 0) {
            int _wDir = (totalScore > 0) ? 1 : -1;
            // Optimal window (phase 1 or 4): amplify — this is when the best entries occur
            if(_xf.optimalEntryWindow) {
                double _wBonus = 4.0 + _xf.beliefConviction * 4.0;  // 4-8pt based on conviction
                totalScore += _wDir * MathMin(8.0, _wBonus);
            }
            // Exhaustion warning (phase 2): strong dampening — move is late
            if(_xf.exhaustionWarning) {
                totalScore *= (1.0 - _xf.waveMaturity * 0.35);  // up to 35% reduction at peak maturity
            }
            // Correction phase: reduce size but don't block — reversals happen in corrections
            if(_xf.wavePhase == 3) {
                totalScore *= 0.85;
            }
        }
    }

    // -- SCORE VELOCITY (signal momentum layer) ------------------------
    // Rate of change of the CEUS score itself across bars.
    // A score accelerating toward the threshold is more predictive than one hovering.
    // Chess equivalent: a position that is "getting better" on each move evaluation.
    if(!g_Calibration.isCalibrating && shift == 0 && MathAbs(totalScore) > 15.0) {
        static double _sv1 = 0.0, _sv2 = 0.0;
        static datetime _svBar = 0;
        if(Time[0] != _svBar) {
            // New bar — shift history
            _sv2 = _sv1;
            // Compute prior bar score using current calibrated weights
            {   ComponentWeights _svW;
                // Explicit init — MQL4 doesn't zero-init struct members
                _svW.mtf=1.0;_svW.momentum=1.0;_svW.volume=1.0;
                _svW.volatility=1.0;_svW.session=1.0;_svW.pattern=1.0;
                _svW.validated=false; _svW.trainingWR=0.5; _svW.validationWR=0.5;
                _svW.expectedValue=0.0; _svW.sampleSize=0;
                if(g_WeightsOptimized && g_RegimeState.currentRegime >= 0 &&
                   g_RegimeState.currentRegime < 9)
                    _svW = g_RegimeOptimalWeights[MathMin(8,MathMax(0,g_RegimeState.currentRegime))];
                _sv1 = CalculateScoreWithWeights(1, _svW);
            }  // 1-bar ago score
            _svBar = Time[0];
        }
        if(_sv1 != 0.0 && _sv2 != 0.0) {
            double _scoreVel  = totalScore - _sv1;  // current vs 1 bar ago
            double _scoreAcc  = _scoreVel - (_sv1 - _sv2);  // acceleration
            int _sDir = (totalScore > 0) ? 1 : -1;
            // Accelerating in signal direction: +3pt (signal gaining strength)
            if(_scoreAcc * _sDir > 5.0)       totalScore += _sDir * 3.0;
            // Strongly accelerating: +5pt (deep conviction increase)
            else if(_scoreAcc * _sDir > 10.0) totalScore += _sDir * 5.0;
            // Decelerating: -2pt (signal weakening)
            else if(_scoreAcc * _sDir < -5.0) totalScore -= _sDir * 2.0;
        }
    }

    // -- COMPONENT CONVERGENCE BONUS ------------------------------------
    // When 5 or 6 CEUS components agree on direction, that convergence is
    // statistically more predictive than any single component.
    // Chess equivalent: multiple tactical lines all pointing to the same move.
    if(!g_Calibration.isCalibrating && shift == 0 && MathAbs(totalScore) > 10.0) {
        int _cvDir = (totalScore > 0) ? 1 : -1;
        int _cvAgree = 0;
        // Test each component's raw direction (positive = agrees with signal direction)
        // MTF — only count if M15 data is loaded (avoid unreliable cross-TF data)
        { double _ma15 = iMA(NULL,PERIOD_M15,20,0,MODE_EMA,PRICE_CLOSE,0);
          double _ma15b = iMA(NULL,PERIOD_M15,50,0,MODE_EMA,PRICE_CLOSE,0);
          if(_ma15 > 0.001 && _ma15b > 0.001 &&
             ((_cvDir > 0 && _ma15 > _ma15b) || (_cvDir < 0 && _ma15 < _ma15b))) _cvAgree++; }
        // Momentum (MACD)
        { double _md = iMACD(NULL,PERIOD_CURRENT,12,26,9,PRICE_CLOSE,MODE_MAIN,0)
                     - iMACD(NULL,PERIOD_CURRENT,12,26,9,PRICE_CLOSE,MODE_SIGNAL,0);
          if((_cvDir > 0 && _md > 0) || (_cvDir < 0 && _md < 0)) _cvAgree++; }
        // Volume
        { double _v0 = (double)iVolume(NULL,PERIOD_CURRENT,0);
          double _v5 = 0; for(int _vi=1;_vi<=5;_vi++){if(_vi<Bars)_v5+=(double)iVolume(NULL,PERIOD_CURRENT,_vi);}
          _v5 /= 5.0;
          if(_v0 > _v5 * 1.1) _cvAgree++; }
        // Volatility: expanding ATR is favourable for the current signal
        { double _a0 = iATR(NULL,PERIOD_CURRENT,14,0);
          double _a5 = iATR(NULL,PERIOD_CURRENT,14,5);
          if(_a0 > 0 && _a5 > 0 && _a0 > _a5 * 1.05) _cvAgree++; }
        // Session
        { int _gH = (TimeHour(Time[shift]) - g_ServerTimeOffsetHours + 24) % 24;
          bool _peak = (_gH >= 7 && _gH < 21);
          if(_peak) _cvAgree++; }
        // Pattern
        { if(g_PatternState.patternBuySignal && _cvDir > 0) _cvAgree++;
          else if(g_PatternState.patternSellSignal && _cvDir < 0) _cvAgree++; }

        // Apply convergence bonus only for strong alignment
        if(_cvAgree >= 6)      totalScore += _cvDir * 6.0;  // perfect convergence
        else if(_cvAgree == 5) totalScore += _cvDir * 3.5;  // strong convergence
        // No bonus for 4 or fewer — no penalty either
    }

    // -- CEO CONVICTION AMPLIFIER (CCA) ------------------------------------─
    // When a high-IC component is at extreme conviction AND agrees with signal
    // direction, it earns additional influence — shifting the score toward threshold.
    // This detects missed potential wins where one intelligence has a strong view
    // that the consensus missed. Guards: min score 15, min IC 0.030, max +8pt.
    // NOT a threshold override — it raises the score, not lowers the gate.
    g_CEO_CCA_Active = false;
    if(!g_Calibration.isCalibrating && g_CorrelationsLearned && g_WeightsOptimized
       && regime >= 0 && regime < 9 && MathAbs(totalScore) > 15.0) {

        int    _ccaDir    = (totalScore > 0) ? 1 : -1;
        double _ccaBoost  = 0.0;
        int    _ccaPrimary = -1;
        double _ccaPrimaryBoost = 0.0;

        // Component max scores (unsigned) for normalisation
        double _ccaMax[6];
        _ccaMax[0]=36.0; _ccaMax[1]=25.0; _ccaMax[2]=15.0;
        _ccaMax[3]=15.0; _ccaMax[4]=10.0; _ccaMax[5]=20.0;

        double _ccaFloorIC = 0.030;  // IC noise floor — below this = not predictive
        double _ccaMaxIC   = 0.120;  // IC above this = max information content
        double _ccaExtThr  = 0.55;   // extremity threshold — below this = weak statement

        // Per-component: conviction extremity x IC quality - boost contribution
        for(int _cca_c = 0; _cca_c < 6; _cca_c++) {
            double _ic = MathAbs(g_RegimeIC[MathMin(8,MathMax(0,regime))][_cca_c]);
            if(_ic < _ccaFloorIC) continue;  // below noise floor — not predictive here

            double _ext = (_ccaMax[_cca_c] > 0) ? _ccaRaw[_cca_c] / _ccaMax[_cca_c] : 0.0;
            if(_ext < _ccaExtThr) continue;  // component not making a strong statement

            // IC normalised to [0,1] within meaningful range
            double _icN = MathMax(0.0, MathMin(1.0,
                         (_ic - _ccaFloorIC) / (_ccaMaxIC - _ccaFloorIC)));

            // Extremity excess above threshold, normalised
            double _extExcess = (_ext - _ccaExtThr) / (1.0 - _ccaExtThr);

            // Boost = IC quality x conviction extremity excess - max +2pt per component
            double _compBoost = _icN * _extExcess * 2.0;
            _ccaBoost += _compBoost;

            // Track which component is driving the most
            if(_compBoost > _ccaPrimaryBoost) {
                _ccaPrimaryBoost = _compBoost;
                _ccaPrimary = _cca_c;
            }
        }

        // Apply boost — capped at +8pt, direction-aware, minimum threshold to log
        _ccaBoost = MathMin(8.0, _ccaBoost);
        if(_ccaBoost >= 0.5) {  // only apply boosts worth recording
            totalScore += _ccaDir * _ccaBoost;
            g_CEO_CCA_Active     = true;
            g_CEO_CCA_LastBoost  = _ccaBoost;
            g_CEO_CCA_PrimaryComp = _ccaPrimary;
            // Log when CCA is the tipping factor (score crossed threshold due to boost)
            static datetime _ccaLogTime = 0;
            if(shift == 0 && TimeCurrent() - _ccaLogTime > 300 && !g_CalibSilent) {
                static const string _ccaNames[6] = {"MTF","Momentum","VolCtx","Volume","Session","Pattern"};
                string _primName = (_ccaPrimary >= 0 && _ccaPrimary < 6) ?
                    _ccaNames[_ccaPrimary] : "?";
                PrintFormat("  CEO   |   CCA   +%.1fpt   |   primary: %s (%.0f%% ext IC %.3f)   |   score %.1f",
                    _ccaBoost, _primName,
                    (_ccaPrimary>=0) ? _ccaRaw[_ccaPrimary]/_ccaMax[_ccaPrimary]*100 : 0.0,
                    (_ccaPrimary>=0) ? MathAbs(g_RegimeIC[regime][_ccaPrimary]) : 0.0,
                    totalScore);
                _ccaLogTime = TimeCurrent();
            }
        }
    }

    // ===== SLS12 T2: LEARNED INDICATOR CONFLUENCE =====
    // Fold the indicator ensemble into the score using the weights LEARNED during the Indicator
    // Intelligence phase (per-indicator IC, regime-conditioned). The contribution is bounded in
    // [-1..+1] by construction, scaled to a capped point band so it can tip a signal across the
    // threshold but never dominate the CEUS engine. Direction-correct: positive confluence adds
    // to bullish scores, negative to bearish. Zero-effect before intelligence is learned, so
    // this is fully backward-compatible until calibration runs. Live and calibration share this
    // exact path (T1 core), so they cannot diverge.
    if(g_IndIntelReady) {
        double _indC = GetIndicatorContribution(shift, regime);   // [-1..+1]
        // Learned blend strength: how much of the score the indicators may move. Scaled by how
        // much directional signal the ensemble actually carries on this instrument (sum of
        // weights is 1; average dirIC sets the trust). Capped at ±18 pts — meaningful, bounded.
        double _indCap = 18.0;
        totalScore += _indC * _indCap;
    }

    // ===== SLS13 S1: SCORE-INTEGRITY NORMALIZATION =====
    // DEFECT FIXED: raw score routinely reaches 250-350 under alignment while the old
    // saturation knee sat at 80 — so the top 3 aligned components already pinned the score
    // to ~100, destroying all resolution between a decent and an excellent setup. We now
    // normalize the raw score against a realistic strong-conviction reference so the FULL
    // 0..100 range discriminates: a perfect setup approaches 100, threshold-quality lands
    // at the threshold, partial alignment scores proportionally. Sign and order are strictly
    // preserved (bullish stays bullish, stronger stays higher) so NO downstream logic inverts.
    // Reference = the directional component caps scaled by THIS regime's calibrated weights
    // (the realistic ceiling a clean setup achieves), not the absurd all-bonus theoretical max.
    double _wM = (weights.mtf>0?weights.mtf:1.0), _wMo=(weights.momentum>0?weights.momentum:1.0);
    double _wV = (weights.volatility>0?weights.volatility:1.0), _wVo=(weights.volume>0?weights.volume:1.0);
    double _wS = (weights.session>0?weights.session:1.0), _wP=(weights.pattern>0?weights.pattern:1.0);
    // realistic strong-setup reference: core directional components aligned at calibrated weight
    double _refMax = 42.0*_wM + 25.0*_wMo + 18.0*_wV + 14.0*_wVo + 10.0*_wS + 22.0*_wP
                     + 20.0 + 18.0;   // + predictive band + indicator term (structural bonuses excluded: they're a tailwind, not required)
    if(_refMax < 60.0) _refMax = 60.0;   // floor: never divide by an unrealistically small ref
    // map raw onto 0..100 where _refMax -> ~88 (leaves headroom so exceptional stacking can push toward 100)
    double _norm = totalScore * (88.0 / _refMax);
    // gentle soft-knee only very near the top (|x|>92) so the discriminating zone is the full 0..92
    double _finalScore = (MathAbs(_norm) <= 92.0) ? _norm :
        MathSign(_norm) * (92.0 + 8.0*(1.0-1.0/(1.0+MathExp((MathAbs(_norm)-92.0)/6.0))));
    return MathMax(-100.0, MathMin(100.0, _finalScore));

}

// --─ L2 CALIBRATION — Phase 0: Score distribution analysis ------------
// GAP-3 FIX: Server Time Offset Auto-Detection
void DetectServerTimeOffset() {
    double hourVolume[24];
    int    hourCount[24];
    ArrayInitialize(hourVolume, 0.0);
    ArrayInitialize(hourCount, 0);
    
    int barsToScan = MathMin(3000, MathMax(0, Bars - 30));
    for(int bar = 10; bar < barsToScan; bar++) {
        int h = TimeHour(Time[bar]);
        if(h >= 0 && h < 24) {
            hourVolume[h] += (double)iVolume(Symbol(), 0, bar);
            hourCount[h]++;
        }
    }
    
    // Normalize to average volume per bar per hour
    double avgPerHour[24];
    double peakVol = 0;
    int    peakHour = 10; // default: UTC+2 -> server 10 = GMT 8
    for(int h = 0; h < 24; h++) {
        avgPerHour[h] = (hourCount[h] > 0) ? hourVolume[h] / hourCount[h] : 0;
        if(avgPerHour[h] > peakVol) {
            peakVol = avgPerHour[h];
            peakHour = h;
        }
    }
    
    // London open is 8:00 GMT. Peak volume hour = GMT 8.
    // Offset = peakHour - 8 (mod 24)
    int rawOffset = peakHour - 8;
    // Constrain to realistic broker range: -1 to +5 (UTC-1 to UTC+5)
    if(rawOffset < -1 || rawOffset > 5) {
        // Out of realistic range - use UTC+2 as safe default
        rawOffset = 2;
    }
    g_ServerTimeOffsetHours = rawOffset;
    g_TimeOffsetDetected = true;
    
    PrintFormat("  server time   |   UTC%+d   |   London at server hr %d   |   NY at server hr %d",
                g_ServerTimeOffsetHours, 8+g_ServerTimeOffsetHours, 13+g_ServerTimeOffsetHours);
}

struct AdaptiveRegimeThresholds {
    bool   calibrated;
    // Hurst distribution -> trend / mean-rev cut-points
    double hurstTrend;     // upper band (was 0.57)
    double hurstMeanRev;   // lower band (was 0.43)
    // ADX -> energy/trend-strength cut-points
    double adxEnergy;      // was 18
    double adxStrong;      // was 20
    // Directional gap -> direction confirmation
    double diGap;          // was 8
    // Fractal dimension -> complexity
    double fdComplex;      // was 1.55
    // Entropy -> unpredictability
    double entropyHigh;    // was 0.65
    // priceChange20 -> meaningful move
    double moveSig;        // was 0.01
    // SLS27-CLAUDE: structural-trend consensus cut-points. These were hardcoded (0.8 / 0.3
    // ATR) when the consensus was introduced in SLS(25) -- a one-size-fits-all constant in
    // a system that had already solved this problem with ART. Empirically, 0.8 ATR sits at
    // only the ~14th percentile of EURUSD-M5 displacement, far too permissive; the
    // instrument's own 60th percentile nearly tripled trend/chop discrimination
    // (+11.9 -> +32.4 against an orthogonal regression-R2 label). Now learned, not assumed.
    double emaDispTrend;   // |price-EMA200| in ATR: displacement that counts as "far" HERE
    double emaSlopeTrend;  // |20-bar change in that displacement|: slope that counts as "moving" HERE
    // WARRANT#8 (SLS29-FORGE): ema21Angle is already ATR-normalised at the point it's computed
    // (see the _atrA-normalised block in CalculateMarketFeatures), so the angle itself is
    // legal Form-3. But the CUT-POINTS applied to it (10.0 deg twice, 12.0 deg once, three
    // separate un-agreeing magic numbers) were never learned -- exactly the defect this file's
    // own audit flagged as still OPEN. Measured on 121,026 real EURUSD M5 bars: p93 of
    // |ema21Angle| = 10.54 deg, which is where both the old 10.0 and 12.0 cut-points actually
    // sit on this instrument (~p92-p95) -- so p93 preserves current fire-rate/behaviour on this
    // pass (legality conversion only; Stage 3 resurrection, not this stage, is where the
    // *rarity* itself would be re-examined).
    double ema21AngleTrend; // learned p93 of |ema21Angle|, was 10.0/10.0/12.0 hardcoded degrees
};
AdaptiveRegimeThresholds g_ART = {false, 0.57,0.43, 18.0,20.0, 8.0, 1.55, 0.65, 0.01, 0.8, 0.3, 10.54};

void AnalyzeScoreDistribution(int barsToAnalyze) {
    // Initialize scoreFrequency array (struct member)
    for(int i = 0; i < 101; i++) {
        g_ScoreDistribution.scoreFrequency[i] = 0;
    }
    
    double scores[];
    ArrayResize(scores, barsToAnalyze);
    int validScores = 0;

    // FIX60: sample the regime-character features on the SAME bars, to learn this
    // instrument's actual distribution and calibrate adaptive classifier thresholds.
    double _hArr[]; double _adxArr[]; double _diArr[]; double _fdArr[]; double _entArr[]; double _mvArr[];
    ArrayResize(_hArr, barsToAnalyze); ArrayResize(_adxArr, barsToAnalyze);
    ArrayResize(_diArr, barsToAnalyze); ArrayResize(_fdArr, barsToAnalyze);
    ArrayResize(_entArr, barsToAnalyze); ArrayResize(_mvArr, barsToAnalyze);
    int _artN = 0;

    g_ScoreDistribution.min = 999;
    g_ScoreDistribution.max = 0;
    double sum = 0;
    
    datetime startTime = TimeCurrent();
    int updateInterval = 2000;  // Update progress every 2000 bars
    
    // Silently scan all bars and collect scores
    for(int i = 0; i < barsToAnalyze && i < Bars - 100; i++) {
                        double score = CalculateEnhancedUnifiedScore(i);
        
        // Progress update
        if(i % updateInterval == 0 && i > 0) {
            ShowCompactProgress("Phase 0: Score Distribution", i, barsToAnalyze, startTime);
        }
        
        // FIX60: sample regime-character features (every 3rd bar keeps it light yet dense)
        if(i % 3 == 0 && _artN < barsToAnalyze) {
            double _hS = E99_HurstExponent(i, 100);
            double _adxS = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, i);
            double _pdiS = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_PLUSDI, i);
            double _mdiS = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MINUSDI, i);
            double _fdS = E99_FractalDimension(i, 50);
            double _entS = E99_MarketEntropy(i, 100);
            double _mvS = (i + 20 < Bars) ? MathAbs((Close[i] - Close[i+20]) / Close[i+20]) : 0.0;
            if(_hS > 0 && _hS < 1) {
                _hArr[_artN]   = _hS;
                _adxArr[_artN] = (_adxS > 0) ? _adxS : 0.0;
                _diArr[_artN]  = MathAbs(_pdiS - _mdiS);
                _fdArr[_artN]  = (_fdS > 1.0 && _fdS < 2.0) ? _fdS : 1.5;
                _entArr[_artN] = (_entS >= 0 && _entS <= 1.5) ? _entS : 0.5;
                _mvArr[_artN]  = _mvS;
                _artN++;
            }
        }

        // ARCH-7 FIX: Use MathAbs(score) so both bullish and bearish bars are included.
        double absScore = MathAbs(score);
        if(absScore <= 100) {
            scores[validScores] = absScore;
            validScores++;
            sum += absScore;
            if(absScore < g_ScoreDistribution.min) g_ScoreDistribution.min = absScore;
            if(absScore > g_ScoreDistribution.max) g_ScoreDistribution.max = absScore;
            int scoreInt = (int)MathRound(absScore);
            if(scoreInt >= 0 && scoreInt <= 100) g_ScoreDistribution.scoreFrequency[scoreInt]++;
        }
    }
    
    // Final progress
    ShowCompactProgress("Phase 0: Score Distribution", barsToAnalyze, barsToAnalyze, startTime);
    
    if(validScores == 0) {
        Print("  score distribution   |   no valid samples   |   check indicator data");
        g_ScoreDistribution.analysisComplete = false;
        return;
    }

    // FIX60: learn this instrument's regime-character thresholds from the sampled distribution.
    ART_Calibrate(_hArr, _adxArr, _diArr, _fdArr, _entArr, _mvArr, _artN);
    // SLS27-CLAUDE: learn the structural-consensus gates from this instrument too.
    ART_CalibrateStructural(barsToAnalyze);
    
    // Calculate statistics
    g_ScoreDistribution.totalSamples = validScores;
    g_ScoreDistribution.mean = sum / validScores;
    
    // Sort scores for percentile calculation
    ArraySort(scores, WHOLE_ARRAY, 0, MODE_ASCEND);
    
    g_ScoreDistribution.p25 = scores[(int)(validScores * 0.25)];
    g_ScoreDistribution.median = scores[(int)(validScores * 0.50)];
    g_ScoreDistribution.p50 = g_ScoreDistribution.median;
    // SLS23 FIX: p60/p70/p85 were never populated, so DetermineOptimalThreshold() always read
    // zero and always fell back to its own [60,80] sanity clamp -- the "adapt to measured score
    // distribution" logic never actually ran.
    g_ScoreDistribution.p60 = scores[(int)(validScores * 0.60)];
    g_ScoreDistribution.p70 = scores[(int)(validScores * 0.70)];
    g_ScoreDistribution.p75 = scores[(int)(validScores * 0.75)];
    g_ScoreDistribution.p85 = scores[(int)(validScores * 0.85)];
    g_ScoreDistribution.p90 = scores[(int)(validScores * 0.90)];
    g_ScoreDistribution.p95 = scores[(int)(validScores * 0.95)];
    // Aliases: minScore/maxScore map to min/max so both access paths are consistent
    g_ScoreDistribution.minScore = g_ScoreDistribution.min;
    g_ScoreDistribution.maxScore = g_ScoreDistribution.max;
    // stdDev: single-pass variance calculation over sorted scores
    {
        double _variance = 0.0;
        for(int _i = 0; _i < validScores; _i++)
            _variance += (scores[_i] - g_ScoreDistribution.mean) * (scores[_i] - g_ScoreDistribution.mean);
        g_ScoreDistribution.stdDev = SafeSqrt(_variance / validScores);
    }
    
    g_ScoreDistribution.analysisComplete = true;
}

double DetermineOptimalThreshold() {
    if(!g_ScoreDistribution.analysisComplete) return 68;  // Fallback
    
    // Data-driven threshold selection based on actual market scores
    double threshold;
    
    // If market is very weak (median < 55), be highly selective
    if(g_ScoreDistribution.median < 55) {
        threshold = g_ScoreDistribution.p85;  // Top 15% only
    }
    // If market is strong (median > 70), can be more aggressive
    else if(g_ScoreDistribution.median > 70) {
        threshold = g_ScoreDistribution.p60;  // Top 40%
    }
    // Standard market - target top 30%
    else {
        threshold = g_ScoreDistribution.p70;  // Top 30%
    }
    
    // Sanity bounds - only apply if NOT using calibrated regime-specific thresholds
    if(!g_WeightsOptimized) {
        if(threshold < 60) threshold = 60;
        if(threshold > 80) threshold = 80;
    }
    
    return threshold;
}

void ShowCompactProgress(string phaseName, int current, int total, datetime startTime) {
    double pct = (total > 0) ? (double)current / total * 100.0 : 0.0;  // FIX
    int elapsed = (int)(TimeCurrent() - startTime);
    
    // Build visual progress bar
    string bar = "[";
    int barWidth = 24;
    int filled = (int)(pct / 100.0 * barWidth);
    
    for(int i = 0; i < barWidth; i++) {
        if(i < filled) bar += "#";
        else bar += " ";
    }
    bar += "]";
    
    // Calculate ETA
    string etaStr = "";
    if(pct < 99 && elapsed > 0) {
        double rate = (double)current / elapsed;
        int eta = (int)((total - current) / MathMax(0.1, rate));
        if(eta > 0) {
            etaStr = StringFormat(" | ETA: %ds", eta);
        }
    }
    
    PrintFormat("%s %s %.0f%% | %d/%d | %ds%s",
               phaseName, bar, pct, current, total, elapsed, etaStr);
}

// --─ L2 CALIBRATION — Historical outcome analysis (E8 exam answers) --─
void AnalyzeHistoricalOutcomes() {
    // Derive historical learning metrics from ghost session results
    if(g_SmartCB.ghostWins + g_SmartCB.ghostLosses <= 0) return;
    int _wc = g_SmartCB.ghostWins;
    int _lc = g_SmartCB.ghostLosses;
    int _tot = _wc + _lc;
    g_HistoricalLearning.totalAnalyzed = _tot;
    g_HistoricalLearning.winners       = _wc;
    g_HistoricalLearning.losers        = _lc;
    // ADX-based discrimination: higher WR sessions correlate with higher ADX
    double _ghostWR = (_tot > 0) ? (double)_wc / _tot : 0.0;
    double _curADX  = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 1);
    if(_curADX == EMPTY_VALUE || _curADX <= 0) _curADX = 25.0;
    g_HistoricalLearning.avgScoreWinners = _ghostWR * 100.0;
    g_HistoricalLearning.avgScoreLosers  = (1.0 - _ghostWR) * 100.0;
    g_HistoricalLearning.adxWinnerAvg    = _curADX;
    g_HistoricalLearning.adxLoserAvg     = _curADX * 0.7;
    g_HistoricalLearning.adxDifferential = _curADX * 0.3;
    g_HistoricalLearning.minimumADX      = MathMax(15.0, _curADX * 0.5);
    g_HistoricalLearning.volumeWinnerAvg = 1.2;
    g_HistoricalLearning.volumeLoserAvg  = 0.8;
    g_HistoricalLearning.requireVolumeConfirmation = (_ghostWR < 0.65);
}



bool CheckCompoundSafeguards() {
    // Returns TRUE if trading allowed, FALSE if halted
    // NO emotional nonsense - pure mathematics
    
    datetime now = TimeCurrent();
    double currentBalance = AccountBalance();
    double currentEquity = AccountEquity();
    
    // CHECK #1: Hard Stop (Maximum Drawdown) - CIRCUIT BREAKER
    if(currentEquity > g_Safeguards.peakBalance) {
        g_Safeguards.peakBalance = currentEquity;
        if(g_Safeguards.currentDrawdownPercent > 0) {
            PrintFormat("  new peak   |   $%.0f   |   drawdown reset   |   CEO %.0f", AccountBalance(), g_CEO_CompetenceScore);
            g_Safeguards.currentDrawdownPercent = 0.0;
            g_Safeguards.inRecoveryMode = false;
            g_Safeguards.recoveryRiskMultiplier = 1.0;
        }
    } else {
        double drawdown = 0.0;
        if(g_Safeguards.peakBalance > 0) {
            drawdown = ((g_Safeguards.peakBalance - currentEquity) / NonZero(g_Safeguards.peakBalance)) * 100.0;
        }
        g_Safeguards.currentDrawdownPercent = drawdown;
        
        if(drawdown > g_Safeguards.longestDrawdown) {
            g_Safeguards.longestDrawdown = drawdown;
        }
        if(drawdown > g_Safeguards.largestDrawdown) {
            g_Safeguards.largestDrawdown = drawdown;
        }
        
        // HARD STOP - Only protection that halts trading
        if(drawdown >= MaxDrawdownPercent) {
            if(!g_Safeguards.hardStopTriggered) {
                PrintFormat("  HARD STOP   |   drawdown %.1f%%   |   limit %.1f%%", drawdown, MaxDrawdownPercent);
                
                LogCriticalEvent("HARD STOP: Maximum drawdown exceeded", "CRITICAL");
                g_Safeguards.hardStopTriggered = true;
            }
            return false; // Trading HALTED
        }
        
        // Warning level (info only)
        if(drawdown >= DrawdownWarningPercent && drawdown < MaxDrawdownPercent) {
            static datetime lastWarning = 0;
            if(now - lastWarning > 3600) {
                PrintFormat("  LIVE  |   drawdown   %.1f%%   |   %.1fpp to slingshot   |   %.0f%% of max",
                        drawdown, MathMax(0, RecoveryDrawdownTrigger - drawdown),
                        (drawdown/MaxDrawdownPercent)*100);
                lastWarning = now;
            }
        }
        
        // Enable recovery mode (reduces risk mathematically)
        if(EnableDrawdownRecovery && drawdown >= DrawdownRecoveryThreshold) {
            if(!g_Safeguards.inRecoveryMode) {
                PrintFormat("  SLING |   recovery mode   |   risk x0.60   |   protecting capital   |   floor %.1f%%", g_Risk.minRisk);
                g_Safeguards.inRecoveryMode = true;
            }
            // Calculate recovery multiplier: reduces risk as DD increases
            double ddRatio = drawdown / NonZero(MaxDrawdownPercent);
            g_Safeguards.recoveryRiskMultiplier = 1.0 - (ddRatio * 0.5); // 50% reduction at max
            g_Safeguards.recoveryRiskMultiplier = MathMax(0.3, g_Safeguards.recoveryRiskMultiplier);
        } else {
            g_Safeguards.inRecoveryMode = false;
            g_Safeguards.recoveryRiskMultiplier = 1.0;
        }
    }
    
    // CHECK #2: Broker Exposure Limit (REAL CONSTRAINT)
    if(EnableBrokerLimitCheck) {
        double margin = AccountMargin();
        double equity = AccountEquity();
        
        if(equity > 0) {
            double exposurePercent = (margin / NonZero(equity)) * 100.0;
            g_Safeguards.currentBrokerExposure = exposurePercent;
            
            if(exposurePercent >= MaxBrokerExposurePercent) {
                static datetime lastExposureLog = 0;
                if(now - lastExposureLog > 300) {
                    PrintFormat("  broker exposure   |   %.1f%%   |   no new trades", exposurePercent);
                    lastExposureLog = now;
                }
                g_Safeguards.brokerLimitReached = true;
                return false; // No new trades (real broker constraint)
            } else {
                g_Safeguards.brokerLimitReached = false;
            }
        }
    }
    
    // CHECK #3: Balance Milestones (INFORMATIONAL ONLY)
    if(EnableBalanceMilestones && currentBalance >= g_Safeguards.nextMilestone) {
        g_Safeguards.milestoneReached = true;
        g_Safeguards.milestoneReachedTime = now;
        g_Safeguards.totalMilestones++;
        
        double growthMultiplier = (g_Safeguards.lastMilestone > 0) ? 
                                 (currentBalance / NonZero(g_Safeguards.lastMilestone)) : 1.0;
        PrintFormat("  MILE  |   $%.0f   |   %.1fx growth", currentBalance, growthMultiplier);
        PrintFormat("  MILE  |   $%.0f   |   consider securing a portion", AccountBalance());
        
        LogCriticalEvent(StringFormat("Balance milestone: $%.0f", currentBalance), "MILESTONE");
        
        g_Safeguards.lastMilestone = currentBalance;
        g_Safeguards.nextMilestone = currentBalance * BalanceMilestoneMultiplier;
    }
    
    return true; // All checks passed - Trading ALLOWED 
}

void UpdateSafeguardsAfterTrade(bool wasWin, double profitLoss) {
    // Minimal tracking - no emotional nonsense
    // Just update statistics if needed
    
    // LIVE LEARNING: Update probability patterns with actual results
    if(g_ProbDB.calibrated && g_LastTradeEntry.recorded) {
        // Calculate profit percentage
        double equity = AccountEquity();
        double profitPct = (equity > 0) ? (profitLoss / equity) * 100.0 : 0.0;
        
        // Update probability pattern using stored entry conditions
        UpdateProbabilityPattern(
            g_LastTradeEntry.score, 
            g_LastTradeEntry.regime, 
            g_LastTradeEntry.atr, 
            g_LastTradeEntry.hour, 
            wasWin, 
            profitPct
        );
        
        // Log learning event
        static int learningUpdates = 0;
        learningUpdates++;
        
        if(learningUpdates % 10 == 0) {
            PrintFormat("  live learning   |   %d trades processed", learningUpdates);
        } else if(ShowOptimizationLogs) {
            string result = wasWin ? "win" : "LOSS";
        }
        
        // Clear recorded flag
        g_LastTradeEntry.recorded = false;
    }
    
    if(!wasWin) {
        double equity = AccountEquity();
        if(equity > 0) {
            double lossPercent = MathAbs(profitLoss / NonZero(equity)) * 100.0;
            if(lossPercent >= 2.0) {
                PrintFormat("  significant loss   |   %.1f%% of account", lossPercent);
            }
        }
    }
}

double GetSafeguardRiskMultiplier() {
    // Returns risk multiplier based on MATHEMATICAL conditions only
    double multiplier = 1.0;
    
    // Apply drawdown recovery (MATHEMATICAL)
    if(g_Safeguards.inRecoveryMode) {
        multiplier *= g_Safeguards.recoveryRiskMultiplier;
    }
    
    return MathMax(0.3, MathMin(1.0, multiplier));
}

void LogSafeguardsStatus() {
    // Log status periodically
    static datetime lastLog = 0;
    datetime now = TimeCurrent();
    
    if(now - lastLog < 3600) return; // Once per hour
    lastLog = now;
    
    string _recov2 = g_Safeguards.inRecoveryMode ? "   |   recovery mode" : "";
    PrintFormat("  LIVE  |   status   $%.2f   |   drawdown %.1f%%/%.0f%%   |   exposure %.1f%%   |   WR %.1f%%%s",
               AccountEquity(), g_Safeguards.currentDrawdownPercent, MaxDrawdownPercent,
               g_Safeguards.currentBrokerExposure, g_Risk.recentWinRate, _recov2);
}

