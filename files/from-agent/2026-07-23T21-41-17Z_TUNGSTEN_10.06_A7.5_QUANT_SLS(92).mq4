//| INTELLIGENT PHASE CORRECTION SYSTEM                              |
//| Each phase can diagnose failures and retry with adjustments      |

// Phase diagnostic structure
struct PhaseDiagnostic {
    bool success;                  // Did phase meet its goals?
    string failureReason;          // What exactly went wrong?
    string diagnosis;              // Root cause analysis
    string suggestedFix;           // How to fix it
    int retryCount;                // How many retries attempted
    int maxRetries;                // Maximum retries allowed
    bool canRetry;                 // Can this be fixed by retry?
    bool isFatal;                  // Fundamental flaw requiring manual fix?
    
    // Detailed metrics for diagnosis
    double actualValue;            // What we got
    double targetValue;            // What we needed
    double percentageOfTarget;     // How close we got
    
    // Phase-specific diagnostics
    int phase1_barsCollected;
    int phase1_targetBars;
    int phase1_featureErrors;
    
    int phase2_regimesFound;
    int phase2_regimesNeeded;
    double phase2_largestRegimePct;
    double phase2_smallestRegimePct;
    
    double phase3_boundaryClarity;
    double phase3_overlapPct;
    
    double phase4_accuracy;
    double phase4_targetAccuracy;
    int phase4_misclassifications;
    
    double ghost_bestWR;
    double ghost_targetWR;
    int ghost_totalTrades;
};

PhaseDiagnostic g_Phase1Diagnostic;
