// NEW: Log regime changes with context
void LogRegimeChange() {
    static int lastRegimeLogged = -1;
    static int pendingRegime = -1;
    static datetime regimeChangeTime = 0;
    
    int currentRegime = (int)engine.regime;
    
    // CRITICAL FIX #24: Add hysteresis to prevent rapid regime oscillation
    // Require regime to stay changed for 30 seconds before logging/accepting
    if(currentRegime != lastRegimeLogged) {
        if(currentRegime != pendingRegime) {
            // New regime detected, start timer
            pendingRegime = currentRegime;
            regimeChangeTime = TimeCurrent();
            return;  // Don't log yet
        } else {
            // Same pending regime, check if 30 seconds elapsed
            if(TimeCurrent() - regimeChangeTime < 30) {
                return;  // Still pending
            }
            // 30 seconds elapsed, regime change confirmed
        }
    } else {
        // Regime same as last logged, reset pending
        pendingRegime = -1;
        return;  // No change
    }
    
    // Get regime name
    string regimeName = "";
    string implication = "";
    
    switch(engine.regime) {
        case REGIME_ULTRA_BULLISH:
            regimeName = "Ultra-Bullish";
            implication = "Extremely strong uptrend - favoring long positions with extended targets";
            break;
        case REGIME_STRONG_BULLISH:
            regimeName = "Strong Bullish";
            implication = "Solid uptrend - long positions preferred";
            break;
        case REGIME_BULLISH:
            regimeName = "Bullish";
            implication = "Upward bias - cautiously favoring longs";
            break;
        case REGIME_NEUTRAL_BULLISH:
            regimeName = "Neutral-Bullish";
            implication = "Slight bullish lean - selective long opportunities";
            break;
        case REGIME_CONSOLIDATION:
            regimeName = "Consolidation";
            implication = "Range-bound market - waiting for breakout confirmation";
            break;
        case REGIME_NEUTRAL_BEARISH:
            regimeName = "Neutral-Bearish";
            implication = "Slight bearish lean - selective short opportunities";
            break;
        case REGIME_BEARISH:
            regimeName = "Bearish";
            implication = "Downward bias - cautiously favoring shorts";
            break;
        case REGIME_STRONG_BEARISH:
            regimeName = "Strong Bearish";
            implication = "Solid downtrend - short positions preferred";
            break;
        case REGIME_ULTRA_BEARISH:
            regimeName = "Ultra-Bearish";
            implication = "Extremely strong downtrend - favoring short positions with extended targets";
            break;
        case REGIME_MICRO_BREAKOUT:
            regimeName = "Micro-Breakout";
            implication = "Potential breakout forming - preparing for directional move";
            break;
        case REGIME_VOLATILITY_SPIKE:
            regimeName = "Volatility Spike";
            implication = "Sharp volatility increase - reducing position sizes, tighter stops";
            break;
        case REGIME_UNDEFINED:
            regimeName = "Undefined";
            implication = "Market transitioning - awaiting clearer signals";
            break;
        default:
            regimeName = StringFormat("Unknown (%d)", currentRegime);
            implication = "Analyzing market structure";
            break;
    }
    
    // Show transition if we had a previous regime
    if(lastRegimeLogged != -1) {
        string _awR2 = g_Awareness.isValid ? ("  [" + g_Awareness.awarenessNote + "]") : "";
        PrintFormat("  regime - %s   |   %s%s", regimeName, implication, _awR2);
    }
    lastRegimeLogged = currentRegime;
}

// Example minimal integration snippet (safe, non-destructive) - place inside E99_ProcessExecutionDecisions where decisions are evaluated:
#define MAX_STRUCTURE_CANDLES 30

struct CandleSnapshot {
   double open;
   double close;
   double high;
   double low;
   double body;
   double wickTop;
   double wickBottom;
   double range;
};

CandleSnapshot CandleHistory[MAX_STRUCTURE_CANDLES];
int CandleHistoryCount = 0;

// Populate the CandleHistory sliding window (most recent MAX_STRUCTURE_CANDLES candles)
void UpdateCandleHistory()
{
    int maxc = MAX_STRUCTURE_CANDLES;
    // Ensure we have at least 2 bars
    int barsAvail = Bars(_Symbol, PERIOD_M5);
    int limit = MathMin(maxc, barsAvail);
    if(limit <= 0) {
        CandleHistoryCount = 0;
        return;
    }
    CandleHistoryCount = limit;
    for(int i = 0; i < limit; i++) {
        CandleHistory[i].open = iOpen(_Symbol, PERIOD_M5, i);
        CandleHistory[i].close = iClose(_Symbol, PERIOD_M5, i);
        CandleHistory[i].high = iHigh(_Symbol, PERIOD_M5, i);
        CandleHistory[i].low = iLow(_Symbol, PERIOD_M5, i);
        CandleHistory[i].body = MathAbs(CandleHistory[i].close - CandleHistory[i].open);
        CandleHistory[i].range = CandleHistory[i].high - CandleHistory[i].low;
        CandleHistory[i].wickTop = CandleHistory[i].high - MathMax(CandleHistory[i].open, CandleHistory[i].close);
        CandleHistory[i].wickBottom = MathMin(CandleHistory[i].open, CandleHistory[i].close) - CandleHistory[i].low;
    }
}

// Analyze larger structure and return a structure score (positive -> bullish, negative -> bearish)
// This score is intentionally bounded and conservative so it nudges thresholds, not replaces them.
double AnalyzeDynamicStructure()
{
    if(CandleHistoryCount < 3) return 0.0;
    int window = CandleHistoryCount;
    // adaptive window: reduce sensitivity in very volatile markets
    double atr = intelligence.atrVolatility;
    if(atr <= 0) atr = MarketInfo(_Symbol, MODE_POINT) * 10.0; // fallback
    int evalWindow = window;
    if(atr > 0 && atr > MarketInfo(_Symbol, MODE_POINT) * 50.0) {
        evalWindow = MathMax(8, window/2);
    } else {
        evalWindow = MathMin(window, MAX_STRUCTURE_CANDLES);
    }

    double score = 0.0;
    double avgRange = 0.0;
    for(int i=0;i<evalWindow;i++) avgRange += CandleHistory[i].range;
    avgRange = (evalWindow>0) ? avgRange / evalWindow : 0.0;

    // Trend persistence: count consecutive directional closes (momentum)
    int bullCount = 0, bearCount = 0;
    for(int i=0;i<evalWindow-1;i++) {
        if(CandleHistory[i].close > CandleHistory[i+1].close) bullCount++;
        if(CandleHistory[i].close < CandleHistory[i+1].close) bearCount++;
    }
    // Normalize
    double trendBias = (double)(bullCount - bearCount) / (double)MathMax(1, evalWindow-1);

    // Wick pressure: many top wicks -> sellers; many bottom wicks -> buyers
    int topWicks=0, bottomWicks=0;
    for(int i=0;i<evalWindow;i++) {
        if(CandleHistory[i].wickTop > CandleHistory[i].body * 1.2) topWicks++;
        if(CandleHistory[i].wickBottom > CandleHistory[i].body * 1.2) bottomWicks++;
    }
    double wickBias = (double)(bottomWicks - topWicks) / (double)MathMax(1, evalWindow);

    // Compression detection (squeeze): low avgRange relative to ATR
    double compression = 0.0;
    if(atr > 0) compression = MathMax(0.0, (atr - avgRange) / (atr + 1e-9));

    // Score composition (bounded)
    score += trendBias * 6.0;      // trend has meaningful weight
    score += wickBias * 4.0;       // wick bias supports/contradicts trend
    score += compression * 3.0;    // compression slightly favors breakout bias

    // bound score to reasonable range [-12..12]
    if ((double)score > 12.0) score = 12.0;
    if(score < -12.0) score = -12.0;
    return score;
}

// Translate structure score into threshold adjustments. The adjustment mechanism is conservative:
// - Positive structureScore tightens buy threshold and loosens sell threshold (favoring buys)
// - Negative structureScore tightens sell threshold and loosens buy threshold (favoring sells)
// Returned pair: buyAdj (added to buy threshold), sellAdj (added to sell threshold) -- these adjustments are small

// NOTE: Integration point (safe): call UpdateCandleHistory(); double sScore = AnalyzeDynamicStructure();

void GenerateAndExecuteSignals(){
    // CRITICAL: Execute actual trade logic

    // Call the high-frequency signal generation which leads to OrderSend
    GenerateHighFrequencySignals();
}



