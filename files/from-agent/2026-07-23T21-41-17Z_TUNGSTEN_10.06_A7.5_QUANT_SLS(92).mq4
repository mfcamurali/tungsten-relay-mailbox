// E9.9 EXECUTION ENGINE RISK-REWARD ANALYSIS SYSTEM
struct RiskRewardOpportunity {
    // Edge Analysis
    double edgeStrength;              // 0.0-1.0: How strong is our edge?
    double edgeClarity;               // 0.0-1.0: How clear/obvious is the edge?
    double edgeConsistency;           // 0.0-1.0: How consistent across indicators?
    bool hasStatisticalEdge;          // True if edge is statistically significant
    
    // Risk Assessment
    double riskScore;                 // 0.0-1.0: Overall risk level
    double marketRisk;                // Volatility, spread, liquidity risks
    double executionRisk;             // Slippage, timing risks
    double correlationRisk;           // Portfolio correlation risk
    double maxAcceptableRisk;         // Max % we can risk
    
    // Reward Assessment
    double rewardPotential;           // 0.0-1.0: Reward quality
    double expectedValue;             // Statistical expected value
    double riskRewardRatio;           // Actual RR ratio for this setup
    double profitProbability;         // Probability of profit
    
    // Position Sizing
    double basePositionSize;          // Base size (1.0 = normal)
    double confidenceMultiplier;      // Multiplier based on confidence (0.5-2.0)
    double riskAdjustment;            // Adjustment for risk (0.5-1.0)
    double finalPositionSize;         // Final position multiplier
    
    // Decision Factors
    bool isHighConfidenceSetup;       // Clear edge + low risk
    bool isModerateSetup;             // Good edge + moderate risk
    bool isLowConfidenceSetup;        // Weak edge or high risk
    
    string edgeType;                  // What's the primary edge?
    string riskFactors;               // What are the main risks?
    
    // Safety Checks
    bool passesRiskCheck;
    bool passesEdgeCheck;
    bool passesExecutionCheck;
    int safetyChecksPassed;
};

// INTELLIGENT DECISION COMPONENT (Data-driven like Taylor)
struct IntelligentComponent {
    string name;
    
    // Signal Analysis
    double signalStrength;            // -1.0 to +1.0
    double signalQuality;             // 0.0-1.0: How reliable is this signal?
    double signalConsistency;         // Historical consistency
    
    // Edge Assessment
    double edgeContribution;          // How much edge does this add?
    double confidenceLevel;           // 0.0-1.0: Our confidence
    
    // Risk Assessment
    double riskContribution;          // How much risk does this add?
    double falseSignalRate;           // Historical false signal rate
    
    // Performance Tracking
    int recentSignals[12];            // By regime
    int correctSignals[12];           // Correct signals by regime
    double averageProfit[12];         // Average profit when correct
    double averageLoss[12];           // Average loss when wrong
    double sharpeRatio[12];           // Sharpe ratio by regime
    
    // Weighting
    double baseWeight;
    double performanceWeight;         // Based on actual profitability
    double riskAdjustedWeight;        // Adjusted for risk delivered
    double effectiveWeight;
    
    // Vote
    double vote;                      // Final weighted vote
    
    datetime lastUpdate;
};

// REGIME-SPECIFIC STRATEGY (What works in each regime)
struct RegimeStrategy {
    // Risk Parameters
    double maxPositionSize;           // Max position multiplier
    double maxRiskPercent;            // Max risk %
    double requiredEdgeStrength;      // Minimum edge required
    
    // Component Weights (What matters most in this regime)
    double momentumWeight;
    double reversalWeight;
    double volatilityWeight;
    double biasWeight;
    double patternWeight;
    double predictiveWeight;
    
    // Profit Targets
    double conservativeTP;            // Conservative TP multiplier
    double aggressiveTP;              // Aggressive TP multiplier
    double optimalTP;                 // Optimal TP for this regime
    
    // Risk Tolerance
    double riskTolerance;             // 0.5-1.5: How much risk to accept
    bool allowAggressive;             // Allow aggressive sizing
    
    // Historical Performance
    double winRate;
    double profitFactor;
    double sharpeRatio;
};

// E9.9 EXECUTION ENGINE DECISION STATE (Rational, calculated)
struct E99_ExecutionState {
    // Analysis Results
    RiskRewardOpportunity opportunity;
    
    // Decision Path
    bool edgeIdentified;              // Phase 2.1: Found an edge?
    bool riskAcceptable;              // Phase 2.2: Risk manageable?
    bool executionViable;             // Phase 2.3: Can execute well?
    
    // Position Sizing Decision
    double calculatedSize;            // Math-based size
    double riskAdjustedSize;          // Risk-adjusted size
    double finalSize;                 // Final decision
    
    // Take Profit Strategy
    double conservativeTP;            // Safe TP target
    double optimalTP;                 // Optimal TP target
    double aggressiveTP;              // Stretch TP target
    double selectedTP;                // Chosen TP
    
    // Stop Loss Strategy
    double tightSL;                   // Tight stop
    double normalSL;                  // Normal stop
    double wideSL;                    // Wide stop
    double selectedSL;                // Chosen SL
    
    // Execution Decision
    bool approvedForExecution;
    string rejectionReason;
    int confidenceScore;              // 0-100
    
    // Performance Tracking
    double expectedProfit;
    double expectedLoss;
    double expectedValue;
    double kellyCriterion;            // Kelly optimal size
};


//| INTELLIGENT RETRY SYSTEM OVERVIEW                                |
// - Phase 0: Can't classify market - Try broader regime boundaries
// - Phase 1: WR < 65% - Try different threshold/weights

// Diagnostic results for each phase
struct PhaseFailureDiagnostic {
    // What failed
    int    phaseId;          // phase number (was string phaseName)
    int phaseNumber;
    datetime failureTime;
    
    // Root cause identification
    bool lowWinRate;              // WR below target
    bool insufficientTrades;      // Not enough trades generated
    bool highVolatility;          // Market too volatile
    bool lowVolatility;           // Market too quiet
    bool wrongRegime;             // Regime classification issue
    bool poorParameterFit;        // Parameters don't match market
    bool excessiveDrawdown;       // Trades losing too much
    
    // Specific metrics that failed
    double actualWinRate;
    double targetWinRate;
    int actualTrades;
    int targetTrades;
    double actualVolatility;
    double marketEfficiency;      // How predictable market is
    
    // Strategic fix to apply
    int    fixCode;          // fix code (was string strategicFix)
    bool lowerThreshold;          // Make entry easier
    bool raiseThreshold;          // Make entry stricter
    bool adjustWeights;           // Change component weights
    bool changeRegimeLogic;       // Reclassify market
    bool extendTestPeriod;        // Test more data
    bool changeTimeframe;         // Try different bars
    
    // Retry tracking
    int retryAttempt;
    int maxRetries;
    bool canRetry;
};

// Global diagnostic state (COMMENTED OUT - using PhaseDiagnostic instead)
// PhaseFailureDiagnostic g_Phase0Diagnostic;
// PhaseFailureDiagnostic g_Phase1Diagnostic;

// Strategic retry state

//| INTELLIGENT RETRY SYSTEM                                         |

// Retry tracking structure
struct PhaseRetrySystem {
    // Phase 0 - Regime Learning
    int phase0Attempts;
    int phase0MaxAttempts;
    string phase0FailureReason;
    double phase0LastAccuracy;
    int phase0Strategy;  // 0=normal, 1=broader, 2=narrower, 3=alternative
    
    // Phase 1 - Parameter Optimization
    int phase1Attempts;
    int phase1MaxAttempts;
    string phase1FailureReason;
    double phase1BestWR;
    int phase1Strategy;  // 0=normal, 1=extreme_ranges, 2=conservative, 3=aggressive
    
    // Phase 2 - Regime Optimization
    int phase2Attempts;
    int phase2MaxAttempts;
    string phase2FailureReason;
    
    // Phase 3 - Ghost Validation
    int phase3Attempts;
    int phase3MaxAttempts;
    string phase3FailureReason;
    double phase3LastWR;
    int phase3TotalTrades;
    int phase3Strategy;  // 0=normal, 1=looser_tp, 2=tighter_sl, 3=different_regime
    
    // Global retry tracking
    int totalCalibrationAttempts;
    int maxTotalAttempts;
    bool intelligenceGained;
};

PhaseRetrySystem g_RetrySystem;

//| Initialize Retry System                                          |
void InitializeRetrySystem() {
    g_RetrySystem.phase0Attempts = 0;
    g_RetrySystem.phase0MaxAttempts = 3;
    g_RetrySystem.phase0Strategy = 0;
    
    g_RetrySystem.phase1Attempts = 0;
    g_RetrySystem.phase1MaxAttempts = 3;
    g_RetrySystem.phase1Strategy = 0;
    
    g_RetrySystem.phase2Attempts = 0;
    g_RetrySystem.phase2MaxAttempts = 2;
    
    g_RetrySystem.phase3Attempts = 0;
    g_RetrySystem.phase3MaxAttempts = 2;
    g_RetrySystem.phase3Strategy = 0;
    
    g_RetrySystem.totalCalibrationAttempts = 0;
    g_RetrySystem.maxTotalAttempts = 5;
    g_RetrySystem.intelligenceGained = false;
}

//| Analyze Phase 3 Failure - Returns intelligent retry strategy     |

//| Apply Intelligent Retry Strategy for Phase 3                     |

//| Analyze Phase 1 Failure - Parameter optimization didn't hit 65%  |

//| Analyze Phase 0 Failure - Regime learning didn't achieve accuracy|


//| Diagnose Why Phase Failed - ROOT CAUSE ANALYSIS                  |
PhaseFailureDiagnostic DiagnosePhaseFailure(int phaseNum, double actualWR, int actualTrades, double threshold) {
    PhaseFailureDiagnostic diag;
    
    diag.phaseNumber = phaseNum;
    diag.failureTime = TimeCurrent();
    diag.actualWinRate = actualWR;
    diag.actualTrades = actualTrades;
    diag.retryAttempt = 0;
    diag.maxRetries = 2;
    diag.canRetry = true;
    
    // Analyze root cause based on phase
    if(phaseNum == 0) {
        diag.phaseId = 0;  // was string phaseName
        diag.targetWinRate = 0;  // No WR target for Phase 0
        diag.targetTrades = 0;
        
        // Phase 0 failure = can't classify market regimes
        diag.wrongRegime = true;
        diag.fixCode = 0;  // was string strategicFix
        diag.changeRegimeLogic = true;
        diag.extendTestPeriod = true;
    }
    else if(phaseNum == 1) {
        diag.phaseId = 0;  // was string phaseName
        diag.targetWinRate = 65.0;
        diag.targetTrades = 30;
        
        // Analyze why parameter optimization failed
        if(actualWR < 60.0) {
            // Win rate too low - parameters don't fit market
            diag.lowWinRate = true;
            diag.poorParameterFit = true;
            
            if(threshold > 70) {
                diag.fixCode = 0;  // was string strategicFix
                diag.lowerThreshold = true;
            } else if(threshold < 60) {
                diag.fixCode = 0;  // was string strategicFix
                diag.raiseThreshold = true;
            } else {
                diag.fixCode = 0;  // was string strategicFix
                diag.adjustWeights = true;
            }
        }
        
        if(actualTrades < 30) {
            // Not enough trades - threshold too strict
            diag.insufficientTrades = true;
            diag.fixCode = 0;  // was string strategicFix
            diag.lowerThreshold = true;
        }
    }
    else if(phaseNum == 2) {
        diag.phaseId = 0;  // was string phaseName
        diag.targetWinRate = 65.0;
        diag.targetTrades = 20;
        
        // Phase 2 failure = wrong regime classification
        diag.wrongRegime = true;
        diag.fixCode = 0;  // was string strategicFix
        diag.changeRegimeLogic = true;
    }
    else if(phaseNum == 3) {
        diag.phaseId = 0;  // was string phaseName
        diag.targetWinRate = 60.0;
        diag.targetTrades = 30;
        
        // Analyze ghost mode failure
        if(actualWR < 55.0) {
            // Severe WR issue
            diag.lowWinRate = true;
            diag.poorParameterFit = true;
            diag.fixCode = 0;  // was string strategicFix
            diag.lowerThreshold = true;
            diag.adjustWeights = true;
        }
        else if(actualWR < 60.0) {
            // Marginal WR - try adjustment
            diag.lowWinRate = true;
            diag.fixCode = 0;  // was string strategicFix
            diag.lowerThreshold = true;
        }
        
        if(actualTrades < 30) {
            diag.insufficientTrades = true;
            diag.fixCode = 0;  // was string strategicFix
            diag.lowerThreshold = true;
        }
    }
    
    return diag;
}

//| Apply Strategic Fix Based on Diagnosis                           |

//| Reset for Full Recalibration from Phase 0                        |

// Global intelligent components
IntelligentComponent momentumIntel;
IntelligentComponent reversalIntel;
IntelligentComponent volatilityIntel;
IntelligentComponent biasIntel;
IntelligentComponent patternIntel;
IntelligentComponent predictiveIntel;

RegimeStrategy regimeStrategies[12];
E99_ExecutionState taylorDecision;

// Risk control globals
double maxDailyRiskUsed = 0.0;
double maxPortfolioHeat = 0.0;
int consecutiveStopOuts = 0;
bool conservativeModeActive = false;

// STEP 3: ADD INITIALIZATION (Insert into InitializeEnhancedSystem)

void E99_InitComponentTracking() {
    // Initialize intelligent components
    InitializeIntelligentComponent(momentumIntel, "Momentum");
    InitializeIntelligentComponent(reversalIntel, "Reversal");
    InitializeIntelligentComponent(volatilityIntel, "Volatility");
    InitializeIntelligentComponent(biasIntel, "Bias");
    InitializeIntelligentComponent(patternIntel, "Pattern");
    InitializeIntelligentComponent(predictiveIntel, "Predictive");
    
    // Initialize regime strategies with BALANCED parameters
    E99_InitRegimeStrategies();
    
    // Initialize Taylor decision state
    taylorDecision.edgeIdentified = false;
    taylorDecision.riskAcceptable = false;
    taylorDecision.executionViable = false;
    taylorDecision.approvedForExecution = false;
    taylorDecision.confidenceScore = 0;
    
    // Initialize risk controls
    maxDailyRiskUsed = 0.0;
    maxPortfolioHeat = 0.0;
    consecutiveStopOuts = 0;
    conservativeModeActive = false;
    
    LogCriticalEvent("E9.9 COMPONENT TRACKING INITIALIZED", "TAYLOR");
}

void InitializeIntelligentComponent(IntelligentComponent &comp, string name) {
    comp.name = name;
    comp.signalStrength = 0.0;
    comp.signalQuality = 0.5;
    comp.signalConsistency = 0.5;
    comp.edgeContribution = 0.5;
    comp.confidenceLevel = 0.5;
    comp.riskContribution = 0.5;
    comp.falseSignalRate = 0.5;
    comp.baseWeight = 1.0;
    comp.performanceWeight = 1.0;
    comp.riskAdjustedWeight = 1.0;
    comp.effectiveWeight = 1.0;
    comp.vote = 0.0;
    comp.lastUpdate = 0;
    
    for(int i = 0; i < 12; i++) {
        comp.recentSignals[i] = 0;
        comp.correctSignals[i] = 0;
        comp.averageProfit[i] = 0.0;
        comp.averageLoss[i] = 0.0;
        comp.sharpeRatio[i] = 0.0;
    }
}

