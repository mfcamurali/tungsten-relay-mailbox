    lastDump = TimeCurrent();
    if(!g_CalibSilent) PrintFormat("  LIVE  |   state   %s   |   score %.1f   |   thresholds %.0f/%.0f   |   regime %d   |   ATR %.5f",
                TimeToString(TimeCurrent(), TIME_SECONDS),
                engine.unifiedScore,
                (thresholdIntelligence.currentThresholds[0]==0 ? (double)ENHANCED_BUY_THRESHOLD : thresholdIntelligence.currentThresholds[0]),
                (thresholdIntelligence.currentThresholds[1]==0 ? (double)ENHANCED_SELL_THRESHOLD : thresholdIntelligence.currentThresholds[1]),
                (int)engine.regime,
                intelligence.atrVolatility);
}


