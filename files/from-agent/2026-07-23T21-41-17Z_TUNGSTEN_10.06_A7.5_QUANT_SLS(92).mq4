// --─ L9 LOGGING — Contextual log filter (feeds unified logging engine) ─
string g_LastLogMessage = "";
datetime g_LastLogTime = 0;
int g_LogRepeatCount = 0;
bool g_VerboseMode = false;  // Set true for debugging only

void PrintClean(string message) {
    // Suppress duplicate messages within 3 seconds
    if(message == g_LastLogMessage && TimeCurrent() - g_LastLogTime < 3) {
        g_LogRepeatCount++;
        if(g_LogRepeatCount > 1) return;  // Allow 1 repeat max
    } else {
        g_LogRepeatCount = 0;
    }
    
    Print(message);
    g_LastLogMessage = message;
    g_LastLogTime = TimeCurrent();
}

void PrintEmpathetic(string context, string message) {
    // Context-aware logging - only shows what user needs when they need it
    // Context types: "calibration", "trading", "error", "milestone"
    
    if(context == "calibration") {
        // During calibration: minimal updates, major milestones only
        if(StringFind(message, "PHASE") >= 0 || 
           StringFind(message, "COMPLETE") >= 0 ||
           StringFind(message, "FAILED") >= 0) {
            PrintClean(message);
        }
        // Skip verbose progress updates
    }
    else if(context == "trading") {
        // During trading: trades and significant events only
        if(StringFind(message, "BUY") >= 0 || 
           StringFind(message, "SELL") >= 0 ||
           StringFind(message, "CLOSED") >= 0 ||
           StringFind(message, "MILESTONE") >= 0) {
            PrintClean(message);
        }
    }
    else if(context == "error") {
        // Always show errors
        Print("  ! " + message);
    }
    else if(context == "milestone") {
        // Always show milestones
        PrintClean("*** " + message + " ***");
    }
    else if(g_VerboseMode) {
        // Only if user explicitly wants verbose
        PrintClean(message);
    }
}

