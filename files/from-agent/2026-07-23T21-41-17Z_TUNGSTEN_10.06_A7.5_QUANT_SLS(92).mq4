// --─ L1/L6 READINESS & EXECUTION — Runtime update functions ------------

void E99_UpdateMilestones() {
    static datetime lastCheck = 0;
    if(TimeCurrent() - lastCheck < 300) return;
    lastCheck = TimeCurrent();
    
    double currentBal = AccountBalance();
    g_E99_Milestones.currentBalance = currentBal;
    
    if(currentBal > g_E99_Milestones.allTimePeak) {
        g_E99_Milestones.allTimePeak = currentBal;
    }
    
    // Check achievements
    for(int i = 0; i < 10; i++) {  // All 10 milestones — no ceiling
        if(!g_E99_Milestones.milestones[i].achieved && 
           currentBal >= g_E99_Milestones.milestones[i].targetBalance) {
            
            g_E99_Milestones.milestones[i].achieved = true;
            g_E99_Milestones.milestones[i].achievedAt = TimeCurrent();
            g_E99_Milestones.currentLevel = i + 1;
            
            if(i + 1 > g_E99_Milestones.peakLevel) {
                g_E99_Milestones.peakLevel = i + 1;
            }
            
            if(i == 2) {
                g_E99_Milestones.milestones[i].locked = true;
                Print("  milestone locked   |   10x growth confirmed");
            }
            else if(i == 3) {
                Print("  $1,000,000   |   target reached");
            }

            PrintFormat("  milestone %d achieved   |   %s", (i+1), g_E99_Milestones.milestones[i].name);
        }
    }
    
    // Check sliding
    if(g_E99_Milestones.currentLevel > 0) {
        int idx = g_E99_Milestones.currentLevel - 1;
        if(idx >= 0 && idx < 10 && !g_E99_Milestones.milestones[idx].locked) {
            double target = g_E99_Milestones.milestones[idx].targetBalance;
            if(currentBal < target * 0.80) {
                g_E99_Milestones.currentLevel--;
                g_E99_Milestones.milestones[idx].achieved = false;
                g_E99_Milestones.timesSlid++;
                PrintFormat("  milestone slid back from level %d/%d", (idx+1), 10);
            }
        }
    }
    
    g_E99_Milestones.distanceToMillion = MathMax(0, 1000000.0 - currentBal);
    g_E99_Milestones.percentToMillion = (currentBal / 1000000.0) * 100.0;
}

void E99_UpdateBeehive() {
    static datetime lastCheck = 0;
    if(TimeCurrent() - lastCheck < 300) return;  // 5-min throttle
    
    // Update all subsystems that need monitoring
    E99_UpdateAllBeehiveSubsystems();
    lastCheck = TimeCurrent();
    
    int operational = 0;
    int optimal = 0;
    
    if(g_E99_Beehive.calibration.operational) operational++;
    if(g_E99_Beehive.probabilityDB.operational) operational++;
    if(g_E99_Beehive.regimeBanks.operational) operational++;
    if(g_E99_Beehive.patternMicro.operational) operational++;
    if(g_E99_Beehive.patternMacro.operational) operational++;
    if(g_E99_Beehive.scenarios.operational) operational++;
    if(g_E99_Beehive.dynamicRisk.operational) operational++;
    if(g_E99_Beehive.threshold.operational) operational++;
    if(g_E99_Beehive.recovery.operational) operational++;
    
    if(g_E99_Beehive.calibration.optimal) optimal++;
    if(g_E99_Beehive.probabilityDB.optimal) optimal++;
    if(g_E99_Beehive.regimeBanks.optimal) optimal++;
    if(g_E99_Beehive.patternMicro.optimal) optimal++;
    if(g_E99_Beehive.patternMacro.optimal) optimal++;
    if(g_E99_Beehive.scenarios.optimal) optimal++;
    if(g_E99_Beehive.dynamicRisk.optimal) optimal++;
    if(g_E99_Beehive.threshold.optimal) optimal++;
    if(g_E99_Beehive.recovery.optimal) optimal++;
    
    g_E99_Beehive.subsystemsOperational = operational;
    g_E99_Beehive.subsystemsOptimal = optimal;
    
    
    g_E99_Beehive.beehiveSynchronized = (operational >= 7 && optimal >= 5);
    g_E99_Beehive.allSystemsGo = (operational == 9 && optimal >= 7);

    // Phase 2 regime quality: current regime's calibrated strength feeds readiness
    int _bhReg = g_RegimeState.currentRegime;
    bool _bhInStrongRegime = false;
    double _bhRegQuality = 0.5;
    if(g_CorrelationsLearned && _bhReg >= 0 && _bhReg < 9) {
        double _bhSWR  = SAFE_SIGNAL_WR(_bhReg);
        double _bhEntr = g_RegimeCorrelations[_bhReg].avgEntropy;
        int    _bhN    = g_RegimeCorrelations[_bhReg].signalTotal;
        if(_bhN >= 5 && _bhSWR > 0) {
            _bhRegQuality = _bhSWR;
            _bhInStrongRegime = (_bhSWR >= 0.68 && _bhEntr < 0.55);
        }
    }
    if(operational > 0) {
    // FIX17b: mean of all subsystem readiness scores (thesis spec)
    double _sumR = g_E99_Beehive.calibration.readiness + g_E99_Beehive.probabilityDB.readiness +
                   g_E99_Beehive.regimeBanks.readiness + g_E99_Beehive.patternMicro.readiness +
                   g_E99_Beehive.patternMacro.readiness + g_E99_Beehive.scenarios.readiness +
                   g_E99_Beehive.dynamicRisk.readiness + g_E99_Beehive.threshold.readiness +
                   g_E99_Beehive.recovery.readiness;
    g_E99_Beehive.overallReadiness = _sumR / 9.0;
    }
    
    if(g_E99_Beehive.allSystemsGo) {
        g_E99_Beehive.canTradeAggressively = _bhInStrongRegime;
        g_E99_Beehive.canScalePositions    = _bhInStrongRegime || _bhRegQuality >= 0.62;
        g_E99_Beehive.commanderStatus = _bhInStrongRegime ? "ALL SYSTEMS GO" : "GO  measured pace";
        g_E99_TradingAllowed = true;
    }
    else if(g_E99_Beehive.beehiveSynchronized) {
        g_E99_Beehive.canTradeAggressively = false;
        g_E99_Beehive.canScalePositions = false;
        g_E99_Beehive.commanderStatus = "Operational";
        g_E99_TradingAllowed = true;
    }
    else if(g_Calibration.isComplete && !g_Calibration.executionSuspended
            && operational >= 6
            && g_E99_Beehive.calibration.operational
            && g_E99_Beehive.dynamicRisk.operational
            && g_E99_Beehive.threshold.operational) {
        // BOOTSTRAP (FIX53): calibration armed and the core trade-critical subsystems
        // (calibration, risk, threshold) are live. Some subsystems only reach "optimal"
        // AFTER real trades accumulate — blocking until then is a deadlock. Permit
        // cautious, measured-pace trading so they can mature on live data.
        g_E99_Beehive.canTradeAggressively = false;
        g_E99_Beehive.canScalePositions    = false;
        g_E99_Beehive.commanderStatus      = "BOOTSTRAP  cautious";
        g_E99_TradingAllowed = true;
    }
    else {
        g_E99_Beehive.canTradeAggressively = false;
        g_E99_Beehive.canScalePositions = false;
        g_E99_Beehive.commanderStatus = "DEFENSIVE";
        g_E99_TradingAllowed = false;
    }
    
    static string _lastBHStatus = ""; static int _lastBHOp = -1;
    string _bhCur = StringFormat("%s|%d", g_E99_Beehive.commanderStatus, operational);
    if(_bhCur != _lastBHStatus && _lastBHStatus != "") {
        PrintFormat("  BEE   |   %s   |   %d/9 operational", g_E99_Beehive.commanderStatus, operational);
    }
    _lastBHStatus = _bhCur; _lastBHOp = operational;
}

// --─ L1 READINESS GATE — Integration hooks ------------------------------

/*
TO INTEGRATE E9.9 INTO E9.5:

1. In OnInit() - add AFTER all E9.5 initialization:

2. In OnTick() - add AT THE BEGINNING:
   E99_UpdateMilestones();
   E99_UpdateBeehive();
        E99_UpdateTimeOptimizer();
        E99_UpdateMemory();
        E99_CalculatePathToMillion();
        E99_PrintManagerReport();

3. After calibration completes - add:
   g_E99_Beehive.calibration.operational = g_Calibration.isComplete;
   g_E99_Beehive.calibration.optimal = (g_Calibration.calibrationQuality >= 0.80);

4. When trading - check:
   if(!g_E99_TradingAllowed && g_E99_Initialized) return;  // Beehive says no

THAT'S IT - E9.9 is non-intrusive and works alongside E9.5
*/

// ------------------------------------------------------------------------─

// ========================================================================
// L6/L8 EXECUTION & RECOVERY — Position scaling, time optimizer,
//        memory management, validation, live checks, master init
// ========================================================================

struct E99_OrganizedMemory {
    double last10TradesWR;
    double last50TradesWR;
    double last100TradesWR;
    double last10TradesPF;
    double last50TradesPF;
    double last100TradesPF;
    int recentWins;
    int recentLosses;
    datetime lastCleanup;
    bool memoryHealthy;
};

E99_OrganizedMemory g_E99_Memory;

// --─ L7 LIVE ADAPTATION — Time optimizer functions ----------------------

void E99_UpdateTimeOptimizer() {
    static datetime lastCheck = 0;
    if(TimeCurrent() - lastCheck < 3600) return;  // Hourly
    lastCheck = TimeCurrent();
    
    // Calculate time metrics
    int minutesElapsed = (int)((TimeCurrent() - g_E99_TimeOpt.milestoneStartTime) / 60);
    g_E99_TimeOpt.currentDaysElapsed = minutesElapsed / 1440;
    
    // Calculate efficiency
    double _cBal = AccountBalance();
    double progressPercent = 0.0;
    
    if(g_E99_Milestones.currentLevel < 5) {
        double startBal = g_E99_TimeOpt.balanceAtStart;
        double targetBal = g_E99_Milestones.milestones[g_E99_Milestones.currentLevel].targetBalance;
        
        if(targetBal > startBal) {
            progressPercent = ((_cBal - startBal) / (targetBal - startBal)) * 100.0;
        }
    }
    
    double timePercent = ((double)g_E99_TimeOpt.currentDaysElapsed / g_E99_TimeOpt.targetDaysToMilestone) * 100.0;
    
    if(timePercent > 0) {
        g_E99_TimeOpt.timeEfficiency = progressPercent / timePercent;
    }
    
    g_E99_TimeOpt.aheadOfSchedule = (progressPercent > timePercent);
    g_E99_TimeOpt.behindSchedule = (progressPercent < timePercent * 0.80);
    
    // Update recommendation
    if(g_E99_TimeOpt.behindSchedule) {
        g_E99_TimeOpt.canAccelerate = true;
        g_E99_TimeOpt.speedRecommendation = "ACCELERATE - behind schedule";
        g_E99_TimeOpt.currentSelectivity = 0.60;  // Less selective
    }
    else if(g_E99_TimeOpt.aheadOfSchedule) {
        g_E99_TimeOpt.canAccelerate = false;
        g_E99_TimeOpt.speedRecommendation = "MAINTAIN - ahead of schedule";
        g_E99_TimeOpt.currentSelectivity = 0.70;  // Normal
    }
    else {
        g_E99_TimeOpt.canAccelerate = false;
        g_E99_TimeOpt.speedRecommendation = "NORMAL - on schedule";
        g_E99_TimeOpt.currentSelectivity = 0.70;
    }
}

// --─ L7 LIVE ADAPTATION — Memory management ----------------------------─

void E99_InitializeMemory() {
    g_E99_Memory.last10TradesWR = 0.0;
    g_E99_Memory.last50TradesWR = 0.0;
    g_E99_Memory.last100TradesWR = 0.0;
    g_E99_Memory.last10TradesPF = 0.0;
    g_E99_Memory.last50TradesPF = 0.0;
    g_E99_Memory.last100TradesPF = 0.0;
    g_E99_Memory.recentWins = 0;
    g_E99_Memory.recentLosses = 0;
    g_E99_Memory.lastCleanup = TimeCurrent();
    g_E99_Memory.memoryHealthy = true;
    
    // Memory initialised silently
}

void E99_UpdateMemory() {
    // Update performance windows from E9.5 history
    int totalTrades = 0;
    int wins10 = 0, wins50 = 0, wins100 = 0;
    int total10 = 0, total50 = 0, total100 = 0;
    double profitSum10 = 0, profitSum50 = 0, profitSum100 = 0;
    double lossSum10 = 0, lossSum50 = 0, lossSum100 = 0;
    int profitCount10 = 0, profitCount50 = 0, profitCount100 = 0;
    int lossCount10 = 0, lossCount50 = 0, lossCount100 = 0;
    
    for(int i = OrdersHistoryTotal() - 1; i >= 0 && totalTrades < 100; i--) {
        if(!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) continue;
        if(OrderMagicNumber() != MagicNumber) continue;
        
        double profit = OrderProfit() + OrderSwap() + OrderCommission();

        totalTrades++;
        
        // Last 10
        if(total10 < 10) {
            total10++;
            if(profit > 0) {
                wins10++;
                profitSum10 += profit;
                profitCount10++;
            } else {
                lossSum10 += MathAbs(profit);
                lossCount10++;
            }
        }
        
        // Last 50
        if(total50 < 50) {
            total50++;
            if(profit > 0) {
                wins50++;
                profitSum50 += profit;
                profitCount50++;
            } else {
                lossSum50 += MathAbs(profit);
                lossCount50++;
            }
        }
        
        // Last 100
        if(total100 < 100) {
            total100++;
            if(profit > 0) {
                wins100++;
                profitSum100 += profit;
                profitCount100++;
            } else {
                lossSum100 += MathAbs(profit);
                lossCount100++;
            }
        }
    }
    
    // Calculate WR
    if(total10 > 0) g_E99_Memory.last10TradesWR = ((double)wins10 / total10) * 100.0;
    if(total50 > 0) g_E99_Memory.last50TradesWR = ((double)wins50 / total50) * 100.0;
    if(total100 > 0) g_E99_Memory.last100TradesWR = ((double)wins100 / total100) * 100.0;
    
    // Calculate PF
    double avgWin10 = profitCount10 > 0 ? profitSum10 / profitCount10 : 0;
    double avgLoss10 = lossCount10 > 0 ? lossSum10 / lossCount10 : 1;
    if(avgLoss10 > 0) g_E99_Memory.last10TradesPF = avgWin10 / avgLoss10;
    
    double avgWin50 = profitCount50 > 0 ? profitSum50 / profitCount50 : 0;
    double avgLoss50 = lossCount50 > 0 ? lossSum50 / lossCount50 : 1;
    if(avgLoss50 > 0) g_E99_Memory.last50TradesPF = avgWin50 / avgLoss50;
    
    double avgWin100 = profitCount100 > 0 ? profitSum100 / profitCount100 : 0;
    double avgLoss100 = lossCount100 > 0 ? lossSum100 / lossCount100 : 1;
    if(avgLoss100 > 0) g_E99_Memory.last100TradesPF = avgWin100 / avgLoss100;
    
    g_E99_Memory.recentWins = wins10;
    g_E99_Memory.recentLosses = total10 - wins10;
    g_E99_Memory.memoryHealthy = true;
}

// 9.38: live replacement for the dead MED_DAILY_GROWTH_RATE/MED_MEDIAN_RETURN constants.
// Derives a defensible sustained daily growth rate from the SAME half-Kelly sizing logic
// CalculateOptimalPositionSizing() actually uses (not a separately-imagined number), fed
// by the system's own live rolling win rate and RR -- not an aspirational/full-Kelly figure.
// g = p*ln(1+f*R) + (1-p)*ln(1-f)   (per-trade geometric growth under fractional Kelly)
// 9.40 (thesis item 2): single source of truth for "how fast will this system compound,"
// callable with either live rolling stats or out-of-sample ghost/calibration stats.
// Previously RunMarketCalibration()'s GAME PLAN block answered the same question with a
// SEPARATE, additive-edge formula (edge-per-trade x trades/day x risk%) instead of this
// half-Kelly geometric one -- two different numbers for the same concept. p/R/tradesPerDay
// are now parameters so both call sites share the actual math; only the input source differs
// (ghost stats pre-live, live rolling stats once real trades exist).
double CalculateDefensibleDailyGrowthRateCore(double p, double R, double tradesPerDay,
                                               double &outStartingProjection, double &outMedianReturn,
                                               double costHaircutR) {
    if(R <= 0) R = TARGET_RISK_REWARD_RATIO;
    if(p <= 0 || p >= 1 || R <= 0) { outStartingProjection = 0; outMedianReturn = 0; return 0; }

    // SLS22-ERM M2.3: friction (spread+slippage) eats directly into the reward
    // side of each trade. Reducing R by the realized cost (expressed in R-units)
    // makes the projection price in real, measured friction instead of assuming
    // none (ghost/calibration R never included it; live R only did so implicitly
    // and inconsistently once real trades existed). costHaircutR defaults to 0,
    // so the ghost-stats call site (which has no live fills to measure) is unchanged.
    R = MathMax(0.1, R - MathMax(0.0, costHaircutR));

    double kellyFraction = MathMax(0.0, MathMin(0.25, (p * (R + 1.0) - 1.0) / NonZero(R)));
    double f = kellyFraction * 0.5;  // half-Kelly, matching CalculateOptimalPositionSizing()
    if(f <= 0) { outStartingProjection = 0; outMedianReturn = 0; return 0; }

    double gPerTrade = p * MathLog(1.0 + f * R) + (1.0 - p) * MathLog(MathMax(0.0001, 1.0 - f));
    double dailyGrowthRate = MathExp(gPerTrade * MathMax(1.0, tradesPerDay)) - 1.0;

    outStartingProjection = AccountBalance() > 0 ? AccountBalance() : StartingBalance;
    outMedianReturn = outStartingProjection * MathPow(1.0 + dailyGrowthRate, MED_PROJECTION_DAYS);
    return dailyGrowthRate;
}

double CalculateDefensibleDailyGrowthRate(double &outStartingProjection, double &outMedianReturn) {
    double p = CalculateRecentWinRate() / 100.0;
    double R = tpslSystem.recentRR;
    int tradesPerDay = (g_Tier.currentTier == TIER_MEDIUM) ? MED_TRADES_PER_DAY : FLOOR_TRADES_PER_DAY;
    // SLS22-ERM M2.3: convert the realized avg cost-per-trade (points) into R-units
    // using the current SL distance as the "1 R" reference, so the growth-rate core
    // prices in real friction. 0 until at least one live trade has filled.
    double _slDistPts = tpslSystem.optimalSLDistance / NonZero(Point);
    double costHaircutR = (_slDistPts > 0) ? ERM_GetAvgCostHaircutPoints() / _slDistPts : 0.0;
    return CalculateDefensibleDailyGrowthRateCore(p, R, tradesPerDay, outStartingProjection, outMedianReturn, costHaircutR);
}

// --─ L1 READINESS GATE — Trajectory and milestone calculation ----------─

void E99_CalculatePathToMillion() {
    double _cBal = g_E99_Milestones.currentBalance;
    g_E99_Milestones.distanceToMillion = MathMax(0, 1000000.0 - _cBal);
    g_E99_Milestones.percentToMillion = (_cBal / 1000000.0) * 100.0;
    
    if(_cBal >= 1000000.0 && !g_E99_Milestones.millionAchieved) {
        g_E99_Milestones.millionAchieved = true;
        Print("  $1,000,000   |   million achieved   |   compounding continues indefinitely");
    }
    if(_cBal >= 1000000.0) {
        // Post-million: track distance to next milestone, not to 1M
        int _nextM = g_E99_Milestones.currentLevel;
        if(_nextM < 10) {
            g_E99_Milestones.distanceToMillion =
                MathMax(0, g_E99_Milestones.milestones[_nextM].targetBalance - _cBal);
            g_E99_Milestones.percentToMillion = (_cBal /
                MathMax(1, g_E99_Milestones.milestones[_nextM].targetBalance)) * 100.0;
        } else {
            g_E99_Milestones.distanceToMillion  = 0;
            g_E99_Milestones.percentToMillion   = 100.0;
        }
        // Still compute roadmap — no ceiling
    }
    
    // Estimate trades and days remaining based on current performance
    double avgWR = g_E99_Memory.last50TradesWR;
    if(avgWR < 50) avgWR = 65;  // Assume minimum 65% if no history
    
    double avgProfitPerTrade = (_cBal - g_E99_Milestones.absoluteStartBalance) / MathMax(1, g_E99_Memory.last100TradesWR);
    if(avgProfitPerTrade <= 0) avgProfitPerTrade = _cBal * 0.02;  // Assume 2% per winning trade
    
    double remainingProfit = g_E99_Milestones.distanceToMillion;
    int estimatedTradesNeeded = (int)(remainingProfit / avgProfitPerTrade);
    
    // Assuming 50-100 trades per day at current pace
    // Use actual daily trade rate if available
    // 9.39: was subtracting a dollar balance from a Unix timestamp -- type-confusion
    // bug, not just imprecise. startTime is the real wall-clock EA-start reference.
    double _daysSoFar = MathMax(1.0, (TimeCurrent() - g_E99_Milestones.startTime) / 86400.0);
    double _actualDailyRate = (_daysSoFar > 1) ? (double)g_State.totalTrades / _daysSoFar : 75.0;
    double _dailyRate = MathMax(10.0, _actualDailyRate);  // floor at 10 trades/day
    int estimatedDays = (int)(estimatedTradesNeeded / _dailyRate);
    
    // Build roadmap string
    string roadmap = "";
    for(int i = g_E99_Milestones.currentLevel; i < 10; i++) {
        if(i > g_E99_Milestones.currentLevel) roadmap += " -> ";
        roadmap += "$" + DoubleToString(g_E99_Milestones.milestones[i].targetBalance, 0);
    }
    
    g_E99_Milestones.roadmap = roadmap;

    // 9.38: live, defensible growth-rate projection (replaces the dead MED_DAILY_GROWTH_RATE
    // constant) -- derived from actual half-Kelly sizing + actual rolling WR/RR, not a fixed
    // aspirational number. Logged periodically rather than every call.
    static datetime _lastGrowthLog = 0;
    if(TimeCurrent() - _lastGrowthLog >= 3600) {
        double _startProj = 0, _medianReturn = 0;
        double _dailyGrowth = CalculateDefensibleDailyGrowthRate(_startProj, _medianReturn);
        if(_dailyGrowth > 0) {
            PrintFormat("  GROWTH  |   defensible daily %.2f%%   |   %d-day projection $%.2f -> $%.2f   |   WR %.1f%%   RR %.2f   half-Kelly",
                        _dailyGrowth * 100.0, MED_PROJECTION_DAYS, _startProj, _medianReturn,
                        CalculateRecentWinRate(), tpslSystem.recentRR);
        }
        _lastGrowthLog = TimeCurrent();
    }
}

// --─ L2 CALIBRATION — Post-calibration ProbDB validation --------------─

void E99_ValidateCalibration() {
    // Run silently - results emitted as single summary line below
    
    int passedChecks = 0;
    
    // Check 1: Score Distribution (read from E9.5 if available)
    if(g_ScoreDistribution.analysisComplete) {
        double range = g_ScoreDistribution.maxScore - g_ScoreDistribution.minScore;
        double spread = g_ScoreDistribution.stdDev;
        
        if(range >= 30 && range <= 100 && spread >= 10 && spread <= 30) {
            g_E99_Validation.scoreDistributionValid = true;
            passedChecks++;
        } else {
            // score distribution outside expected range
        }
    } else {
        // no score distribution data - skipped
    }
    
    // Check 2: Probability DB
    if(g_ProbDB.calibrated && g_ProbDB.patternCount >= 50) {
        bool sampleOK = (g_ProbDB.outcomeCount >= 1000);
        bool baselineOK = (g_ProbDB.baselineWinProb >= 0.40 && g_ProbDB.baselineWinProb <= 0.80);
        
        if(sampleOK && baselineOK) {
            g_E99_Validation.probabilityDBValid = true;
            passedChecks++;
        }
        // else: outcomes or baseline out of range
    }
    // else: DB not calibrated - skipped
    
    // Check 3: Regime Classification
    int calibratedRegimes = 0;
    for(int i = 0; i < 8; i++) {
        if(g_RegimeBanks[i].calibrated) calibratedRegimes++;
    }
    
    if(calibratedRegimes >= 6) {
        g_E99_Validation.regimeClassificationValid = true;
        passedChecks++;
    }
    
    // Check 4: Scenario Reliability (count reliable scenarios)
    int reliableScenarios = 0;
    for(int r = 0; r < 9; r++) {
        for(int s = 0; s < g_RegimeBanks[r].configCount; s++) {
            if(g_RegimeBanks[r].configs[s].winRate >= 0.60 && 
               g_RegimeBanks[r].configs[s].timesTested >= 10) {
                reliableScenarios++;
            }
        }
    }
    
    if(reliableScenarios >= 30) {
        g_E99_Validation.scenarioReliabilityValid = true;
        passedChecks++;
    }
    
    // Check 5: Holdout Test (assume passes if 3+ other checks passed)
    if(passedChecks >= 3) {
        g_E99_Validation.holdoutTestPassed = true;
        passedChecks++;
    }
    
    // Calculate overall quality
    g_E99_Validation.calibrationQuality = (double)passedChecks / 5.0;
    
    // Store expected WR
    if(g_Calibration.calibratedWR > 0.05) {
        // The system's expectation is its own calibrated OOS WR — the pattern-DB
        // baseline (~32%) is a per-pattern hit rate, not a system win rate.
        g_E99_Validation.expectedWinRate = g_Calibration.calibratedWR * 100.0;
    } else if(g_ProbDB.calibrated) {
        g_E99_Validation.expectedWinRate = g_ProbDB.baselineWinProb * 100.0;
    }
    
    // Final verdict -- single summary line
    if(g_E99_Validation.calibrationQuality >= 0.80) {
        g_E99_Validation.calibrationTrusted = true;
        g_E99_Validation.flukeDetected = false;
        g_E99_Validation.validationReport = "TRUSTED - Not a fluke";
        PrintFormat("  P6    |   validation   %d/5 checks   |   %.0f%%   |   trusted   |   expected WR %.1f%%",
                    passedChecks, g_E99_Validation.calibrationQuality * 100,
                    g_E99_Validation.expectedWinRate);
    } else {
        g_E99_Validation.calibrationTrusted = false;
        g_E99_Validation.flukeDetected = true;
        g_E99_Validation.validationReport = "QUESTIONABLE - Only " + IntegerToString(passedChecks) + "/5 checks passed";
        PrintFormat("  P6    |   validation   %d/5 checks   |   %.0f%%   |   monitor closely",
                    passedChecks, g_E99_Validation.calibrationQuality * 100);
    }
    
    // Update beehive after validation
    g_E99_Beehive.calibration.operational = g_Calibration.isComplete;
    g_E99_Beehive.calibration.optimal = (g_E99_Validation.calibrationQuality >= 0.80);
    g_E99_Beehive.calibration.readiness = g_E99_Validation.calibrationQuality;
    g_E99_Beehive.calibration.confidence = g_E99_Validation.calibrationQuality;
}

// --─ L7 LIVE ADAPTATION — Live validation (100-trade gate) ------------─

void E99_ValidateLivePerformance() {
    g_E99_Validation.liveTradesSoFar++;
    
    if(g_E99_Validation.liveTradesSoFar >= g_E99_Validation.liveTradesForValidation) {
        g_E99_Validation.liveWinRate = g_E99_Memory.last100TradesWR;
        // Alignment context: if CEO says model is misaligned, WR deviation
        // is expected -- don't flag it as a calibration problem.
        g_E99_Validation.alignmentAtValidation = GetMarketAlignment();
        double deviation = MathAbs(g_E99_Validation.liveWinRate - g_E99_Validation.expectedWinRate);
        g_E99_Validation.deviation = deviation;

        // ## PERFORMANCE FLOOR CHECKS #################################################
        // Minimum spec: FLOOR_START_WR 65% -> FLOOR_LEARNED_WR 69%  |  FLOOR_TRADES_PER_DAY 5
        // System may far exceed these when conditions allow.
        bool aboveFloor    = (g_E99_Validation.liveWinRate >= FLOOR_START_WR);
        bool approachFloor = (g_E99_Validation.liveWinRate >= SpecLearnedWR());

        if(deviation <= 10.0) {
            g_E99_Validation.liveMatchesCalibration = true;
            PrintFormat("  live validation   |   WR %.1f%%   |   expected %.1f%%   |   floor %.0f%%   |   %s",
                        g_E99_Validation.liveWinRate, g_E99_Validation.expectedWinRate,
                        FLOOR_START_WR,
                        approachFloor ? "above learned floor" : aboveFloor ? "at start floor" : "BELOW FLOOR");
        } else {
            g_E99_Validation.liveMatchesCalibration = false;
            PrintFormat("  live validation   |   WR %.1f%%   |   expected %.1f%%   |   deviation %.1f%%   |   %s",
                        g_E99_Validation.liveWinRate, g_E99_Validation.expectedWinRate, deviation,
                        aboveFloor ? "above floor  |  consider recalibration" : "BELOW FLOOR  |  recalibrate");
        }
    }
}

// --─ L1 READINESS GATE — Manager status report --------------------------

void E99_PrintManagerReport() {
    static datetime lastReport = 0;
    if(TimeCurrent() - lastReport < 3600) return;
    lastReport = TimeCurrent();

    // Line 1: balance progress
    {
        double _calWR = (g_WeightsOptimized && g_E99_Validation.expectedWinRate > 0.1)
            ? g_E99_Validation.expectedWinRate : FLOOR_START_WR;
        double _liveWR = g_E99_Memory.last50TradesWR;
        double _wrDelta = _liveWR - _calWR;
        PrintFormat("  milestone %d/10   |   $%.0f   |   peak $%.0f   |   %.1f%% to $1M   |   WR %.0f%% (%s%.0fpp vs cal)   |   PF %.1f",
            g_E99_Milestones.currentLevel, g_E99_Milestones.currentBalance,
            g_E99_Milestones.allTimePeak, g_E99_Milestones.percentToMillion,
            _liveWR, _wrDelta >= 0 ? "+" : "", _wrDelta, g_E99_Memory.last10TradesPF);
    }

    // Floor trajectory check -- median spec: FLOOR_MEDIAN_55D_RETURN ($769K) in 55 days from $100.
    // Daily growth rate required: FLOOR_DAILY_GROWTH_RATE (28%). Checked against live balance.
    int daysLive = g_E99_TimeOpt.currentDaysElapsed;
    double floorTarget55d = FLOOR_MEDIAN_55D_RETURN;  // $769K at day 55
    double floorTrajectory = MathMax(100.0, StartingBalance) * MathPow(1.0 + FLOOR_DAILY_GROWTH_RATE, daysLive);
    bool onTrack = (g_E99_Milestones.currentBalance >= floorTrajectory * 0.5);  // 50% of floor = still viable

    // Line 2: system health
    // CEO: Market Alignment Score
    PrintFormat("  LIVE  |   alignment   %.2f   |   %s   |   WR %.0f%%   |   disc %.0f%%   |   %s",
                g_Alignment.overallScoreSmoothed,
                g_Alignment.overallScoreSmoothed >= 0.75 ? "STRONG" :
                g_Alignment.overallScoreSmoothed >= 0.50 ? "ok" :
                g_Alignment.overallScoreSmoothed >= 0.30 ? "WEAK" : "CRITICAL",
                g_Alignment.components[0].score * 100,
                g_Alignment.components[1].score * 100,
                g_Alignment.shouldSuspendTrading ? "SUSPENDED" :
                g_Alignment.shouldReduceRisk     ? "reducing risk" :
                g_Alignment.shouldIncreaseTier   ? "increasing tier" : "normal");

    // Live adaptive state log
    if(g_LiveAdaptive.selfCalibrated) {
        int _regEdge=0;
        for(int _rei=0;_rei<9;_rei++) if(g_LiveAdaptive.regimeLiveWR[_rei]>=0.63&&g_LiveAdaptive.regimeTrades[_rei]>=10)_regEdge++;
        PrintFormat("  live adaptive   |   %d trades   |   WR %.0f%%   |   edge %.0f%%   |   thr %.0f   |   regimes %d/8   |   conf %.0f%%",
                    g_LiveAdaptive.totalLiveTrades, g_LiveAdaptive.liveWR30*100,
                    g_LiveAdaptive.liveEdgeScore*100, g_LiveAdaptive.liveOptimalThreshold,
                    _regEdge, g_LiveAdaptive.liveThresholdConfidence*100);
    } else {
        int _rSamp=0; for(int _rsi=0;_rsi<9;_rsi++) if(g_LiveAdaptive.regimeTrades[_rsi]>=15)_rSamp++;
        PrintFormat("  live adaptive   |   %d trades   |   building (%d/30, %d regimes sampled)",
                    g_LiveAdaptive.totalLiveTrades, g_LiveAdaptive.totalLiveTrades, _rSamp);
    }
    PrintFormat("  BEE   |   %d/9   |   %.0f%% ready   |   scale %s   |   aggr %s   |   %dd/%dd   |   eff %.0f%%   |   %s",
        g_E99_Beehive.subsystemsOperational, g_E99_Beehive.overallReadiness*100,
        (g_E99_Beehive.canScalePositions?"Y":"N"), (g_E99_Beehive.canTradeAggressively?"Y":"N"),
        g_E99_TimeOpt.currentDaysElapsed, g_E99_TimeOpt.targetDaysToMilestone,
        g_E99_TimeOpt.timeEfficiency*100,
        onTrack ? "on track" : "below floor trajectory");
}

// --─ L1 READINESS GATE — Master initialization (all subsystems) ----------

// --─ L8 RECOVERY — Trade closure hook: updates all learning systems ------─

void E99_OnTradeClose(double profit) {
    // Update memory with latest performance
    E99_UpdateMemory();
    
    // Validate live performance (after 100 trades)
    if(E99_EnableValidation) {
        E99_ValidateLivePerformance();
    }
    
    // Check if milestone achieved with this trade
    E99_UpdateMilestones();
}

// --─ L6 EXECUTION ENGINE — Position scaling ----------------------------─

// --─ L6 EXECUTION ENGINE — Position scaling: 7-criteria gate ----------─
bool E99_CheckScalingCriteria(bool isBuy, double currentScore, double entryPrice) {
    if(!E99_EnableScaling) return false;
    if(!g_E99_Beehive.canScalePositions) return false;
    if(g_E99_Scaling.currentScaleLevel >= g_E99_Scaling.maxScaleLevel) return false;
    
    int criteriaMet = 0;
    string failReasons = "";
    
    // CRITERION 1: Beehive Synchronized (7/9 operational, 5/9 optimal)
    if(g_E99_Beehive.beehiveSynchronized) {
        g_E99_Scaling.beehiveSynced = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.beehiveSynced = false;
        failReasons += "Beehive not synced; ";
    }
    
    // CRITERION 2: Calibration Trusted (validation passed)
    if(g_E99_Validation.calibrationTrusted) {
        g_E99_Scaling.calibrationTrusted = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.calibrationTrusted = false;
        failReasons += "Calibration not trusted; ";
    }
    
    // CRITERION 3: Patterns Aligned (check E9.5 pattern state)
    // Read from E9.5 micro and macro pattern alignment
    bool microAligned = false;
    bool macroAligned = false;
    
    // Check if micro pattern matches direction
    // FIX29: Broadened pattern alignment for scaling criteria
    bool _bMicro = (g_PatternState.currentMicroPattern == PATTERN_HH || g_PatternState.currentMicroPattern == PATTERN_HL);
    bool _bMacro = (g_PatternState.currentMacroPattern == PATTERN_HH || g_PatternState.currentMacroPattern == PATTERN_BULLISH_CHOCH);
    bool _sMicro = (g_PatternState.currentMicroPattern == PATTERN_LL || g_PatternState.currentMicroPattern == PATTERN_LH);
    bool _sMacro = (g_PatternState.currentMacroPattern == PATTERN_LL || g_PatternState.currentMacroPattern == PATTERN_BEARISH_CHOCH);
    bool _noMicro = (g_PatternState.currentMicroPattern == PATTERN_UNKNOWN || g_PatternState.currentMicroPattern == PATTERN_NONE);
    bool _noMacro = (g_PatternState.currentMacroPattern == PATTERN_UNKNOWN || g_PatternState.currentMacroPattern == PATTERN_NONE);
    microAligned = isBuy ? (_bMicro || _noMicro) : (_sMicro || _noMicro);
    macroAligned = isBuy ? (_bMacro || _noMacro) : (_sMacro || _noMacro);
    if(g_PatternState.currentMacroPattern == PATTERN_HH && isBuy) macroAligned = true;
    if(g_PatternState.currentMacroPattern == PATTERN_LL && !isBuy) macroAligned = true;
    
    if(microAligned && macroAligned) {
        g_E99_Scaling.patternsAligned = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.patternsAligned = false;
        failReasons += "Patterns not aligned; ";
    }
    
    // CRITERION 4: Momentum Strong (score exceeds threshold by 15+)
    double currentThreshold = isBuy ? g_DynThreshold.buyThreshold : g_DynThreshold.sellThreshold;
    double scoreExcess = isBuy ? (currentScore - currentThreshold) : (currentThreshold - currentScore);
    
    if(scoreExcess >= 15.0) {
        g_E99_Scaling.momentumStrong = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.momentumStrong = false;
        failReasons += StringFormat("Momentum weak (excess: %.1f); ", scoreExcess);
    }
    
    // CRITERION 5: Win Streak Active (6/10 recent wins)
    int recentWins = 0;
    // SLS23 FIX: was reading fixed slots [0..9] instead of the ring-buffer's actual last 10 trades
    for(int i = 0; i < 10; i++) {
        int _idx_sc54305 = ((g_State.resultIndex - 1 - i) + 100) % 100;
        if(g_State.lastTradeResults[_idx_sc54305] > 0) recentWins++;
    }
    
    if(recentWins >= 6) {
        g_E99_Scaling.winStreakActive = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.winStreakActive = false;
        failReasons += StringFormat("No win streak (%d/10); ", recentWins);
    }
    
    // CRITERION 6: Risk Budget Available (total position risk < 15%)
    double totalRisk = g_E99_Scaling.totalPositionRisk;
    
    if(totalRisk < g_E99_Scaling.maxTotalRisk) {
        g_E99_Scaling.riskBudgetAvailable = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.riskBudgetAvailable = false;
        failReasons += StringFormat("Risk budget full (%.1f%%); ", totalRisk);
    }
    
    // CRITERION 7: Price Moved Favorably (15+ pips from last entry)
    double pipsPerPoint = 1.0;
    if(Digits == 3 || Digits == 5) pipsPerPoint = 10.0;

    double pipsMoved = 0;
    // SLS21 FIX: was direction-agnostic (MathAbs only) despite being named "Favorably" --
    // would equally pass if price moved against the position, i.e. scale into a loser.
    bool priceFavorable = true;
    if(g_E99_Scaling.lastScalePrice > 0) {
        double priceDelta = entryPrice - g_E99_Scaling.lastScalePrice;
        pipsMoved = MathAbs(priceDelta) / Point * pipsPerPoint;
        priceFavorable = isBuy ? (priceDelta > 0) : (priceDelta < 0);
    } else {
        pipsMoved = E99_ScaleThresholdPips;  // First scale, assume threshold met
    }

    if(pipsMoved >= E99_ScaleThresholdPips && priceFavorable) {
        g_E99_Scaling.priceMoved = true;
        criteriaMet++;
    } else {
        g_E99_Scaling.priceMoved = false;
        failReasons += StringFormat("Price not moved favorably (%.1f pips); ", pipsMoved);
    }
    
    // Decision: Need ALL 7 criteria
    if(criteriaMet == 7) {
        g_E99_Scaling.allowScaling = true;
        g_E99_Scaling.scalingRationale = "All 7 criteria met - scaling approved";
        return true;
    } else {
        g_E99_Scaling.allowScaling = false;
        g_E99_Scaling.scalingRationale = StringFormat("%d/7 criteria met: %s", criteriaMet, failReasons);
        return false;
    }
}

// --─ L6 EXECUTION ENGINE — Position scale-in (MT4 compliant) ----------─
bool E99_ExecuteScaleIn(bool isBuy, double baseLots, double entryPrice, double stopLevel, double targetLevel, int baseMagic) {
    if(!E99_EnableScaling) return false;
    if(g_E99_Scaling.currentScaleLevel >= g_E99_Scaling.maxScaleLevel) return false;
    
    // Calculate scale-in lot size (fraction of base)
    double scaleLots = NormalizeDouble(baseLots * E99_ScaleRiskMult, 2);
    if(scaleLots < MarketInfo(Symbol(), MODE_MINLOT)) {
        PrintFormat("  SCALE |   scaling   lot %.3f too small   |   skipped", scaleLots);
        return false;
    }
    
    // MT4 COMPLIANCE: Sleep before next order
    Sleep(100);
    
    // Prepare comment
    g_E99_Scaling.currentScaleLevel++;
    string scaleComment = StringFormat("E9.9_SCALE_%d", g_E99_Scaling.currentScaleLevel);
    
    // Get fresh price
    RefreshRates();
    double scalePrice = isBuy ? Ask : Bid;
    
    // Execute scale-in order
    int scaleTicket = SafeOrderSend(
        isBuy ? OP_BUY : OP_SELL,
        scaleLots,
        scalePrice,
        3,
        stopLevel,
        targetLevel,
        scaleComment,
        baseMagic,
        0,
        isBuy ? clrGreen : clrRed
    );
    
    if(scaleTicket > 0) {
        // Success - update tracking
        g_E99_Scaling.lastScalePrice = scalePrice;
        
        // Calculate risk added
        double _ptS4    = MathMax(Point, MarketInfo(Symbol(), MODE_POINT));
        double _ptV4    = MarketInfo(Symbol(), MODE_TICKVALUE);
        double _atr4    = iATR(Symbol(), 0, 14, 0);
        double _slDist4 = (_atr4 > 0) ? _atr4 * 1.5 / MathMax(_ptS4, 0.000001) : 0.0;
        double riskAdded   = scaleLots * _slDist4 * _ptV4;
        double riskPercent = (AccountEquity() > 0) ? (riskAdded / AccountEquity() * 100.0) : 0.0;
        // SLS21 FIX: riskPercent was computed and logged but never added to totalPositionRisk,
        // so CRITERION 6 ("Risk Budget Available") in E99_CheckScalingCriteria was permanently
        // vacuous -- it could never block further scaling on accumulated risk grounds.
        g_E99_Scaling.totalPositionRisk += riskPercent;
        PrintFormat("  scale-in #%d   |   ticket #%d   |   %.2f lots   |   $%.2f risk (%.1f%%)   |   total risk %.1f%%",
                   g_E99_Scaling.currentScaleLevel, scaleTicket, scaleLots, riskAdded, riskPercent,
                   g_E99_Scaling.totalPositionRisk);
        Print("  rationale   |   " + g_E99_Scaling.scalingRationale);
        
        return true;
    } else {
        g_E99_Scaling.currentScaleLevel--;  // Rollback on failure
        int error = GetLastError();
        PrintFormat("  SCALE |   scaling   error %d   |   scale-in failed", error);
        return false;
    }
}

// --─ L6 EXECUTION ENGINE — Scaling state reset --------------------------
void E99_ResetScaling() {
    g_E99_Scaling.hasBasePosition = false;
    g_E99_Scaling.currentScaleLevel = 0;
    g_E99_Scaling.baseEntryPrice = 0;
    g_E99_Scaling.lastScalePrice = 0;
    g_E99_Scaling.totalPositionRisk = 0;
    g_E99_Scaling.allowScaling = false;
    g_E99_Scaling.scalingRationale = "";
}

// --─ L1 READINESS GATE — Beehive subsystem updaters --------------------

// --─ L1 READINESS GATE — Beehive: pattern subsystem update ------------─
void E99_UpdatePatternSubsystems() {
    // Check if micro patterns are operational
    // E9.5 updates pattern state every tick, so if it's being calculated, it's operational
    bool microOperational = (g_PatternState.currentMicroPattern != PATTERN_UNKNOWN &&
                              g_PatternState.currentMicroPattern != PATTERN_NONE);
    bool macroOperational = (g_PatternState.currentMacroPattern != PATTERN_UNKNOWN &&
                              g_PatternState.currentMacroPattern != PATTERN_NONE);
    
    g_E99_Beehive.patternMicro.operational = microOperational;
    g_E99_Beehive.patternMacro.operational = macroOperational;
    
    // Check if optimal (confidence high, accuracy good)
    g_E99_Beehive.patternMicro.optimal = (microOperational && g_PatternState.microConfidence >= 0.70);
    g_E99_Beehive.patternMacro.optimal = (macroOperational && g_PatternState.macroConfidence >= 0.70);
    
    // Readiness based on confidence
    // Pattern readiness floor: 0.30 when no pattern detected (neutral, not failed).
    // Clean trending bars often have no classic template but ARE tradeable.
    // Zero readiness would suspend trading on valid setups — inverted direction.
    g_E99_Beehive.patternMicro.readiness = MathMax(0.30, g_PatternState.microConfidence);
    g_E99_Beehive.patternMacro.readiness = MathMax(0.30, g_PatternState.macroConfidence);
    
    g_E99_Beehive.patternMicro.confidence = g_PatternState.microConfidence;
    g_E99_Beehive.patternMacro.confidence = g_PatternState.macroConfidence;
}

// --─ L1 READINESS GATE — Beehive: scenario subsystem update ------------
void E99_UpdateScenarioSubsystem() {
    // Count reliable scenarios across all regimes
    int reliableScenarios = 0;
    int totalScenarios = 0;
    
    for(int r = 0; r < 9; r++) {
        if(!g_RegimeBanks[r].calibrated) continue;
        
        for(int s = 0; s < g_RegimeBanks[r].configCount; s++) {
            totalScenarios++;
            if(g_RegimeBanks[r].configs[s].winRate >= 0.60 && 
               g_RegimeBanks[r].configs[s].timesTested >= 10) {
                reliableScenarios++;
            }
        }
    }
    
    g_E99_Beehive.scenarios.operational = (totalScenarios >= 20);
    g_E99_Beehive.scenarios.optimal = (reliableScenarios >= 30);
    g_E99_Beehive.scenarios.readiness = totalScenarios > 0 ? (double)reliableScenarios / totalScenarios : 0.0;
    g_E99_Beehive.scenarios.confidence = g_E99_Beehive.scenarios.readiness;
}

// --─ L1 READINESS GATE — Beehive: threshold subsystem update ----------─
void E99_UpdateThresholdSubsystem() {
    // Threshold system is operational if dynamic thresholds are being calculated
    bool buyThresholdValid = (g_DynThreshold.buyThreshold > 0 && g_DynThreshold.buyThreshold < 100);
    bool sellThresholdValid = (g_DynThreshold.sellThreshold > 0 && g_DynThreshold.sellThreshold < 100);
    
    g_E99_Beehive.threshold.operational = (buyThresholdValid && sellThresholdValid);
    
    // Optimal if thresholds are within reasonable range (not too high/low)
    bool thresholdsReasonable = (g_DynThreshold.buyThreshold >= 50 && g_DynThreshold.buyThreshold <= 80 &&
                                 g_DynThreshold.sellThreshold >= 20 && g_DynThreshold.sellThreshold <= 50);
    
    g_E99_Beehive.threshold.optimal = (g_E99_Beehive.threshold.operational && thresholdsReasonable);
    g_E99_Beehive.threshold.readiness = g_E99_Beehive.threshold.operational ? 1.0 : 0.0;
    g_E99_Beehive.threshold.confidence = g_E99_Beehive.threshold.readiness;
}

// --─ L1 READINESS GATE — Beehive: master updater ------------------------
void E99_UpdateAllBeehiveSubsystems() {
    // Update all subsystems that need continuous monitoring
    E99_UpdatePatternSubsystems();
    E99_UpdateScenarioSubsystem();
    E99_UpdateThresholdSubsystem();

    // REGIME BANKS -- was initialised to false and never updated.
    bool regimeBanksOperational = (g_RegimeLearning.regimesLearned && g_WeightsOptimized);
    bool regimeBanksOptimal     = (regimeBanksOperational && g_CorrelationsLearned);

    g_E99_Beehive.regimeBanks.operational = regimeBanksOperational;
    g_E99_Beehive.regimeBanks.optimal     = regimeBanksOptimal;

    // Readiness = fraction of 8 regimes that have complete knowledge
    int knownRegimes = 0;
    for(int r = 0; r < 9; r++) {
        if(g_RegimeLearning.regimes[r].timesDetected >= 10) knownRegimes++; // timesDetected = correct RegimeCharacteristics field
    }
    g_E99_Beehive.regimeBanks.readiness   = knownRegimes / 8.0;
    g_E99_Beehive.regimeBanks.confidence  = g_E99_Beehive.regimeBanks.readiness;

    // Dynamic Risk and Recovery are always operational (set in init)
    // Calibration, ProbDB, and RegimeBanks are updated by hooks
}

// --─ L1 READINESS GATE — Master initialization --------------------------
double CalibBudgetUsed() {
    if(!g_Calibration.isCalibrating) return 0.0;
    double el = (double)(TimeCurrent() - g_Calibration.calibrationStartTime);
    double mx = MathMax(5, MaxCalibrationMinutes) * 60.0;
    return (mx > 0) ? el / mx : 1.0;
}

bool CalibrationTimedOut() {
    if(!g_Calibration.isCalibrating) return false;
    
    datetime elapsed = TimeCurrent() - g_Calibration.calibrationStartTime;
    int maxSeconds = MathMax(5, MaxCalibrationMinutes) * 60;  // honor user budget (was hardcoded 60 min)

    if(elapsed > maxSeconds) {
        // FIX(29): log once per calibration run — reset when a new calibration starts
        static bool _calTmOut = false;
        static datetime _lastCalibStart = 0;
        if(g_Calibration.calibrationStartTime != _lastCalibStart) {
            _calTmOut = false;
            _lastCalibStart = g_Calibration.calibrationStartTime;
        }
        if(!_calTmOut) {
            PrintFormat("  calibration timeout   |   %d min   |   budget exhausted", elapsed/60);
            _calTmOut = true;
        }
        return true;
    }
    
    return false;
}

//| Identify candlestick pattern at bar                              |
PatternType IdentifyCandlePattern(int bar) {
    // Use the built-in pattern library for recognition
    // Ensure library is initialized
    if(g_PatternLibraryCount == 0) InitializePatternLibrary();
    
    if(bar >= Bars - 5) return PATTERN_NONE;
    
    double open  = iOpen(_Symbol, PERIOD_CURRENT, bar);
    double high  = iHigh(_Symbol, PERIOD_CURRENT, bar);
    double low   = iLow(_Symbol, PERIOD_CURRENT, bar);
    double close = iClose(_Symbol, PERIOD_CURRENT, bar);
    
    double body      = MathAbs(close - open);
    double range     = high - low;
    double upperWick = high - MathMax(open, close);
    double lowerWick = MathMin(open, close) - low;
    
    if(range < 0.000001) return PATTERN_NONE;
    
    double bodyRatio  = body / range;
    double lwickRatio = lowerWick / range;
    double uwickRatio = upperWick / range;
    bool   isBull     = (close > open);

    // Two-candle context
    double prevOpen  = (bar < Bars - 2) ? iOpen(_Symbol, PERIOD_CURRENT, bar + 1)  : open;
    double prevClose = (bar < Bars - 2) ? iClose(_Symbol, PERIOD_CURRENT, bar + 1) : close;
    double prevBody  = MathAbs(prevClose - prevOpen);
    bool   prevBull  = (prevClose > prevOpen);
    
    // Three-candle context
    double prev2Open  = (bar < Bars - 3) ? iOpen(_Symbol, PERIOD_CURRENT, bar + 2)  : prevOpen;
    double prev2Close = (bar < Bars - 3) ? iClose(_Symbol, PERIOD_CURRENT, bar + 2) : prevClose;
    bool   prev2Bull  = (prev2Close > prev2Open);
    double prev2Body  = MathAbs(prev2Close - prev2Open);
    double prev2Range = (bar < Bars - 3) ?
        iHigh(_Symbol, PERIOD_CURRENT, bar + 2) - iLow(_Symbol, PERIOD_CURRENT, bar + 2) : range;
    double prev2BodyR = prev2Range > 0 ? prev2Body / prev2Range : 0;

    // ---- SINGLE-CANDLE PATTERNS ----

    // Spinning Top / Doji: tiny body, wicks both sides
    if(bodyRatio < 0.15 && lwickRatio > 0.2 && uwickRatio > 0.2)
        return PATTERN_DOJI;

    // Hammer (bullish at low): long lower wick, small body in upper 30%
    if(lwickRatio >= 0.55 && bodyRatio <= 0.35 && uwickRatio < 0.15)
        return PATTERN_HAMMER_AT_SUPPORT;

    // Shooting Star (bearish at high): long upper wick, small body in lower 30%
    if(uwickRatio >= 0.55 && bodyRatio <= 0.35 && lwickRatio < 0.15)
        return PATTERN_SHOOTING_STAR_AT_RES;

    // Spinning Top at Extreme (large wicks both sides, tiny body)
    if(bodyRatio < 0.25 && lwickRatio > 0.30 && uwickRatio > 0.30)
        return PATTERN_SPINNING_TOP_EXTREME;

    // ---- TWO-CANDLE PATTERNS ----

    // Bullish Engulfing: bull body > bear body, opens below prior close
    if(isBull && !prevBull && body > prevBody * 1.1 &&
       open <= prevClose && close >= prevOpen)
        return PATTERN_BULLISH_ENGULFING;

    // Bearish Engulfing: bear body > bull body, opens above prior close
    if(!isBull && prevBull && body > prevBody * 1.1 &&
       open >= prevClose && close <= prevOpen)
        return PATTERN_BEARISH_ENGULFING;

    // Failed Breakout / Range Fakeout: direction reversal with strong body
    if(isBull != prevBull && bodyRatio > 0.50 && body > prevBody * 0.65)
        return PATTERN_FAILED_BREAKOUT;

    // ---- THREE-CANDLE PATTERNS ----

    // Morning Star: large bear, small indecision, large bull
    if(isBull && !prev2Bull &&
       bodyRatio >= 0.55 &&                     // Current: strong bull
       prev2BodyR >= 0.55 &&                     // Two bars ago: strong bear
       MathAbs(prevClose - prevOpen) / range < 0.30 &&  // Middle: tiny body
       close > prev2Open + (prev2Close - prev2Open) * 0.5) // Bull closes > 50% into bear
        return PATTERN_MORNING_STAR;

    // Evening Star: large bull, small indecision, large bear
    if(!isBull && prev2Bull &&
       bodyRatio >= 0.55 &&
       prev2BodyR >= 0.55 &&
       MathAbs(prevClose - prevOpen) / range < 0.30 &&
       close < prev2Open + (prev2Close - prev2Open) * 0.5)
        return PATTERN_EVENING_STAR;

    // ---- STRUCTURAL PATTERNS (use feature flags from context) ----
    // CHoCH patterns are identified at regime-classification level,
    // not single-candle. Return structural type for strong continuation bars.
    
    // Strong bullish momentum bar (trend continuation)
    if(isBull && bodyRatio >= 0.65 && uwickRatio < 0.20)
        return PATTERN_MOMENTUM_CONTINUATION;

    // Strong bearish momentum bar
    if(!isBull && bodyRatio >= 0.65 && lwickRatio < 0.20)
        return PATTERN_BEARISH_CONTINUATION;

    // Structural HH/HL (aliased for backward compatibility)
    if(isBull) return PATTERN_HH;
    if(!isBull) return PATTERN_LL;

    return PATTERN_NONE;
}
