    regimeStrategies[7].volatilityWeight = 1.0;
    regimeStrategies[7].biasWeight = 1.3;
    regimeStrategies[7].patternWeight = 0.9;
    regimeStrategies[7].predictiveWeight = 1.1;
    regimeStrategies[7].conservativeTP = 1.8;
    regimeStrategies[7].aggressiveTP = 3.0;
    regimeStrategies[7].optimalTP = 2.2;
    regimeStrategies[7].riskTolerance = 1.1;
    regimeStrategies[7].allowAggressive = true;
    
    // ULTRA BEARISH (8)
    regimeStrategies[8].maxPositionSize = 1.4;
    regimeStrategies[8].maxRiskPercent = 1.5;
    regimeStrategies[8].requiredEdgeStrength = 0.28;  // FIX: Lowered from 0.32 to 0.28
    regimeStrategies[8].momentumWeight = 2.0;
    regimeStrategies[8].reversalWeight = 0.3;
    regimeStrategies[8].volatilityWeight = 1.0;
    regimeStrategies[8].biasWeight = 1.5;
    regimeStrategies[8].patternWeight = 0.8;
    regimeStrategies[8].predictiveWeight = 1.2;
