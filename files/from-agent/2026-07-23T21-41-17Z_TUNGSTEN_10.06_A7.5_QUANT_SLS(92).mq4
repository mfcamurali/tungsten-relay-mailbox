};

// Global instances

//| FORWARD DECLARATIONS FOR ALL HELPER FUNCTIONS                    |

// E9.9 Core Functions
void E99_InitializeAll();
void E99_InitializeMilestones() {
    double startBal = AccountBalance();
    if(startBal <= 0) startBal = 100.0;  // FIX: guard against 0 balance on reconnect
    // 9.39: only set once -- if this fires again on a restart, don't overwrite the
    // real original start time with "now", or every days-elapsed calc downstream resets.
    if(g_E99_Milestones.startTime == 0) g_E99_Milestones.startTime = TimeCurrent();
    g_E99_Milestones.absoluteStartBalance = startBal;
    g_E99_Milestones.currentBalance = startBal;
    g_E99_Milestones.allTimePeak = startBal;
    g_E99_Milestones.currentLevel = 0;
    g_E99_Milestones.peakLevel = 0;
    g_E99_Milestones.timesSlid = 0;
    g_E99_Milestones.millionAchieved = false;
    // E9.94: 10 strictly-ascending absolute targets
    // Ratios from startBal with hard dollar floors ensure each milestone
    //   L9  x18000 ~$15M   M9 projection ceiling
    double t[10];
    t[0] = MathMax(startBal * 2.0,       1000.0);
    t[1] = MathMax(startBal * 10.0,      5000.0);
    t[2] = MathMax(startBal * 100.0,     50000.0);
    t[3] = MathMax(startBal * 600.0,     250000.0);
    t[4] = MathMax(startBal * 1200.0,    1000000.0);
    t[5] = MathMax(startBal * 2400.0,    2000000.0);
    t[6] = MathMax(startBal * 5000.0,    4000000.0);
    t[7] = MathMax(startBal * 9600.0,    8000000.0);
    t[8] = MathMax(startBal * 18000.0,   15000000.0);
    t[9] = MathMax(startBal * 36000.0,   30000000.0);
    // Guarantee strict ascension (in case startBal floors dominate)
    for(int fi = 1; fi < 10; fi++) {
        if(t[fi] <= t[fi-1]) t[fi] = t[fi-1] * 1.5;
    }
    string mNames[10] = {
        "x2 - FOUNDATION", "x10 - CALIBRATED", "x100 - COMPOUNDING",
        "x600 - SCALING",  "x1200 - MILLIONAIRE", "x2400 - WEALTH TIER",
        "x5000 - FOUR MILLION", "x9600 - EIGHT MILLION",
        "x18000 - FIFTEEN MILLION", "x36000 - THIRTY MILLION"
    };
    double mWR[10] = { 65.0, 65.0, 68.0, 70.0, 72.0, 73.0, 73.0, 74.0, 74.0, 75.0 };
    for(int mi = 0; mi < 10; mi++) {
        g_E99_Milestones.milestones[mi].level          = mi + 1;
        g_E99_Milestones.milestones[mi].name           = mNames[mi];
        g_E99_Milestones.milestones[mi].multiplier     = t[mi] / startBal;
        g_E99_Milestones.milestones[mi].startBalance   = (mi == 0) ? startBal : t[mi-1];
        g_E99_Milestones.milestones[mi].targetBalance  = t[mi];
        g_E99_Milestones.milestones[mi].requiredWinRate= mWR[mi];
        g_E99_Milestones.milestones[mi].achieved       = false;
        g_E99_Milestones.milestones[mi].locked         = false;
    }

    // Milestone targets logged at ARMED seal
};

// PATTERN FORMATION PARAMETERS - Natural span ranges per pattern
struct PatternFormationParams {
    PatternType type;
    int minSwings;      // Minimum swing points this formation requires
    int maxSwings;      // Maximum swings to consider (efficiency cap)
    int minBars;        // Minimum bars this pattern can form in
    int maxBars;        // Maximum bars before timeout (pattern too extended)
    int scanStep;       // Bar increment for efficiency (adaptive)
    bool needsVolume;   // Whether volume confirmation is structural marker
};

PatternFormationParams g_FormationParams[40];
int g_FormationParamsCount = 0;

// REGIME STABILITY SYSTEM - Prevents rapid oscillation
// Hysteresis = different thresholds to enter vs exit a regime
struct RegimeState {
    int currentRegime;           // Confirmed regime (0-7)
    int confirmedBars;           // Duration in this regime
    int transitionRegime;        // Pending regime (-1 if none)
    int transitionConfirmBars;   // Bars confirming transition
    datetime lastChange;
    bool inTransition;           // Flag: market in flux
};

struct RegimeHysteresis {
    double entryThresholdLow;     // ADX to enter from below
    double entryThresholdHigh;    // ADX to enter from above
    double exitThresholdLow;      // ADX to exit downward (buffer)
    double exitThresholdHigh;     // ADX to exit upward (buffer)
    double minADX;                // Minimum ADX to maintain
    int minConfirmBars;           // Bars needed to confirm change
};

RegimeState g_RegimeState;
RegimeHysteresis g_RegimeHysteresis[9];
bool g_RegimeHysteresisInitialized = false;

// REGIME CONFIDENCE AND DECAY TRACKING
double g_RegimeScores[9];
double g_RegimeConfidence[9];
double g_RegimeMomentum[9];
double g_RegimeScoreHistory[9][6];   // rolling 6-bar window per regime
int    g_RegimeScoreHistoryHead = 0;
bool   g_RegimeScoreHistoryFull = false;
bool   g_DominantRegimeDecaying = false;
double g_DominantRegimeStrength = 0.5;
// BEHAVIORAL COHERENCE + MATURITY PHASE
double g_RegimeBehavioralCoherence = 0.5;  // 0-1: bar-level behavioral fit
int    g_RegimeMaturityPhase       = 0;     // 0=FORMING 1=DEVELOPING 2=MATURE 3=EXHAUSTING
int    g_RegimeSubPattern          = 0;     // sub-type within active regime (0=generic)
int    g_RegimeTransitionPressure  = -1;    // runner-up regime gaining momentum (-1=none)


// MathSign - Returns sign of value (MQL4 doesn't have built-in)
double MathSign(double value) {
    if(value > 0) return 1.0;
    if(value < 0) return -1.0;
    return 0.0;
}

// INTELLIGENT LOGGING SYSTEM - Production Grade

enum LogLevel {
    LOG_CRITICAL = 0,  // Always shown: errors, calibration complete, trading enabled
    LOG_IMPORTANT = 1, // Key milestones: phase transitions, major decisions
    LOG_INFO = 2,      // Helpful context: performance updates, regime changes
    LOG_DEBUG = 3,     // Development only: detailed diagnostics
    LOG_VERBOSE = 4    // Everything: individual calculations (disable in production)
};

input LogLevel UserLogLevel = LOG_IMPORTANT;  // User-adjustable verbosity

// Professional logging function - clean, well-timed, human-friendly
void LogMessage(LogLevel level, string message) {
    if(level > UserLogLevel) return;  // Skip if below user's threshold
    
    string prefix = "";
    switch(level) {
        case LOG_CRITICAL:  prefix = "[TUNGSTEN]"; break;
        case LOG_IMPORTANT: prefix = "[INFO]    "; break;
        case LOG_INFO:      prefix = "[DETAIL]  "; break;
        case LOG_DEBUG:     prefix = "[DEBUG]   "; break;
        case LOG_VERBOSE:   prefix = "[TRACE]   "; break;
    }
    
    Print(prefix + " " + message);
}

// Quick access functions
void LogCritical(string msg) { LogMessage(LOG_CRITICAL, msg); }
void LogInfo(string msg) { LogMessage(LOG_INFO, msg); }

// LOG_CRITICAL - Use for:
// LOG_IMPORTANT - Use for:
//   - Phase completions during calibration


// CORRELATION LEARNING SYSTEM - Neural-Like Pattern Recognition
// Like GPT learns "these words together mean X", this learns:
// "HH+HL+RSI60+ADX25 = Regime 0 with 92% accuracy"

struct FeatureCorrelation {
    // PRESENCE FLAGS (binary structural state)
    bool hasHH, hasHL, hasLL, hasLH;
    bool hasBOS, hasCHoCH;

    // INDICATOR RANGES (center +/- tolerance stored explicitly)
    // Matching uses Gaussian proximity -- partial matches count.
    // Original 6 features:
    double rsiMin, rsiMax;
    double adxMin, adxMax;
    double macdMin, macdMax;
    double structureClarityMin, structureClarityMax;
    double volumeRatioMin, volumeRatioMax;
    double trendConsistencyMin, trendConsistencyMax;

    // EXPANDED CONDITION FEATURES (added for high-fidelity)
    // Every feature available during live trading that has
    // demonstrated discriminating power across regimes.
    double pricePositionMin,    pricePositionMax;    // 0-1 where in range
    double marketBias20Min,     marketBias20Max;     // -1..+1 directional bias
    double volatilityTrendMin,  volatilityTrendMax;  // ATR expanding/contracting
    double rangeCompressionMin, rangeCompressionMax; // range tightening signal
    double macdNormMin,         macdNormMax;         // ATR-normalised MACD delta
    double rsislopeMin,         rsislopeMax;         // RSI rate of change
    double volumeTrendMin,      volumeTrendMax;      // volume momentum
    double atrPctMin,           atrPctMax;           // ATR as % of price
    double bodyToWickMin,       bodyToWickMax;       // candle body quality
    bool   nearBullOB;          // near bullish order block
    bool   nearBearOB;          // near bearish order block

    int    observations;        // times this pattern appeared in history
    int    correctPredictions;  // regime classification correct
    double accuracy;            // correctPredictions / observations
    int    targetRegime;        // which regime this predicts
    double confidence;          // accuracy x log(obs) composite

    // OUTCOME METRICS (condition -> what actually happened)
    double avgForwardReturn;    // mean signed return over regime's exitH bars
    double avgFavorableExcursion; // mean max move in signal direction
    int    winCount;            // profitable outcomes
    int    lossCount;           // unprofitable outcomes
    double outcomeWinRate;      // winCount / (winCount + lossCount)

    // STATISTICAL CHARACTER FEATURES (added for Hurst/FD/DI)
    // These are the most discriminating features for distinguishing
    // trending from ranging markets and are independent of pattern recognition.
    double hurstMin, hurstMax;          // Hurst exponent (trending > 0.55, ranging < 0.45)
    double fractalDimMin, fractalDimMax;// Fractal dimension (trending < 1.5, noisy > 1.6)
    double diGapMin, diGapMax;          // DI+ minus DI- (positive = bullish pressure)

    datetime lastSeen;
    bool validated;
};

struct RegimeCorrelationMatrix {
    FeatureCorrelation correlations[200];
    int    correlationCount;
    double overallAccuracy;       // Classification accuracy (predicted==actual label)
    bool   learned;
    int    totalObservations;
    int    correctPredictions;
    // -- Trading performance fields (Phase 2 signal WR per regime) ----------
    int    signalWins;            // Signals that hit TP in holdout
    int    signalTotal;           // Total signals fired in holdout
    double signalWR;              // signalWins / signalTotal — the KEY metric
    // Volatility-stratified WR — allows vol-aware threshold adjustment
    double lowVolWR;    // WR when ATR < regime p33 — calm conditions
    double medVolWR;    // WR at medium volatility
    double highVolWR;   // WR when ATR > regime p66 — volatile conditions
    int    lowVolCount;  int medVolCount;  int highVolCount;
    double signalPF;              // Profit factor in this regime
    // -- Market character fields --------------------------------------------
    double avgHurst;              // Mean Hurst exponent (> 0.55 = trending character)
    double avgATRPct;             // Mean ATR percentile (volatility level 0-1)
    double avgEntropy;            // Mean market entropy (> 0.65 = unpredictable)
    double avgMomentumBias;       // Mean 5-bar momentum bias (-1 to +1)
    double avgBodyRatio;          // Mean candle body/range ratio (conviction)
    double avgStructureClarity;   // Mean structure clarity score (0-1)
    // -- Session intelligence ----------------------------------------------─
    int    sessionWins[4];        // Signal wins per session in this regime
    int    sessionTotal[4];       // Signal count per session in this regime
    double sessionWR[4];          // Per-session WR within this regime
    int    dominantSession;       // Session index with highest WR (0=Asian 1=London 2=NY 3=Late)
    // -- Regime prevalence --------------------------------------------------
    int    barCount;              // Total bars classified to this regime
    double pctOfMarket;           // Fraction of training bars in this regime
      // -- Component discrimination (added Phase 2 — per-component accuracy) ─
      double compAccuracy[6];       // per-component: fraction of signals it pointed correctly
      double compDiscrimination[6]; // accuracy on winners minus accuracy on losers
      double winnerFingerprint[6];  // fraction of winners where component agreed with direction
      double loserFingerprint[6];   // fraction of losers where component agreed with direction
      int    compSampleN;           // number of signal bars with component data
      // Per signal type WR — continuation / reversal / breakout
      double contWR; int contN;   // continuation: WR and sample count
      double revWR;  int revN;    // reversal: WR and sample count
      double brkWR;  int brkN;    // breakout: WR and sample count
      int    dominantSignalType;  // type that fires most in this regime
    double medianScore;           // Median |score| of signals in this regime
};

// One matrix per regime - learns the "grammar" of each regime
RegimeCorrelationMatrix g_RegimeCorrelations[9];
bool g_CorrelationsLearned = false;

// BAR OUTCOME STRUCT -- precomputed ATR TP/SL result per bar.
// Phase 3B (weight search) precomputes both long and short outcomes
struct BarOutcomeATR {
    double longPnL;   // PnL (ATR units) if signal was long: +tpMult on TP hit, -slMult on SL hit, 0 on time exit flat
    double shortPnL;  // PnL (ATR units) if signal was short
    double atr;       // ATR at entry bar (0 = invalid, skip)
    double recency;   // Recency weight: exp(-(barIndex - startBar)/tau). Newest training bar = 1.0.
    double longR;    // longPnL / ATR — R-multiple (vol-neutral)
    double shortR;   // shortPnL / ATR
};

// COMPONENT WEIGHT OPTIMIZATION SYSTEM

struct ComponentWeights {
    double mtf;           // Multi-timeframe alignment weight (0.5 to 1.5)
    double momentum;      // Momentum/MACD weight (0.5 to 1.5)
    double volatility;    // Volatility/ATR weight (0.5 to 1.5)
    double volume;        // Volume weight (0.5 to 1.5)
    double session;       // Session timing weight (0.5 to 1.5)
    double pattern;       // Pattern weight (0.5 to 1.5)
    // 9.38: restored as independently tunable fields -- a prior struct consolidation
    // silently merged these into momentum/volatility/pattern above (see call sites that
    // used to carry "/* was: X */" comments), discarding real, distinct backtested and
    // live-adapted weight values every time they were saved, loaded, or applied.
    double reversal;      // Reversal-signal weight (0.5 to 1.5)
    double directional;   // Directional-bias weight (0.5 to 1.5)
    double predictive;    // Predictive-system weight (0.5 to 1.5)
    // 9.41: currency-strength weight, derived directly from its measured Phase 2 IC
    // (see g_RegimeICCcy) rather than from the Phase 3 grid search the other fields
    // above go through -- this signal now earns/loses trust the same principled way
    // the other components do, without touching the combinatorial grid-search code.
    double currencyStrength; // Currency-strength/cross-pair weight (0.5 to 1.5)

    // Performance metrics
    double trainingWR;      // Win rate on training set
    double validationWR;    // Win rate on validation set (out-of-sample)
    double expectedValue;   // Expected value per trade
    int sampleSize;         // Number of observations
    bool validated;         // Passed validation checks
};

// Optimal weights discovered per regime during calibration
ComponentWeights g_RegimeOptimalWeights[9];

// Optimal thresholds discovered per regime during calibration
double g_RegimeOptimalThresholds[9];  // SIGNED-MARGIN space: |signedScore| >= thr gates entries (0=neutral).
                                          // Live bridge: normalized = 50 + thr/2 (L40765). 16 here == 58 live.

// OVERHAUL: Per-regime optimal exit horizon (bars) discovered during calibration
// Replaces the hardcoded 20-bar exit used everywhere. Range tested: 5-50 bars.
int g_RegimeOptimalExitBars[9];   // Initialized to 20, overwritten by Phase 3A
double g_RegimeOptimalSLMult[9];  // ATR SL multiplier per regime -- default 1.5, calibrated in Phase 3C
int    g_P3B_ValidatedRegimes = 0;  // 9.23: regimes with genuinely validated P3B weights (not fallback); P4 uses to scale observation floor
double   g_RegimeTPByType[9][4];  // [regime][SIGTYPE_*] per-type TP (Phase 3C)
double   g_RegimeSLByType[9][4];  // [regime][SIGTYPE_*] per-type SL (Phase 3C)
double g_RegimeOptimalTPMult[9];  // ATR TP multiplier per regime -- default 2.5, calibrated in Phase 3C
bool   g_TPSLMultCalibrated = false;  // 9.42: true once Phase 3C has written real multipliers
bool   g_RegimeBracketFallback[9];  // WARRANT#80: true if this regime's SL/TP reverted to the fixed
                                     // default after a recheck showed the calibrated bracket losing
                                     // to it -- diagnostic-only tracking, not itself persisted (the
                                     // effect is already captured by the SLMult/TPMult overwrite,
                                     // which IS persisted via the existing save/load path).

// OVERHAUL: Information Coefficient per component across full history
// Spearman rank-IC between each component score and 20-bar aligned return.
// Used as Phase 3 starting-point weights so grid search begins near the true optimum.
double g_RegimeIC[9][6];
double g_PriorRegimeIC[9][6]; // Prior calibration IC for 70/30 persistence blend
// 9.41: currency-strength IC, measured by the SAME Phase 2 process (MeasureRegimeIC)
// as the 6 components above, but kept in its own array rather than widening
// g_RegimeIC to [9][7] -- g_RegimeIC and its blend/persistence are already read at
// ~20 call sites (avg-IC calcs, weight caps, FileWrite/FileRead in 3 separate save
// paths that 9.39/9.40 just finished reconciling after real drift bugs). Widening a
// shared, already-fragile array for one new component risks reproducing exactly the
// invariant-drift failure mode the 9.40 thesis diagnosed; a parallel array is the
// same measurement, isolated blast radius.
double g_RegimeICCcy[9];
double g_PriorRegimeICCcy[9];
double g_RegimeLiveWR[9];  // Per-regime calibrated WR from Phase 2 (prior for live adaptive)

// Phase 3B.5: Session-specific weight refinement per regime
// Dimensions: [session][regime]  (session: 0=London 1=NY 2=Asia 3=Sydney)
ComponentWeights g_SessionRegimeWeights[4][9];
bool g_SessionWeightsValid[4][9];

// Phase 3B.6: Volatility-state weight refinement per regime
// Dimensions: [vol_state][regime]  (vol_state: 0=Low 1=Normal 2=High)
ComponentWeights g_VolatilityRegimeWeights[3][9];
bool g_VolatilityWeightsValid[3][9];

// Phase 3C.5: Session-specific TP/SL multipliers [session][regime]
double g_SessionSLMult[4][9];
double g_SessionTPMult[4][9];

double g_CalibratedAvgSpread = 0;  // Avg spread in pips from Phase 1. Used by Phase 6 ghost sim.
bool g_ICMeasured = false;

// Calibrated ATR-ratio percentile thresholds for live volatility classification.
double g_CalibratedVolLowThresh  = 0.75;
double g_CalibratedVolHighThresh = 1.30;

// Phase 3B.7: calibrated blend ratios for 3-way weight blend.
double g_BlendAlphaRegime  = 0.50;
double g_BlendAlphaSession = 0.30;
double g_BlendAlphaVol     = 0.20;
bool   g_BlendCalibrated   = false;

int g_LiveTradeEntryRegime = -1;
int g_ServerTimeOffsetHours = 0;
// SLS25-CLAUDE: 20-bar EMA200-distance history for the windowed macro-slope test.
// Ring buffer; g_Ema200DistHist20 holds the value from ~20 classifications ago.
double g_Ema200DistRing[20];
int    g_Ema200DistRingIdx = 0;
bool   g_Ema200DistRingFull = false;
double g_Ema200DistHist20 = 0.0;
bool g_TimeOffsetDetected = false;
bool g_WeightsOptimized = false;

// -- PRE-LOSS DETECTION SYSTEM (PLDS) ----------------------------------------─
// Six leading indicators that precede losing streaks, monitored continuously.
// Proactively scales risk and tightens entry threshold — not binary halt, but
// continuous calibration of exposure to match predicted reliability.
#define PLDS_IC_HIST    50
#define PLDS_DISC_HIST  30
#define PLDS_COHER_HIST 20
struct PreLossState {
    double icSlopeDanger;    // IC falling - signal losing edge
    double discSlopeDanger;  // score WR gap narrowing - noise rising
    double regimeDriftDanger;// conditions diverging from training data
    double transitionDanger; // elevated adverse regime transition prob
    double coherenceDecay;   // awareness coherence falling
    double awareMissRate;    // system's own forward predictions proving wrong
    double compositeRisk;    // weighted composite [0,1]
    double riskScaleFactor;  // lot multiplier [0.40, 1.00]
    double thresholdBoost;   // added to entry threshold [0, 10]
    double icHistory[50];    // ring buffer of IC values per trade
    double discHistory[30];  // ring buffer of discrimination values
    double coherHistory[20]; // ring buffer of coherence per bar
    int    icIdx, discIdx, coherIdx, icFilled;
    int    predTotal, predCorrect;
    bool   predPending;
    bool   active;
    datetime lastUpdated;
};
PreLossState g_PLDS;

// -- ONLINE GRADIENT ACCUMULATOR ----------------------------------------------─
// After every closed trade, a tiny gradient step nudges g_RegimeOptimalWeights
// toward configurations that predict outcomes better. This is NOT gradient descent
// on a differentiable loss — MQL4 can't do that. Instead it's a finite-difference
// approximation: components that scored higher on wins get a small upward nudge,
// components that scored higher on losses get a downward nudge.
// Learning rate α = 0.008 (small enough that a single trade doesn't destabilise,
// large enough that 100 trades produce visible adaptation).
// Gate: only active after ≥20 live trades in the regime (statistical floor).
#define ONLINE_LR 0.008
double g_OnlineGradAccum[9][6]; // accumulated gradient per [regime][component]
int    g_OnlineGradCount[9];    // trade count for denominator normalisation

// -- PER-REGIME QUARANTINE SYSTEM --------------------------------------------─
// When a regime's live WR falls below 58% over 8+ trades, it is quarantined:
// no new entries are taken in that regime until ghost repair raises WR ≥ 62%.
// This is the missing link: weak regimes previously traded at equal participation
// while the rest of the system remained healthy. Now they pause and self-repair.
bool   g_RegimeQuarantined[9];        // true = regime suspended from live entries
double g_RegimeQuarantineWR[9];       // WR that triggered quarantine
int    g_RegimeQuarantineTrades[9];   // sample size when quarantine fired
datetime g_RegimeQuarantineTime[9];   // when quarantine was triggered
int    g_RegimeRepairAttempts[9];     // how many ghost repairs attempted per regime
double g_RegimeRepairBestWR[9];       // best WR found during ghost repair for this regime
// Escalation: if 4+ regimes quarantined simultaneously - trigger CATREC
// (patching individually is futile if the market has structurally shifted)
int    g_QuarantinedRegimeCount = 0;
// -- UPGRADE 5: Regime Transition Matrix --------------------------------------
// g_RegimeTransitions[from][to]: count of observed regime→regime transitions in live trading.
// Populated every time a confirmed regime commit fires (DetermineRegime - commit block).
// Used by live execution to pre-adjust TP/SL based on P(volatile | currentRegime).
int g_RegimeTransitions[9][9];    // [fromRegime][toRegime] observation counts
int g_RegimePrevCapture = -1;     // last regime that committed — seeds the from-side

// -- ONLINE WEIGHT ADAPTER (OWA) — gradient-style post-trade weight nudges ----
double g_OWA_NudgeWeights[9][6];  // [regime][component] signed accumulated nudge
int    g_OWA_NudgeCount[9];       // live trades since last calibration per regime

// -- META-CALIBRATION MEMORY (MCM) — durable weight region history --------─
double g_MCM_Weights[4][9][6];    // [slot][regime][component]
double g_MCM_Thresholds[4][9];
double g_MCM_OOS_WR[4];
int    g_MCM_DurabilityBars[4];
int    g_MCM_WalkForwardOK[4];     // 9.21: 1 if ghost walk-forward was OK at that calibration
double g_MCM_RegWR[4][9];          // 9.24: per-slot per-regime ghost WR (regime alignment scoring)
int    g_MCM_RegObs[4][9];         // 9.24: per-slot per-regime obs count (gates alignment bonus)
datetime g_MCM_CalibTime[4];       // 9.30: timestamp of each slot's calibration — enables age discount in slot selection
int    g_MCM_Count = 0;
// ===== SLS13 R5: RECALIBRATION CARRY-FORWARD LEDGER =====
// Per-regime memory that persists across calibration cycles so recalibration starts ahead
// and never re-makes known mistakes. g_CF_BestWR is the best HOLDOUT WR ever achieved for a
// regime; g_CF_Ceiling marks regimes that repeatedly could NOT clear target (likely no edge
// on this instrument) so the retry ladder can spend its effort where it can actually win
// rather than retreading hopeless ground. g_CF_Seen tracks whether we have prior history.
// CRITICAL GUARD: carried intel is a SEED, not a truth — every cycle re-validates on fresh
// holdout, and a regime can be promoted OUT of the ceiling if a new cycle beats its old best.
double g_CF_BestWR[9];        // best holdout WR ever seen per regime
int    g_CF_FailStreak[9];    // consecutive cycles a regime missed its target
bool   g_CF_Ceiling[9];       // true = repeatedly hit a ceiling below target (deprioritize)
bool   g_CF_Seen = false;     // do we have any prior-cycle memory yet?
// ===== SLS13 T1: LEARNED CONVICTION TIERS (per regime) =====
// Three execution bands READ from the win-rate-vs-score curve, never hand-set:
//   |score| >= g_TierExcellent  -> EXCELLENT: near-certain, trade with full conviction/size
//   |score| >= g_TierGood       -> GOOD: solid +EV, trade normal
//   |score| <  g_TierGood       -> NO-TRADE: ambiguous, stand down on purpose
// The GOOD floor is anchored to cost-adjusted breakeven (49's-maths-as-friend): the score
// level where measured WR first clears breakeven+cushion. EXCELLENT is where WR reaches a
// high bar. Discovered from outcomes, validated on holdout — decreed by nothing.
double g_TierGood[9];         // |score| floor for a tradeable (good) setup, per regime
double g_TierExcellent[9];    // |score| floor for an excellent (near-certain) setup
bool   g_TiersLearned = false;

// -- LIVE SIGNAL MONITOR (LSM) — per-bar mid-trade condition tracking --------
int    g_LSM_EntryRegime  = -1;
double g_LSM_EntrySeqMult =  1.0;
double g_LSM_EntryScore   =  0.0;
double g_LSM_VolRiskAtEntry = 0.0;
bool   g_LSM_Active       = false;
bool   g_LSM_BEForced     = false;

// -- SEQMULT LIVE CACHE ----------------------------------------------------─
double   g_seqMultLiveCache    = 1.0;
datetime g_seqMultLiveCacheBar = 0;

// -- CROSS-REGIME NEIGHBOUR PAIRS ------------------------------------------─
int g_RegimeNeighbourA[9];
int g_RegimeNeighbourB[9];

MarketCalibration g_Calibration;

// -- Regime change and monthly tracking structs --------------------------─
struct RegimeChangeTracker {
    double   rolling30DayWR;
    int      consecutiveBadMonths;
    bool     regimeShiftSuspected;
    string   regimeWarning;
    datetime lastRegimeCheck;
};
RegimeChangeTracker g_RegimeChange;

struct MonthlyGoalTracker {
    double   monthStartBalance;
    double   expectedGrowthPercent;
    datetime monthStartTime;
    int      daysIntoMonth;
    double   currentProgress;
    int      urgencyLevel;
};
MonthlyGoalTracker g_MonthlyGoals;

struct VolatilityFilterState {
    double   minimumATR;
    double   currentATR;
    bool     sufficientVolatility;
    datetime lastVolatilityCheck;
};
VolatilityFilterState g_VolatilityFilter;

// -- DYNAMIC FREQUENCY ADVISOR ------------------------------------------------─
// Answers: "How many trades/day do we need at current WR to match a higher WR class?"
// Mathematics: per-trade geometric factor g = (1+r*b)^p * (1-r)^(1-p)
// Compensation ratio = ln(g_benchmark) / ln(g_current) — exact, no approximation.
// The system never lowers quality thresholds to chase signals — purely advisory.
struct FrequencyAdvisor {
    // Current state
    double currentDailyFreq;      // Observed trades/day this month
    double currentMonthlyWR;      // Observed WR this month (live)
    double currentRisk;           // Current average risk per trade
    double perTradeGFactor;       // g = geometric factor per trade at current WR+risk

    // Targets
    double targetDailyFreq;       // Trades/day needed to hit tier monthly target
    double targetMonthlyGrowth;   // The tier target (e.g. 0.40 for sub-$10k 65% WR)

    // Compensation vs benchmark classes
    double compRatio70;           // n_needed_current / n_at_70pct — how many more vs 70% benchmark
    double compRatio75;           // n_needed_current / n_at_75pct — vs 75% benchmark
    double equivWRClass;          // What WR% does current freq+WR effectively deliver

    // Safety
    double safeMaxFreq;           // Quality-gated maximum — never chase beyond this
    bool   frequencyDeficit;      // actual < target (need more sessions / timeframe coverage)
    bool   frequencyExcess;       // actual > safeMax (quality dilution risk)
    bool   compensationFeasible;  // target achievable within quality cap
    string advisoryMessage;       // Human-readable guidance
    int    tradesThisMonth;       // Running count for frequency calculation
    int    monthlyTradingDays;    // Days with at least 1 trade this month
};
struct WRFloorGuardian {
    datetime tier1StartTime;    // When tier 1 first activated (CATREC deferral)
    bool   tier1Active;          // WR -5pp below calibration: +3pt threshold
    bool   tier2Active;          // WR -10pp: +6pt threshold, 0.80x risk
    bool   tier3Active;          // WR -15pp: ghost mode
    double guardianThreshBoost;  // Threshold addition from guardian
    double guardianRiskMult;     // Risk multiplier from guardian
};
WRFloorGuardian g_WRGuardian;
FrequencyAdvisor g_FreqAdvisor;

// SLS(24) T3: one-time flag -- old-program live statistics (rolling WR/RR, guardian
// floors, streak counters) must not grade the corrected system. Set the first time
// RunComprehensiveGhostValidation passes its gate under this build; persisted via the
// 0xF116 guarded tail in SaveSystemState/LoadSystemState so it never repeats.
bool g_SLS24_StatsRebased = false;

// -- SHADOW LEARNER — near-threshold signals that ALMOST fired --------─
// Each WAIT-zone signal (within 5pt of effective threshold) is recorded.
// Outcomes are evaluated over the next 20 bars. If shadow WR >= 65%,
// GetLearnedOptimalThreshold nudges the threshold downward — the system
// earns additional trades by proving the edge exists just below the gate.
struct ShadowRecord {
    datetime openTime;   // when the near-miss occurred
    bool     isBuy;      // direction
    double   score;      // normalized 0-100 score at that moment
    double   effThr;     // effective threshold (including CEO relax)
    double   gap;        // effThr - score (how close it was)
    int      regime;     // market regime index
    double   entryPrice; // price at signal time
    double   targetTP;   // theoretical TP (Phase 3C multiplier x ATR)
    double   targetSL;   // theoretical SL
    bool     closed;     // outcome evaluated?
    bool     wouldWin;   // hit TP before SL?
};

struct ShadowLearner {
    ShadowRecord records[60];  // rolling buffer — 60 shadow signals
    int          head;         // write pointer (circular)
    int          total;        // total recorded lifetime
    int          wins;         // evaluated wins
    int          evaluated;    // evaluated total
    double       nudge;        // cumulative threshold reduction earned (max 3.0pt)
    datetime     lastNudgeBar; // last bar a nudge was applied
    // SLS13 T2: per-regime retrospective memory — the "routes not taken".
    // missedWins[r]  = near-miss bars in regime r the system DIDN'T take that would have WON.
    // avoidedLoss[r] = near-miss bars it correctly stood aside on that would have LOST.
    // missedTotal[r] = evaluated near-misses in regime r (denominator). Together these say:
    // "in THIS regime, my no-trade zone is leaving money on the table" (lots of missed wins)
    // vs "my caution here is justified" (mostly avoided losses) — situation-specific learning.
    int          missedWins[9];
    int          avoidedLoss[9];
    int          missedTotal[9];
};
ShadowLearner g_Shadow;

// -- COMPOUNDING PHASE DETECTOR ----------------------------------------─
// Identifies growth acceleration: 4+ winning days in last 7 creates
// a multiplier on maxTradesPerDay so the system captures more signals
// during proven strong performance phases.
struct CompoundingPhase {
    double  dailyGrowth[7];   // rolling 7-day growth rates
    int     head;             // circular write pointer
    bool    isActive;         // currently in compounding phase
    int     activeDays;       // consecutive compounding days
    double  boostMultiplier;  // 1.0 = baseline, 1.2 = +2 tpd, 1.4 = +4 tpd
    datetime lastEval;        // last evaluation time
};
CompoundingPhase g_Compounding;



// DEEP HISTORICAL INTELLIGENCE -- built from 10,000 bars during calibration
// Gives the system statistical knowledge that requires 1.4 years of data
// to accumulate -- an edge unavailable to discretionary retail traders.

// Per-hour historical WR (24 hours GMT) -- ~400 obs/hour from 10k bars.
// Used as real-time threshold modifier: high-WR hours allow earlier entry.
double g_HourlyWR[24];            // WR per GMT hour (0.0 = no data)
int    g_HourlyObs[24];           // Observation count per hour
bool   g_HourlyCalibrated = false;
double g_MarketMemoryConviction = 0.0;

// -- CEO Competence Score (CCS) ----------------------------------------─
// Single rolling 0-100 metric. All subsystems read this.
// 0-39: Proving ground.  40-59: Developing.  60-74: Competent.
// 75-89: High performance.  90-100: Elite — 7% risk unlocked.
double g_CEO_CompetenceScore    = 50.0;  // start neutral until live data arrives
double g_LastSignalMargin        = 0.0;   // SVJ-D: conviction margin at last signal
double g_BrokerMinLot            = 0.0;   // Probed actual broker minimum lot (set in ProbeBrokerLotLimits)
bool   g_ScaleLog15M             = false;  // once-only $15M scale tier log
bool   g_ScaleLog5M              = false;  // once-only $5M scale tier log
double g_CEO_RiskCeiling        = 2.0;   // max risk % — rises with competence
double g_CEO_ThresholdRelax     = 0.0;   // pts to SUBTRACT from base threshold
int    g_CEO_MaxConcurrentTrades = 1;    // scales 1→4 with competence
int    g_CEO_GhostTriggerLosses  = 3;    // unproven systems trigger ghost sooner — protection first
struct CatrecDiagnosis {
    double worstComponentIdx;  // 0=MTF, 1=Mom, 2=Vol, 3=Volatility, 4=Session, 5=Pattern
    double overconfidenceScore; // were signals too far above threshold (overconfident)?
    double regimeMisclassRate;  // how often was the classified regime wrong? (proxy: loss rate by regime)
    double thresholdBias;      // were thresholds systematically too low or too high?
    double timingBias;         // was there a session/hour pattern in losses?
    bool   exitHorizonWrong;   // were losses caused by hitting SL before TP?
    bool   componentWeightDrift; // did a specific component dominate losses?
    bool   regimeConfusionMode;  // was the system confusing similar regimes?
    double preserveRegimes[9]; // 0.0=rebuild this regime, 1.0=preserve it (was working)
    string summary;
};

struct ErrorAttribution {
    int regime; double worstComponent;
    double failureScore; double avgLossR; double preCalibWR;
    datetime timestamp;
};
ErrorAttribution g_ErrorMemory[50];
int g_ErrorMemoryCount=0, g_ErrorMemoryIdx=0;
// Per-regime component attribution — 9 regimes x 6 components
// Win accumulator: scores on trades that won, per regime
