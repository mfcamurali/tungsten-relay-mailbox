int GetCurrentMilliseconds() {
    static int baseSeconds = 0;
    static int tickCounter = 0;
    static uint lastTickCount = 0;
    
    int currentSeconds = (int)TimeCurrent();
    uint currentTick = GetTickCount();
    
    // Use system tick count for more accurate millisecond resolution
    if(currentTick > 0 && lastTickCount > 0) {
        uint tickDiff = currentTick - lastTickCount;
        if(tickDiff < 60000) { // Sanity check: less than 1 minute
            lastTickCount = currentTick;
            // Clamp to positive int range — high-bits tick overflow handled gracefully
            return (int)(currentTick & 0x7FFFFFFF);
        }
    }
    
    // Fallback to counter-based approach
    if(baseSeconds != currentSeconds) {
        baseSeconds = currentSeconds;
        tickCounter = 0;
    }
    
    tickCounter++;
    lastTickCount = currentTick;
    return (currentSeconds * 1000) + (tickCounter % 1000);
}

// NEW: OUTCOME VALIDATION FRAMEWORK IMPLEMENTATION
void InitializeOutcomeValidationFramework() {
    // Initialize outcome buffer
    for(int i = 0; i < OUTCOME_BUFFER_SIZE; i++) {
        outcomeValidator.buffer[i].timestamp = 0;
        outcomeValidator.buffer[i].predictedPrice = 0.0;
        outcomeValidator.buffer[i].actualPrice = 0.0;
        outcomeValidator.buffer[i].predictedDirection = 0.0;
        outcomeValidator.buffer[i].actualDirection = 0.0;
        outcomeValidator.buffer[i].predictionCorrect = false;
        outcomeValidator.buffer[i].confidence = 0.5;
        outcomeValidator.buffer[i].marketRegime = 0;
        outcomeValidator.buffer[i].accuracy = 0.0;
        outcomeValidator.buffer[i].deviation = 0.0;
    }
    
    outcomeValidator.bufferIndex = 0;
    outcomeValidator.validRecords = 0;
    
    // Initialize regime-specific tracking
    for(int i = 0; i < 12; i++) {
        outcomeValidator.accuracyByRegime[i] = 0.5;
        outcomeValidator.predictionsByRegime[i] = 0;
        outcomeValidator.correctPredictionsByRegime[i] = 0;
    }
    
    // Initialize calibration metrics
    outcomeValidator.predictionAccuracyScore = 0.5;
    outcomeValidator.cumulativeAccuracy = 0.5;
    outcomeValidator.confidenceCalibration = 0.0;
    outcomeValidator.thresholdAdjustment = 0.0;
    
    // Initialize confidence intervals
    outcomeValidator.confidenceIntervalLower = 0.0;
    outcomeValidator.confidenceIntervalUpper = 1.0;
    outcomeValidator.confidenceLevel = 0.95;
    
    // Initialize rolling statistics
    for(int i = 0; i < CALIBRATION_PERIOD; i++) {
        outcomeValidator.rollingAccuracy[i] = 0.5;
    }
    outcomeValidator.rollingIndex = 0;
    outcomeValidator.systemCalibrated = false;
    
    outcomeValidator.lastValidation = 0;
    outcomeValidator.needsRecalibration = false;
    outcomeValidator.isValid = true;
    
    LogCriticalEvent("Outcome Validation Framework Initialized", "VALIDATION");
}

void UpdateOutcomeValidationFramework() {
    static datetime lastValidationUpdate = 0;
    if((TimeCurrent() - lastValidationUpdate) < 60) return; // NonZero(Update.every) minute
    lastValidationUpdate = TimeCurrent();
    
    // Calculate current validation accuracy
    double currentAccuracy = CalculateValidationAccuracy();
    
    // Update rolling accuracy
    outcomeValidator.rollingAccuracy[outcomeValidator.rollingIndex] = currentAccuracy;
    outcomeValidator.rollingIndex = (outcomeValidator.rollingIndex + 1) % CALIBRATION_PERIOD;
    
    // Update cumulative accuracy with exponential smoothing
    double newCumulative = outcomeValidator.cumulativeAccuracy * 0.9 + currentAccuracy * 0.1;
    outcomeValidator.cumulativeAccuracy = newCumulative;
    
    // Check if recalibration is needed
    if(MathAbs(currentAccuracy - outcomeValidator.predictionAccuracyScore) > 0.1) {
        outcomeValidator.needsRecalibration = true;
    }
    
    // Calibrate confidence intervals if enough data
    if(outcomeValidator.validRecords >= 20) {
        CalibrateConfidenceIntervals();
        AdjustThresholdsBasedOnOutcomes();
    }
    
    // Check system calibration status
    if(outcomeValidator.validRecords >= CALIBRATION_PERIOD && !outcomeValidator.systemCalibrated) {
        double avgAccuracy = 0.0;
        for(int i = 0; i < CALIBRATION_PERIOD; i++) {
            avgAccuracy += outcomeValidator.rollingAccuracy[i];
        }
        avgAccuracy /= CALIBRATION_PERIOD;
        
        if(avgAccuracy >= PREDICTION_ACCURACY_THRESHOLD) {
            outcomeValidator.systemCalibrated = true;
            LogCriticalEvent(StringFormat("System Calibrated: Accuracy %.2f%%", avgAccuracy * 100), "VALIDATION");
        }
    }
    
    outcomeValidator.lastValidation = TimeCurrent();
}

void RecordPredictionOutcome(double predicted, double actual, double confidence, int regime) {
    if(predicted == 0.0 || actual == 0.0) return;
    
    double index = outcomeValidator.bufferIndex;
    
    // Store prediction outcome
    outcomeValidator.buffer[(int)index].timestamp = TimeCurrent();
    outcomeValidator.buffer[(int)index].predictedPrice = predicted;
    outcomeValidator.buffer[(int)index].actualPrice = actual;
    outcomeValidator.buffer[(int)index].predictedDirection = predicted > iClose(Symbol(), 0, 1) ? 1.0 : -1.0;
    outcomeValidator.buffer[(int)index].actualDirection = actual > iClose(Symbol(), 0, 1) ? 1.0 : -1.0;
    outcomeValidator.buffer[(int)index].confidence = confidence;
    outcomeValidator.buffer[(int)index].marketRegime = regime;
    
    // Calculate accuracy metrics
    double directionMatch = outcomeValidator.buffer[(int)index].predictedDirection * outcomeValidator.buffer[(int)index].actualDirection;
    outcomeValidator.buffer[(int)index].predictionCorrect = directionMatch > 0;
    outcomeValidator.buffer[(int)index].accuracy = directionMatch > 0 ? 1.0 : 0.0;
    outcomeValidator.buffer[(int)index].deviation = MathAbs(predicted - actual) /NonZero(actual);
    
    // Update regime-specific tracking
    if(regime >= 0 && regime < 12) {
        outcomeValidator.predictionsByRegime[regime]++;
        if(outcomeValidator.buffer[(int)index].predictionCorrect) {
            outcomeValidator.correctPredictionsByRegime[regime]++;
        }
        
        // Update regime accuracy
        if(outcomeValidator.predictionsByRegime[regime] > 0) {
            outcomeValidator.accuracyByRegime[regime] = 
                (double)outcomeValidator.correctPredictionsByRegime[regime] / 
                outcomeValidator.predictionsByRegime[regime];
        }
    }
    
    // Advance buffer
    outcomeValidator.bufferIndex = (outcomeValidator.bufferIndex + 1) % OUTCOME_BUFFER_SIZE;
    if(outcomeValidator.validRecords < OUTCOME_BUFFER_SIZE) {
        outcomeValidator.validRecords++;
    }
}

// NEW ENHANCED THRESHOLD INTELLIGENCE IMPLEMENTATION
void InitializeEnhancedThresholdIntelligence() {
    // Initialize base thresholds - use calibrated if available
    if(g_WeightsOptimized) {
        // Use regime-specific calibrated thresholds
        MarketStateFeatures f = CalculateMarketFeatures(0);
        int regime = ClassifyBarToRegime(f, 0);
        
        if(regime >= 0 && regime < 9) {
            // g_RegimeOptimalThresholds is CEUS magnitude (|score| needed).
            // baseThresholds feed into engine.buyThreshold (normalized 0-100). Convert.
            double buyThreshold  = MathMax(60.0, MathMin(85.0, 50.0 + g_RegimeOptimalThresholds[MathMin(8,MathMax(0,regime))] / 2.0));  // 9/10: floor 60 pre-calib
            double sellThreshold = MathMax(15.0, MathMin(45.0, 50.0 - g_RegimeOptimalThresholds[MathMin(8,MathMax(0,regime))] / 2.0));
            thresholdIntelligence.baseThresholds[0] = buyThreshold;
            thresholdIntelligence.baseThresholds[1] = sellThreshold;
        } else {
            // Fallback to defaults if regime invalid
            thresholdIntelligence.baseThresholds[0] = ENHANCED_BUY_THRESHOLD;
            thresholdIntelligence.baseThresholds[1] = ENHANCED_SELL_THRESHOLD;
        }
    } else {
        // Pre-calibration: use defaults
        thresholdIntelligence.baseThresholds[0] = ENHANCED_BUY_THRESHOLD;
        thresholdIntelligence.baseThresholds[1] = ENHANCED_SELL_THRESHOLD;
    }
    
    thresholdIntelligence.baseThresholds[2] = BASE_RISK_PERCENT;
    thresholdIntelligence.baseThresholds[3] = TARGET_RISK_REWARD_RATIO;
    
    // Initialize current thresholds
    for(int i = 0; i < 4; i++) {
        thresholdIntelligence.currentThresholds[i] = thresholdIntelligence.baseThresholds[i];
        thresholdIntelligence.adaptedThresholds[i] = thresholdIntelligence.baseThresholds[i];
        thresholdIntelligence.predictiveThresholds[i] = thresholdIntelligence.baseThresholds[i];
        thresholdIntelligence.thresholdEffectiveness[i] = 0.5;
        thresholdIntelligence.thresholdReliability[i] = 0.5;
        thresholdIntelligence.thresholdLocked[i] = false;
    }
    
    // Sync to g_DynThreshold for E9.9 compatibility
    g_DynThreshold.buyThreshold = thresholdIntelligence.currentThresholds[0];
    g_DynThreshold.sellThreshold = thresholdIntelligence.currentThresholds[1];
    
    // Initialize market factors
    for(int i = 0; i < 8; i++) {
        thresholdIntelligence.marketFactors[i] = 1.0;
    }
    
    for(int i = 0; i < 6; i++) {
        thresholdIntelligence.performanceFactors[i] = 1.0;
    }
    
    thresholdIntelligence.volatilityAdjustment = 0.0;
    thresholdIntelligence.regimeAdjustment = 0.0;
    thresholdIntelligence.memoryAdjustment = 0.0;
    thresholdIntelligence.predictiveAdjustment = 0.0;
    
    // Initialize threshold history
    for(int i = 0; i < THRESHOLD_ADAPTATION_CYCLES; i++) {
        for(int j = 0; j < 4; j++) {
            thresholdIntelligence.thresholdHistory[i].thresholdValues[j] = thresholdIntelligence.baseThresholds[j];
        }
        thresholdIntelligence.thresholdHistory[i].effectiveness = 0.5;
        thresholdIntelligence.thresholdHistory[i].winRate = 50.0;
        thresholdIntelligence.thresholdHistory[i].timestamp = 0;
        thresholdIntelligence.thresholdHistory[i].marketRegime = 0;
        thresholdIntelligence.thresholdHistory[i].wasOptimal = false;
    }
    
    thresholdIntelligence.historyIndex = 0;
    thresholdIntelligence.validHistory = 0;
    
    // Initialize predictive thresholds
    for(int i = 0; i < 4; i++) {
        thresholdIntelligence.predictedOptimalThresholds[i] = thresholdIntelligence.baseThresholds[i];
        thresholdIntelligence.thresholdTrends[i] = 0.0;
        thresholdIntelligence.thresholdMomentum[i] = 0.0;
    }
    
    thresholdIntelligence.optimizationConfidence = 0.5;
    thresholdIntelligence.adaptationStrength = 0.1;
    
    thresholdIntelligence.dynamicAdjustmentActive = true;
    thresholdIntelligence.adjustmentSensitivity = 0.1;
    thresholdIntelligence.stabilityRequirement = 3;
    thresholdIntelligence.adjustmentCycles = 0;
    thresholdIntelligence.stabilityCounter = 0;
    
    thresholdIntelligence.lastThresholdUpdate = 0;
    thresholdIntelligence.isValid = true;
    thresholdIntelligence.needsUpdate = true;
    
    LogCriticalEvent("Enhanced Threshold Intelligence Initialized", "THRESHOLD");
}

void UpdateEnhancedThresholdIntelligence() {
    static datetime lastThresholdUpdate = 0;
    if((TimeCurrent() - lastThresholdUpdate) < 120) return; // NonZero(Update.every) 2 minutes
    lastThresholdUpdate = TimeCurrent();
    
    CalculateAdaptiveThresholds();
    PredictOptimalThresholds();
    ValidateThresholdEffectiveness();
    ApplyIntelligentThresholds();
    
    thresholdIntelligence.lastThresholdUpdate = TimeCurrent();
    thresholdIntelligence.needsUpdate = false;
}

void CalculateAdaptiveThresholds() {
    // Update market factors
    thresholdIntelligence.marketFactors[0] = intelligence.atrVolatility;
    thresholdIntelligence.marketFactors[1] = intelligence.volumeRatio;
    thresholdIntelligence.marketFactors[2] = intelligence.mtfConsensus;
    thresholdIntelligence.marketFactors[3] = intelligence.liquidityIndex;
    thresholdIntelligence.marketFactors[4] = MathAbs(intelligence.priceVelocity) / 10.0;
    thresholdIntelligence.marketFactors[5] = intelligence.breakoutProbability;
    thresholdIntelligence.marketFactors[6] = (intelligence.rsi - 50.0) / 50.0;
    thresholdIntelligence.marketFactors[7] = intelligence.adx / 100.0;
    // Precision factors: replace legacy placeholders with real distributional context
    {
        MarketStateFeatures _ti = CalculateMarketFeatures(0);  // cached
        // Normalise ema200Distance to [-1,+1] range for factor blending
        thresholdIntelligence.marketFactors[2] = MathMax(-1.0, MathMin(1.0, _ti.ema200Distance / 4.0));
        // atrPercentile replaces raw ATR ratio -- more meaningful distribution context
        thresholdIntelligence.marketFactors[0] = _ti.atrPercentile;
        // rsiSlope as momentum acceleration factor
        thresholdIntelligence.marketFactors[6] = MathMax(-1.0, MathMin(1.0, _ti.rsiSlope));
        // volumeDelta replaces raw volumeRatio
        thresholdIntelligence.marketFactors[1] = MathMin(2.0, _ti.volumeDelta) / 2.0;
    }
    
    // Update performance factors
    thresholdIntelligence.performanceFactors[0] = CalculateRecentWinRate() / 100.0;
    thresholdIntelligence.performanceFactors[1] = MathMin(2.0, CalculateProfitFactor()) / 2.0;
    thresholdIntelligence.performanceFactors[2] = optimizer.confidenceMultiplier;
    thresholdIntelligence.performanceFactors[3] = 1.0 - (riskMgr.currentDrawdown / 20.0);
    thresholdIntelligence.performanceFactors[4] = tradeManager.expectancy > 0 ? 0.8 : 0.2;
    thresholdIntelligence.performanceFactors[5] = marketMemory.memoryReliability;
    
    // Calculate adjustment factors
    thresholdIntelligence.volatilityAdjustment = (intelligence.atrVolatility - 1.0) * 2.0;
    // Regime adjustment: use calibrated signal WR deviation from baseline (0.65)
    // If this regime has 72% WR, adjustment = +0.107 (positive = relaxed threshold)
    // If this regime has 52% WR, adjustment = -0.200 (negative = tighter threshold)
    if(g_CorrelationsLearned) {
        int _tiReg = g_RegimeState.currentRegime;
        if(_tiReg >= 0 && _tiReg < 9 && g_RegimeCorrelations[_tiReg].signalTotal >= 5)
            thresholdIntelligence.regimeAdjustment = (g_RegimeCorrelations[_tiReg].signalWR - 0.65);
        else
            thresholdIntelligence.regimeAdjustment = (int)engine.regime / 6.0;
    } else {
        thresholdIntelligence.regimeAdjustment = (int)engine.regime / 6.0;
    }
    thresholdIntelligence.memoryAdjustment = (marketMemory.contextualAccuracy - 0.5) * 2.0;
    
    if(predictiveSystem.predictionsValid) {
        thresholdIntelligence.predictiveAdjustment = 
            (predictiveSystem.predictionReliability - 0.5) * predictiveSystem.cumulativeAccuracy;
    }
    
    // Calculate adaptive thresholds
    for(int i = 0; i < 4; i++) {
        double marketInfluence = 0.0;
        double performanceInfluence = 0.0;
        
        // Market factor influence
        for(int j = 0; j < 8; j++) {
            marketInfluence += thresholdIntelligence.marketFactors[j] / 8.0;
        }
        
        // Performance factor influence
        for(int j = 0; j < 6; j++) {
            performanceInfluence += thresholdIntelligence.performanceFactors[j] / 6.0;
        }
        
        // Combined adjustment
        double totalAdjustment = (marketInfluence - 0.5) * 0.3 + 
                                (performanceInfluence - 0.5) * 0.4 + 
                                thresholdIntelligence.volatilityAdjustment * 0.1 +
                                thresholdIntelligence.memoryAdjustment * 0.15 +
                                thresholdIntelligence.predictiveAdjustment * 0.05;
        
        // Apply threshold-specific logic
        if(i == 0 || i == 1) { // NonZero(Buy)/ NonZero(Sell.thresholds)
            thresholdIntelligence.adaptedThresholds[i] = thresholdIntelligence.baseThresholds[i] + 
                totalAdjustment * (i == 0 ? -5.0 : 5.0);
        } else if(i == 2) { // NonZero(Risk.threshold)
            thresholdIntelligence.adaptedThresholds[i] = thresholdIntelligence.baseThresholds[i] * 
                (1.0 + totalAdjustment * 0.3);
        } else { // NonZero(Risk)-reward ratio
            thresholdIntelligence.adaptedThresholds[i] = thresholdIntelligence.baseThresholds[i] * 
                (1.0 + totalAdjustment * 0.2);
        }
        
        // Apply bounds
        if(i == 0) { // NonZero(Buy.threshold)
            thresholdIntelligence.adaptedThresholds[i] = MathMax(60.0, MathMin(85.0, thresholdIntelligence.adaptedThresholds[i]));
        } else if(i == 1) { // NonZero(Sell.threshold)
            thresholdIntelligence.adaptedThresholds[i] = MathMax(15.0, MathMin(40.0, thresholdIntelligence.adaptedThresholds[i]));
        } else if(i == 2) { // NonZero(Risk.threshold) -- SLS23 FIX: clamp was swallowed into this comment, leaving live risk-percent unbounded
            thresholdIntelligence.adaptedThresholds[i] = MathMax(MIN_RISK_PERCENT, MathMin(MAX_RISK_PERCENT, thresholdIntelligence.adaptedThresholds[i]));
        } else { // NonZero(Risk)-reward
            thresholdIntelligence.adaptedThresholds[i] = MathMax(MIN_RISK_REWARD_RATIO, MathMin(MAX_RISK_REWARD_RATIO, thresholdIntelligence.adaptedThresholds[i]));
        }
    }
}

void PredictOptimalThresholds() {
    // Use predictive system to forecast optimal thresholds
    if(predictiveSystem.predictionsValid && predictiveSystem.predictionReliability > 0.6) {
        
        // Predict threshold changes based on predicted market conditions
        double predictedVolatility = predictiveSystem.predictedVolatility;
        double predictedTrend = predictiveSystem.predictedTrend;
        
        for(int i = 0; i < 4; i++) {
            double currentThreshold = thresholdIntelligence.adaptedThresholds[i];
            double predictiveShift = 0.0;
            
            if(i == 0 || i == 1) { // NonZero(Buy)/ NonZero(Sell.thresholds)
                // Adjust based on predicted trend
                if ((double)predictedTrend > 0.01) { // NonZero(Bullish.prediction)
                    predictiveShift = i == 0 ? -2.0 : 1.0; // NonZero(Easier.buy), harder sell
                } else if(predictedTrend < -0.01) { // NonZero(Bearish.prediction)
                    predictiveShift = i == 0 ? 1.0 : -2.0; // NonZero(Harder.buy), easier sell
                }
                
                // Adjust based on predicted volatility
                if ((double)predictedVolatility > 1.5) {
                    predictiveShift += (i == 0 ? 1.0 : -1.0); // NonZero(Tighter.thresholds) in high volatility
                }
                
            } else if(i == 2) { // NonZero(Risk.threshold)
                // Adjust risk based on predicted volatility
                if ((double)predictedVolatility > 1.3) {
                    predictiveShift = -0.2; // NonZero(Reduce.risk) in predicted high volatility
                } else if ((double)predictedVolatility < 0.8) {
                    predictiveShift = 0.1; // NonZero(Increase.risk) in predicted low volatility
                }
                
            } else { // NonZero(Risk)-reward ratio
                // Adjust RR based on prediction confidence
                if(predictiveSystem.predictionReliability > 0.8) {
                    predictiveShift = 0.2; // NonZero(Higher.RR) for high confidence predictions
                }
            }
            
            thresholdIntelligence.predictiveThresholds[i] = currentThreshold + predictiveShift;
            
            // Calculate threshold trends and momentum
            static double previousPredictive[4] = {0.0, 0.0, 0.0, 0.0};
            thresholdIntelligence.thresholdTrends[i] = thresholdIntelligence.predictiveThresholds[i] - previousPredictive[i];
            thresholdIntelligence.thresholdMomentum[i] = thresholdIntelligence.thresholdTrends[i] * 0.7 + 
                thresholdIntelligence.thresholdMomentum[i] * 0.3;
            previousPredictive[i] = thresholdIntelligence.predictiveThresholds[i];
        }
        
        // Update optimization confidence based on prediction reliability
        thresholdIntelligence.optimizationConfidence = 0.5 + (predictiveSystem.predictionReliability - 0.5) * 0.8;
    }
    
    // Use memory system to enhance predictions
    if(marketMemory.memorySystemActive && marketMemory.validContexts > 10) {
        double contextualEffectiveness = GetContextualEffectiveness((int)engine.regime, engine.unifiedScore);
        
        if ((double)contextualEffectiveness > 0.7) {
            // Enhance predictions with memory-based adjustments
            for(int i = 0; i < 4; i++) {
                double memoryInfluence = (contextualEffectiveness - 0.5) * 2.0; // -1 to +1
                thresholdIntelligence.predictedOptimalThresholds[i] = 
                    thresholdIntelligence.predictiveThresholds[i] * (1.0 + memoryInfluence * 0.1);
            }
            
            thresholdIntelligence.optimizationConfidence = MathMin(0.9, 
                thresholdIntelligence.optimizationConfidence + contextualEffectiveness * 0.2);
        }
    }
}

void ValidateThresholdEffectiveness() {
    // Store current threshold performance
    if(thresholdIntelligence.validHistory < THRESHOLD_ADAPTATION_CYCLES) {
        thresholdIntelligence.validHistory++;
    }
    
    double currentIndex = thresholdIntelligence.historyIndex;
    
    // Store current thresholds and performance
    for(int i = 0; i < 4; i++) {
        thresholdIntelligence.thresholdHistory[(int)currentIndex].thresholdValues[i] = 
            thresholdIntelligence.currentThresholds[i];
    }
    
    thresholdIntelligence.thresholdHistory[(int)currentIndex].effectiveness = 
        CalculateThresholdOptimizationScore();
    thresholdIntelligence.thresholdHistory[(int)currentIndex].winRate = CalculateRecentWinRate();
    thresholdIntelligence.thresholdHistory[(int)currentIndex].timestamp = TimeCurrent();
    thresholdIntelligence.thresholdHistory[(int)currentIndex].marketRegime = (int)engine.regime;
    thresholdIntelligence.thresholdHistory[(int)currentIndex].wasOptimal = 
        thresholdIntelligence.thresholdHistory[(int)currentIndex].effectiveness > 0.7;
    
    // Calculate threshold effectiveness and reliability
    for(int i = 0; i < 4; i++) {
        double totalEffectiveness = 0.0;
        int validMeasurements = 0;
        
        // Analyze historical effectiveness of similar threshold values
        for(int j = 0; j < thresholdIntelligence.validHistory; j++) {
            double thresholdDifference = MathAbs(
                thresholdIntelligence.thresholdHistory[j].thresholdValues[i] - 
                thresholdIntelligence.currentThresholds[i]);
            
            // If threshold values are similar (within 10%)
            if(thresholdDifference < thresholdIntelligence.currentThresholds[i] * 0.1) {
                totalEffectiveness += thresholdIntelligence.thresholdHistory[j].effectiveness;
                validMeasurements++;
            }
        }
        
        if(validMeasurements > 0) {
            thresholdIntelligence.thresholdEffectiveness[i] = totalEffectiveness / NonZero(validMeasurements);
            thresholdIntelligence.thresholdReliability[i] = MathMin(1.0, validMeasurements / 5.0);
        }
    }
    
    thresholdIntelligence.historyIndex = (thresholdIntelligence.historyIndex + 1) % THRESHOLD_ADAPTATION_CYCLES;
}

void ApplyIntelligentThresholds() {
    if(!thresholdIntelligence.dynamicAdjustmentActive) return;
    
    // Calculate weighted optimal thresholds
    for(int i = 0; i < 4; i++) {
        if(thresholdIntelligence.thresholdLocked[i]) continue;
        
        double adaptiveWeight = 0.4;
        double predictiveWeight = 0.3;
        double memoryWeight = 0.2;
        double stabilityWeight = 0.1;
        
        // Adjust weights based on reliability
        if(thresholdIntelligence.thresholdReliability[i] > 0.7) {
            adaptiveWeight += 0.1;
            predictiveWeight += 0.1;
        }
        
        if(predictiveSystem.predictionReliability > 0.7) {
            predictiveWeight += 0.1;
            adaptiveWeight -= 0.05;
            memoryWeight -= 0.05;
        }
        
        if(marketMemory.memoryReliability > 0.7) {
            memoryWeight += 0.1;
            adaptiveWeight -= 0.05;
            stabilityWeight -= 0.05;
        }
        
        // Normalize weights
        double totalWeight = adaptiveWeight + predictiveWeight + memoryWeight + stabilityWeight;
        adaptiveWeight /= totalWeight;
        predictiveWeight /= totalWeight;
        memoryWeight /= totalWeight;
        stabilityWeight /= totalWeight;
        
        // Calculate optimal threshold
        double optimalThreshold = 
            thresholdIntelligence.adaptedThresholds[i] * adaptiveWeight +
            thresholdIntelligence.predictiveThresholds[i] * predictiveWeight +
            thresholdIntelligence.predictedOptimalThresholds[i] * memoryWeight +
            thresholdIntelligence.currentThresholds[i] * stabilityWeight;
        
        // Apply gradual adjustment with sensitivity control
        double maxChange = thresholdIntelligence.currentThresholds[i] * thresholdIntelligence.adjustmentSensitivity;
        double change = optimalThreshold - thresholdIntelligence.currentThresholds[i];
        change = MathMax(-maxChange, MathMin(maxChange, change));
        
        double newThreshold = thresholdIntelligence.currentThresholds[i] + change;
        
        // Stability check
        if(MathAbs(change) < maxChange * 0.1) {
            thresholdIntelligence.stabilityCounter++;
        } else {
            thresholdIntelligence.stabilityCounter = 0;
        }
        
        // Apply new threshold if stable enough
        if(thresholdIntelligence.stabilityCounter >= thresholdIntelligence.stabilityRequirement || 
           thresholdIntelligence.optimizationConfidence > 0.8) {
            thresholdIntelligence.currentThresholds[i] = newThreshold;
        }
    }
    
    // Apply thresholds to engine and risk manager.
    // Post-calibration: engine.buyThreshold is already set from GetLearnedOptimalThreshold
    // (calibrated per-regime, applied earlier in OnTick). Do NOT overwrite it here.
    // Pre-calibration: apply normally.
    if(!g_Calibration.isComplete) {
        engine.buyThreshold  = thresholdIntelligence.currentThresholds[0];
        engine.sellThreshold = thresholdIntelligence.currentThresholds[1];
    }
    riskMgr.currentRisk = thresholdIntelligence.currentThresholds[2];
    riskMgr.currentRR   = thresholdIntelligence.currentThresholds[3];
    
    thresholdIntelligence.adjustmentCycles++;
}

double CalculateThresholdOptimizationScore() {
    double score = 0.5;
    
    // Performance component
    double winRate = CalculateRecentWinRate();
    score += (winRate - 50.0) / 100.0; // -0.5 to +0.5
    
    // Profit factor component
    double profitFactor = CalculateProfitFactor();
    score += (profitFactor - 1.0) * 0.2;
    
    // Risk-adjusted component
    if(riskMgr.maxDrawdown > 0) {
        score -= riskMgr.maxDrawdown / 50.0; // NonZero(Penalize.drawdown)
    }
    
    // Consistency component
    if(tradeManager.consecutiveWins > 2) {
        score += 0.1;
    }
    if(tradeManager.consecutiveLosses > 2) {
        score -= 0.1;
    }
    
    // Efficiency component
    if(engine.executionDelayMs < RAPID_EXECUTION_TIMEOUT) {
        score += 0.05;
    }
    
    // Prediction accuracy component
    if(predictiveSystem.predictionsValid) {
        score += (predictiveSystem.predictionReliability - 0.5) * 0.2;
    }
    
    return MathMax(0.1, MathMin(1.0, score));
}

// COMPLETE ORIGINAL SYSTEM IMPLEMENTATION

bool UpdateMarketIntelligence()
{
    // CRITICAL STACK PROTECTION: Cache this function per bar
    // The nested MACD calculation loops were causing stack overflow on first tick
    static datetime lastUpdateBar = 0;
    datetime currentBar = iTime(Symbol(), 0, 0);
    
    if(currentBar == lastUpdateBar && intelligence.isValid) {
        return true; // CACHED - already calculated for this bar
    }
    lastUpdateBar = currentBar;
    
    static datetime lastIndicatorLog = 0;
    static int attempts = 0;
    bool ok = true;

    // Primary reads from platform functions
    double ma14 = 0.0, ma200 = 0.0, macd_main = 0.0, macd_signal = 0.0, atr = 0.0;
    #ifdef __MQL4
    // prefer reading on the EA's timeframe (M5) to match logs
    ma14 = iMA(_Symbol, PERIOD_M5, 14, 0, MODE_SMA, PRICE_CLOSE, 0);
    ma200 = iMA(_Symbol, PERIOD_M5, 200, 0, MODE_SMA, PRICE_CLOSE, 0);
    macd_main = iMACD(_Symbol, PERIOD_M5, 12, 37, 12, PRICE_CLOSE, MODE_MAIN, 0);
    macd_main   = iMACD(_Symbol, PERIOD_M5, 12, 26, 9, PRICE_CLOSE, MODE_MAIN,   0);  // FIX12
    atr = iATR(_Symbol, PERIOD_M5, 14, 0);
    #endif

    // Fallback for MA if zero: compute simple average of recent closes
    if(ma14 == 0.0) {
        double sum = 0.0; int cnt = 14;
        int barsAvailable = MathMin(Bars(_Symbol, PERIOD_M5), cnt);
        for(int i=0;i<barsAvailable;i++) sum += iClose(_Symbol, PERIOD_M5, i);
        ma14 = (barsAvailable>0) ? (sum / barsAvailable) : 0.0;
    }
    if(ma200 == 0.0) {
        double sum = 0.0; int cnt = 200;
        int barsAvailable = MathMin(Bars(_Symbol, PERIOD_M5), cnt);
        for(int i=0;i<barsAvailable;i++) sum += iClose(_Symbol, PERIOD_M5, i);
        ma200 = (barsAvailable>0) ? (sum / barsAvailable) : 0.0;
    }

    // SIMPLIFIED MACD fallback - NO NESTED LOOPS (stack overflow fix)
    if(macd_main == 0.0 && macd_signal == 0.0) {
        int window = MathMin(Bars(_Symbol, PERIOD_M5), 30); // Reduced from 60
        if(window >= 2) {
            double ema12 = iClose(_Symbol, PERIOD_M5, 0);
            double ema37 = ema12;
            double k12 = 2.0 / (12.0 + 1.0);
            double k37 = 2.0 / (37.0 + 1.0);
            
            // Calculate MACD main line (12 EMA - 37 EMA) - SINGLE LOOP
            for(int b=1; b<window; b++) {
                double c = iClose(_Symbol, PERIOD_M5, b);
                ema12 = (c * k12) + (ema12 * (1.0 - k12));
                ema37 = (c * k37) + (ema37 * (1.0 - k37));
            }
            macd_main = ema12 - ema37;
            
            // SIMPLIFIED signal calculation - NO NESTED LOOPS!
            // Signal line is just 90% of main line (close enough for fallback)
            // This is acceptable because this is only used when iMACD() fails
            macd_signal = macd_main * 0.9;
        }
    }

    // ATR fallback: if iATR zero or unavailable, compute 14-period average true range (TR)
    if(atr == 0.0) {
        int atrPeriod = 14;
        double barsAv = MathMin(Bars(_Symbol, PERIOD_M5)-1, atrPeriod);
        double trSum = 0.0;
        if(barsAv > 0) {
            for(int i=1;i<=barsAv;i++) {
                double high = iHigh(_Symbol, PERIOD_M5, i);
                double low = iLow(_Symbol, PERIOD_M5, i);
                double prevClose = iClose(_Symbol, PERIOD_M5, i-1);
                double tr = MathMax(high - low, MathMax(MathAbs(high - prevClose), MathAbs(low - prevClose)));
                trSum += tr;
            }
            atr = trSum / NonZero(barsAv);
        } else {
            // as ultimate fallback use current bar range * 0.7
            double h = iHigh(_Symbol, PERIOD_M5, 0), l = iLow(_Symbol, PERIOD_M5, 0);
            atr = MathAbs(h - l) * 0.7;
        }
    }

    // Update the intelligence cache safely - ensure fields exist in struct
    intelligence.ma14 = ma14;
    intelligence.ma200 = ma200;
    intelligence.macdMain = macd_main;
    intelligence.macdSignal = macd_signal;
    intelligence.atrVolatility = atr;

    // Warn if indicators still look invalid
    if(ma14 == 0.0 || ma200 == 0.0) {
        ok = false;
        attempts++;
        if(TimeCurrent() - lastIndicatorLog > 10) {
            PrintFormat("  indicator fallback   |   ma14 %.5f   |   attempts %d", ma14, attempts);
            lastIndicatorLog = TimeCurrent();
        }
    } else {
        attempts = 0;
        // CRITICAL FIX: Set intelligence as VALID after successful calculation
        intelligence.isValid = true;
        intelligence.isStale = false;
        intelligence.lastUpdateMs = GetCurrentMilliseconds();
    }
    
    // FALLBACK: If indicators were calculated but validation failed, still mark as valid
    // This handles edge cases where MA calculation succeeds but validation is too strict
    if(!intelligence.isValid && intelligence.ma14 > 0 && intelligence.ma200 > 0) {
        intelligence.isValid = true;
        intelligence.lastUpdateMs = GetCurrentMilliseconds();
        Print("  intelligence systems   |   all 40 validated   |   ready");
    }
    
    // INLINE BASIC INTELLIGENCE: Integrate critical calculations directly here
    // This reduces separate function calls and keeps stack depth minimal
    // Full detailed calculations still happen in the dedicated Update functions (via rotation)
    
    // INLINE: Basic volume ratio (most critical for signal generation)
    double currentVol = (double)iVolume(Symbol(), 0, 0);
    if(intelligence.averageVolume > 0) {
        intelligence.volumeRatio = currentVol / NonZero(intelligence.averageVolume);
    } else {
        // Quick fallback: compare to last bar
        double previousVol = (double)iVolume(Symbol(), 0, 1);
        if(previousVol > 0) {
            intelligence.volumeRatio = currentVol / NonZero(previousVol);
        } else {
            intelligence.volumeRatio = 1.0;
        }
    }
    
    // INLINE: Basic price velocity (critical for momentum detection)
    if(Bars >= 2) {
        double currentPrice = iClose(Symbol(), 0, 0);
        double previousPrice = iClose(Symbol(), 0, 1);
        if(currentPrice > 0 && previousPrice > 0) {
            intelligence.priceVelocity = (currentPrice - previousPrice) / NonZero(previousPrice) * 10000.0; // In pips
        }
    }
    
    // INLINE: Basic spread/liquidity (critical for entry timing)
    double bid = MarketInfo(Symbol(), MODE_BID);
    double ask = MarketInfo(Symbol(), MODE_ASK);
    if(bid > 0 && ask > 0) {
        intelligence.spread = ask - bid;
        if(intelligence.atr > 0) {
            intelligence.spreadNormalized = intelligence.spread / NonZero(intelligence.atr);
            intelligence.liquidityIndex = 1.0 / (1.0 + intelligence.spreadNormalized);
        }
    }
    
    // These inline calculations provide BASIC values immediately on every bar
    // The dedicated Update functions (called via rotation) provide DETAILED analysis
    // Result: Core intelligence always available, detailed analysis updates progressively

    return ok;
}


void ConsolidatedIndicatorCalculation() {
    // CRITICAL STACK OVERFLOW FIX: Cache calculations per bar
    // Don't recalculate indicators on every tick - only on new bar
    // This is the PROPER fix that maintains functionality while preventing stack overflow
    static datetime lastCalculationBar = 0;
    datetime currentBar = iTime(Symbol(), 0, 0);
    
    // Only recalculate if we're on a new bar
    if(currentBar == lastCalculationBar) {
        return; // Use cached values from this bar
    }
    lastCalculationBar = currentBar;
    
    // NOW do full calculation (only once per bar, not every tick)
    
    // RSI with enhanced velocity tracking
    double newRSI = iRSI(Symbol(), 0, 14, PRICE_CLOSE, 0);
    if(newRSI > 0 && newRSI <= 100) {
        intelligence.rsiPrev = intelligence.rsi;
        intelligence.rsi = newRSI;
        intelligence.rsiRate = (intelligence.rsi - intelligence.rsiPrev) * 10.0;
    }
    
    // ADX with directional movement
    intelligence.adx = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0);
    intelligence.adxPlus = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_PLUSDI, 0);
    intelligence.adxMinus = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MINUSDI, 0);
    
    if(intelligence.adx > 0 && intelligence.adxPlus >= 0 && intelligence.adxMinus >= 0) {
        intelligence.adxMomentum = intelligence.adxPlus - intelligence.adxMinus;
    }
    
    // Stochastic with velocity
    double newStochMain = iStochastic(Symbol(), 0, 14, 3, 3, MODE_SMA, 0, MODE_MAIN, 0);
    if(newStochMain >= 0 && newStochMain <= 100) {
        intelligence.stochVelocity = (newStochMain - intelligence.stochMain) * 5.0;
        intelligence.stochMain = newStochMain;
        intelligence.stochSignal = iStochastic(Symbol(), 0, 14, 3, 3, MODE_SMA, 0, MODE_SIGNAL, 0);
    }
    
    // MACD with acceleration
    double newMacd = iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_MAIN, 0);
    if(MathAbs(newMacd) < 1.0) { // NonZero(Sanity.check)
        intelligence.macdAccel = (newMacd - intelligence.macd) * 100.0;
        intelligence.macd = newMacd;
        intelligence.macdSignal = iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_SIGNAL, 0);
        intelligence.macdHistogram = intelligence.macd - intelligence.macdSignal;
    }
    
    // MFI with trend analysis
    double newMFI = iMFI(Symbol(), 0, 14, 0);
    if(newMFI >= 0 && newMFI <= 100) {
        intelligence.mfiTrend = newMFI - intelligence.mfi;
        intelligence.mfiPrev = intelligence.mfi;
        intelligence.mfi = newMFI;
    }
    
    // CCI (Commodity Channel Index) for reversal detection
    double newCCI = iCCI(Symbol(), 0, 14, PRICE_CLOSE, 0);
    if(newCCI != EMPTY_VALUE) {
        intelligence.cciTrend = newCCI - intelligence.cci;
        intelligence.cciPrev = intelligence.cci;
        intelligence.cci = newCCI;
    } else {
        intelligence.cci = 0;
    }
    
    // ATR with volatility normalization
    double newATR = iATR(Symbol(), 0, 14, 0);
    if(newATR > 0) {
        intelligence.atr = newATR;
    // VWAP: daily volume-weighted avg price (institutional benchmark)
    { datetime _dVp=iTime(Symbol(),PERIOD_D1,0); double _tVp=0,_vlVp=0;
      for(int _vbp=0;_vbp<300&&_vbp<Bars;_vbp++){if(Time[_vbp]<_dVp)break;
          double _vp=(double)iVolume(Symbol(),0,_vbp);
          _tVp+=((High[_vbp]+Low[_vbp]+Close[_vbp])/3.0)*_vp;_vlVp+=_vp;}
      intelligence.vwap=(_vlVp>0)?_tVp/_vlVp:Close[0];
      intelligence.aboveVWAP=(Close[0]>intelligence.vwap); }
        
        // Calculate ATR average for volatility measurement
        double atrSum = 0.0;
        int atrPeriods = MathMin(14, Bars);
        
        for(int i = 0; i < atrPeriods; i++) {
            double atrValue = iATR(Symbol(), 0, 14, i);
            if(atrValue > 0) {
                atrSum += atrValue;
            }
        }
        
        intelligence.atrAvg = atrSum / NonZero(atrPeriods);
        
        if(intelligence.atrAvg > 0) {
            intelligence.atrVolatility = intelligence.atr / NonZero(intelligence.atrAvg);
        }
    }
    
    // CRITICAL STACK FIX: DO NOT call sub-functions from here
    // UpdateVolumeIntelligence, UpdatePriceActionIntelligence, UpdateMicrostructureIntelligence
    // are now called separately with their own caching to flatten call stack
    // This prevents: ConsolidatedIndicatorCalculation -> UpdateVolume -> loops (too deep)
}

void UpdateVolumeIntelligence() {
    // CRITICAL STACK PROTECTION: Cache per bar
    static datetime lastVolumeUpdateBar = 0;
    datetime currentBar = iTime(Symbol(), 0, 0);
    
    if(currentBar == lastVolumeUpdateBar) {
        return; // CACHED
    }
    lastVolumeUpdateBar = currentBar;
    
    // Advanced volume analysis
    double currentVol = (double)iVolume(Symbol(), 0, 0);
    
    // Calculate volume moving average
    double volumeSum = 0.0;
    int volumePeriods = MathMin(20, Bars);
    
    for(int i = 1; i <= volumePeriods; i++) {
        volumeSum += (double)iVolume(Symbol(), 0, i);
    }
    
    intelligence.averageVolume = volumeSum / NonZero(volumePeriods);
    
    if(intelligence.averageVolume > 0) {
        intelligence.volumeRatio = currentVol / NonZero(intelligence.averageVolume);
        
        // Volume trend calculation
        double recentVolumeSum = 0.0;
        double olderVolumeSum = 0.0;
        int halfPeriod = volumePeriods / 2;
        
        for(int i = 1; i <= halfPeriod; i++) {
            recentVolumeSum += (double)iVolume(Symbol(), 0, i);
        }
        
        for(int i = halfPeriod + 1; i <= volumePeriods; i++) {
            olderVolumeSum += (double)iVolume(Symbol(), 0, i);
        }
        
        if(olderVolumeSum > 0) {
            intelligence.volumeTrend = (recentVolumeSum / NonZero(halfPeriod)) / (olderVolumeSum / NonZero(halfPeriod));
        }
        
        // Volume acceleration
        double previousVolumeRatio = 1.0;
        if(Bars > 1) {
            double previousVol = (double)iVolume(Symbol(), 0, 1);
            previousVolumeRatio = previousVol / NonZero(intelligence.averageVolume);
        }
        
        intelligence.volumeAcceleration = intelligence.volumeRatio - previousVolumeRatio;
        
        // Institutional vs retail flow estimation
        // KEY: High volume with conviction (strong close) = institutional directional
        // High volume with indecision (doji/small body) = accumulation/distribution battle
        // Low volume = retail noise, no institutional interest
        double candleConviction = 0.5;  // default mid
        if(Bars >= 2) {
            double _range = iHigh(Symbol(),0,0) - iLow(Symbol(),0,0);
            double _body  = MathAbs(iClose(Symbol(),0,0) - iOpen(Symbol(),0,0));
            double _close = (_range > 0.000001) ? (iClose(Symbol(),0,0) - iLow(Symbol(),0,0)) / _range : 0.5;
            // Conviction = body fill x closing extremity
            candleConviction = (_range > 0.000001) ? (_body / _range) * (MathAbs(_close - 0.5) * 2.0) : 0.0;
        }

        if(intelligence.volumeRatio > 2.0 && candleConviction > 0.5) {
            // High volume + strong directional close = institutional order flow
            intelligence.institutionalFlow = 0.85;
            intelligence.retailSentiment   = 0.15;
        } else if(intelligence.volumeRatio > 2.0 && candleConviction < 0.2) {
            // High volume + indecision = accumulation/distribution, not directional
            intelligence.institutionalFlow = 0.40;
            intelligence.retailSentiment   = 0.60;
        } else if(intelligence.volumeRatio > 1.5 && candleConviction > 0.4) {
            intelligence.institutionalFlow = 0.60;
            intelligence.retailSentiment   = 0.40;
        } else if(intelligence.volumeRatio > 1.5) {
            intelligence.institutionalFlow = 0.45;
            intelligence.retailSentiment   = 0.55;
        } else {
            // Low volume = retail-dominated, thin participation
            intelligence.institutionalFlow = 0.25;
            intelligence.retailSentiment   = 0.75;
        }

        // Order flow imbalance: net candle direction x volume conviction
        // Positive = net buying pressure, Negative = net selling
        if(Bars >= 2) {
            double _cs = (iHigh(Symbol(),0,0) - iLow(Symbol(),0,0) > 0.000001)
                ? (iClose(Symbol(),0,0) - iLow(Symbol(),0,0)) / (iHigh(Symbol(),0,0) - iLow(Symbol(),0,0))
                : 0.5;
            intelligence.orderFlowImbalance = (_cs - 0.5) * 2.0 * candleConviction
                                             * MathMin(1.5, intelligence.volumeRatio);
            intelligence.orderFlowImbalance = MathMax(-1.0, MathMin(1.0, intelligence.orderFlowImbalance));
        }
    }
}

void UpdatePriceActionIntelligence() {
    // CRITICAL STACK PROTECTION: Cache per bar
    static datetime lastPriceActionUpdateBar = 0;
    datetime currentBar = iTime(Symbol(), 0, 0);
    
    if(currentBar == lastPriceActionUpdateBar) {
        return; // CACHED
    }
    lastPriceActionUpdateBar = currentBar;
    
    // Enhanced price action analysis
    if(Bars < 3) return;
    
    double currentPrice = iClose(Symbol(), 0, 0);
    double previousPrice = iClose(Symbol(), 0, 1);
    double price2 = iClose(Symbol(), 0, 2);
    
    if(currentPrice > 0 && previousPrice > 0 && price2 > 0) {
        // Price velocity (first derivative)
        intelligence.priceVelocity = (currentPrice - previousPrice) / NonZero(previousPrice) * 10000.0; // NonZero(In.pips)
        
        // Price acceleration (second derivative)
        double previousVelocity = (previousPrice - price2) / NonZero(price2) * 10000.0;
        intelligence.priceAcceleration = intelligence.priceVelocity - previousVelocity;
        
        // Price jerk (third derivative)
        if(Bars >= 4) {
            double price3 = iClose(Symbol(), 0, 3);
            if(price3 > 0) {
                double velocity2 = (price2 - price3) / NonZero(price3) * 10000.0;
                double acceleration2 = previousVelocity - velocity2;
                intelligence.priceJerk = intelligence.priceAcceleration - acceleration2;
            }
        }
    }
    
    // Support and resistance strength calculation
    double atr = intelligence.atr;
    if(atr > 0) {
        // Find recent highs and lows for support/resistance
        int period = MathMin(50, Bars);
        if(period >= 1 && Bars > period) {  // Safety check
            int highestIdx = SafeHL(iHighest(Symbol(), 0, MODE_HIGH, period, 0));
            int lowestIdx = SafeHL(iLowest(Symbol(), 0, MODE_LOW, period, 0));
            
            double highestHigh = 0, lowestLow = 0;
            if(highestIdx >= 0 && highestIdx < Bars) {
                highestHigh = iHigh(Symbol(), 0, highestIdx);
            }
            if(lowestIdx >= 0 && lowestIdx < Bars) {
                lowestLow = iLow(Symbol(), 0, lowestIdx);
            }
        
            if(highestHigh > 0 && lowestLow > 0 && currentPrice > 0) {
                intelligence.resistanceStrength = (highestHigh - currentPrice) / NonZero(atr);
                intelligence.supportStrength = (currentPrice - lowestLow) / NonZero(atr);
                
                // Breakout probability based on proximity to key levels
                double proximityToResistance = MathAbs(currentPrice - highestHigh) / NonZero(atr);
                double proximityToSupport = MathAbs(currentPrice - lowestLow) / NonZero(atr);
            
            if(proximityToResistance < 0.5 || proximityToSupport < 0.5) {
                intelligence.breakoutProbability = 0.8;
            } else if(proximityToResistance < 1.0 || proximityToSupport < 1.0) {
                intelligence.breakoutProbability = 0.6;
            } else {
                intelligence.breakoutProbability = 0.3;
            }
            
            // Reversal probability based on exhaustion signals
            intelligence.reversalProbability = 0.2; // NonZero(Base.probability)
            if(intelligence.rsi > 80 || intelligence.rsi < 20) {
                intelligence.reversalProbability += 0.3;
            }
            // CRITICAL FIX: Reduced from 0.001 to 0.0001 for real forex M5 ranges
            // Typical: +/-0.00005-0.0002, this catches normal-to-active moves (20% of time)
            if(MathAbs(intelligence.macdHistogram) > 0.0001) {
                intelligence.reversalProbability += 0.2;
            }
            if(intelligence.atrVolatility > 1.8) {
                intelligence.reversalProbability += 0.2;
            }
            
            intelligence.reversalProbability = MathMin(0.9, intelligence.reversalProbability);
            }  // Close if(highestHigh > 0 && lowestLow > 0 && currentPrice > 0)
        }  // Close if(period >= 1 && Bars > period)
    }  // Close if(atr > 0)

    // ## CANDLE ANATOMY OVERRIDES ##############################################
    // Use bar 1 (last complete bar) anatomy to refine the intelligence outputs.
    // This runs AFTER the basic calculations so it can layer on top seamlessly.
    if(Bars >= 3) {
        MarketStateFeatures _pai = CalculateMarketFeatures(1);

        // reversalProbability: anatomy-informed refinement
        if(_pai.isBullishRejection || _pai.isBearishRejection) {
            double w = g_CandleWeightsCalibrated
                ? g_CalibratedCandleWeights[_pai.isBullishRejection ? 0 : 1] : 1.0;
            intelligence.reversalProbability = MathMin(0.90,
                intelligence.reversalProbability + 0.22 * _pai.barDrama * w);
        }
        if(_pai.isMorningStar || _pai.isEveningStar)
            intelligence.reversalProbability = MathMin(0.90, intelligence.reversalProbability + 0.18);
        if(_pai.isBullishEngulf || _pai.isBearishEngulf) {
            double w = g_CandleWeightsCalibrated
                ? g_CalibratedCandleWeights[_pai.isBullishEngulf ? 2 : 3] : 1.0;
            intelligence.reversalProbability = MathMin(0.90, intelligence.reversalProbability + 0.15 * w);
        }
        if(_pai.isConvictionCandle) intelligence.reversalProbability *= 0.80;  // continuation > reversal
        if(_pai.isIndecisionCandle) intelligence.reversalProbability = MathMin(0.90,
            intelligence.reversalProbability + 0.10);

        // breakoutProbability: inside bar = coiled spring
        if(_pai.isInsideBar)  intelligence.breakoutProbability = MathMax(intelligence.breakoutProbability, 0.72);
        if(_pai.isOutsideBar) intelligence.breakoutProbability = MathMax(intelligence.breakoutProbability, 0.55);
        if(_pai.isThreeWhiteSoldiers || _pai.isThreeBlackCrows)
            intelligence.breakoutProbability = MathMin(intelligence.breakoutProbability, 0.28);

        // priceVelocity: blend closing strength as a sharper directional signal
        double closingVel = (_pai.closingStrength - 0.5) * 2.0 *
                            MathMax(intelligence.atr, 0.0001) * 10000.0;
        intelligence.priceVelocity = intelligence.priceVelocity * 0.60 + closingVel * 0.40;
    }
}

void UpdateMicrostructureIntelligence() {

    // CRITICAL STACK PROTECTION: Cache per bar
    static datetime lastMicrostructureUpdateBar = 0;
    datetime currentBar = iTime(Symbol(), 0, 0);
    
    if(currentBar == lastMicrostructureUpdateBar) {
        return; // CACHED
    }
    lastMicrostructureUpdateBar = currentBar;
    
    // SAFETY: Require minimum bars
    if(Bars < 10) return;
    
    // Market microstructure analysis
    double bid = MarketInfo(Symbol(), MODE_BID);
    double ask = MarketInfo(Symbol(), MODE_ASK);
    
    if(bid > 0 && ask > 0) {
        intelligence.spread = ask - bid;
        
        // Normalize spread by ATR
        if(intelligence.atr > 0) {
            intelligence.spreadNormalized = intelligence.spread /NonZero(intelligence.atr);
        }
        
        // Liquidity (int)index based on spread tightness
        if(intelligence.spreadNormalized > 0) {
            intelligence.liquidityIndex = 1.0 / (1.0 + intelligence.spreadNormalized);
        } else {
            intelligence.liquidityIndex = 1.0;
        }
        
        // Order flow imbalance -- preserved from UpdateVolumeIntelligence if already set
        // (conviction-adjusted version is more accurate than naive close-to-close).
        // Only override with fallback if volume intelligence didn't run yet.
        if(intelligence.orderFlowImbalance == 0.0) {
            double _cd = 0.0;
            if(Bars >= 2) {
                double cClose = iClose(Symbol(), 0, 0);
                double pClose = iClose(Symbol(), 0, 1);
                if(cClose > 0 && pClose > 0)
                    _cd = (cClose > pClose) ? 1.0 : -1.0;
            }
            intelligence.orderFlowImbalance = _cd * MathMin(1.5, intelligence.volumeRatio);
        }

        // Pressure index: OFI x liquidity -- amplified when spread is tight (clean conditions)
        // Dampened when spread is wide (noise/illiquid -- pressure signals unreliable)
        intelligence.pressureIndex = intelligence.orderFlowImbalance * intelligence.liquidityIndex;

        // Spread-regime awareness: if spread > 2x normalised ATR, flag as thin liquidity
        // This is a direct market DNA read -- the broker is showing you the order book is sparse
        static bool _lastLiquidityWarn = false;
        bool thinLiquidity = (intelligence.spreadNormalized > GetAdaptiveSpreadCeiling());
        if(thinLiquidity && !_lastLiquidityWarn) {
            PrintFormat("  SKIP  |   liquidity   spread %.1f pips   |   %.0f%% of ATR   |   reducing signal confidence",
                intelligence.spread / Point / 10.0,
                intelligence.spreadNormalized * 100.0);
            _lastLiquidityWarn = true;
        } else if(!thinLiquidity) _lastLiquidityWarn = false;
    }
}

// FIXED CalculateAdvancedSharpeRatio function to completely avoid array initialization issues
double CalculateAdvancedSharpeRatio() {
    // FIXED: Completely explicit array declaration and initialization
    double ret_0 = 0.0, ret_1 = 0.0, ret_2 = 0.0, ret_3 = 0.0, ret_4 = 0.0;
    double ret_5 = 0.0, ret_6 = 0.0, ret_7 = 0.0, ret_8 = 0.0, ret_9 = 0.0;
    
    // Array with explicit initialization
    double returns[10];
    returns[0] = 0.0; returns[1] = 0.0; returns[2] = 0.0; returns[3] = 0.0; returns[4] = 0.0;
    returns[5] = 0.0; returns[6] = 0.0; returns[7] = 0.0; returns[8] = 0.0; returns[9] = 0.0;
    
    int count = 0;
    int maxReturns = 10;
    
    for(int i = 0; i < OrdersHistoryTotal() && count < maxReturns; i++) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                double equity = AccountEquity();
                if(equity > 0 && count < 10) { 
                    double returnValue = profit / NonZero(equity) * 100.0;
                    returns[count] = returnValue;
                    count = count + 1;
                }
            }
        }
    }
    
    if(count < 5) return 0.0;
    
    double sum = 0.0;
    for(int i = 0; i < count; i++) {
        sum = sum + returns[i];
    }
    double mean = sum / NonZero(count);
    
    double varianceSum = 0.0;
    for(int i = 0; i < count; i++) {
        double deviation = returns[i] - mean;
        double deviationSquared = deviation * deviation;
        varianceSum = varianceSum + deviationSquared;
    }
    double variance = varianceSum / NonZero(count);
    double stdDev = MathSqrt(variance);
    
    return (stdDev > 0) ? (mean / NonZero(stdDev)) : 0.0;
}

void ConsolidatedMarketAnalysis() {
    // Multi-timeframe consensus (enhanced)
    bool m5Bull = iClose(Symbol(), PERIOD_M5, 0) > iMA(Symbol(), PERIOD_M5, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
    bool m15Bull = iClose(Symbol(), PERIOD_M15, 0) > iMA(Symbol(), PERIOD_M15, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
    bool h1Bull = iClose(Symbol(), PERIOD_H1, 0) > iMA(Symbol(), PERIOD_H1, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
    
    intelligence.mtfBullishStrength = 0.0;
    intelligence.mtfBearishStrength = 0.0;
    intelligence.biasTimeframes = 0;
    
    if(m5Bull) { intelligence.mtfBullishStrength += 0.25; intelligence.biasTimeframes++; }
    else intelligence.mtfBearishStrength += 0.25;
    
    if(m15Bull) { intelligence.mtfBullishStrength += 0.35; intelligence.biasTimeframes++; }
    else intelligence.mtfBearishStrength += 0.35;
    
    if(h1Bull) { intelligence.mtfBullishStrength += 0.4; intelligence.biasTimeframes++; }
    else intelligence.mtfBearishStrength += 0.4;
    
    intelligence.mtfConsensus = MathAbs(intelligence.mtfBullishStrength - intelligence.mtfBearishStrength);
    intelligence.mtfAligned = intelligence.mtfConsensus > 0.6;
    intelligence.biasValid = intelligence.mtfAligned;
    intelligence.biasStrong = intelligence.mtfConsensus > 0.8;
    intelligence.biasConfidence = intelligence.mtfConsensus;
    
    // Market microstructure
    intelligence.spread = MarketInfo(Symbol(), MODE_SPREAD) * Point;
    intelligence.spreadNormalized = intelligence.spread /NonZero(intelligence.atr);
    intelligence.liquidityIndex = 1.0 / NonZero(MathMax(1.0, intelligence.spreadNormalized));
}

void ConsolidatedPatternRecognition() {
    if(Bars < 5) return;
    
    // Simplified but effective pattern recognition
    intelligence.dominantPattern = 0;
    intelligence.patternStrength = 0.0;
    intelligence.patternConfidence = 0.5;
    
    // Current and previous candle analysis
    double o0 = iOpen(Symbol(), 0, 0), h0 = iHigh(Symbol(), 0, 0);
    double l0 = iLow(Symbol(), 0, 0), c0 = iClose(Symbol(), 0, 0);
    double o1 = iOpen(Symbol(), 0, 1), h1 = iHigh(Symbol(), 0, 1);
    double l1 = iLow(Symbol(), 0, 1), c1 = iClose(Symbol(), 0, 1);
    
    if(o0 > 0 && h0 > 0 && l0 > 0 && c0 > 0 && o1 > 0 && h1 > 0 && l1 > 0 && c1 > 0) {
        // Bullish engulfing
        if(c1 < o1 && c0 > o0 && c0 > o1 && o0 < c1) {
            intelligence.dominantPattern = 1;
            intelligence.patternStrength = 0.8;
            intelligence.patternConfidence = intelligence.volumeRatio > 1.3 ? 0.9 : 0.7;
        }
        // Bearish engulfing
        else if(c1 > o1 && c0 < o0 && c0 < o1 && o0 > c1) {
            intelligence.dominantPattern = -1;
            intelligence.patternStrength = 0.8;
            intelligence.patternConfidence = intelligence.volumeRatio > 1.3 ? 0.9 : 0.7;
        }
        // Hammer/Doji patterns
        else {
            double bodySize = MathAbs(c0 - o0);
            double range = h0 - l0;
            if(range > 0 && bodySize / NonZero(range) < 0.3) {
                if(intelligence.rsi < 30) {
                    intelligence.dominantPattern = 1;
                    intelligence.patternStrength = 0.6;
                } else if(intelligence.rsi > 70) {
                    intelligence.dominantPattern = -1;
                    intelligence.patternStrength = 0.6;
                }
            }
        }
    }
    
    intelligence.patternMaturity = MathMin(1.0, (currentTickMs - intelligence.lastUpdateMs) / 1000.0);
}

// Duplicate definition of function 'E99_ProcessExecutionDecisions' removed by auto-fix. Kept the most complete implementation.

// COMPLETE TRADE MANAGEMENT IMPLEMENTATION
void SynchronizeActiveTrades() {
    int liveOrderCount = 0;
    
    // First pass: mark all trades as potentially stale
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        tradeManager.activeTrades[i].needsUpdate = true;
    }
    
    // Second pass: sync with live orders
    for(int i = 0; i < OrdersTotal(); i++) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                
                // Find existing trade record or create new one
                int tradeIndex = -1;
                for(int j = 0; j < tradeManager.activeTradeCount; j++) {
                    if(tradeManager.activeTrades[j].ticket == OrderTicket()) {
                        tradeIndex = j;
                        break;
                    }
                }
                
                if(tradeIndex == -1) {
                    // Create new trade record
                    for(int j = 0; j < 50; j++) {
                        if(!tradeManager.activeTrades[j].isValid) {
                            CreateTradeRecord(j, i);
                            tradeIndex = j;
                            if(j >= tradeManager.activeTradeCount) {
                                tradeManager.activeTradeCount = j + 1;
                            }
                            break;
                        }
                    }
                } else {
                    // Update existing record
                    UpdateTradeRecord(tradeIndex, i);
                }
                
                if(tradeIndex >= 0) {
                    tradeManager.activeTrades[tradeIndex].needsUpdate = false;
                }
                liveOrderCount++;
            }
        }
    }
    
    // Third pass: clear stale trades
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        if(tradeManager.activeTrades[i].needsUpdate && tradeManager.activeTrades[i].isValid) {
            ClearTradeRecord(i);
        }
    }
    
    // Compact array and update count
    int compactIndex = 0;
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        if(tradeManager.activeTrades[i].isValid) {
            if(i != compactIndex) {
                tradeManager.activeTrades[compactIndex] = tradeManager.activeTrades[i];
                ClearTradeRecord(i);
            }
            compactIndex++;
        }
    }
    tradeManager.activeTradeCount = compactIndex;
    engine.activeTrades = liveOrderCount;
}

void CreateTradeRecord(int index, int orderIndex) {
    if((int)index >= 50 || !OrderSelect(orderIndex, SELECT_BY_POS, MODE_TRADES)) return;
    
    tradeManager.activeTrades[(int)index].ticket = OrderTicket();
    tradeManager.activeTrades[(int)index].type = OrderType();
    tradeManager.activeTrades[(int)index].openPrice = OrderOpenPrice();
    {double _osl=OrderStopLoss(); tradeManager.activeTrades[(int)index].stopLoss = (_osl > 0) ? _osl : tradeManager.activeTrades[(int)index].stopLoss;}
    tradeManager.activeTrades[(int)index].takeProfit = OrderTakeProfit();
    tradeManager.activeTrades[(int)index].lotSize = OrderLots();
    tradeManager.activeTrades[(int)index].openTime = OrderOpenTime();
    tradeManager.activeTrades[(int)index].tradeComment = OrderComment();
    
    // Initialize trade metrics
    tradeManager.activeTrades[(int)index].currentPrice = (OrderType() == OP_BUY) ? Bid : Ask;
    tradeManager.activeTrades[(int)index].profit = OrderProfit() + OrderSwap() + OrderCommission();
    tradeManager.activeTrades[(int)index].profitPips = (OrderType() == OP_BUY) ? 
        (tradeManager.activeTrades[(int)index].currentPrice - OrderOpenPrice()) / NonZero(Point) :
        (OrderOpenPrice() - tradeManager.activeTrades[(int)index].currentPrice) / NonZero(Point);
    
    tradeManager.activeTrades[(int)index].currentTime = TimeCurrent();
    tradeManager.activeTrades[(int)index].holdingMinutes = (int)((TimeCurrent() - OrderOpenTime()) / 60);
    
    // Initialize risk management
    // SLS21 FIX: was using raw OrderStopLoss() (0 if the broker stripped/never set the SL),
    // which blew initialRisk up to ~entry-price magnitude -> tripped portfolio-heat breach ->
    // force-closed the whole book. Use the sanitized .stopLoss set two lines above, with an
    // ATR-based floor if that is also unset, instead of ever dividing by a zero SL distance.
    {
        double _crRiskSL = tradeManager.activeTrades[(int)index].stopLoss;
        if(_crRiskSL <= 0) _crRiskSL = OrderOpenPrice() + ((OrderType()==OP_BUY) ? -1.0 : 1.0) * iATR(Symbol(),0,14,1) * 1.5;
        tradeManager.activeTrades[(int)index].initialRisk = MathAbs(OrderOpenPrice() - _crRiskSL) * OrderLots() * MarketInfo(Symbol(), MODE_TICKVALUE) / NonZero(Point);
    }
    tradeManager.activeTrades[(int)index].currentRisk = tradeManager.activeTrades[(int)index].initialRisk;
    tradeManager.activeTrades[(int)index].breakEvenLevel = OrderOpenPrice();
    tradeManager.activeTrades[(int)index].breakEvenSet = false;
    tradeManager.activeTrades[(int)index].partialProfitTaken = false;
    
    // Initialize intelligence tracking
    tradeManager.activeTrades[(int)index].entryScore = engine.unifiedScore;
    tradeManager.activeTrades[(int)index].entryRegime = (int)engine.regime;
    tradeManager.activeTrades[(int)index].currentRegime = (int)engine.regime;
    tradeManager.activeTrades[(int)index].regimeChanged = false;
    tradeManager.activeTrades[(int)index].entryConfidence = CalculateConfidenceMultiplier();
    
    // Trade classification and calibrated time exit
    if(StringFind(OrderComment(), "HF") >= 0) {
        tradeManager.activeTrades[(int)index].isScalpingTrade = true;
    } else {
        tradeManager.activeTrades[(int)index].isSwingTrade = true;
    }
    // Use calibrated exit bar count x timeframe minutes per bar.
    {
        int _entryR = (int)engine.regime;
        int _exitBars = (g_WeightsOptimized && _entryR >= 0 && _entryR < 9 && g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_entryR))] > 0)
                        ? g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_entryR))] : 20;
        // Safety: clamp to [5, 80] bars
        _exitBars = MathMax(5, MathMin(80, _exitBars));
        // Convert bars to minutes. Period() returns the current chart TF in minutes.
        tradeManager.activeTrades[(int)index].maxHoldingTime = _exitBars * Period();
    }
    
    tradeManager.activeTrades[(int)index].isValid = true;
    tradeManager.activeTrades[(int)index].needsUpdate = false;
    
    LogTradeExecution(StringFormat("Trade Record Created: #%d | %s | %.2f lots | Entry: %.5f", 
                     OrderTicket(), (OrderType() == OP_BUY) ? "BUY" : "SELL", 
                     OrderLots(), OrderOpenPrice()));
}

void UpdateTradeRecord(int index, int orderIndex) {
    if((int)index >= 50 || !tradeManager.activeTrades[(int)index].isValid || 
       !OrderSelect(orderIndex, SELECT_BY_POS, MODE_TRADES)) return;
    
    // Update current metrics
    tradeManager.activeTrades[(int)index].currentPrice = (OrderType() == OP_BUY) ? Bid : Ask;
    tradeManager.activeTrades[(int)index].profit = OrderProfit() + OrderSwap() + OrderCommission();
    tradeManager.activeTrades[(int)index].profitPips = (OrderType() == OP_BUY) ? 
        (tradeManager.activeTrades[(int)index].currentPrice - OrderOpenPrice()) / NonZero(Point) :
        (OrderOpenPrice() - tradeManager.activeTrades[(int)index].currentPrice) / NonZero(Point);
    
    tradeManager.activeTrades[(int)index].currentTime = TimeCurrent();
    tradeManager.activeTrades[(int)index].holdingMinutes = (int)((TimeCurrent() - OrderOpenTime()) / 60);
    
    // Update intelligence tracking
    tradeManager.activeTrades[(int)index].currentScore = engine.unifiedScore;
    tradeManager.activeTrades[(int)index].currentRegime = (int)engine.regime;
    
    if(tradeManager.activeTrades[(int)index].currentRegime != tradeManager.activeTrades[(int)index].entryRegime) {
        tradeManager.activeTrades[(int)index].regimeChanged = true;
    }
    
    // Update performance tracking
    tradeManager.activeTrades[(int)index].outperforming = tradeManager.activeTrades[(int)index].profit > 0;
    tradeManager.activeTrades[(int)index].underperforming = tradeManager.activeTrades[(int)index].profit < 0;
    
    // Update current confidence
    tradeManager.activeTrades[(int)index].currentConfidence = CalculateConfidenceMultiplier();
    
    tradeManager.activeTrades[(int)index].needsUpdate = false;
}

void ClearTradeRecord(int index) {
    if((int)index >= 50) return;
    
    tradeManager.activeTrades[(int)index].ticket = -1;
    tradeManager.activeTrades[(int)index].isValid = false;
    tradeManager.activeTrades[(int)index].needsUpdate = false;
}

void UpdateIndividualTrades() {
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        if(tradeManager.activeTrades[i].isValid) {
            ManageIndividualTradeAdvanced(i);
        }
    }
}

void ManageIndividualTradeAdvanced(int index) {
    if((int)index >= 50 || !tradeManager.activeTrades[(int)index].isValid) return;
    
    // Check emergency exit conditions first
    if(CheckEmergencyExitConditions((int)index)) {
        ExecuteTradeExit((int)index, "Emergency Exit");
        return;
    }
    
    // Check regime change exit
    if(ShouldExitOnRegimeChange((int)index)) {
        ExecuteTradeExit((int)index, "Regime Change");
        return;
    }

    // WARRANT#84 (keys-3 item 15, "dissipation exit wired"): HARD OFF by default via
    // EnableDissipationExit. See ShouldExitOnDissipation() for the cost-audited, per-bar-cached
    // implementation.
    if(EnableDissipationExit && ShouldExitOnDissipation()) {
        ExecuteTradeExit((int)index, "Dissipation Exit");
        return;
    }

    // WARRANT#89 (2026-07-22, "finish stalled wiring"): HARD OFF by default via
    // EnableOptimalStoppingExit. See ShouldExitOnOptimalStopping() below.
    if(EnableOptimalStoppingExit && ShouldExitOnOptimalStopping((int)index)) {
        ExecuteTradeExit((int)index, "Optimal Stopping Exit");
        return;
    }

    // Check time-based exit for scalping trades
    if(tradeManager.activeTrades[(int)index].isScalpingTrade && 
       tradeManager.activeTrades[(int)index].holdingMinutes > tradeManager.activeTrades[(int)index].maxHoldingTime) {
        ExecuteTradeExit((int)index, "Time Limit");
        return;
    }
    
    // Manage break-even
    ManageBreakEven((int)index);
    
    // Update trailing stop
    UpdateTrailingStopAdvanced((int)index);
    
    // Manage partial profits
    ManagePartialProfits((int)index);
}

bool ShouldExitOnRegimeChange(int index) {
    if(!tradeManager.activeTrades[(int)index].regimeChanged) return false;

    bool isBuyTrade = (tradeManager.activeTrades[(int)index].type == OP_BUY);
    int currentRegime = tradeManager.activeTrades[(int)index].currentRegime;

    // Enhanced: also check EMA200 structural opposition -- if the EMA200 is now
    // firmly against the trade direction, the structural context has shifted.
    MarketStateFeatures _ef = CalculateMarketFeatures(0);  // cached
    bool structuralOpposition = isBuyTrade
        ? (_ef.ema200Distance < -1.5)   // buy trade but price now >1.5 ATR below EMA200
        : (_ef.ema200Distance >  1.5);  // sell trade but price now >1.5 ATR above EMA200
    if(structuralOpposition) return true;

    if(isBuyTrade) {
        return (currentRegime == REGIME_STRONG_BEARISH || currentRegime == REGIME_ULTRA_BEARISH);
    } else {
        // Exit sell trades in strong bullish regimes
        return (currentRegime == REGIME_STRONG_BULLISH || currentRegime == REGIME_ULTRA_BULLISH);
    }
}

void UpdateTrailingStopAdvanced(int index) {
    if(!tradeManager.activeTrades[(int)index].isValid) return;
    
    bool isBuy = (tradeManager.activeTrades[(int)index].type == OP_BUY);
    double currentPrice = tradeManager.activeTrades[(int)index].currentPrice;
    double openPrice = tradeManager.activeTrades[(int)index].openPrice;
    double currentSL = tradeManager.activeTrades[(int)index].stopLoss;
    
    // Only trail if in profit
    bool inProfit = (isBuy && currentPrice > openPrice) || (!isBuy && currentPrice < openPrice);
    if(!inProfit) return;
    
    // Adaptive trailing distance: scale with vol expansion so normal intrabar
    // swings in a high-volatility environment don't prematurely stop out runners.
    // Base: 1.5x ATR. Expanding vol: up to 2.0x. Compressed vol: down to 1.2x.
    MarketStateFeatures _trf = CalculateMarketFeatures(0);  // cached
    double _trailMult = 1.5;
    if     (_trf.volExpansion > 1.4) _trailMult = 1.5 + (_trf.volExpansion - 1.0) * 0.5;  // expand with vol
    else if(_trf.volExpansion < 0.7) _trailMult = 1.2;  // compressed -- tighter trail
    _trailMult = MathMax(1.1, MathMin(2.2, _trailMult));
    // OP: Hurst exponent trailing stop refinement
    // H>0.60 = strong trend - trail wide (let the move extend)
    // H<0.43 = mean-reverting - trail tight (lock profit fast)
    { double _hT = E99_HurstExponent(0, 50);
      if(_hT > 0.60)      _trailMult *= MathMin(1.25, 1.0+(_hT-0.60)*1.25); // trend: wider
      else if(_hT < 0.43 && _hT > 0) _trailMult *= MathMax(0.75, 1.0-(_hT-0.43)*(-2.0)); // MR: tighter
      // Proven regime bonus: allow more room for high-confidence setups
      if(g_CorrelationsLearned) { int _hReg=g_RegimeState.currentRegime;
        if(_hReg>=0&&_hReg<9&&g_RegimeCorrelations[_hReg].signalWR>=0.68) _trailMult*=1.08; }
      _trailMult = MathMax(1.0, MathMin(2.5, _trailMult)); }

    // CHESS ENGINE: Transition-aware trail compression.
    // If the market is about to change character, lock profit NOW rather than
    // riding the reversal. A chess engine doesn't hold a winning position into
    // a forced mate sequence for the opponent.
    if(g_Awareness.isValid && g_Awareness.continuationProb < 0.45) {
        // Regime shift anticipated: compress trail to lock profit
        // Sharper compression when next regime is hostile or path WR is low
        double _transComp = 1.0;
        if(g_Awareness.pathExpectedWR < 0.55)
            _transComp = 0.80;  // hostile path — compress aggressively
        else
            _transComp = 0.90;  // uncertain path — moderate compression
        // Ensure we never go below 1.0x ATR (min safe trail)
        _trailMult = MathMax(1.0, _trailMult * _transComp);
        static datetime _lastTransLog = 0;
        if(TimeCurrent() - _lastTransLog > 600 && EnableFriendlyLogs && !g_CalibSilent) {
            PrintFormat("  LIVE  |   trail   regime transition anticipated   |   compression %.0f%%   |   mult %.2f",
                        (1.0 - _transComp) * 100, _trailMult);
            _lastTransLog = TimeCurrent();
        }
    }
    double trailDistance = intelligence.atr * _trailMult;
    double newSL = 0.0;
    
    if(isBuy) {
        newSL = currentPrice - trailDistance;
        if(newSL > currentSL && newSL > openPrice) {
            if(OrderSelect(tradeManager.activeTrades[(int)index].ticket, SELECT_BY_TICKET)) {
                if(OrderModify(OrderTicket(), OrderOpenPrice(), newSL, OrderTakeProfit(), 0, Blue)) {
                    tradeManager.activeTrades[(int)index].stopLoss = newSL;
                    tradeManager.activeTrades[(int)index].trailingStop = newSL;
                }
            }
        }
    } else {
        newSL = currentPrice + trailDistance;
        if((currentSL == 0 || newSL < currentSL) && newSL < openPrice) {
            if(OrderSelect(tradeManager.activeTrades[(int)index].ticket, SELECT_BY_TICKET)) {
                if(OrderModify(OrderTicket(), OrderOpenPrice(), newSL, OrderTakeProfit(), 0, Red)) {
                    tradeManager.activeTrades[(int)index].stopLoss = newSL;
                    tradeManager.activeTrades[(int)index].trailingStop = newSL;
                }
            }
        }
    }
}

void ManageBreakEven(int index) {
    if(!tradeManager.activeTrades[(int)index].isValid || tradeManager.activeTrades[(int)index].breakEvenSet) return;
    
    bool isBuy = (tradeManager.activeTrades[(int)index].type == OP_BUY);
    double currentPrice = tradeManager.activeTrades[(int)index].currentPrice;
    double openPrice = tradeManager.activeTrades[(int)index].openPrice;
    
    // Adaptive BE trigger: if the last completed bar showed a conviction close
    // in the trade direction, set BE earlier (1.0x ATR) -- the move has momentum.
    // Otherwise use standard 1.5x ATR trigger.
    MarketStateFeatures _bef = CalculateMarketFeatures(0);
    double _convictionBE = (isBuy  && _bef.closePosition > 0.78 && _bef.bodyRatio > 0.50) ||
                           (!isBuy && _bef.closePosition < 0.22 && _bef.bodyRatio > 0.50);
    // Regime-aware breakeven: trend = let it run, range = lock early
    int _beReg = g_RegimeState.currentRegime;
    double _beDist = (_beReg==0||_beReg==1) ? 2.0 :  // trend: run 2 ATR before locking
                     (_beReg==8)            ? 1.3 :  // pullback: medium (defined target)
                     (_beReg==4||_beReg==5) ? 0.9 :  // range: early lock (bounces limited)
                     1.5;                            // default
    double breakEvenTrigger = intelligence.atr * (_convictionBE ? _beDist*0.75 : _beDist);
    // -- LSM signal degradation - earlier BE ----------------------------------
    // If the Live Signal Monitor flagged that the entry's sequence agreement has
    // collapsed (seqMult dropped from >1.05 to <0.80), tighten BE trigger by 35%.
    // The pattern that justified this trade is no longer persisting — lock in earlier.
    if(g_LSM_BEForced) breakEvenTrigger *= 0.65;
    bool shouldSetBreakEven = false;
    
    if(isBuy && (currentPrice - openPrice) >= breakEvenTrigger) {
        shouldSetBreakEven = true;
    } else if(!isBuy && (openPrice - currentPrice) >= breakEvenTrigger) {
        shouldSetBreakEven = true;
    }
    
    if(shouldSetBreakEven) {
        double newSL = openPrice + (isBuy ? intelligence.atr * 0.125 : -intelligence.atr * 0.125); // WARRANT#1: ATR-ratio buffer beyond break-even (was Point*5, illegal absolute)
        
        if(OrderSelect(tradeManager.activeTrades[(int)index].ticket, SELECT_BY_TICKET)) {
            if(OrderModify(OrderTicket(), OrderOpenPrice(), newSL, OrderTakeProfit(), 0, Yellow)) {
                tradeManager.activeTrades[(int)index].stopLoss = newSL;
                tradeManager.activeTrades[(int)index].breakEvenSet = true;
                tradeManager.activeTrades[(int)index].breakEvenLevel = newSL;
                
                LogTradeExecution(StringFormat("Break-Even Set: #%d | New SL: %.5f", 
                                 tradeManager.activeTrades[(int)index].ticket, newSL));
            }
        }
    }
}

void ManagePartialProfits(int index) {
    if(!tradeManager.activeTrades[(int)index].isValid || tradeManager.activeTrades[(int)index].partialProfitTaken) return;
    
    bool isBuy = (tradeManager.activeTrades[(int)index].type == OP_BUY);
    double currentPrice = tradeManager.activeTrades[(int)index].currentPrice;
    double openPrice = tradeManager.activeTrades[(int)index].openPrice;
    double lotSize = tradeManager.activeTrades[(int)index].lotSize;
    
    // Take partial profit at 2.5 ATR
    // Regime-aware partial: don't cut trending moves short
    int _ppReg = g_RegimeState.currentRegime;
    double _ppDist = (_ppReg==0||_ppReg==1) ? 3.5 :  // trend: wait, take only 25% then
                     (_ppReg==8)            ? 2.0 :  // pullback: structured — take at 2.0
                     (_ppReg==4||_ppReg==5) ? 1.5 :  // range: modest, take at 1.5
                     2.5;
    double _ppFraction = (_ppReg==0||_ppReg==1) ? 0.30 : 0.50;  // trend: only 30%
    double partialProfitTrigger = intelligence.atr * _ppDist;
    bool shouldTakePartial = false;
    
    if(isBuy && (currentPrice - openPrice) >= partialProfitTrigger) {
        shouldTakePartial = true;
    } else if(!isBuy && (openPrice - currentPrice) >= partialProfitTrigger) {
        shouldTakePartial = true;
    }
    
    if(shouldTakePartial && lotSize >= 0.02) { // NonZero(Only.if) lot size allows partial
        double partialLotSize = MathRound(lotSize * _ppFraction / 0.01) * 0.01; // regime-aware fraction0%
        
        if(partialLotSize >= 0.01) {
            // [FIX-K] Use SafeOrderClose (3-attempt retry) instead of raw OrderClose.
     bool closeResult = SafeOrderClose(tradeManager.activeTrades[(int)index].ticket, partialLotSize,
                                       currentPrice, 3);
            if(closeResult) {
                tradeManager.activeTrades[(int)index].partialProfitTaken = true;
                tradeManager.activeTrades[(int)index].lotSize = lotSize - partialLotSize;
                
                LogTradeExecution(StringFormat("Partial Profit Taken: #%d | %.2f lots closed at %.5f", 
                                 tradeManager.activeTrades[(int)index].ticket, partialLotSize, currentPrice));
            }
        }
    }
}

bool CheckEmergencyExitConditions(int index) {
    if(!tradeManager.activeTrades[(int)index].isValid) return false;
    
    // Emergency exit conditions
    bool emergencyExit = false;
    
    // 1. System emergency mode
    if(riskMgr.emergencyActive || engine.emergencyMode) {
        emergencyExit = true;
    }
    
    // 2. Excessive loss (> 5% of account)
    double accountEquity = AccountEquity();
    if(accountEquity > 0 && tradeManager.activeTrades[(int)index].profit < -(accountEquity * 0.05)) {
        emergencyExit = true;
    }
    
    // 3. Extreme market conditions (legacy ATR ratio)
    if(intelligence.atrVolatility > 3.0 && tradeManager.activeTrades[(int)index].profit < 0) {
        emergencyExit = true;
    }

    // 4. Major spread widening
    // SLS21 FIX: was missing the profit-sign gate every other condition here has, so a
    // spread spike (often a news event) could force-close a currently WINNING trade too.
    if(intelligence.spreadNormalized > 5.0 && tradeManager.activeTrades[(int)index].profit < 0) {
        emergencyExit = true;
    }

    // 5. Precision: atrPercentile in extreme spike while losing
    // Top 8% of historical volatility while a trade is losing = spike event.
    // The SL distance is no longer statistically valid -- the market has
    // moved into a distribution tail. Exit before it gets worse.
    {
        MarketStateFeatures _ef2 = CalculateMarketFeatures(0);  // cached
        bool _losing = tradeManager.activeTrades[(int)index].profit < 0;
        if(_ef2.atrPercentile > 0.92 && _losing) emergencyExit = true;

        // 6. Structural capitulation: EMA200 firmly against trade AND losing
        bool _isBuyPos = (tradeManager.activeTrades[(int)index].type == OP_BUY);
        bool _structural = (_isBuyPos  && _ef2.ema200Distance < -3.5) ||
                           (!_isBuyPos && _ef2.ema200Distance >  3.5);
        if(_structural && _losing) emergencyExit = true;
    }

    return emergencyExit;
}

void ExecuteTradeExit(int index, string reason) {
    if(!tradeManager.activeTrades[(int)index].isValid) return;
    
    int ticket = tradeManager.activeTrades[(int)index].ticket;
    double lotSize = tradeManager.activeTrades[(int)index].lotSize;
    double currentPrice = tradeManager.activeTrades[(int)index].currentPrice;
    
    if(OrderSelect(ticket, SELECT_BY_TICKET)) {
        // [FIX-K] Use SafeOrderClose (3-attempt retry) instead of raw OrderClose.
        bool closeResult = SafeOrderClose(ticket, lotSize, currentPrice, 5);
        
        // E9.9: Reset scaling state when position closes
        if(E99_Enable && E99_EnableScaling) {
            E99_ResetScaling();
        }

        if(closeResult) {
            tradeManager.activeTrades[(int)index].exitReason = reason;
            double finalProfit = OrderProfit() + OrderSwap() + OrderCommission();
            bool wasWin = finalProfit > 0;
            
            // Calculate R-multiple
            double openPrice = OrderOpenPrice();
            double stopLoss = OrderStopLoss();
            double riskDistance = MathAbs(openPrice - stopLoss);
            double rMultiple = 0.0;
            if(riskDistance > 0) {
                double profitDistance = MathAbs(OrderClosePrice() - openPrice);
                rMultiple = profitDistance / riskDistance;
                if(!wasWin) rMultiple = -rMultiple;
            }
            
            // TRADE EXIT LOG -- one line per event
            if(wasWin) {
                static int winStreak = 0;
                winStreak = tradeManager.consecutiveWins + 1;
                int totalTrades = tradeManager.winningTrades + tradeManager.losingTrades + 1;
                int wins = tradeManager.winningTrades + 1;
                string sTag = (winStreak>=5) ? StringFormat(" streak %d",winStreak) : (winStreak>=3) ? StringFormat(" x%d",winStreak) : "";
                string lbl = (rMultiple>=3.0) ? "elite" : (rMultiple>=2.0) ? "strong" : "win";
                lastSignificantLog = TimeCurrent();
            // SLS13 operator voice: win — outcome in R and $, then a one-line read.
            {
              double _wr2 = (totalTrades>0) ? (double)wins/totalTrades*100.0 : 0.0;
              string _read = (rMultiple>=3.0) ? "ran well past target — let it work" :
                             (rMultiple>=2.0) ? "clean follow-through, thesis held" :
                                                "target hit; took what the setup offered";
              PrintFormat("  WIN  +%.1fR  (+$%.0f)  #%d%s   │   %s",
                        rMultiple, finalProfit, ticket, sTag, _read);
              PrintFormat("        read: %s. day %d trades, WR %.0f%%.",
                        _read, totalTrades, _wr2);
            }
            } else {
                int totalTrades2 = tradeManager.winningTrades + tradeManager.losingTrades + 1;
                lastSignificantLog = TimeCurrent();
            // SLS13 operator voice: loss — outcome, then an honest read that feeds learning.
            {
              string _read = (rMultiple<=-1.0) ? "stop hit on reversal — setup didn't hold" :
                                                 "exited weak — signal faded early";
              PrintFormat("  LOSS  %.1fR  ($%.0f)  #%d   │   %s",
                        rMultiple, finalProfit, ticket, _read);
              PrintFormat("        read: %s. noting the conditions for this regime.", _read);
            }
                g_LastLossTime = TimeCurrent();
            }
            
            UpdateSafeguardsAfterTrade(wasWin, finalProfit);

            // Immediate E9.9 feedback -- beehive/milestones/validation
            // This fires synchronously without waiting for the 10s history poll
            E99_OnTradeClose(finalProfit);

            // Immediate drawdown forensics update via live adaptive
            // (UpdateDrawdownForensics takes TradeRecord& -- handled by RecordTradeResult)
            // Direct anatomy tracking for the exit context
            if(!wasWin) {
                MarketStateFeatures _ddf = CalculateMarketFeatures(0);
                for(int _li2=0;_li2<14;_li2++) {
                    // anatomy suppression happens inside UpdateLiveAdaptive via RecordTradeResult
                }
            }

            ClearTradeRecord((int)index);
            
            // Update performance tracking
            if(finalProfit > 0) {
                tradeManager.winningTrades++;
                tradeManager.totalProfit += finalProfit;
                if(finalProfit > tradeManager.largestWin) tradeManager.largestWin = finalProfit;
                tradeManager.consecutiveWins++;
                tradeManager.consecutiveLosses = 0;
            } else {
                tradeManager.losingTrades++;
                tradeManager.totalLoss += MathAbs(finalProfit);
                if(MathAbs(finalProfit) > tradeManager.largestLoss) tradeManager.largestLoss = MathAbs(finalProfit);
                tradeManager.consecutiveLosses++;
                tradeManager.consecutiveWins = 0;
                
                // Analyze loss if significant
                if(MathAbs(finalProfit) > AccountEquity() * 0.02) {
                    AnalyzeLossPatterns();
                    AdjustParametersAfterLoss(MathAbs(finalProfit));
                }
            }
            
            tradeManager.totalTrades++;
            tradeManager.netProfit = tradeManager.totalProfit - tradeManager.totalLoss;
        }
    }
}

void UpdateTradeManagerPortfolioMetrics() {
    tradeManager.totalActiveRisk = 0.0;
    tradeManager.totalActiveReward = 0.0;
    tradeManager.correlationRisk = 0.0;
    
    int buyTrades = 0, sellTrades = 0;
    
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        if(tradeManager.activeTrades[i].isValid) {
            // Sum active risk
            tradeManager.totalActiveRisk += tradeManager.activeTrades[i].currentRisk;
            
            // Sum potential reward
            double potentialReward = 0.0;
            if(tradeManager.activeTrades[i].takeProfit > 0) {
                bool isBuy = (tradeManager.activeTrades[i].type == OP_BUY);
                potentialReward = MathAbs(tradeManager.activeTrades[i].takeProfit - tradeManager.activeTrades[i].openPrice) * 
                                tradeManager.activeTrades[i].lotSize * MarketInfo(Symbol(), MODE_TICKVALUE) / NonZero(Point);
            }
            tradeManager.totalActiveReward += potentialReward;
            
            // Count trade directions for correlation
            if(tradeManager.activeTrades[i].type == OP_BUY) buyTrades++;
            else sellTrades++;
        }
    }
    
    // Calculate portfolio heat
    double accountEquity = AccountEquity();
    if(accountEquity > 0) {
        tradeManager.portfolioHeat = (tradeManager.totalActiveRisk / NonZero(accountEquity)) * 100.0;
        engine.portfolioHeat = tradeManager.portfolioHeat;
        riskMgr.portfolioHeat = tradeManager.portfolioHeat;
    }
    
    // Calculate correlation risk (all trades in same direction = higher risk)
    if(tradeManager.activeTradeCount > 1) {
        double directionBalance = MathAbs(buyTrades - sellTrades) / (double)MathMax(1, tradeManager.activeTradeCount);
        tradeManager.correlationRisk = directionBalance * 100.0;
    }
    
    // Risk limit checks
    tradeManager.riskLimitsBreached = (tradeManager.portfolioHeat > PORTFOLIO_HEAT_LIMIT * 1.5);
    
    if(tradeManager.riskLimitsBreached) {
        riskMgr.emergencyActive = true;
        LogCriticalEvent(StringFormat("RISK LIMITS BREACHED | Portfolio Heat: %.2f%% | Active Risk: %.2f", 
                        tradeManager.portfolioHeat, tradeManager.totalActiveRisk), "RISK");
    }
}

void UpdateTradePerformanceStatistics() {
    // Basic performance metrics
    if(tradeManager.totalTrades > 0) {
        tradeManager.winRate = ((double)tradeManager.winningTrades / NonZero(tradeManager.totalTrades)) * 100.0;
        tradeManager.expectancy = (tradeManager.totalProfit - tradeManager.totalLoss) / NonZero(tradeManager.totalTrades);
    }
    
    if(tradeManager.totalLoss > 0) {
        tradeManager.profitFactor = tradeManager.totalProfit / NonZero(tradeManager.totalLoss);
    }
    
    // Update consecutive tracking
    if(tradeManager.consecutiveWins > tradeManager.maxConsecutiveWins) {
        tradeManager.maxConsecutiveWins = tradeManager.consecutiveWins;
    }
    if(tradeManager.consecutiveLosses > tradeManager.maxConsecutiveLosses) {
        tradeManager.maxConsecutiveLosses = tradeManager.consecutiveLosses;
    }
    
    // Calculate average metrics
    if(tradeManager.winningTrades > 0) {
        tradeManager.averageWin = tradeManager.totalProfit / NonZero(tradeManager.winningTrades);
    }
    if(tradeManager.losingTrades > 0) {
        tradeManager.averageLoss = tradeManager.totalLoss / NonZero(tradeManager.losingTrades);
    }
    
    // Calculate advanced metrics
    tradeManager.sharpeRatio = CalculateAdvancedSharpeRatio();
    
    // Update system-level metrics
    engine.recentWinRate = tradeManager.winRate;
    engine.recentProfitFactor = tradeManager.profitFactor;
    engine.consecutiveWins = tradeManager.consecutiveWins;
    engine.consecutiveLosses = tradeManager.consecutiveLosses;
    
    tradeManager.lastPerformanceUpdate = TimeCurrent();
}

void CheckTradeRiskLimits() {
    // Daily risk check
    double dailyRisk = CalculateDailyRisk();
    tradeManager.currentDailyRisk = dailyRisk;
    
    if(dailyRisk > tradeManager.maxDailyRisk) {
        tradeManager.emergencyExitActive = true;
        riskMgr.emergencyActive = true;
        
        LogCriticalEvent(StringFormat("DAILY RISK LIMIT EXCEEDED | Current: %.2f%% | Limit: %.2f%%", 
                        dailyRisk, tradeManager.maxDailyRisk), "RISK");
        
        // Emergency close all trades
        for(int i = 0; i < tradeManager.activeTradeCount; i++) {
            if(tradeManager.activeTrades[i].isValid) {
                ExecuteTradeExit(i, "Daily Risk Limit");
            }
        }
    }
    
    // Check for maximum adverse excursion
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        if(tradeManager.activeTrades[i].isValid && tradeManager.activeTrades[i].profit < 0) {
            double adverseExcursion = MathAbs(tradeManager.activeTrades[i].profit) / NonZero(AccountEquity()) * 100.0;
            
            if ((double)adverseExcursion > 3.0) { // 3% maximum adverse excursion
                ExecuteTradeExit(i, "Max Adverse Excursion");
            }
        }
    }
}

double CalculateDailyRisk() {
    datetime todayStart = StrToTime(TimeToString(TimeCurrent(), TIME_DATE));
    double dailyLoss = 0.0;
    
    // Calculate losses from closed trades today
    for(int i = 0; i < OrdersHistoryTotal(); i++) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber && 
               OrderCloseTime() >= todayStart) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                if(profit < 0) dailyLoss += MathAbs(profit);
            }
        }
    }
    
    // Add unrealized losses from active trades
    for(int i = 0; i < tradeManager.activeTradeCount; i++) {
        if(tradeManager.activeTrades[i].isValid && tradeManager.activeTrades[i].profit < 0) {
            dailyLoss += MathAbs(tradeManager.activeTrades[i].profit);
        }
    }
    
    return (dailyLoss / NonZero(AccountEquity())) * 100.0;
}

void ApplyTradeManagementRules() {
    // Update all trade management components in sequence
    SynchronizeActiveTrades();
    UpdateIndividualTrades();
    UpdateTradeManagerPortfolioMetrics();
    UpdateTradePerformanceStatistics();
    CheckTradeRiskLimits();
    
    // Apply emergency protocols if needed
    if(tradeManager.emergencyExitActive && tradeManager.activeTradeCount > 0) {
        LogCriticalEvent("EMERGENCY PROTOCOL ACTIVE - Closing all trades", "EMERGENCY");
        for(int i = 0; i < tradeManager.activeTradeCount; i++) {
            if(tradeManager.activeTrades[i].isValid) {
                ExecuteTradeExit(i, "Emergency Protocol");
            }
        }
    }
}

// MARKET STRUCTURE IMPLEMENTATIONS
void UpdateSupportResistanceLevels() {
    if(Bars < 50) return;
    
    int lookback = MathMin(100, MathMax(0, Bars - 1));
    
    // FIXED: Completely explicit array declaration and initialization
    double high_0 = 0.0, high_1 = 0.0, high_2 = 0.0, high_3 = 0.0, high_4 = 0.0;
    double high_5 = 0.0, high_6 = 0.0, high_7 = 0.0, high_8 = 0.0, high_9 = 0.0;
    double low_0 = 0.0, low_1 = 0.0, low_2 = 0.0, low_3 = 0.0, low_4 = 0.0;
    double low_5 = 0.0, low_6 = 0.0, low_7 = 0.0, low_8 = 0.0, low_9 = 0.0;
    
    double highs[10];
    double lows[10];
    
    // Explicit initialization of all array elements
    highs[0] = 0.0; highs[1] = 0.0; highs[2] = 0.0; highs[3] = 0.0; highs[4] = 0.0;
    highs[5] = 0.0; highs[6] = 0.0; highs[7] = 0.0; highs[8] = 0.0; highs[9] = 0.0;
    lows[0] = 0.0; lows[1] = 0.0; lows[2] = 0.0; lows[3] = 0.0; lows[4] = 0.0;
    lows[5] = 0.0; lows[6] = 0.0; lows[7] = 0.0; lows[8] = 0.0; lows[9] = 0.0;
    
    int highCount = 0, lowCount = 0;
    
    for(int i = 2; i < lookback - 2; i++) {
        double high = iHigh(Symbol(), 0, i);
        double low = iLow(Symbol(), 0, i);
        
        // Check if it's a swing high
        if(high > iHigh(Symbol(), 0, i-1) && high > iHigh(Symbol(), 0, i+1) && 
           high > iHigh(Symbol(), 0, i-2) && high > iHigh(Symbol(), 0, i+2)) {
            if(highCount < 10) {
                highs[highCount] = high;
                highCount++;
            }
        }
        
        // Check if it's a swing low
        if(low < iLow(Symbol(), 0, i-1) && low < iLow(Symbol(), 0, i+1) && 
           low < iLow(Symbol(), 0, i-2) && low < iLow(Symbol(), 0, i+2)) {
            if(lowCount < 10) {
                lows[lowCount] = low;
                lowCount++;
            }
        }
    }
    
    // Find the most significant levels
    if(highCount > 0) {
        // Sort highs in descending order
        for(int i = 0; i < highCount - 1; i++) {
            for(int j = i + 1; j < highCount; j++) {
                if(highs[j] > highs[i]) {
                    double temp = highs[i];
                    highs[i] = highs[j];
                    highs[j] = temp;
                }
            }
        }
        marketStructure.primaryResistance = highs[0];
        if(highCount > 1) marketStructure.secondaryResistance = highs[1];
    }
    
    if(lowCount > 0) {
        // Sort lows in ascending order
        for(int i = 0; i < lowCount - 1; i++) {
            for(int j = i + 1; j < lowCount; j++) {
                if(lows[j] < lows[i]) {
                    double temp = lows[i];
                    lows[i] = lows[j];
                    lows[j] = temp;
                }
            }
        }
        marketStructure.primarySupport = lows[0];
        if(lowCount > 1) marketStructure.secondarySupport = lows[1];
    }
    
    // Calculate dynamic support/resistance using moving averages
    marketStructure.dynamicSupport = iMA(Symbol(), 0, 50, 0, MODE_EMA, PRICE_LOW, 0);
    marketStructure.dynamicResistance = iMA(Symbol(), 0, 50, 0, MODE_EMA, PRICE_HIGH, 0);
}

void UpdateSwingAnalysis() {
    if(Bars < 20) return;
    
    int swingPeriod = 5;
    int maxSwings = 20;
    // SLS21 FIX: highs and lows used to share one write index (swingIndex), so
    // swingHighs[]/swingLows[] landed interleaved instead of paired per-slot --
    // the strength loop below (which requires both arrays >0 at the SAME index)
    // almost never matched, silently zeroing out swing strength/reliability.
    // Two independent indices keep each array densely packed from 0 upward.
    int swingHighIndex = 0;
    int swingLowIndex = 0;

    // Reset swing data
    for(int i = 0; i < maxSwings; i++) {
        marketStructure.swingHighs[i] = 0.0;
        marketStructure.swingLows[i] = 0.0;
        marketStructure.swingHighTimes[i] = 0;
        marketStructure.swingLowTimes[i] = 0;
    }

    // Identify swing points
    for(int i = swingPeriod; i < MathMin(200, Bars) - swingPeriod; i++) {
        if(swingHighIndex >= maxSwings && swingLowIndex >= maxSwings) break;

        double high = iHigh(Symbol(), 0, i);
        double low = iLow(Symbol(), 0, i);
        bool isSwingHigh = true, isSwingLow = true;

        // Check if current bar is higher than surrounding bars
        for(int j = 1; j <= swingPeriod; j++) {
            if(high <= iHigh(Symbol(), 0, i-j) || high <= iHigh(Symbol(), 0, i+j)) {
                isSwingHigh = false;
                break;
            }
        }

        // Check if current bar is lower than surrounding bars
        for(int j = 1; j <= swingPeriod; j++) {
            if(low >= iLow(Symbol(), 0, i-j) || low >= iLow(Symbol(), 0, i+j)) {
                isSwingLow = false;
                break;
            }
        }

        if(isSwingHigh && swingHighIndex < maxSwings) {
            marketStructure.swingHighs[swingHighIndex] = high;
            marketStructure.swingHighTimes[swingHighIndex] = iTime(Symbol(), 0, i);
            swingHighIndex++;
        }

        if(isSwingLow && swingLowIndex < maxSwings) {
            marketStructure.swingLows[swingLowIndex] = low;
            marketStructure.swingLowTimes[swingLowIndex] = iTime(Symbol(), 0, i);
            swingLowIndex++;
        }
    }

    marketStructure.swingCount = MathMax(swingHighIndex, swingLowIndex);
    
    // Calculate swing strength based on the range and volume
    if(marketStructure.swingCount > 0) {
        double totalRange = 0.0;
        for(int i = 0; i < marketStructure.swingCount; i++) {
            if(marketStructure.swingHighs[i] > 0 && marketStructure.swingLows[i] > 0) {
                totalRange += marketStructure.swingHighs[i] - marketStructure.swingLows[i];
            }
        }
        marketStructure.swingStrength = totalRange / NonZero(marketStructure.swingCount);
        marketStructure.swingReliability = MathMin(1.0, marketStructure.swingCount / 10.0);
    }
}

void UpdateTrendAnalysis() {
    if(Bars < 50) return;
    
    // Analyze multiple timeframe trends using moving averages
    double ma20 = iMA(Symbol(), 0, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
    double ma50 = iMA(Symbol(), 0, 50, 0, MODE_EMA, PRICE_CLOSE, 0);
    double ma200 = iMA(Symbol(), 0, 200, 0, MODE_EMA, PRICE_CLOSE, 0);
    double currentPrice = iClose(Symbol(), 0, 0);
    
    // Primary trend (long-term)
    if(currentPrice > ma200 && ma50 > ma200 && ma20 > ma50) {
        marketStructure.primaryTrend = 1.0; // NonZero(Bullish.marketStructure.isBullishTrend)[0] = true;
        marketStructure.isBearishTrend[0] = false;
        marketStructure.isSidewaysTrend[0] = false;
    } else if(currentPrice < ma200 && ma50 < ma200 && ma20 < ma50) {
        marketStructure.primaryTrend = -1.0; // NonZero(Bearish.marketStructure.isBullishTrend)[0] = false;
        marketStructure.isBearishTrend[0] = true;
        marketStructure.isSidewaysTrend[0] = false;
    } else {
        marketStructure.primaryTrend = 0.0; // NonZero(Sideways.marketStructure.isBullishTrend)[0] = false;
        marketStructure.isBearishTrend[0] = false;
        marketStructure.isSidewaysTrend[0] = true;
    }
    
    // Secondary trend (medium-term)
    if(currentPrice > ma50 && ma20 > ma50) {
        marketStructure.secondaryTrend = 1.0;
        marketStructure.isBullishTrend[1] = true;
        marketStructure.isBearishTrend[1] = false;
        marketStructure.isSidewaysTrend[1] = false;
    } else if(currentPrice < ma50 && ma20 < ma50) {
        marketStructure.secondaryTrend = -1.0;
        marketStructure.isBullishTrend[1] = false;
        marketStructure.isBearishTrend[1] = true;
        marketStructure.isSidewaysTrend[1] = false;
    } else {
        marketStructure.secondaryTrend = 0.0;
        marketStructure.isBullishTrend[1] = false;
        marketStructure.isBearishTrend[1] = false;
        marketStructure.isSidewaysTrend[1] = true;
    }
    
    // Tertiary trend (short-term)
    if(currentPrice > ma20) {
        marketStructure.tertiaryTrend = 1.0;
        marketStructure.isBullishTrend[2] = true;
        marketStructure.isBearishTrend[2] = false;
        marketStructure.isSidewaysTrend[2] = false;
    } else if(currentPrice < ma20) {
        marketStructure.tertiaryTrend = -1.0;
        marketStructure.isBullishTrend[2] = false;
        marketStructure.isBearishTrend[2] = true;
        marketStructure.isSidewaysTrend[2] = false;
    } else {
        marketStructure.tertiaryTrend = 0.0;
        marketStructure.isBullishTrend[2] = false;
        marketStructure.isBearishTrend[2] = false;
        marketStructure.isSidewaysTrend[2] = true;
    }
    
    // Calculate trend strengths
    marketStructure.trendStrengths[0] = MathAbs(marketStructure.primaryTrend);
    marketStructure.trendStrengths[1] = MathAbs(marketStructure.secondaryTrend);
    marketStructure.trendStrengths[2] = MathAbs(marketStructure.tertiaryTrend);
    
    // Calculate trend angles (slope of moving averages)
    // WARRANT#7: ATR-normalised denominator (was 5*Point -- illegal absolute, and diverged
    // from the correctly ATR-normalised ema21Angle/ema8Angle calc elsewhere in this file;
    // same underlying quantity should never be computed two different ways -- PARITY class)
    if(Bars > 10) {
        double ma20_prev = iMA(Symbol(), 0, 20, 0, MODE_EMA, PRICE_CLOSE, 5);
        double ma50_prev = iMA(Symbol(), 0, 50, 0, MODE_EMA, PRICE_CLOSE, 5);
        double ma200_prev = iMA(Symbol(), 0, 200, 0, MODE_EMA, PRICE_CLOSE, 5);
        double _atrTA = iATR(Symbol(), 0, 14, 0); if(_atrTA <= 0) _atrTA = Point * 100;

        marketStructure.trendAngles[0] = MathArctan((ma200 - ma200_prev) / (_atrTA * 5)) * 180.0 / NonZero(M_PI);
        marketStructure.trendAngles[1] = MathArctan((ma50 - ma50_prev) / (_atrTA * 5)) * 180.0 / NonZero(M_PI);
        marketStructure.trendAngles[2] = MathArctan((ma20 - ma20_prev) / (_atrTA * 5)) * 180.0 / NonZero(M_PI);
    }
}

void UpdateMovingAverageAnalysis() {
    if(Bars < 200) return;
    
    int maPeriods[10] = {5, 10, 20, 50, 100, 200, 8, 13, 21, 55}; // NonZero(Including.Fibonacci) periods
    double currentPrice = iClose(Symbol(), 0, 0);
    
    marketStructure.maAlignmentBullish = 0;
    marketStructure.maAlignmentBearish = 0;
    
    double _atrMA = iATR(Symbol(), 0, 14, 0); if(_atrMA <= 0) _atrMA = Point * 100; // WARRANT#7b (same defect as trendAngles, this function's own copy)

    for(int i = 0; i < 10; i++) {
        marketStructure.ma[i] = iMA(Symbol(), 0, maPeriods[i], 0, MODE_EMA, PRICE_CLOSE, 0);

        // Calculate MA slopes
        if(Bars > maPeriods[i] + 5) {
            double maPrev = iMA(Symbol(), 0, maPeriods[i], 0, MODE_EMA, PRICE_CLOSE, 5);
            marketStructure.maSlopes[i] = (marketStructure.ma[i] - maPrev) / NonZero(_atrMA * 5);
        }
        
        // Calculate distance from price
        marketStructure.maDistances[i] = (currentPrice - marketStructure.ma[i]) / NonZero(Point);
        
        // Determine bias
        if(currentPrice > marketStructure.ma[i] && marketStructure.maSlopes[i] > 0) {
            marketStructure.maBullish[i] = true;
            marketStructure.maBearish[i] = false;
            marketStructure.maNeutral[i] = false;
            marketStructure.maAlignmentBullish++;
        } else if(currentPrice < marketStructure.ma[i] && marketStructure.maSlopes[i] < 0) {
            marketStructure.maBullish[i] = false;
            marketStructure.maBearish[i] = true;
            marketStructure.maNeutral[i] = false;
            marketStructure.maAlignmentBearish++;
        } else {
            marketStructure.maBullish[i] = false;
            marketStructure.maBearish[i] = false;
            marketStructure.maNeutral[i] = true;
        }
    }
}

void UpdateMarketPhases() {
    // Determine market phase using Wyckoff methodology
    double currentPrice = iClose(Symbol(), 0, 0);
    double volume = (double)iVolume(Symbol(), 0, 0);
    double priceChange = 0.0;
    
    if(Bars > 1) {
        priceChange = currentPrice - iClose(Symbol(), 0, 1);
    }
    
    // Phase determination based on price action and volume
    marketStructure.isAccumulation = false;
    marketStructure.isDistribution = false;
    marketStructure.isMarkup = false;
    marketStructure.isMarkdown = false;
    
    // Analyze recent price and volume patterns
    double avgVolume = intelligence.averageVolume;
    bool highVolume = (volume > avgVolume * 1.5);
    bool lowVolume = (volume < avgVolume * 0.7);
    
    // Accumulation: Low prices, high volume, little price movement
    if(intelligence.rsi < 40 && highVolume && MathAbs(priceChange) < intelligence.atr * 0.3) {
        marketStructure.isAccumulation = true;
        marketStructure.currentPhase = 1;
        marketStructure.phaseStrength = 0.8;
    }
    // Distribution: High prices, high volume, little price movement
    else if(intelligence.rsi > 60 && highVolume && MathAbs(priceChange) < intelligence.atr * 0.3) {
        marketStructure.isDistribution = true;
        marketStructure.currentPhase = 2;
        marketStructure.phaseStrength = 0.8;
    }
    // Markup: Rising prices, increasing volume
    else if(priceChange > 0 && currentPrice > marketStructure.ma[2] && volume > avgVolume) {
        marketStructure.isMarkup = true;
        marketStructure.currentPhase = 3;
        marketStructure.phaseStrength = 0.7;
    }
    // Markdown: Falling prices, increasing volume
    else if(priceChange < 0 && currentPrice < marketStructure.ma[2] && volume > avgVolume) {
        marketStructure.isMarkdown = true;
        marketStructure.currentPhase = 4;
        marketStructure.phaseStrength = 0.7;
    }
    else {
        marketStructure.currentPhase = 0; // NonZero(Undefined.marketStructure.phaseStrength) = 0.3;
    }
    
    // Calculate phase progress (simplified)
    static int phaseStartTime = 0;
    static int lastPhase = 0;
    
    if(marketStructure.currentPhase != lastPhase) {
        phaseStartTime = (int)TimeCurrent();
        lastPhase = marketStructure.currentPhase;
    }
    
    int phaseDuration = (int)TimeCurrent() - phaseStartTime;
    marketStructure.phaseDuration = phaseDuration / 3600.0; // NonZero(Duration.in) hours
    marketStructure.phaseProgress = MathMin(1.0, phaseDuration / 86400.0); // NonZero(Progress.over) 24 hours
}

void UpdateVolumeProfile() {
    if(Bars < 50) return;
    
    int lookback = MathMin(100, Bars);
    
    // SAFETY: Validate indices before using
    int lowestIdx = SafeHL(iLowest(Symbol(), 0, MODE_LOW, lookback, 0));
    int highestIdx = SafeHL(iHighest(Symbol(), 0, MODE_HIGH, lookback, 0));
    
    double priceMin = 0, priceMax = 0;
    if(lowestIdx >= 0 && lowestIdx < Bars) {
        priceMin = iLow(Symbol(), 0, lowestIdx);
    }
    if(highestIdx >= 0 && highestIdx < Bars) {
        priceMax = iHigh(Symbol(), 0, highestIdx);
    }
    
    double priceRange = priceMax - priceMin;
    
    if(priceRange <= 0) return;
    
    // Initialize volume profile array
    for(int i = 0; i < 100; i++) {
        marketStructure.volumeProfile[i] = 0.0;
    }
    
    // Build volume profile
    for(int i = 0; i < lookback; i++) {
        double high = iHigh(Symbol(), 0, i);
        double low = iLow(Symbol(), 0, i);
        double volume = (double)iVolume(Symbol(), 0, i);
        
        // Distribute volume across price levels
        int startLevel = (int)((low - priceMin) / NonZero(priceRange) * 99);
        int endLevel = (int)((high - priceMin) / NonZero(priceRange) * 99);
        
        startLevel = MathMax(0, MathMin(99, startLevel));
        endLevel = MathMax(0, MathMin(99, endLevel));
        
        double volumePerLevel = volume / NonZero(MathMax(1, endLevel - startLevel + 1));
        
        for(int j = startLevel; j <= endLevel; j++) {
            marketStructure.volumeProfile[j] += volumePerLevel;
        }
    }
    
    // Find point of control (highest volume level)
    double maxVolume = 0.0;
    int pocLevel = 0;
    
    for(int i = 0; i < 100; i++) {
        if(marketStructure.volumeProfile[i] > maxVolume) {
            maxVolume = marketStructure.volumeProfile[i];
            pocLevel = i;
        }
    }
    
    marketStructure.pointOfControl = priceMin + (pocLevel / 99.0) * priceRange;
    
    // Calculate value area (70% of volume)
    double totalVolume = 0.0;
    for(int i = 0; i < 100; i++) {
        totalVolume += marketStructure.volumeProfile[i];
    }
    
    double targetVolume = totalVolume * 0.7;
    double accumulatedVolume = marketStructure.volumeProfile[pocLevel];
    int lowerBound = pocLevel, upperBound = pocLevel;
    
    // Expand from POC until we capture 70% of volume
    while(accumulatedVolume < targetVolume && (lowerBound > 0 || upperBound < 99)) {
        double lowerVolume = (lowerBound > 0) ? marketStructure.volumeProfile[lowerBound - 1] : 0.0;
        double upperVolume = (upperBound < 99) ? marketStructure.volumeProfile[upperBound + 1] : 0.0;
        
        if(lowerVolume >= upperVolume && lowerBound > 0) {
            lowerBound--;
            accumulatedVolume += lowerVolume;
        } else if(upperBound < 99) {
            upperBound++;
            accumulatedVolume += upperVolume;
        } else {
            break;
        }
    }
    
    marketStructure.valueAreaLow = priceMin + (lowerBound / 99.0) * priceRange;
    marketStructure.valueAreaHigh = priceMin + (upperBound / 99.0) * priceRange;
}

void UpdateFibonacciLevels() {
    if(Bars < 50) return;
    
    // Find recent significant swing high and low
    int lookback = MathMin(100, Bars);
    
    // SAFETY: Validate indices before using
    int highestIdx = SafeHL(iHighest(Symbol(), 0, MODE_HIGH, lookback, 0));
    int lowestIdx = SafeHL(iLowest(Symbol(), 0, MODE_LOW, lookback, 0));
    
    double swingHigh = 0, swingLow = 0;
    if(highestIdx >= 0 && highestIdx < Bars) {
        swingHigh = iHigh(Symbol(), 0, highestIdx);
    }
    if(lowestIdx >= 0 && lowestIdx < Bars) {
        swingLow = iLow(Symbol(), 0, lowestIdx);
    }
    
    double range = swingHigh - swingLow;
    
    if(range <= 0) return;
    
    // Standard Fibonacci retracement levels
    double fibLevels[13] = {0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0, 1.272, 1.414, 1.618, 2.0, 2.618, 4.236};
    
    // Calculate retracement levels (from high to low)
    for(int i = 0; i < 13; i++) {
        marketStructure.fibonacciLevels[i] = swingHigh - (range * fibLevels[i]);
    }
    
    // Calculate extension levels (beyond the range)
    for(int i = 0; i < 8; i++) {
        marketStructure.fibonacciRetracements[i] = swingLow + (range * fibLevels[i]);
    }
    
    // Determine which levels act as support or resistance
    double currentPrice = iClose(Symbol(), 0, 0);
    
    for(int i = 0; i < 13; i++) {
        double levelPrice = marketStructure.fibonacciLevels[i];
        double distance = MathAbs(currentPrice - levelPrice);
        
        if(distance < intelligence.atr * 0.5) {
            // Price is near this Fibonacci level
            if(currentPrice > levelPrice) {
                marketStructure.fibonacciSupport[i] = true;
                marketStructure.fibonacciResistance[i] = false;
            } else {
                marketStructure.fibonacciSupport[i] = false;
                marketStructure.fibonacciResistance[i] = true;
            }
        } else {
            marketStructure.fibonacciSupport[i] = false;
            marketStructure.fibonacciResistance[i] = false;
        }
    }
    
    // Calculate overall Fibonacci strength based on proximity to key levels
    double minDistance = intelligence.atr * 10.0; // NonZero(Initialize.with) large value
    for(int i = 0; i < 13; i++) {
        double distance = MathAbs(currentPrice - marketStructure.fibonacciLevels[i]);
        if(distance < minDistance) {
            minDistance = distance;
        }
    }
    
    marketStructure.fibonacciStrength = 1.0 - MathMin(1.0, minDistance /NonZero(intelligence.atr));
    marketStructure.fibonacciReliability = (range > intelligence.atr * 5.0) ? 0.8 : 0.4;
}

// COMPLETE PREDICTIVE INTELLIGENCE IMPLEMENTATION
double CalculateEnhancedProbability(bool isBuy) {
    double prob = 0.5;
    
    // RSI probability with velocity consideration
    if(intelligence.rsi > 0 && intelligence.rsi <= 100) {
        if(isBuy) {
            if(intelligence.rsi < 20) prob = 0.92;
            else if(intelligence.rsi < 30) prob = 0.85;
            else if(intelligence.rsi < 40) prob = 0.72;
            else prob = 0.5 - (intelligence.rsi - 50.0) * 0.008;
            
            // Velocity adjustment
            if(intelligence.rsiRate > 0 && intelligence.rsi < 40) prob += 0.1;
        } else {
            if(intelligence.rsi > 80) prob = 0.92;
            else if(intelligence.rsi > 70) prob = 0.85;
            else if(intelligence.rsi > 60) prob = 0.72;
            else prob = 0.5 + (intelligence.rsi - 50.0) * 0.008;
            
            // Velocity adjustment
            if(intelligence.rsiRate < 0 && intelligence.rsi > 60) prob += 0.1;
        }
    }
    
    // MACD probability with acceleration
    // CRITICAL FIX: Reduced thresholds from 0.0005 to 0.0003
    // Typical forex M5: +/-0.0002 (active) to +/-0.0005 (strong)
    // This catches active-to-strong moves (8-10% of time) for high probability
    double macdProb = 0.5;
    if(isBuy) {
        if(intelligence.macdHistogram < -0.0003) macdProb = 0.88;  // Strong bearish = bullish opportunity
        else if(intelligence.macdHistogram < 0) macdProb = 0.75;
        if(intelligence.macdAccel > 0) macdProb += 0.08;
    } else {
        if(intelligence.macdHistogram > 0.0003) macdProb = 0.88;  // Strong bullish = bearish opportunity
        else if(intelligence.macdHistogram > 0) macdProb = 0.75;
        if(intelligence.macdAccel < 0) macdProb += 0.08;
    }
    
    // Multi-timeframe probability
    double mtfProb = 0.5;
    if(intelligence.biasValid) {
        bool mtfAligned = (isBuy && intelligence.mtfBullishStrength > intelligence.mtfBearishStrength) ||
                         (!isBuy && intelligence.mtfBearishStrength > intelligence.mtfBullishStrength);
        if(mtfAligned) {
            mtfProb = 0.5 + intelligence.biasConfidence * 0.4;
        } else {
            mtfProb = 0.5 - intelligence.biasConfidence * 0.3;
        }
    }
    
    // Volume probability
    double volProb = 0.5;
    if(intelligence.volumeRatio > 1.3) {
        bool volumeAligned = (isBuy && intelligence.volumeTrend > 0) ||
                            (!isBuy && intelligence.volumeTrend < 0);
        volProb = volumeAligned ? 0.75 : 0.35;
    }
    
    // Pattern probability
    double patternProb = 0.5;
    if(intelligence.dominantPattern != 0) {
        bool patternAligned = (isBuy && intelligence.dominantPattern > 0) ||
                             (!isBuy && intelligence.dominantPattern < 0);
        if(patternAligned) {
            patternProb = 0.5 + intelligence.patternStrength * intelligence.patternConfidence * 0.4;
        } else {
            patternProb = 0.5 - intelligence.patternStrength * intelligence.patternConfidence * 0.3;
        }
    }
    
    // NEW: Predictive probability enhancement
    double predictiveProb = 0.5;
    if(predictiveSystem.predictionsValid) {
        predictiveProb = CalculatePredictiveScore(isBuy);
    }
    
    // NEW: Outcome validation adjustment
    double validationProb = 0.5;
    if(outcomeValidator.systemCalibrated) {
        int currentRegime = (int)engine.regime;
        if(currentRegime >= 0 && currentRegime < 12) {
            validationProb = outcomeValidator.accuracyByRegime[currentRegime];
        }
    }
    
    // Weighted probability with enhanced intelligence
    double finalProb = prob * 0.25 + macdProb * 0.18 + mtfProb * 0.13 + 
                      volProb * 0.09 + patternProb * 0.07 + predictiveProb * 0.15 + validationProb * 0.13;
    
    return MathMax(0.2, MathMin(0.95, finalProb));
}

// [SLS13 C3] retired dead function AdjustDynamicThresholds (59 lines, zero refs)

ENHANCED_MARKET_REGIME ClassifyEnhancedRegime() {
    // SINGLE SOURCE OF TRUTH with HYSTERESIS

    // Update MTF context (kept for downstream use)
    UpdateComprehensiveMTFContext();

    // Priority override: volatility spike detection
    double atr    = iATR(_Symbol, PERIOD_CURRENT, 14, 0);
    double atr20  = 0;
    for(int k = 1; k <= 20; k++) atr20 += iATR(_Symbol, PERIOD_CURRENT, 14, k);
    atr20 /= 20.0;
    if(atr > atr20 * 2.2) return REGIME_VOLATILITY_SPIKE;

    // Get stable regime from hysteresis-protected classifier
    if(Bars < 50) return REGIME_CONSOLIDATION;
    MarketStateFeatures f = CalculateMarketFeatures(0);
    int r8 = ClassifyBarToRegime_WithHysteresis(f, 0);

    // Refine within regime using ADX + MTF for granular buckets
    double adx = f.adx;
    int mtfDir = g_MTFContext.trendH1;

    switch(r8) {
        case 0:  // Strong Bullish Trend
            if(adx > 38 && mtfDir == 1) return REGIME_ULTRA_BULLISH;
            if(adx > 25)                return REGIME_STRONG_BULLISH;
            return REGIME_BULLISH;

        case 1:  // Strong Bearish Trend
            if(adx > 38 && mtfDir == -1) return REGIME_ULTRA_BEARISH;
            if(adx > 25)                 return REGIME_STRONG_BEARISH;
            return REGIME_BEARISH;

        case 2:  // Bullish Reversal
            return REGIME_NEUTRAL_BULLISH;

        case 3:  // Bearish Reversal
            return REGIME_NEUTRAL_BEARISH;

        case 4:  // Clean Range
            if(intelligence.breakoutProbability > 0.7 &&
               g_MTFContext.alignmentCount >= 2)
                return REGIME_MICRO_BREAKOUT;
            return REGIME_CONSOLIDATION;

        case 5:  // Choppy Tradeable Range
            return REGIME_CONSOLIDATION;

        case 6:  // Pure Noise
            return REGIME_CONSOLIDATION;

        case 7:  // Exhaustion / Distribution
            return (mtfDir >= 0) ? REGIME_NEUTRAL_BEARISH : REGIME_NEUTRAL_BULLISH;

        default:
            return REGIME_CONSOLIDATION;
    }
}

//| Log Comprehensive Signal (ONE line with ALL information)         |

//| Get Current Trading Session                                      |
TradingSession GetCurrentSession() {
    datetime serverTime = TimeCurrent();
    int hour = TimeHour(serverTime);
    
    // SLS21 FIX: Asian was hour<9 and checked first, so hour 8 (documented as London open
    // one line below) always fell through to SESSION_ASIAN and the London check never saw it.
    // Asian Session: 00:00 - 08:00 GMT
    if(hour >= 0 && hour < 8) return SESSION_ASIAN;

    // London Session: 08:00 - 17:00 GMT
    if(hour >= 8 && hour < 17) return SESSION_LONDON;
    
    // NY Session: 13:00 - 22:00 GMT (overlaps with London)
    if(hour >= 13 && hour < 22) {
        // London-NY Overlap: 13:00 - 17:00
        if(hour >= 13 && hour < 17) return SESSION_OVERLAP;
        return SESSION_NEW_YORK;
    }
    
    // Closed/Low activity
    return SESSION_CLOSED;
}

void GenerateHighFrequencySignals() {
    // g_DominantRegimeDecaying: the regime that currently owns the bar
    static double g_DecayThresholdAdj   = 0.0;   // extra threshold added during decay
    static double g_DecayLotSizeFactor  = 1.0;   // lot multiplier during decay

    bool inDecay       = g_DominantRegimeDecaying;
    bool inTransition  = g_RegimeState.inTransition;

    if(inDecay || inTransition) {
        g_DecayThresholdAdj  = 5.0;
        g_DecayLotSizeFactor = 0.80;
    } else {
        g_DecayThresholdAdj  = 0.0;
        g_DecayLotSizeFactor = 1.0;
    }

    // ## BEHAVIORAL COHERENCE GATE #####################################
    if(g_RegimeBehavioralCoherence < 0.36 && g_RegimeMaturityPhase == 2) {
        g_DecayThresholdAdj  = MathMax(g_DecayThresholdAdj, 4.0);
        g_DecayLotSizeFactor = MathMin(g_DecayLotSizeFactor, 0.85);
    }
    // EXHAUSTING phase: systematic caution -- regime structure degrading
    if(g_RegimeMaturityPhase == 3 && !inDecay) {
        g_DecayThresholdAdj  = MathMax(g_DecayThresholdAdj, 3.0);
        g_DecayLotSizeFactor = MathMin(g_DecayLotSizeFactor, 0.88);
    }

    // Hard gate: if both decay AND transition fire simultaneously AND
    // dominant confidence is very low (< 0.40), the market is genuinely
    // between states -- skip entirely until the dust settles.
    if(inDecay && inTransition && g_DominantRegimeStrength < 0.40) {
        static datetime lastDecayLog = 0;
        if(TimeCurrent() - lastDecayLog > 300) {
            // regime in flux: handled by PULSE (was per-tick noise) // PrintFormat("  regime in flux... bar",
            // (silenced: regime in flux log was per-tick noise)
            lastDecayLog = TimeCurrent();
        }
        return;
    }

    // INTELLIGENT SIGNAL GENERATION (Post-Calibration)
    // Uses all learned intelligence: regime weights, probabilities, etc.
    
    // === INTELLIGENT SIGNAL PATH ===========================================
    // Post-calibration: full pipeline with calibrated weights and ProbDB.
    // Pre-calibration: same CEUS+GIS pipeline, equal weights, stricter threshold,
    // Centralised mode guard — exit immediately if any mode blocks trading
    if(!CanTradeNow()) return;

    // SLS22-ERM M2.1: one spread sample per entry-decision evaluation (not
    // every tick) -- this is that evaluation point.
    ERM_RecordEvaluationSample();

    bool _calibDone = (g_Calibration.isComplete && g_WeightsOptimized && g_ProbabilityDatabaseBuilt);
    // SLS18 HIGH2: gate pre-calib trading on ghost arm — invariant 1 (never trade without calibration)
    bool _preCalibOk = (!_calibDone && !g_Calibration.isCalibrating && !g_Calibration.calibrationFailed && g_PRI[6].armedWithBest);
    {
        static bool _preCalibWarnFired = false;
        if(!_calibDone && !g_Calibration.isCalibrating && !g_PRI[6].armedWithBest && !_preCalibWarnFired) {
            TLog("  GATE  ·  pre-calib blocked  ·  ghost not armed  ·  standing down until calibration");
            _preCalibWarnFired = true;
        }
        if(_calibDone) _preCalibWarnFired = false;
    }

    if(_calibDone) ProcessClosedTrades();

    if(_calibDone || _preCalibOk) {
        IntelligentSignal signal = GenerateIntelligentSignal();

        if(_preCalibOk) {
            // Require stronger score conviction before calibration completes
            if(MathAbs(signal.score) < 60.0) signal.valid = false;
            if(signal.valid) signal.confidence = MathMin(signal.confidence, 0.55);
        }

        if(signal.valid) {
            bool   _gisBuy   = (signal.direction == 1);
            double _gisDist  = MathAbs(signal.score) - signal.regimeThreshold;
            bool   _gisTim   = ValidateSignalTiming(_gisBuy);
            bool   _gisOpp   = DetectHighFrequencyOpportunity(_gisBuy);
            bool   _gisGates = ValidateFlexibleGates(_gisBuy, signal.regime,
                                   _gisDist, signal.confidence, _gisTim, _gisOpp);
            // SOM: record every near-miss signal regardless of gate outcome
            {
                double _somATR = iATR(Symbol(), 0, 14, 1);
                double _somPx  = _gisBuy ? Ask : Bid;
                SOM_RecordSignal(signal.score, signal.regimeThreshold, _gisBuy,
                                 signal.regime, _somPx, _somATR, _gisGates);
            }
            // Gate counter: feeds the block-rate monitor in GenerateHighFrequencySignals
            g_GIS_SignalsEvaluated++;
            if(!_gisGates) { g_GIS_GateBlocks++; return; }
            // FIX2: All gates passed — execute
            double decayedConfidence = signal.confidence * g_DecayLotSizeFactor;
            bool success = ExecuteHighFrequencySignal(_gisBuy, decayedConfidence);
            if(success) {
                int ticket = -1;
                for(int i = OrdersTotal() - 1; i >= 0; i--) {
                    if(OrderSelect(i, SELECT_BY_POS) && OrderSymbol() == Symbol() &&
                       OrderMagicNumber() == MagicNumber) {
                        ticket = OrderTicket(); break;
                    }
                }
                if(ticket > 0) TrackLiveTrade(ticket, signal);
            }
            return;
        }
        // Status heartbeat: one compact line every 5 minutes so the operator knows the system is alive
        {
            static datetime _hb = 0;
            if(TimeCurrent() - _hb >= 300) {
                _hb = TimeCurrent();
                int _hbReg = g_RegimeState.currentRegime;
                double _hbWR = g_Risk.recentWinRate;
                double _hbBal = AccountEquity();
                if(EnableFriendlyLogs)
                    PrintFormat("  %s   |   $%.0f   |   %s   |   WR %.0f%%   |   score %.0f   |   thr %.0f",
                                Symbol(), _hbBal, GetRegimeName(_hbReg), _hbWR,
                                MathAbs(CalculateEnhancedUnifiedScore(0)),
                                g_CurrentThreshold);
            }
        }
        if(EnableFriendlyLogs && signal.reasonCode != 0) {
            static datetime lastFallbackLog = 0;
            if(TimeCurrent() - lastFallbackLog > 300) {
                PrintFormat("  signal declined   |  code %d   |  using legacy path", signal.reasonCode);
                lastFallbackLog = TimeCurrent();
            }
        }
    }

    
    if(_calibDone) return;  // FIX3: calibrated path must not fall through to legacy
    // LEGACY SIGNAL GENERATION (Pre-Calibration or Fallback)
    // Used during calibration or when intelligent system declines
    
    // Unified score: 0-100 (50 = neutral)
    // Use dynamic thresholds based on regime
    
    double buyThresh = GetDynamicBuyThreshold();   // e.g., 68 (RANGING), 60 (TRENDING)
    double sellThresh = GetDynamicSellThreshold(); // e.g., 32 (RANGING), 40 (TRENDING)

    // Apply decay adjustment: raise bar when regime is weakening
    buyThresh  += g_DecayThresholdAdj;
    sellThresh -= g_DecayThresholdAdj;

    // Apply slingshot adjustments (threshold tightening + risk context)
    // These are applied to the LEGACY path; intelligent path handles it via GenerateIntelligentSignal
    if(g_Slingshot.isActive) {
        double slThreshold = 0.0, slRisk = 1.0, slTargetR = 1.8;
        ApplySlingshotAdjustments(slThreshold, slRisk, slTargetR);
        buyThresh  += slThreshold;
        sellThresh -= slThreshold;
        // slRisk and slTargetR are consumed by OptimizePrecisionLotSize via g_Slingshot fields
    }
    
    // E8 SCENARIO MATCHING: Override with regime-specific threshold
    static datetime lastScenarioLog = 0;
    bool scenarioUsed = false;
    ScenarioMatch bestScenario;
    
    if(g_Calibration.isComplete) {
        FindBestScenario(bestScenario);
        
        if(bestScenario.found) {
            // HIGH PRIORITY FIX #1: Blend thresholds based on confidence
            double scenarioWeight = bestScenario.confidence;  // 0.60-0.95
            double dynamicWeight = 1.0 - scenarioWeight;
            
            double originalBuy = buyThresh;
            double originalSell = sellThresh;
            
            // Weighted blend: high confidence = more scenario influence
            buyThresh = (buyThresh * dynamicWeight) + (bestScenario.threshold * scenarioWeight);
            sellThresh = (sellThresh * dynamicWeight) + ((100 - bestScenario.threshold) * scenarioWeight);
            
            scenarioUsed = true;
            
            // Log scenario match periodically
            if(TimeCurrent() - lastScenarioLog > 300) {
                lastScenarioLog = TimeCurrent();
                PrintFormat("  P5    |   scenario   %s   |   thr %.0f   |   WR %.0f%%   |   conf %.0f%%",
                    GetRegimeName(bestScenario.regime),
                    bestScenario.threshold, bestScenario.expectedWinRate,
                    bestScenario.confidence * 100);
            }
        }
    }
    
    bool buySignal  = (engine.unifiedScore >= buyThresh);
    bool sellSignal = (engine.unifiedScore <= sellThresh);

    // ## PROBABILITY DATABASE GATE (legacy path) ##########################
    // Mirror the same filter used in GenerateIntelligentSignal so the
    // fallback path respects calibrated pattern quality.
    // Skipped when: DB not built, or pattern has < 5 observations (no data).
    if(g_ProbabilityDatabaseBuilt && (buySignal || sellSignal)) {
        MarketStateFeatures _pf = CalculateMarketFeatures(0);
        int _pr = ClassifyBarToRegime(_pf, 0);
        int _psr = MathMax(0, MathMin(9, (int)(engine.unifiedScore / 10.0)));  // 0-100 -> decile 0-9
        int _pses = DetermineSession(TimeHour(Time[0]));
        int _pvol = DetermineVolatility(_pf.atr);
        MicroPattern _ppat = DetectMicroPatternAt(0);
        ConditionalProbability _pp = QueryProbabilityMatrix(_pr, _psr, _ppat.type, _pses, _pvol);
        if(_pp.observations >= 5) {
            if(_pp.winRate < 0.60 || _pp.expectedValue < 0.20) {
                buySignal  = false;
                sellSignal = false;
            }
        }
    }
    
    // Track original signals for rejection logging
    bool originalSellSignal = sellSignal;
    bool originalBuySignal = buySignal;
    
    // Build rejection reasons for troubleshooting
    string sellRejectReason = "";
    string buyRejectReason = "";
    
    // QUALITY GATE 1: Minimum score distance from threshold
    // Requires score to be at least 0.5 points beyond threshold
    if(sellSignal) {
        double sellDistance = MathAbs(engine.unifiedScore - sellThresh); // Distance from sell threshold
        if(sellDistance < 0.5) {
            sellSignal = false;
            sellRejectReason = StringFormat("Distance %.1f<0.5", sellDistance);
        }
    }
    if(buySignal) {
        double buyDistance = MathAbs(engine.unifiedScore - buyThresh); // Distance from buy threshold
        if(buyDistance < 0.5) {
            buySignal = false;
            buyRejectReason = StringFormat("Distance %.1f<0.5", buyDistance);
        }
    }
    
    // QUALITY GATE 2: ADX strength (LEARNED THRESHOLD)
    if((sellSignal || buySignal) && intelligence.isValid) {
        // Check ADX against learned threshold
        if(intelligence.adx < g_CompOpt.minADXRequired) {
            if(sellSignal) {
                if(StringLen(sellRejectReason) > 0) sellRejectReason += ", ";
                sellRejectReason += StringFormat("ADX %.0f<%.0f", intelligence.adx, g_CompOpt.minADXRequired);
            }
            if(buySignal) {
                if(StringLen(buyRejectReason) > 0) buyRejectReason += ", ";
                buyRejectReason += StringFormat("ADX %.0f<%.0f", intelligence.adx, g_CompOpt.minADXRequired);
            }
            sellSignal = false;
            buySignal = false;
        }
        // Volume check with learned threshold
        if(intelligence.volumeRatio < g_CompOpt.minVolumeRequired) {
            if(sellSignal) {
                if(StringLen(sellRejectReason) > 0) sellRejectReason += ", ";
                sellRejectReason += StringFormat("Vol %.2fx<%.2f", intelligence.volumeRatio, g_CompOpt.minVolumeRequired);
            }
            if(buySignal) {
                if(StringLen(buyRejectReason) > 0) buyRejectReason += ", ";
                buyRejectReason += StringFormat("Vol %.2fx<%.2f", intelligence.volumeRatio, g_CompOpt.minVolumeRequired);
            }
            sellSignal = false;
            buySignal = false;
        }
    }
    
    // QUALITY GATE 3: Component alignment (LEARNED THRESHOLD)
    // 9.14: Uses g_CompOpt.bearishThreshold/bullishThreshold which adapt
    if((sellSignal || buySignal) && g_ComponentScores.isValid) {
        int alignedComponents = 0;
        if(sellSignal) {
            if(g_ComponentScores.momentum < g_CompOpt.bearishThreshold) alignedComponents++;
            if(g_ComponentScores.directional < g_CompOpt.bearishThreshold) alignedComponents++;
            if(g_ComponentScores.predictive < g_CompOpt.bearishThreshold) alignedComponents++;
            if(g_ComponentScores.reversal > g_CompOpt.bullishThreshold) alignedComponents++;
            if(alignedComponents < g_CompOpt.minComponentsAligned) {
                sellSignal = false;
                if(StringLen(sellRejectReason) > 0) sellRejectReason += ", ";
                sellRejectReason += StringFormat("Components %d<%d", alignedComponents, g_CompOpt.minComponentsAligned);
            }
        }
        if(buySignal) {
            alignedComponents = 0;
            if(g_ComponentScores.momentum > g_CompOpt.bullishThreshold) alignedComponents++;
            if(g_ComponentScores.directional > g_CompOpt.bullishThreshold) alignedComponents++;
            if(g_ComponentScores.predictive > g_CompOpt.bullishThreshold) alignedComponents++;
            if(g_ComponentScores.reversal < g_CompOpt.bearishThreshold) alignedComponents++;
            if(alignedComponents < g_CompOpt.minComponentsAligned) {
                buySignal = false;
                if(StringLen(buyRejectReason) > 0) buyRejectReason += ", ";
                buyRejectReason += StringFormat("Components %d<%d", alignedComponents, g_CompOpt.minComponentsAligned);
            }
        }
    }
    
    // QUALITY GATE 4: Multi-Timeframe Alignment (INTELLIGENT)
    // 9.14: Validates MTF alignment with smart counter-trend detection
    if((sellSignal || buySignal) && !g_CompOpt.isOptimizing) {
        if(sellSignal && !ValidateMTFAlignment(-1)) {
            sellSignal = false;
            if(StringLen(sellRejectReason) > 0) sellRejectReason += ", ";
            sellRejectReason += "MTF_MISALIGN";
        }
        if(buySignal && !ValidateMTFAlignment(1)) {
            buySignal = false;
            if(StringLen(buyRejectReason) > 0) buyRejectReason += ", ";
            buyRejectReason += "MTF_MISALIGN";
        }
    }
    
    // Edge threshold checks and rejection logging
    static datetime lastRejectLog = 0;
    if(originalSellSignal && !sellSignal && (TimeCurrent() - lastRejectLog) >= 60) {
        PrintFormat("  sell blocked   |   score %.1f   |   %s", engine.unifiedScore, sellRejectReason);
        lastRejectLog = TimeCurrent();
    }
    if(originalBuySignal && !buySignal && (TimeCurrent() - lastRejectLog) >= 60) {
        PrintFormat("  buy blocked   |   score %.1f   |   %s", engine.unifiedScore, buyRejectReason);
        lastRejectLog = TimeCurrent();
    }
    
    // [FIX-H] Prevent conflicting signals using LOCAL threshold variables (buyThresh/sellThresh)
    // which have already been adjusted for scenario blending and regime decay at this point.
    // engine.buyThreshold / engine.sellThreshold are NOT updated until later in the pipeline
    // and would resolve conflicts against stale (pre-adjustment) threshold values.
    if(sellSignal && buySignal) {
        double sellDistance = MathAbs(engine.unifiedScore - sellThresh);
        double buyDistance  = MathAbs(engine.unifiedScore - buyThresh);
        
        if(sellDistance < buyDistance) buySignal = false;
        else sellSignal = false;
    }
    
    // 9.14: Record all signals for comprehensive learning
    if(!g_CompOpt.isOptimizing) {
        if(buySignal || originalBuySignal) {
            RecordComprehensiveSignal(1, engine.unifiedScore, buySignal, 
                                     buySignal ? "" : buyRejectReason);
            g_Confidence.goodSignalsFound++;
            if(buySignal) g_Confidence.goodSignalsExecuted++;
        }
        if(sellSignal || originalSellSignal) {
            RecordComprehensiveSignal(-1, engine.unifiedScore, sellSignal, 
                                     sellSignal ? "" : sellRejectReason);
            g_Confidence.goodSignalsFound++;
            if(sellSignal) g_Confidence.goodSignalsExecuted++;
        }
    }
    
    // Enhanced signal validation with FLEXIBLE GATES
    if(sellSignal) {
        engine.sellSignalStrength = CalculateSignalStrength(false);
        bool timingPass = ValidateSignalTiming(false);
        bool opportunityPass = DetectHighFrequencyOpportunity(false);
        
        // Calculate score distance for Gate 1
        double scoreDistance = sellThresh - engine.unifiedScore;
        
        // Get current regime from decision engine
        int currentRegime = (int)engine.regime;
        if(currentRegime < 0 || currentRegime >= 12) currentRegime = 0;  // ENHANCED_MARKET_REGIME has 12 values
        
        bool gatesPass = ValidateFlexibleGates(false, currentRegime, scoreDistance,
                                                engine.sellSignalStrength, timingPass, opportunityPass);
        
        if(gatesPass) {
            ExecuteHighFrequencySignal(false, engine.sellSignalStrength);
        }
    }
    
    if(buySignal) {
        engine.buySignalStrength = CalculateSignalStrength(true);
        bool timingPass = ValidateSignalTiming(true);
        bool opportunityPass = DetectHighFrequencyOpportunity(true);
        
        // Calculate score distance for Gate 1
        double scoreDistance = engine.unifiedScore - buyThresh;
        
        // Get current regime from decision engine
        int currentRegime = (int)engine.regime;
        if(currentRegime < 0 || currentRegime >= 12) currentRegime = 0;  // ENHANCED_MARKET_REGIME has 12 values
        
        bool gatesPass = ValidateFlexibleGates(true, currentRegime, scoreDistance,
                                                engine.buySignalStrength, timingPass, opportunityPass);
        
        if(gatesPass) {
            ExecuteHighFrequencySignal(true, engine.buySignalStrength);
        }
    }
}

double CalculateSignalStrength(bool isBuy) {
    
    // REGIME-ADAPTIVE INTELLIGENCE: Apply calibration wisdom
    static bool adaptiveInitialized = false;
    static datetime lastAdaptiveCall = 0;
    
    // Call adaptive intelligence every 5 minutes max (avoid overhead)
    if(!adaptiveInitialized || TimeCurrent() - lastAdaptiveCall >= 300) {
        PrepareRegimeAdaptiveTrade();
        adaptiveInitialized = true;
        lastAdaptiveCall = TimeCurrent();
    }
    
    // Calculate signal strength with regime-adapted parameters
    double strength = 0.5;

    // Probability from score: engine.unifiedScore is 0-100 (50=neutral).
    // For buy: distance above 50 represents conviction. For sell: distance below 50.
    // Normalized to -0.5..+0.5 range, scaled by 0.6.
    double scoreDist = isBuy ? (engine.unifiedScore - 50.0) / 100.0
                             : (50.0 - engine.unifiedScore) / 100.0;
    strength += scoreDist * 0.6;
    
    // Multi-timeframe alignment
    if(intelligence.biasValid) {
        bool aligned = (isBuy && intelligence.mtfBullishStrength > intelligence.mtfBearishStrength) ||
                      (!isBuy && intelligence.mtfBearishStrength > intelligence.mtfBullishStrength);
        if(aligned) strength += intelligence.biasConfidence * 0.3;
    }
    
    // Volume confirmation
    if(intelligence.volumeRatio > 1.4) {
        bool volumeAligned = (isBuy && intelligence.priceVelocity > 0) ||
                            (!isBuy && intelligence.priceVelocity < 0);
        if(volumeAligned) strength += 0.15;
    }
    
    // Pattern confirmation
    if(intelligence.dominantPattern != 0) {
        bool patternAligned = (isBuy && intelligence.dominantPattern > 0) ||
                             (!isBuy && intelligence.dominantPattern < 0);
        if(patternAligned) {
            strength += intelligence.patternStrength * intelligence.patternConfidence * 0.2;
        }
    }
    
    // Regime alignment
    bool regimeAligned = false;
    switch(engine.regime) {
        case REGIME_ULTRA_BULLISH:
        case REGIME_STRONG_BULLISH:
        case REGIME_BULLISH:
            regimeAligned = isBuy; break;
        case REGIME_ULTRA_BEARISH:
        case REGIME_STRONG_BEARISH:
        case REGIME_BEARISH:
            regimeAligned = !isBuy; break;
        case REGIME_MICRO_BREAKOUT:
            regimeAligned = true; break;
    }
    
    if(regimeAligned) strength += 0.1;
    
    return MathMax(0.3, MathMin(1.0, strength));
}

bool ValidateSignalTiming(bool isBuy) {
    // Check spread conditions
    if(intelligence.spreadNormalized > 2.0) {
        static datetime lastSpreadLog = 0;
        if((TimeCurrent() - lastSpreadLog) >= 120) {
            PrintFormat("  SKIP  |   timing   spread wide %.2f   |   waiting", intelligence.spreadNormalized);
            lastSpreadLog = TimeCurrent();
        }
        return false;
    }
    
    // Check liquidity
    if(intelligence.liquidityIndex < 0.5) {
        static datetime lastLiquidityLog = 0;
        if((TimeCurrent() - lastLiquidityLog) >= 120) {
            PrintFormat("  SKIP  |   timing   liquidity low %.2f   |   waiting", intelligence.liquidityIndex);
            lastLiquidityLog = TimeCurrent();
        }
        return false;
    }
    
    // Opposite-signal 100ms gate removed: bar-based new-bar check
    // already prevents same-bar whipsaws on M5+ timeframes.
    
    // Check trading hours (if applicable)
    int hour = TimeHour(TimeCurrent());
    if(hour < 1 || hour > 23) {
        static datetime lastHourLog = 0;
        if((TimeCurrent() - lastHourLog) >= 120) {
            PrintFormat("  SKIP  |   timing   off-hours %02d:00   |   waiting", hour);
            lastHourLog = TimeCurrent();
        }
        return false;
    }
    
    return true;
}

int MapRegimeToGateIndex(int regime) {
    // Map 12 ENHANCED_MARKET_REGIME values to 8 gate configuration indices
    // VOLATILITY_SPIKE=9, MICRO_BREAKOUT=10, UNDEFINED=11
    
    switch(regime) {
        case 0:  // ULTRA_BULLISH
        case 1:  // STRONG_BULLISH  
        case 2:  // BULLISH
            return 0;  // Trending bullish gate config
            
        case 6:  // BEARISH
        case 7:  // STRONG_BEARISH
        case 8:  // ULTRA_BEARISH
            return 1;  // Trending bearish gate config
            
        case 3:  // NEUTRAL_BULLISH
        case 5:  // NEUTRAL_BEARISH
            return 2;  // Ranging gate config
            
        case 9:  // VOLATILITY_SPIKE
            return 3;  // Volatile gate config (strict)
            
        case 4:  // CONSOLIDATION
            return 4;  // Low volatility gate config
            
        case 10: // MICRO_BREAKOUT
            return 5;  // Pre-breakout gate config
            
        case 11: // UNDEFINED
        default:
            return 0;  // Default to trending gate config
    }
}

bool ValidateFlexibleGates(bool isBuy, int currentRegime, double scoreDistance, 
                            double signalStrength, bool timingPass, bool opportunityPass) {
    
    // Gate 1 (Score Distance): ALWAYS REQUIRED
    // Gates 2-4: Need to pass based on regime requirements
    
    // Map 12 ENHANCED_MARKET_REGIME values to 8 gate configurations
    int gateIndex = MapRegimeToGateIndex(currentRegime);
    
    int gatesPassed = 0;
    int totalGates = 4;
    
    // Gate 1: Score Distance (ALWAYS REQUIRED)
    bool gate1_ScoreDistance = false;
    double minDistance = g_CustomGates[gateIndex].initialized ? 
                         g_CustomGates[gateIndex].minScoreDistance : 0.5;
    gate1_ScoreDistance = (scoreDistance >= minDistance);
    
    if(!gate1_ScoreDistance) return false;  // Gate 1 always required
    gatesPassed++;
    
    // Gate 2: Signal Strength (component alignment + market strength)
    bool gate2_Strength = false;
    double strengthThreshold = ENHANCED_SIGNAL_QUALITY_THRESHOLD;
    gate2_Strength = (signalStrength >= strengthThreshold);
    if(gate2_Strength) gatesPassed++;
    
    // Gate 3: Timing (spread, liquidity, hours)
    bool gate3_Timing = timingPass;
    if(gate3_Timing) gatesPassed++;
    
    // Gate 4: Opportunity (market conditions favorable)
    bool gate4_Opportunity = opportunityPass;
    if(gate4_Opportunity) gatesPassed++;
    
    // Check if enough gates passed based on regime requirements
    int requiredGates = g_CustomGates[gateIndex].requiredGates;
    
    bool passesFlexibleGates = (gatesPassed >= requiredGates);
    
    return passesFlexibleGates;
}

void InitializeEnhancedSystem() {
    g_SmartDampen.dampeningFactor = 1.0;  // FIX14: init dampening to neutral
    systemStartTimeMs = GetCurrentMilliseconds();
    currentTickMs = systemStartTimeMs;
    lastTickMs = 0;
    
    // Initialize intelligence system
    intelligence.isValid = false;
    intelligence.isStale = false;
    intelligence.validityMs = 0;
    intelligence.lastUpdateMs = 0;
    intelligence.averageVolume = 1000.0; // NonZero(Default.value)
    
    // Initialize decision engine
    engine.state = DECISION_EVALUATE;
    engine.mode = MODE_BALANCED;
    engine.regime = REGIME_UNDEFINED;
    
    // Initialize threshold system
    // New system uses dynamic thresholds based on regime
    // Unified score: 0-100 (50 = neutral)
    // Score >= buyThreshold = BUY, Score <= sellThreshold = SELL
    g_BaseThreshold = 70.0;  // Default threshold (maps to buy=85, sell=15 via SyncEngineThresholdsFromCurrent)
    g_CurrentThreshold = 70.0;
    
    // Sync legacy threshold variables for backwards compatibility
    engine.buyThreshold = ENHANCED_BUY_THRESHOLD;
    engine.sellThreshold = ENHANCED_SELL_THRESHOLD;
    SyncEngineThresholdsFromCurrent();  // Update from g_CurrentThreshold
    
    engine.unifiedScore = 50.0;  // 0-100 space: 50 = neutral (no directional bias on startup)
    // Shadow learner + compounding phase — zero-init
    ZeroMemory(g_Shadow);
    ZeroMemory(g_Compounding);
    g_Compounding.boostMultiplier = 1.0;
    engine.activeTrades = 0;
    engine.emergencyMode = false;
    engine.lastDecisionMs = 0;
    engine.decisionIntervalMs = ULTRA_FAST_SIGNAL_CHECK;
    engine.portfolioHeat = 0.0;
    engine.forceFirstMSRun = true;  // Ensure first millisecond decision runs immediately
    
    // Initialize risk manager -- seed from user input, not the 1.2% internal constant
    riskMgr.baseRisk    = (RiskPercentPerTrade > 0) ? RiskPercentPerTrade : BASE_RISK_PERCENT;
    riskMgr.currentRisk = riskMgr.baseRisk;
    riskMgr.currentRR   = TARGET_RISK_REWARD_RATIO;
    riskMgr.baseRR      = TARGET_RISK_REWARD_RATIO;
    riskMgr.emergencyActive = false;
    riskMgr.maxConcurrentTrades = HIGH_FREQUENCY_TRADES;
    riskMgr.lastUpdateMs = 0;
    riskMgr.isValid = true;
    riskMgr.portfolioHeat = 0.0;
    riskMgr.conservativeMode = false;
    riskMgr.lossAnalysisScore = 0.0;
    riskMgr.parameterAdjustmentFactor = 1.0;

    // NEW: Initialize Intelligent TP/SL System
    InitializeIntelligentTPSL();
    // NEW: Initialize dynamic risk scaling features
    riskMgr.accountPerformanceMultiplier = 1.0;
    riskMgr.volatilityResponseMultiplier = 1.0;
    riskMgr.correlationLimitAdjustment = 0.0;
    riskMgr.maximumAdverseExcursion = 0.0;
    
    // Initialize optimizer
    optimizer.lightOptActive = false;
    optimizer.deepOptActive = false;
    optimizer.hyperOptActive = false;
    optimizer.realTimeAdaptation = true;
    optimizer.continuousLearning = true;
    optimizer.adaptationRate = 0.1;
    optimizer.learningRate = 0.05;
    optimizer.averagePerformance = 0.0;
    optimizer.successfulOptimizations = 0;
    optimizer.failedOptimizations = 0;
    optimizer.confidenceMultiplier = 1.0;
    optimizer.uncertaintyPenalty = 0.0;
    optimizer.favorableConditionBonus = 0.0;
    optimizer.adverseConditionPenalty = 0.0;
    
    // Initialize Comprehensive Safeguards System
    InitializeCompoundSafeguards();
    
    // Initialize parameter matrix
    for(int i = 0; i < 20; i++) {
        optimizer.parameterMatrix[i] = 1.0;
        optimizer.parameterLocked[i] = false;
        optimizer.lockDuration[i] = 0;
    }
    
    // Initialize enhanced directional bias
    InitializeEnhancedDirectionalBias();
    
    // Initialize pattern analysis
    InitializeComprehensivePatternAnalysis();
    
    // Initialize market structure
    InitializeMarketStructureIntelligence();
    
    // Initialize trade manager
    InitializeAdvancedTradeManager();
    
    // Initialize performance analytics
    InitializePerformanceAnalytics();
    
    // Initialize new intelligent systems
    InitializePredictiveIntelligence();
    InitializeMarketMemorySystem();
    InitializeDynamicStrategyGenerator();
    InitializeEnhancedThresholdIntelligence();
    
    // NEW: Initialize outcome validation framework
    InitializeOutcomeValidationFramework();
    
    // NOTE: systemInitialized is now set by progressive initialization (Phase 8)
    // Do NOT set it here - it will skip phases 2-8
    tradingEnabled = IsTradeAllowed();
    emergencyHalt = false;
    InitializeDynamicRisk();        // Dynamic risk sizing system
    InitializeLivePerformance();    // Live WR/perf tracker
    InitializeMonthlyGoal();        // Monthly compounding targets
    InitializeEnhancementSystems(); // HourlyRecalib struct
    LogCriticalEvent("TUNGSTEN " + EA_VERSION + " A7.5 QUANT " + EA_BUILD_ID + " - Enhanced with Predictive Intelligence + Outcome Validation Initialized", "INIT");
}

