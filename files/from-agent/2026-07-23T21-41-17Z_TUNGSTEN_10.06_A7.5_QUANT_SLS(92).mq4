//+------------------------------------------------------------------+
//| INDICATOR ENSEMBLE (SLS12 FIX65a) — guarded, cached readers for   |
//| the standard + custom MQ4 indicator suite. Each indicator is read |
//| ONCE per closed bar and reduced to a normalized signed reading    |
//| in [-1..+1] (-1 = strong bearish, +1 = strong bullish, 0 = none/  |
//| absent). EVERY read is guarded: if an indicator's .ex4 is not in   |
//| the terminal, iCustom returns EMPTY_VALUE/0 and that slot          |
//| contributes 0 — the EA degrades gracefully and NEVER crashes.      |
//| This module only PRODUCES readings; weighting/scoring is learned   |
//| and applied in later stages. Names match the user's reference.     |
//+------------------------------------------------------------------+
#define IND_COUNT 18
// indices into the ensemble reading array
#define IE_ART     0   // Arc Radius Trend (band direction)
#define IE_ETF     1   // Echelon Trend Filter (step spine)
#define IE_KTF     2   // Kalman Trend Filter (price vs filter)
#define IE_PRL     3   // Parallax Regime Lattice (ribbon align)
#define IE_CAN     4   // Candle Architect (long/short signal)
#define IE_ATM     5   // Aura Trend matrix (cloud + pattern)
#define IE_SQE     6   // Signal Qualification Engine (gate)
#define IE_VRC     7   // Volatility Regime Compass (composite vol ratio - 1.0; magnitude signal, not directional)
#define IE_SPG     8   // Session Probability Grid (VWAP side)
#define IE_MACD    9   // MACD histogram
#define IE_RSI    10   // RSI (centered)
#define IE_STOCH  11   // Stochastic
#define IE_CCI    12   // CCI
#define IE_AO     13   // Awesome Oscillator
#define IE_AC     14   // Accelerator
#define IE_SAR    15   // Parabolic SAR (price vs SAR)
#define IE_ALLIG  16   // Alligator (price vs teeth)
#define IE_ICHI   17   // Ichimoku (price vs cloud)

struct IndicatorEnsemble {
    double  reading[IND_COUNT];   // normalized signed value [-1..+1] per indicator
    bool    present[IND_COUNT];   // did this indicator return usable data?
    int     availableCount;       // how many indicators are live this bar
    double  confluenceRaw;        // mean of present readings [-1..+1] (pre-weight)
    datetime barTime;             // bar this snapshot was computed for (cache key)
    bool    valid;                // has this been populated at least once?
};
IndicatorEnsemble g_IE;

// ===== INDICATOR INTELLIGENCE STORAGE (SLS12 FIX65b) =====
// Everything the new "Indicator Intelligence" phase learns about the 18-indicator
// ensemble. Populated during calibration (train bars only), consumed by the unified
// score and live gates. All measurement; safe defaults so absent data never breaks live.
double  g_IndDirIC[IND_COUNT];              // directional IC: does reading predict up/down?
double  g_IndAmpIC[IND_COUNT];             // amplitude IC: does |reading| predict move SIZE?
double  g_IndDirIC_Regime[9][IND_COUNT];   // directional IC conditioned per regime
double  g_IndLoRange[IND_COUNT];           // p10 of reading (typical low)
double  g_IndHiRange[IND_COUNT];           // p90 of reading (typical high)
double  g_IndBullThresh[IND_COUNT];        // reading level above which forward bias is up
double  g_IndBearThresh[IND_COUNT];        // reading level below which forward bias is down
double  g_IndPairWR[IND_COUNT][IND_COUNT]; // win-rate when indicators i & j agree on dir
int     g_IndPairN[IND_COUNT][IND_COUNT];  // samples per pair (confidence)
int     g_IndPairBestA = -1, g_IndPairBestB = -1;
double  g_IndPairBestWR = 0.0;
double  g_IndWeight[IND_COUNT];            // synthesized learned weight (consumed by score)
bool    g_IndIntelReady = false;           // did the phase complete with usable data?
// ===== CONDITIONAL RULE TABLE (SLS12 T3) — x±y±z / outlier-attribution learning =====
// A strong "primary" indicator usually predicts direction, but its rule sometimes BREAKS.
// This learns WHICH OTHER indicator (the "conditioner") explains the break: when the primary
// fires but the conditioner OPPOSES its direction, the primary becomes unreliable. Stored as
// relative rules so they hold for both buy and sell. Consumed live by damping the primary's
// contribution when its conditioner is in the break state.
struct IndicatorRule {
    int    primary;        // indicator making the base directional claim
    int    conditioner;    // the indicator whose opposition breaks the rule (the outlier)
    double baseWR;         // primary's win-rate when it fires (alone)
    double opposeWR;       // primary's win-rate WHEN conditioner opposes its direction
    double lift;           // baseWR - opposeWR (how much the break costs)
    int    samples;        // opposing-state sample count (confidence)
    bool   active;
};
#define MAX_IND_RULES 14
IndicatorRule g_IndRules[MAX_IND_RULES];
int  g_IndRuleCount = 0;

// ===== SLS13 R2-T: TRIPLE-CONFLUENCE EXTENSION =====
// When primary P fires and aligner A agrees, WR is elevated above P alone. But when
// breaker B opposes even that P+A alignment, WR collapses further — the hidden
// invalidator. Captures x+y-z structures that pair-rules miss:
// "ART fires, VRC agrees (great) — but when SPG opposes BOTH, the setup fails 70%+."
struct IndicatorTriple {
    int    primary;     // base indicator (x)
    int    aligner;     // agrees with primary, elevating the baseline WR (y)
    int    breaker;     // opposes even the aligned pair — the hidden invalidator (-z)
    double alignWR;     // WR when primary+aligner both agree (elevated baseline)
    double tripleWR;    // WR when primary+aligner agree but breaker opposes
    double lift;        // alignWR - tripleWR (magnitude of invalidation)
    int    samples;     // triple-opposition sample count
    bool   active;
};
#define MAX_IND_TRIPLES 10
#define TRIPLE_TOP_K     6
IndicatorTriple g_IndTriples[MAX_IND_TRIPLES];
int g_IndTripleCount = 0;
// Calibration accumulators for triple learning — global to avoid large 3-D stack arrays.
// Indexed [top-primary-slot][aligner][breaker]. Zeroed at start of triple learning stage.
double g_TA_pAW[TRIPLE_TOP_K][IND_COUNT];
int    g_TA_pAN[TRIPLE_TOP_K][IND_COUNT];
double g_TA_pABW[TRIPLE_TOP_K][IND_COUNT][IND_COUNT];
int    g_TA_pABN[TRIPLE_TOP_K][IND_COUNT][IND_COUNT];
int    g_TA_TopP[TRIPLE_TOP_K];

string  IE_Name(int idx) {
    switch(idx){
        case IE_ART:return "ART"; case IE_ETF:return "ETF"; case IE_KTF:return "KTF";
        case IE_PRL:return "PRL"; case IE_CAN:return "CAN"; case IE_ATM:return "ATM";
        case IE_SQE:return "SQE"; case IE_VRC:return "VRC"; case IE_SPG:return "SPG";
        case IE_MACD:return "MACD"; case IE_RSI:return "RSI"; case IE_STOCH:return "Stoch";
        case IE_CCI:return "CCI"; case IE_AO:return "AO"; case IE_AC:return "AC";
        case IE_SAR:return "SAR"; case IE_ALLIG:return "Alligator"; case IE_ICHI:return "Ichimoku";
    }
    return "?";
}

// Helper: clamp to [-1,1]
double IE_Clamp(double v) { return MathMax(-1.0, MathMin(1.0, v)); }

// Helper: is an iCustom return usable (not EMPTY_VALUE, not the sentinel)?
bool IE_OK(double v) { return (v != EMPTY_VALUE && v < 2147483646.0 && v > -2147483646.0 && MathAbs(v) < 1e15); }

// Read one custom-indicator buffer with full guarding. Returns EMPTY_VALUE on any issue.
// Custom indicators are read by file name; if absent, iCustom yields EMPTY_VALUE and we skip.
double IE_ReadArrowDir(string name, int bullBuf, int bearBuf, int shift) {
    // For DRAW_ARROW signal pairs: +1 if bull arrow present, -1 if bear, 0 otherwise.
    double bull = iCustom(NULL, 0, name, bullBuf, shift);
    double bear = iCustom(NULL, 0, name, bearBuf, shift);
    bool b = IE_OK(bull), s = IE_OK(bear);
    if(b && !s) return 1.0;
    if(s && !b) return -1.0;
    return 0.0;
}

// WARRANT#21 (forge polish pass, 2026-07-11): SPG's session-probability window was a single
// hardcoded "0930-1600" (a NY-desk-hours-shaped string, server time) fed to every symbol
// including USDJPY -- yet JPY/AUD/NZD crosses live in the Asia session, per this project's
// own doctrine (EDGE_DOCTRINE / SS-IX.3, "session maps weighted by realised activity"). Broker
// server-time GMT offset empirically confirmed GMT+3 this session (broker clock consistently
// 1h00m ahead of local SAST/GMT+2, observed twice tonight: 21:59->22:59 and 22:03->23:04, both
// stable -- not re-verified live here since the market is closed and no fresh TimeCurrent()
// sample is possible; if that offset ever drifts, e.g. a DST change, this window drifts with
// it and should be re-derived). Standard Asia/Tokyo FX session is 00:00-09:00 GMT ->
// 03:00-12:00 at GMT+3 server time. Scope: only JPY/AUD/NZD-quoted symbols get the Asia
// window; every other symbol keeps the existing "0930-1600" unchanged -- zero regression risk
// to whatever majors this project has already been tuned/tested against.
string SPG_SessionWindow() {
    string sym = Symbol();
    if(StringFind(sym,"JPY")>=0 || StringFind(sym,"AUD")>=0 || StringFind(sym,"NZD")>=0)
        return "0300-1200";  // Asia/Tokyo session, GMT 00:00-09:00, converted at broker GMT+3
    return "0930-1600";      // unchanged default for other majors/crosses
}

// Populate the ensemble for the last closed bar. Cached per bar (cheap re-entry).
// Uses default indicator parameters from the integration reference. All guarded.
void IE_Update() {
    datetime bt = Time[0];
    if(g_IE.valid && g_IE.barTime == bt) return;   // already computed this bar
    g_IE.barTime = bt;
    for(int i=0;i<IND_COUNT;i++){ g_IE.reading[i]=0.0; g_IE.present[i]=false; }

    double c1 = Close[1];
    double atr = iATR(NULL, 0, 14, 1); if(atr <= 0) atr = Point*100;

    // ---- CUSTOM SUITE (read by file name; absent -> EMPTY_VALUE -> slot stays 0/false) ----
    // ART: price vs active band + slope; buf5=outer-distance [-1,+1] blended (FIX24)
    {
        double band  = iCustom(NULL,0,"ART_ArcRadiusTrend",21,2.4,8,1.35,1.65,true,0,1);
        double bandP = iCustom(NULL,0,"ART_ArcRadiusTrend",21,2.4,8,1.35,1.65,true,0,2);
        double artOD = iCustom(NULL,0,"ART_ArcRadiusTrend",21,2.4,8,1.35,1.65,true,5,1);
        if(IE_OK(band)&&IE_OK(bandP)){
            double d=(c1-band)/atr+(band-bandP)/atr;
            if(IE_OK(artOD)) d=d*0.6+artOD*0.4;
            g_IE.reading[IE_ART]=IE_Clamp(d); g_IE.present[IE_ART]=true; }
    }
    // ETF: buf3=filter velocity [-1,+1] continuous; spine presence as fallback (FIX24)
    {
        double sb  = iCustom(NULL,0,"ETF_EchelonTrendFilter",12,200,10,60,true,true,true,0,1);
        double sbe = iCustom(NULL,0,"ETF_EchelonTrendFilter",12,200,10,60,true,true,true,1,1);
        double vel = iCustom(NULL,0,"ETF_EchelonTrendFilter",12,200,10,60,true,true,true,3,1);
        bool spineOK = IE_OK(sb)||IE_OK(sbe);
        if(spineOK){
            if(IE_OK(vel)){ g_IE.reading[IE_ETF]=IE_Clamp(vel); g_IE.present[IE_ETF]=true; }
            else{ g_IE.reading[IE_ETF]=(IE_OK(sb)&&!IE_OK(sbe))?1.0:((IE_OK(sbe)&&!IE_OK(sb))?-1.0:0.0); g_IE.present[IE_ETF]=true; } }
    }
    // KTF: price vs Kalman + velocity; buf5=variance trust-weight (InpR=0.5) (FIX24)
    {
        double kf    = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,0,1);
        double kfp   = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,0,2);
        double kfVar = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,5,1);
        if(IE_OK(kf)&&IE_OK(kfp)){
            double d=(c1-kf)/atr+(kf-kfp)/atr*2.0;
            double trust=IE_OK(kfVar)?MathMax(0.0,MathMin(1.0,1.0-kfVar/2.0)):0.5;
            g_IE.reading[IE_KTF]=IE_Clamp(d*(0.5+trust*0.5)); g_IE.present[IE_KTF]=true; }
    }
    // PRL: BiasScore buf8 [-1,+1] primary (70%); ribbon alignment fallback (ADXFloor=20) (FIX24)
    {
        double f   =iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,0,1);
        double m   =iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,1,1);
        double s   =iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,2,1);
        double bias=iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,8,1);
        if(IE_OK(f)&&IE_OK(m)&&IE_OK(s)){
            double d=0; if(f>m&&m>s)d=1.0; else if(f<m&&m<s)d=-1.0; else d=(f-s)/atr*0.5;
            if(IE_OK(bias)) d=d*0.3+bias*0.7;
            g_IE.reading[IE_PRL]=IE_Clamp(d); g_IE.present[IE_PRL]=true; }
    }
    // CAN: SigScore×dir buf5 [-1,+1] continuous (cooldown=8) (FIX24)
    {
        double fe  =iCustom(NULL,0,"CAN_CandleArchitectSignals",21,55,90,14,14,4,4,1.0,82,8,true,true,true,0.55,1.0,1.45,2.5,20,true,40,0,1);
        double sigS=iCustom(NULL,0,"CAN_CandleArchitectSignals",21,55,90,14,14,4,4,1.0,82,8,true,true,true,0.55,1.0,1.45,2.5,20,true,40,5,1);
        if(IE_OK(fe)){ g_IE.reading[IE_CAN]=IE_OK(sigS)?IE_Clamp(sigS):0.0; g_IE.present[IE_CAN]=true; }
    }
    // ATM: CloudStrength buf6 (fast-slow)/ATR [-1,+1] primary; arrow blend fallback (FIX24)
    {
        double fe=iCustom(NULL,0,"ATM_AuraTrendCandlestickMatrix",20,50,true,true,true,true,10,0,1);
        double se=iCustom(NULL,0,"ATM_AuraTrendCandlestickMatrix",20,50,true,true,true,true,10,1,1);
        double cs=iCustom(NULL,0,"ATM_AuraTrendCandlestickMatrix",20,50,true,true,true,true,10,6,1);
        if(IE_OK(fe)&&IE_OK(se)){
            double cloud=(fe>se)?0.5:((fe<se)?-0.5:0.0);
            double sig=IE_ReadArrowDir("ATM_AuraTrendCandlestickMatrix",4,5,1);
            double d=IE_OK(cs)?IE_Clamp(cs):IE_Clamp(cloud+sig*0.5);  // SLS18 MEDIUM1: clamp cs path
            g_IE.reading[IE_ATM]=d; g_IE.present[IE_ATM]=true; }
    }
    // SQE: CompositeScore buf6 (bull-bear)/10 [-1,+1] (InpMinScore=5); arrow fallback (FIX24)
    {
        double fe  =iCustom(NULL,0,"SQE_SignalQualificationEngine",21,55,14,20.0,14,70.0,30.0,14,3,20,1.2,true,5,2,true,5,5,true,1.5,false,9,16,true,0,1);
        double cmpS=iCustom(NULL,0,"SQE_SignalQualificationEngine",21,55,14,20.0,14,70.0,30.0,14,3,20,1.2,true,5,2,true,5,5,true,1.5,false,9,16,true,6,1);
        if(IE_OK(fe)){
            if(IE_OK(cmpS)){ g_IE.reading[IE_SQE]=IE_Clamp(cmpS); g_IE.present[IE_SQE]=true; }
            else{ double std_=IE_ReadArrowDir("SQE_SignalQualificationEngine",2,3,1);
                  double prem=IE_ReadArrowDir("SQE_SignalQualificationEngine",4,5,1);
                  g_IE.reading[IE_SQE]=IE_Clamp(std_*0.6+prem*0.4); g_IE.present[IE_SQE]=true; } }
    }
    // VRC: DIRECTIONLESS — discrete regime buf4 (-1/0/+1/+2); ATR-MA=100, Smooth=5 (FIX24)
    // WARRANT#19: buf1 (composite vol ratio, self-baseline relative, ~1.0=normal) was computed
    // but never read -- reading was hardcoded to 0.0, a dead channel in both IC stages. Now
    // exposes (composite-1.0) as a real magnitude signal. Sign is expansion(+)/compression(-),
    // NOT a directional claim -- the IC pipeline measures whether it predicts anything at all.
    {
        double regSt=iCustom(NULL,0,"VRC_VolatilityRegimeCompass",14,100,20,100,20,2.0,5,0.65,1.35,2.0,true,true,4,1);
        double compR=iCustom(NULL,0,"VRC_VolatilityRegimeCompass",14,100,20,100,20,2.0,5,0.65,1.35,2.0,true,true,1,1);
        if(IE_OK(regSt)){
            g_IE.reading[IE_VRC]=IE_OK(compR)?IE_Clamp(compR-1.0):0.0;
            g_IE.present[IE_VRC]=true; }
    }
    // SPG: price vs VWAP buf1, gated by InSession buf4 (FIX24)
    {
        double vwap  =iCustom(NULL,0,"SPG_SessionProbabilityGrid",SPG_SessionWindow(),6,250,true,true,true,0.25,0.5,0.75,1.0,1.25,1.5,true,24,0.48,true,1,1);
        double inSess=iCustom(NULL,0,"SPG_SessionProbabilityGrid",SPG_SessionWindow(),6,250,true,true,true,0.25,0.5,0.75,1.0,1.25,1.5,true,24,0.48,true,4,1);
        bool sessOK=IE_OK(inSess)&&inSess>0.5;
        if(IE_OK(vwap)&&vwap>0.0&&sessOK){ double d=(c1-vwap)/atr; g_IE.reading[IE_SPG]=IE_Clamp(d); g_IE.present[IE_SPG]=true; }
    }

    // ---- STANDARD INDICATORS (built-in iMACD/iRSI/etc — always available) ----
    { double h=iMACD(NULL,0,12,26,9,PRICE_CLOSE,MODE_MAIN,1)-iMACD(NULL,0,12,26,9,PRICE_CLOSE,MODE_SIGNAL,1);
      g_IE.reading[IE_MACD]=IE_Clamp(h/(atr*0.5)); g_IE.present[IE_MACD]=true; }
    { double r=iRSI(NULL,0,14,PRICE_CLOSE,1); g_IE.reading[IE_RSI]=IE_Clamp((r-50.0)/30.0); g_IE.present[IE_RSI]=true; }
    { double k=iStochastic(NULL,0,5,3,3,MODE_SMA,0,MODE_MAIN,1); g_IE.reading[IE_STOCH]=IE_Clamp((k-50.0)/40.0); g_IE.present[IE_STOCH]=true; }
    { double cc=iCCI(NULL,0,14,PRICE_TYPICAL,1); g_IE.reading[IE_CCI]=IE_Clamp(cc/150.0); g_IE.present[IE_CCI]=true; }
    { double ao=iAO(NULL,0,1); g_IE.reading[IE_AO]=IE_Clamp(ao/(atr*0.5)); g_IE.present[IE_AO]=true; }
    { double ac=iAC(NULL,0,1); g_IE.reading[IE_AC]=IE_Clamp(ac/(atr*0.5)); g_IE.present[IE_AC]=true; }
    { double sar=iSAR(NULL,0,0.02,0.2,1); if(IE_OK(sar)){ g_IE.reading[IE_SAR]=(c1>sar)?1.0:-1.0; g_IE.present[IE_SAR]=true; } }
    { double te=iAlligator(NULL,0,13,8,8,5,5,3,MODE_SMMA,PRICE_MEDIAN,MODE_GATORTEETH,1);
      if(IE_OK(te)&&te>0){ g_IE.reading[IE_ALLIG]=IE_Clamp((c1-te)/atr); g_IE.present[IE_ALLIG]=true; } }
    { double spanA=iIchimoku(NULL,0,9,26,52,MODE_SENKOUSPANA,1); double spanB=iIchimoku(NULL,0,9,26,52,MODE_SENKOUSPANB,1);
      if(IE_OK(spanA)&&IE_OK(spanB)){ double top=MathMax(spanA,spanB),bot=MathMin(spanA,spanB);
        double d=(c1>top)?1.0:((c1<bot)?-1.0:0.0); g_IE.reading[IE_ICHI]=d; g_IE.present[IE_ICHI]=true; } }

    // aggregate
    int n=0; double sum=0;
    for(int i=0;i<IND_COUNT;i++){ if(g_IE.present[i]){ n++; sum+=g_IE.reading[i]; } }
    g_IE.availableCount = n;
    g_IE.confluenceRaw  = (n>0) ? sum/n : 0.0;
    g_IE.valid = true;
}

// Historical-bar ensemble reader (SLS12 FIX65b). Fills out[] with each indicator's
// normalized signed reading [-1..+1] for an arbitrary bar `sh` (shift). Same logic and
// guards as IE_Update but parameterized by shift, so calibration can mine any history bar.
// present[] flags which indicators returned usable data. Never crashes on absent indicators.
void IE_ReadAtBar(int sh, double &out[], bool &present[]) {
    for(int i=0;i<IND_COUNT;i++){ out[i]=0.0; present[i]=false; }
    if(sh < 1 || sh >= Bars-1) return;
    double c1 = Close[sh];
    double atr = iATR(NULL,0,14,sh); if(atr <= 0) atr = Point*100;

    // CUSTOM SUITE (FIX24: new intelligence buffers + updated params)
    {   // ART: band+slope (60%) + outer-distance buf5 (40%)
        double band  = iCustom(NULL,0,"ART_ArcRadiusTrend",21,2.4,8,1.35,1.65,true,0,sh);
        double bandP = iCustom(NULL,0,"ART_ArcRadiusTrend",21,2.4,8,1.35,1.65,true,0,sh+1);
        double artOD = iCustom(NULL,0,"ART_ArcRadiusTrend",21,2.4,8,1.35,1.65,true,5,sh);
        if(IE_OK(band)&&IE_OK(bandP)){ double d=(c1-band)/atr+(band-bandP)/atr;
            if(IE_OK(artOD)) d=d*0.6+artOD*0.4;
            out[IE_ART]=IE_Clamp(d); present[IE_ART]=true; }
    }
    {   // ETF: filter velocity buf3 continuous; spine presence fallback
        double sb  = iCustom(NULL,0,"ETF_EchelonTrendFilter",12,200,10,60,true,true,true,0,sh);
        double sbe = iCustom(NULL,0,"ETF_EchelonTrendFilter",12,200,10,60,true,true,true,1,sh);
        double vel = iCustom(NULL,0,"ETF_EchelonTrendFilter",12,200,10,60,true,true,true,3,sh);
        bool spineOK = IE_OK(sb)||IE_OK(sbe);
        if(spineOK){
            if(IE_OK(vel)){ out[IE_ETF]=IE_Clamp(vel); present[IE_ETF]=true; }
            else{ out[IE_ETF]=(IE_OK(sb)&&!IE_OK(sbe))?1.0:((IE_OK(sbe)&&!IE_OK(sb))?-1.0:0.0); present[IE_ETF]=true; } }
    }
    {   // KTF: d weighted by variance trust (buf5, InpR=0.5)
        double kf    = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,0,sh);
        double kfp   = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,0,sh+1);
        double kfVar = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,5,sh);
        if(IE_OK(kf)&&IE_OK(kfp)){ double d=(c1-kf)/atr+(kf-kfp)/atr*2.0;
            double trust=IE_OK(kfVar)?MathMax(0.0,MathMin(1.0,1.0-kfVar/2.0)):0.5;
            out[IE_KTF]=IE_Clamp(d*(0.5+trust*0.5)); present[IE_KTF]=true; }
    }
    {   // PRL: BiasScore buf8 (70%) + ribbon alignment (30%); ADXFloor=20
        double f   =iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,0,sh);
        double m   =iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,1,sh);
        double s   =iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,2,sh);
        double bias=iCustom(NULL,0,"PRL_ParallaxRegimeLattice",21,55,144,14,1.35,5,0.18,10,6,35,14,20.0,14,61.8,34,0.78,true,true,true,false,true,10,8,sh);
        if(IE_OK(f)&&IE_OK(m)&&IE_OK(s)){ double d=0; if(f>m&&m>s)d=1.0; else if(f<m&&m<s)d=-1.0; else d=(f-s)/atr*0.5;
            if(IE_OK(bias)) d=d*0.3+bias*0.7;
            out[IE_PRL]=IE_Clamp(d); present[IE_PRL]=true; }
    }
    {   // CAN: SigScore×dir buf5 continuous (cooldown=8)
        double fe  =iCustom(NULL,0,"CAN_CandleArchitectSignals",21,55,90,14,14,4,4,1.0,82,8,true,true,true,0.55,1.0,1.45,2.5,20,true,40,0,sh);
        double sigS=iCustom(NULL,0,"CAN_CandleArchitectSignals",21,55,90,14,14,4,4,1.0,82,8,true,true,true,0.55,1.0,1.45,2.5,20,true,40,5,sh);
        if(IE_OK(fe)){ out[IE_CAN]=IE_OK(sigS)?IE_Clamp(sigS):0.0; present[IE_CAN]=true; }
    }
    {   // ATM: CloudStrength buf6 primary; arrow+cloud blend fallback
        double fe=iCustom(NULL,0,"ATM_AuraTrendCandlestickMatrix",20,50,true,true,true,true,10,0,sh);
        double se=iCustom(NULL,0,"ATM_AuraTrendCandlestickMatrix",20,50,true,true,true,true,10,1,sh);
        double cs=iCustom(NULL,0,"ATM_AuraTrendCandlestickMatrix",20,50,true,true,true,true,10,6,sh);
        if(IE_OK(fe)&&IE_OK(se)){
            double cloud=(fe>se)?0.5:((fe<se)?-0.5:0.0);
            double sig=IE_ReadArrowDir("ATM_AuraTrendCandlestickMatrix",4,5,sh);
            double d=IE_OK(cs)?IE_Clamp(cs):IE_Clamp(cloud+sig*0.5);  // SLS18 MEDIUM1: clamp cs path
            out[IE_ATM]=d; present[IE_ATM]=true; }
    }
    {   // SQE: CompositeScore buf6 primary (InpMinScore=5); arrow fallback
        double fe  =iCustom(NULL,0,"SQE_SignalQualificationEngine",21,55,14,20.0,14,70.0,30.0,14,3,20,1.2,true,5,2,true,5,5,true,1.5,false,9,16,true,0,sh);
        double cmpS=iCustom(NULL,0,"SQE_SignalQualificationEngine",21,55,14,20.0,14,70.0,30.0,14,3,20,1.2,true,5,2,true,5,5,true,1.5,false,9,16,true,6,sh);
        if(IE_OK(fe)){
            if(IE_OK(cmpS)){ out[IE_SQE]=IE_Clamp(cmpS); present[IE_SQE]=true; }
            else{ double std_=IE_ReadArrowDir("SQE_SignalQualificationEngine",2,3,sh);
                  double prem=IE_ReadArrowDir("SQE_SignalQualificationEngine",4,5,sh);
                  out[IE_SQE]=IE_Clamp(std_*0.6+prem*0.4); present[IE_SQE]=true; } }
    }
    {   // VRC: DIRECTIONLESS — discrete regime buf4; ATR-MA=100, Smooth=5
        // WARRANT#19: mirrors the live-path fix above -- buf1 composite ratio was computed but
        // never read here either (Parity Invariant: this must match the live block exactly).
        double regSt=iCustom(NULL,0,"VRC_VolatilityRegimeCompass",14,100,20,100,20,2.0,5,0.65,1.35,2.0,true,true,4,sh);
        double compR=iCustom(NULL,0,"VRC_VolatilityRegimeCompass",14,100,20,100,20,2.0,5,0.65,1.35,2.0,true,true,1,sh);
        if(IE_OK(regSt)){
            out[IE_VRC]=IE_OK(compR)?IE_Clamp(compR-1.0):0.0;
            present[IE_VRC]=true; }
    }
    {   // SPG: price vs VWAP buf1, gated by InSession buf4
        double vwap  =iCustom(NULL,0,"SPG_SessionProbabilityGrid",SPG_SessionWindow(),6,250,true,true,true,0.25,0.5,0.75,1.0,1.25,1.5,true,24,0.48,true,1,sh);
        double inSess=iCustom(NULL,0,"SPG_SessionProbabilityGrid",SPG_SessionWindow(),6,250,true,true,true,0.25,0.5,0.75,1.0,1.25,1.5,true,24,0.48,true,4,sh);
        bool sessOK=IE_OK(inSess)&&inSess>0.5;
        if(IE_OK(vwap)&&vwap>0.0&&sessOK){ out[IE_SPG]=IE_Clamp((c1-vwap)/atr); present[IE_SPG]=true; }
    }

    // STANDARD
    { double h=iMACD(NULL,0,12,26,9,PRICE_CLOSE,MODE_MAIN,sh)-iMACD(NULL,0,12,26,9,PRICE_CLOSE,MODE_SIGNAL,sh);
      out[IE_MACD]=IE_Clamp(h/(atr*0.5)); present[IE_MACD]=true; }
    { double r=iRSI(NULL,0,14,PRICE_CLOSE,sh); out[IE_RSI]=IE_Clamp((r-50.0)/30.0); present[IE_RSI]=true; }
    { double k=iStochastic(NULL,0,5,3,3,MODE_SMA,0,MODE_MAIN,sh); out[IE_STOCH]=IE_Clamp((k-50.0)/40.0); present[IE_STOCH]=true; }
    { double cc=iCCI(NULL,0,14,PRICE_TYPICAL,sh); out[IE_CCI]=IE_Clamp(cc/150.0); present[IE_CCI]=true; }
    { double ao=iAO(NULL,0,sh); out[IE_AO]=IE_Clamp(ao/(atr*0.5)); present[IE_AO]=true; }
    { double ac=iAC(NULL,0,sh); out[IE_AC]=IE_Clamp(ac/(atr*0.5)); present[IE_AC]=true; }
    { double sar=iSAR(NULL,0,0.02,0.2,sh); if(IE_OK(sar)){ out[IE_SAR]=(c1>sar)?1.0:-1.0; present[IE_SAR]=true; } }
    { double te=iAlligator(NULL,0,13,8,8,5,5,3,MODE_SMMA,PRICE_MEDIAN,MODE_GATORTEETH,sh);
      if(IE_OK(te)&&te>0){ out[IE_ALLIG]=IE_Clamp((c1-te)/atr); present[IE_ALLIG]=true; } }
    { double spanA=iIchimoku(NULL,0,9,26,52,MODE_SENKOUSPANA,sh); double spanB=iIchimoku(NULL,0,9,26,52,MODE_SENKOUSPANB,sh);
      if(IE_OK(spanA)&&IE_OK(spanB)){ double top=MathMax(spanA,spanB),bot=MathMin(spanA,spanB);
        out[IE_ICHI]=(c1>top)?1.0:((c1<bot)?-1.0:0.0); present[IE_ICHI]=true; } }
}

// Bounded indicator-confluence contribution (SLS12 T2 foundation). Returns a value in
// [-1..+1] built from the LEARNED per-indicator weights (g_IndWeight, summing to 1) times
// each indicator's signed reading, optionally regime-adjusted. Because weights sum to 1 and
// readings are each in [-1,1], the result is in [-1,1] BY CONSTRUCTION — so when the score
// core scales and blends this in, both buy(+) and sell(-) thresholds stay reachable and
// symmetric. Safe before calibration: if intelligence isn't ready, returns 0 (no effect).
// `rdg`/`prs` are the ensemble readings for the bar (from IE_ReadAtBar or live g_IE).
double IE_ConfluenceContribution(double &rdg[], bool &prs[], int regime, int sh=0) {
    if(!g_IndIntelReady) return 0.0;
    double acc = 0.0, wsum = 0.0;
    // ===== SLS16 (Lever 1: BOUNDED REAL-TIME WEIGHT MODULATION) =====
    // KTF-specific: scale KTF's weight by Kalman filter confidence.
    // Narrow band (high trust) -> lift KTF voice. Wide band -> suppress it.
    // Bounded [0.5, 1.2]: evidence-driven, never free-floating.
    double _ktfTrust = IE_KTFTrust(sh);
    double _ktfMod   = MathMax(0.5, MathMin(1.2, 0.8 + _ktfTrust * 0.4));
    // Awareness coherence: scales total ensemble magnitude after re-normalization.
    // Incoherent market -> reduce contribution voice. Familiar+coherent -> modest lift.
    double _cohMod = 1.0;
    if(g_Awareness.isValid) {
        if(g_Awareness.coherence < 0.5)
            _cohMod = MathMax(0.70, 0.70 + g_Awareness.coherence * 0.60);
        else if(g_Awareness.coherence >= 0.70 && g_Awareness.environmentFamiliar)
            _cohMod = MathMin(1.15, 1.0 + (g_Awareness.coherence - 0.70) * 0.50);
    }
    for(int k=0;k<IND_COUNT;k++){
        if(!prs[k]) continue;
        double w = g_IndWeight[k];
        if(w <= 0.0) continue;
        // SLS12 FIX65h: ACTIVATE learned flip-thresholds (were computed but unused). An indicator's
        // reading carries real directional commitment only past its learned bull/bear flip level;
        // inside its neutral zone it's noise. Scale the EFFECTIVE reading by how decisively it has
        // crossed its own learned threshold — turns the dormant range learning into live signal.
        double eff = rdg[k];
        if(rdg[k] > 0 && g_IndBullThresh[k] > 0.01){
            eff = rdg[k] * MathMax(0.3, MathMin(1.0, rdg[k] / MathMax(0.1, g_IndBullThresh[k])));
        } else if(rdg[k] < 0 && g_IndBearThresh[k] < -0.01){
            eff = rdg[k] * MathMax(0.3, MathMin(1.0, rdg[k] / MathMin(-0.1, g_IndBearThresh[k])));
        }
        // regime adjustment: scale by how well this indicator predicts IN THIS regime
        // (relative to its global strength) — situation-specific, never inflating beyond 1.
        if(regime>=0 && regime<9 && g_IndDirIC[k] > 0.0001){
            double regRel = g_IndDirIC_Regime[regime][k] / MathMax(0.0001, g_IndDirIC[k]);
            w *= MathMax(0.25, MathMin(1.5, regRel));   // damp where weak in-regime, modest boost where strong
        }
        // ===== SLS15 (Lever 1: PERCEPTION RESOLUTION) — STRONGEST-PENALTY DAMPING =====
        // A learned rule (pair or triple) that names k as primary and whose breaker(s) oppose
        // means k is unreliable HERE. The danger we are avoiding: multiplying every matching
        // rule's damp onto w compounds overlapping warnings into near-silence (~3%), collapsing
        // the distinction between "somewhat unreliable" and "fully invalidated" — the same
        // resolution-loss SLS13 fought in the score itself, now at the damping layer. Instead we
        // take the SINGLE STRONGEST applicable penalty and apply it once. Penalize by the worst
        // warning, not the product of all warnings, so HOW unreliable k is stays legible.
        double _strongestDamp = 1.0;   // 1.0 = no penalty; lower = stronger single penalty
        if(MathAbs(rdg[k]) > 0.3){
            // pair rules: conditioner opposes
            for(int r=0;r<g_IndRuleCount;r++){
                if(!g_IndRules[r].active || g_IndRules[r].primary != k) continue;
                int cnd = g_IndRules[r].conditioner;
                if(cnd<0 || cnd>=IND_COUNT || !prs[cnd] || MathAbs(rdg[cnd]) < 0.2) continue;
                if((rdg[cnd] > 0) != (rdg[k] > 0)){
                    // 9.25: scale lift by primary k's per-regime IC rel — weak regime IC → lighter penalty
                    double _rrPair=(regime>=0&&regime<9&&g_IndDirIC[k]>0.01)
                        ?MathMax(0.25,MathMin(1.5,g_IndDirIC_Regime[regime][k]/g_IndDirIC[k])):1.0;
                    double damp = MathMax(0.2, 1.0 - g_IndRules[r].lift * _rrPair * 1.5);
                    if(damp < _strongestDamp) _strongestDamp = damp;   // keep the worst, not the product
                }
            }
        }
        // SLS13 R2-T / SLS15: TRIPLE-CONFLUENCE — x+y-z invalidation. A triple is a STRONGER,
        // more specific warning than a pair (aligned-yet-broken), so it competes for the single
        // strongest penalty rather than multiplying on top of the pair damp. Same anti-compression
        // principle: worst single warning wins; warnings are not stacked into silence.
        if(g_IndTripleCount > 0 && MathAbs(rdg[k]) > 0.3){
            for(int tr=0;tr<g_IndTripleCount;tr++){
                if(!g_IndTriples[tr].active || g_IndTriples[tr].primary != k) continue;
                int al = g_IndTriples[tr].aligner;
                int br = g_IndTriples[tr].breaker;
                if(al<0||al>=IND_COUNT||!prs[al]||MathAbs(rdg[al])<0.2) continue;
                if(br<0||br>=IND_COUNT||!prs[br]||MathAbs(rdg[br])<0.2) continue;
                if((rdg[al]>0)==(rdg[k]>0) && (rdg[br]>0)!=(rdg[k]>0)){
                    // 9.25: scale triple lift by primary k's per-regime IC rel
                    double _rrTrip=(regime>=0&&regime<9&&g_IndDirIC[k]>0.01)
                        ?MathMax(0.25,MathMin(1.5,g_IndDirIC_Regime[regime][k]/g_IndDirIC[k])):1.0;
                    double tripleDamp = MathMax(0.15, 1.0 - g_IndTriples[tr].lift * _rrTrip * 2.0);
                    if(tripleDamp < _strongestDamp) _strongestDamp = tripleDamp;
                }
            }
        }
        // Apply the single strongest penalty ONCE — never the product of stacked warnings.
        // This preserves resolution: a doubly-warned indicator is "as unreliable as its worst
        // warning", not crushed to ~3%. Floor at 0.15 so even a severe warning leaves a trace.
        w *= MathMax(0.15, _strongestDamp);
        // SLS16: KTF-specific modulation re-weights KTF vs ensemble (affects weighted average).
        if(k == IE_KTF) w *= _ktfMod;
        acc  += w * eff;
        wsum += w;
    }
    if(wsum <= 0.0001) return 0.0;
    return IE_Clamp((acc / wsum) * _cohMod);   // re-norm + SLS16 awareness coherence envelope
}

// KTF calibrated-uncertainty trust [0..1]: FIX24 reads buf5=sqrt(kf_P)/ATR directly.
// Low variance => Kalman confident => high trust. Returns 0.5 (neutral) if absent.
double IE_KTFTrust(int sh) {
    double kfVar = iCustom(NULL,0,"KTF_KalmanTrendFilter",0.01,0.5,0.001,2.0,0.0,true,5,sh);
    if(!IE_OK(kfVar)) return 0.5;
    return MathMax(0.0, MathMin(1.0, 1.0 - kfVar/2.0)); // kfVar in [0,2]: 0->trust=1.0, 2->trust=0.0
}

// Per-bar cache for the indicator contribution (SLS12 T2). The contribution at a bar is
// independent of CEUS weights and fixed once intelligence is learned, so we memoize it:
// the score core is called repeatedly on the same bars during calibration (many weight
// candidates), and recomputing ~17 iCustom reads each time would be ruinously slow. Lazy
// fill: each bar's contribution is computed at most once. Live (shift 0) always computes
// fresh from the already-cached g_IE. Sentinel -999 = not yet computed.
double  g_IndContribCache[];
bool    g_IndContribCacheReady = false;

void IE_InitContribCache() {
    int n = Bars;
    if(ArrayResize(g_IndContribCache, n) == n) {
        ArrayInitialize(g_IndContribCache, -999.0);
        g_IndContribCacheReady = true;
    } else {
        g_IndContribCacheReady = false;   // alloc failed -> fall back to uncached (still correct)
    }
}

// Bounded indicator contribution for a bar [-1..+1]. `regime` is passed in (the score core
// already knows it) to avoid recomputing. Safe before intelligence is ready (returns 0).
double GetIndicatorContribution(int sh, int regime) {
    if(!g_IndIntelReady) return 0.0;
    double rdg[IND_COUNT]; bool prs[IND_COUNT];
    if(sh == 0) {
        // LIVE: use the live ensemble snapshot (already computed once this bar by IE_Update).
        IE_Update();
        for(int i=0;i<IND_COUNT;i++){ rdg[i]=g_IE.reading[i]; prs[i]=g_IE.present[i]; }
        return IE_ConfluenceContribution(rdg, prs, regime, 0);
    }
    // HISTORICAL: lazy-memoized.
    if(g_IndContribCacheReady && sh > 0 && sh < ArraySize(g_IndContribCache)) {
        if(g_IndContribCache[sh] <= -900.0) {
            IE_ReadAtBar(sh, rdg, prs);
            g_IndContribCache[sh] = IE_ConfluenceContribution(rdg, prs, regime, sh);
        }
        return g_IndContribCache[sh];
    }
    // uncached fallback (cache unavailable) — still correct, just slower
    IE_ReadAtBar(sh, rdg, prs);
    return IE_ConfluenceContribution(rdg, prs, regime, sh);
}


