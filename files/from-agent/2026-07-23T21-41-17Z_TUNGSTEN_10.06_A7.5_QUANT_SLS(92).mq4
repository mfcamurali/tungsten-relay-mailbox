    predictiveSystem.trendReversalProbability = 0.5;
    predictiveSystem.volatilitySpikeProbability = 0.5;
    predictiveSystem.consolidationProbability = 0.5;
    
    // FIXED: Initialize neural network weights with proper random generation
    for(int i = 0; i < 20; i++) {
        int randVal = MathRand() % 10000;
        double randomValue = (double)randVal / 10000.0 - 0.5; // -0.5 to +0.5
        predictiveSystem.neuralWeights[i] = randomValue * 0.2;
    }
    
    for(int i = 0; i < 10; i++) {
        int randVal = MathRand() % 10000;
        double randomValue = (double)randVal / 10000.0 - 0.5; // -0.5 to +0.5
        predictiveSystem.neuralBias[i] = randomValue * 0.1;
    }
    
    for(int i = 0; i < 10; i++) {
        predictiveSystem.neuralInputs[i] = 0.0;
    }
    
    for(int i = 0; i < 3; i++) {
        predictiveSystem.neuralOutputs[i] = 0.0;
    }
    
    predictiveSystem.neuralLearningRate = 0.01;
