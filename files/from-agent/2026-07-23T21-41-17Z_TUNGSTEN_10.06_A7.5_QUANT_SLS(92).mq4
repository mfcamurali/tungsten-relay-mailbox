    marketStructure.primaryResistance = 0.0;
    marketStructure.secondarySupport = 0.0;
    marketStructure.secondaryResistance = 0.0;
    marketStructure.dynamicSupport = 0.0;
    marketStructure.dynamicResistance = 0.0;
    
    // Initialize arrays
    for(int i = 0; i < 10; i++) {
        marketStructure.supportStrengths[i] = 0.0;
        marketStructure.resistanceStrengths[i] = 0.0;
        marketStructure.ma[i] = 0.0;
        marketStructure.maSlopes[i] = 0.0;
        marketStructure.maDistances[i] = 0.0;
        marketStructure.maBullish[i] = false;
        marketStructure.maBearish[i] = false;
        marketStructure.maNeutral[i] = true;
    }
    
    for(int i = 0; i < 20; i++) {
        marketStructure.swingHighs[i] = 0.0;
        marketStructure.swingLows[i] = 0.0;
        marketStructure.swingHighTimes[i] = 0;
        marketStructure.swingLowTimes[i] = 0;
        marketStructure.volumeNodes[i] = 0.0;
    }
    
    for(int i = 0; i < 100; i++) {
        marketStructure.volumeProfile[i] = 0.0;
    }
    
    for(int i = 0; i < 13; i++) {
