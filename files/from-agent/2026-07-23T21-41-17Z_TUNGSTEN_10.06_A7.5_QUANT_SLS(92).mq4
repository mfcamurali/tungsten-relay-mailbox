    double thresholdMax;
    double thresholdStep;           // Test every 2 points
    double weightMin;               // Test weights 0.5X - 1.5X
    double weightMax;
    double weightStep;
    
    // Statistics
    int paramCombinationsTested;
    int ghostTradesPerSecond;       // Rapid burst testing
    datetime lastGhostTradeTime;
    datetime lastLogTime;           // Throttle logging
    int logsThisMinute;             // Log throttling counter
    
    // Current test iteration
