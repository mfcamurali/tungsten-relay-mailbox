// -- Market Self-Awareness State ------------------------------------─
// The system's internal model of its environment.
// Not just indicators — a coherent understanding of what the market
// IS right now and how confident the system is in that understanding.
struct MarketAwarenessState {
    // Market character understanding
    double  coherence;          // 0-1: how well current conditions match calibration
    double  certainty;          // 0-1: system confidence in its own read of the market
    double  regimePurity;       // 0-1: how "textbook" current regime is (vs ambiguous)
    bool    calibrationCovers;  // does current market condition exist in training data?

    // Probable forward path
    double  continuationProb;   // 0-1: probability current regime continues
    double  reversalRisk;       // 0-1: structural evidence suggesting reversal
    double  breakoutPotential;  // 0-1: evidence of compression before expansion
    int     mostLikelyNextReg;  // which regime is most likely next (transition matrix)

    // Self-check
    bool    signalLegitimate;   // current signal aligns with awareness (not anomalous)
    bool    environmentFamiliar;// current environment matches trained conditions
    string  awarenessNote;      // brief human-readable summary of what the market is doing

    // Forward path intelligence (5-step transition simulation)
    double  pathExpectedWR;     // WR expected across 5 future regime steps (0.40-0.80)

    // SLS22-SEG: scheduled-event awareness (per C7, surfaced here even in fail-open state)
    datetime nextEventTime;     // UTC time of the next known upcoming event (0 = none loaded)
    int      nextEventImpact;   // 1=low 2=med 3=high
    bool     eventGateActive;   // true while a SEG entry-blocking window is currently open
    bool     eventFeedFresh;    // false = feed missing/stale, SEG is fail-open (trading as if absent)

    // SLS22-ERM: execution-regime awareness
    string   ermState;          // "UNKNOWN" / "NORMAL" / "DEGRADED" / "HOSTILE"
    bool     ermWarmedUp;       // false until baseline sample count reached

    // Metadata
    datetime lastComputed;
    bool     isValid;
};
