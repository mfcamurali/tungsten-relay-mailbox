//| MILESTONE SYSTEM FUNCTIONS                                       |

//| Initialize Milestone System                                      |
void InitializeMilestoneSystem() {
    g_Goal.startingBalance = AccountBalance();
    g_Goal.currentMilestone = 0;  // Starting, haven't hit 100x yet
    g_Goal.milestoneTarget = g_Goal.startingBalance * 100;  // First milestone: 100x
    g_Goal.progressToMilestone = 0;
    g_Goal.milestoneStartTime = TimeCurrent();
    g_Goal.milestoneJustAchieved = false;
    g_Goal.trajectoryScore = 0;
    g_Goal.daysOnMilestone = 0;
    g_Goal.requiredDailyGrowth = 0;
    g_Goal.actualDailyGrowth = 0;
    
    // Milestone system initialized silently
    Print("  Starting Balance: $", DoubleToString(g_Goal.startingBalance, 2));
    Print("  Milestone 1 Target: $", DoubleToString(g_Goal.milestoneTarget, 2), " (100x)");
}

//| Update Milestone Progress                                        |
void UpdateMilestoneProgress() {
    double currentBalance = AccountBalance();
    // Zero-guard: if init never ran (or balance was 0 at init), self-heal here
    if(g_Goal.milestoneTarget <= 0)
        g_Goal.milestoneTarget = MathMax(1.0, currentBalance) * 100.0;
    g_Goal.progressToMilestone = (currentBalance / g_Goal.milestoneTarget) * 100.0;
    g_Goal.daysOnMilestone = (int)((TimeCurrent() - g_Goal.milestoneStartTime) / 86400);
    
    // Calculate required daily growth to hit milestone in reasonable time
    // Assuming 120 days per milestone (4 months) as baseline
    int targetDays = 120;
    double remainingGrowth = g_Goal.milestoneTarget - currentBalance;
    if(g_Goal.daysOnMilestone > 0 && remainingGrowth > 0) {
        int remainingDays = targetDays - g_Goal.daysOnMilestone;
        if(remainingDays > 0) {
            g_Goal.requiredDailyGrowth = (currentBalance > 0 && remainingDays > 0) ? (remainingGrowth / currentBalance) / remainingDays * 100 : 0.0;
        }
    }
    
    // Calculate actual daily growth
    if(g_Goal.daysOnMilestone > 0 && g_Goal.startingBalance > 0) {
        double totalGrowth = currentBalance - g_Goal.startingBalance;
        g_Goal.actualDailyGrowth = (totalGrowth / g_Goal.startingBalance) / g_Goal.daysOnMilestone * 100;
    }
    
    // Calculate trajectory score (-100 to +100)
    if(g_Goal.requiredDailyGrowth > 0) {
        g_Goal.trajectoryScore = ((g_Goal.actualDailyGrowth - g_Goal.requiredDailyGrowth) / g_Goal.requiredDailyGrowth) * 100;
        g_Goal.trajectoryScore = MathMax(-100, MathMin(100, g_Goal.trajectoryScore));
    }
    
    // Check if milestone achieved
    if(currentBalance >= g_Goal.milestoneTarget && !g_Goal.milestoneJustAchieved) {
        g_Goal.milestoneJustAchieved = true;
        g_Goal.currentMilestone++;
        
        PrintFormat("  milestone %d   |   $%.0f   |   %d days", g_Goal.currentMilestone, currentBalance, g_Goal.daysOnMilestone);
        
        // Set next milestone (1000x from current)
        g_Goal.startingBalance = currentBalance;
        g_Goal.milestoneTarget = currentBalance * 1000;
        g_Goal.milestoneStartTime = TimeCurrent();
        g_Goal.milestoneJustAchieved = false;
        g_Goal.daysOnMilestone = 0;
        
        PrintFormat("  new milestone target   |   #%d", g_Goal.currentMilestone + 1);
    }
}

//| Calculate Smart Adaptive Risk                                    |
//| Integrates milestone progress, market conditions, and streaks    |
double CalculateKellyCeiling() {
    // Full Kelly for asymmetric payoff: f* = (b*p - q)/b
    //   p = live edge (win rate, fraction), q = 1-p, b = reward:risk (winners/losers).
    // We use the system's OWN calibrated/realised numbers — intelligence sets p and b,
    // mathematics turns them into the growth-optimal stake. Then we (a) take a SAFE
    // fraction of full Kelly and (b) scale it down by how deep we are in drawdown, so
    // the stake self-extinguishes before the hard stop is ever in reach.
    if(!UseKellyGovernor) return g_Risk.maxRisk;  // governor off -> legacy ceiling

    // live edge: prefer recent live WR once enough trades exist, else calibrated WR
    double p = g_Risk.recentWinRate / 100.0;
    if(p <= 0.01) p = (g_Calibration.calibratedWR > 0.01 ? g_Calibration.calibratedWR : 0.60);
    p = MathMax(0.50, MathMin(0.85, p));           // sane live bounds
    // 9.21: blend in per-regime ghost OOS WR when sample is adequate — better fuel, same maths
    int _krReg = g_RegimeState.currentRegime;
    if(_krReg >= 0 && _krReg < 9 && g_Ghost_RegObs[_krReg] >= 15) {
        double _regP = (double)g_Ghost_RegWins[_krReg] / g_Ghost_RegObs[_krReg];
        p = p * 0.70 + _regP * 0.30;
        p = MathMax(0.50, MathMin(0.85, p));
    }
    double q = 1.0 - p;
    double b = MathMax(0.8, MathMin(5.0, g_P6_AvgRR > 0.1 ? g_P6_AvgRR : 1.5));

    double fullKelly = (b * p - q) / b;            // optimal growth fraction
    if(fullKelly <= 0.0) return g_Risk.minRisk;    // no edge -> minimum only
    double fBase = fullKelly * MathMax(0.05, MathMin(1.0, KellyFraction));

    // drawdown-aware fade: as current DD -> budget, multiplier -> 0 (ruin-proof)
    double eq   = AccountEquity();
    if(eq > g_Risk.peakEquity) g_Risk.peakEquity = eq;
    double dd   = (g_Risk.peakEquity > 0.0) ? (1.0 - eq / g_Risk.peakEquity) : 0.0;
    double budget = MathMax(5.0, KellyDDBudget) / 100.0;
    double fade = MathMax(0.0, 1.0 - dd / budget);

    double f = fBase * fade * 100.0;               // back to percent
    // LOSS-CLUSTER SENTINEL: cut stake hard during a statistically-confirmed break.
    // Multiplicative and <=1, so it can only ever REDUCE risk, never inflate it.
    if(UseLossSentinel) f *= MathMax(0.05, MathMin(1.0, g_SentinelMult));
    f = MathMax(0.0, MathMin(KellyMaxFraction, f));
    return f;
}

//| Evaluate Smart Acceleration Conditions                           |
//| CEO: MARKET ALIGNMENT SCORE (0.0 - 1.0)                          |


void InitMarketAlignment() {
    g_Alignment.overallScore         = 0.5;
    g_Alignment.overallScorePrev     = 0.5;
    g_Alignment.overallScoreSmoothed = 0.5;
    g_Alignment.trend                = 0.0;
    g_Alignment.trendStrength        = 0.0;
    g_Alignment.shouldReduceRisk     = false;
    g_Alignment.shouldSuspendTrading = false;
    g_Alignment.shouldTriggerReview  = false;
    g_Alignment.shouldIncreaseTier   = false;
    g_Alignment.scoreHistoryIdx      = 0;
    g_Alignment.scoreHistoryLen      = 0;
    g_Alignment.lastFullUpdate       = 0;
    g_Alignment.lastQuickUpdate      = 0;
    g_Alignment.updateCount          = 0;
    g_Alignment.componentCount       = 8;
    for(int i = 0; i < 48; i++) g_Alignment.scoreHistory[i] = 0.5;
    for(int i = 0; i < 8; i++) {
        g_Alignment.components[i].score  = 0.5;
        g_Alignment.components[i].weight = 0.0;
        g_Alignment.components[i].name = "";
        g_Alignment.components[i].status = "ok";
        g_Alignment.components[i].detail = "";
    }
}

double CalcAlignmentComponent(int idx, string name, double weight,
                               double raw, double floor, double ceiling,
                               string detail) {
    // Normalise raw value to 0-1 between floor (=0) and ceiling (=1)
    double score = (raw - floor) / MathMax(0.001, ceiling - floor);
    score = MathMax(0.0, MathMin(1.0, score));
    g_Alignment.components[idx].name   = name;
    g_Alignment.components[idx].score  = score;
    g_Alignment.components[idx].weight = weight;
    g_Alignment.components[idx].detail = detail;
    g_Alignment.components[idx].status =
        score >= 0.75 ? "strong" : score >= 0.50 ? "ok" : score >= 0.25 ? "weak" : "critical";
    return score * weight;
}

void UpdateMarketAlignmentScore() {
    datetime now = TimeCurrent();

    // Quick update every 30 seconds (lightweight)
    if(now - g_Alignment.lastQuickUpdate < 30) return;
    g_Alignment.lastQuickUpdate = now;
    g_Alignment.updateCount++;

    // Only do the heavy full-component recalculation every 5 minutes
    bool fullUpdate = (now - g_Alignment.lastFullUpdate >= 300);
    if(fullUpdate) g_Alignment.lastFullUpdate = now;

    double total = 0.0;

    // ## [0] LIVE WR vs CALIBRATED EXPECTATION (weight 0.22) #############
    // The most direct measure of model-market alignment.
    // If live WR is tracking calibration, the model is valid.
    // If it's significantly below, the market has changed.
    {
        double calibWR  = (g_WeightsOptimized && g_E99_Validation.expectedWinRate > 0.1)
                        ? g_E99_Validation.expectedWinRate / 100.0 : FLOOR_START_WR / 100.0;
        double liveWR   = g_Risk.recentWinRate / 100.0;  // rolling 20-trade
        double allTimeWR = g_LiveWinRate;                 // all-time
        // Use rolling as primary (faster), all-time as anchor
        double effectiveWR = (g_State.totalTrades >= 20)
            ? liveWR * 0.70 + allTimeWR * 0.30 : calibWR;
        // Score: calibWR-15% = 0.0, calibWR = 0.7, calibWR+10% = 1.0
        double floor_wr  = calibWR - 0.15;  // -15pp = critical misalignment
        double target_wr = calibWR + 0.10;  // +10pp = strong alignment
        string wrDetail = StringFormat("live %.1f%% vs calibrated %.1f%% (delta %+.1fpp)",
            effectiveWR*100, calibWR*100, (effectiveWR-calibWR)*100);
        total += CalcAlignmentComponent(0, "WR alignment", 0.22,
            effectiveWR, floor_wr, target_wr, wrDetail);
    }

    // ## [1] SCORE DISCRIMINATION (weight 0.18) ###########################
    // Do high scores actually win more than low scores?
    // If top bucket WR = bottom bucket WR -> score is random noise.
    // If top bucket WR >> bottom -> signal is genuinely discriminating.
    {
        double discrim = 0.5;  // neutral default
        if(g_LiveAdaptive.totalLiveTrades >= 50) {
            double topWR = g_LiveAdaptive.scoreBucketWR[4];   // 40-50pt above neutral
            double botWR = g_LiveAdaptive.scoreBucketWR[0];   // 0-10pt above neutral
            int    topN  = g_LiveAdaptive.scoreBucketTrades[4];
            int    botN  = g_LiveAdaptive.scoreBucketTrades[0];
            if(topN >= 5 && botN >= 5) {
                discrim = 0.5 + (topWR - botWR) * 1.5;  // 15pp discrimination = 0.725
                discrim = MathMax(0.0, MathMin(1.0, discrim));
            }
        }
        string disc_detail = g_LiveAdaptive.totalLiveTrades >= 50
            ? StringFormat("top bucket WR %.0f%%  bot %.0f%%  disc %+.0fpp",
                g_LiveAdaptive.scoreBucketWR[4]*100, g_LiveAdaptive.scoreBucketWR[0]*100,
                (g_LiveAdaptive.scoreBucketWR[4]-g_LiveAdaptive.scoreBucketWR[0])*100)
            : StringFormat("building (%d/50 trades)", g_LiveAdaptive.totalLiveTrades);
        total += CalcAlignmentComponent(1, "Score discrimination", 0.18,
            discrim, 0.0, 1.0, disc_detail);
    }

    // ## [2] REGIME CLASSIFICATION STABILITY (weight 0.14) ################
    // The regime classifier should be stable -- not flipping between regimes
    // every bar. Instability means the market structure is ambiguous.
    // Also: at least one regime should have live WR >= 63%.
    {
        double regimeScore = 0.5;
        if(fullUpdate) {
            int regimesWithEdge = 0;
            double bestRegimeWR = 0.0;
            for(int ri = 0; ri < 9; ri++) {
                if(g_LiveAdaptive.regimeTrades[ri] >= 10) {
                    if(g_LiveAdaptive.regimeLiveWR[ri] >= 0.63) regimesWithEdge++;
                    if(g_LiveAdaptive.regimeLiveWR[ri] > bestRegimeWR)
                        bestRegimeWR = g_LiveAdaptive.regimeLiveWR[ri];
                }
            }
            int totalRegimeSampled = 0;
            for(int ri2 = 0; ri2 < 8; ri2++)
                if(g_LiveAdaptive.regimeTrades[ri2] >= 5) totalRegimeSampled++;
            // Score: 0 regimes with edge = 0.1, 4+ = 1.0
            regimeScore = (totalRegimeSampled > 0)
                ? MathMax(0.10, MathMin(1.0, 0.25 + regimesWithEdge * 0.20 + bestRegimeWR * 0.3))
                : 0.50;  // insufficient data -- neutral
        } else {
            regimeScore = g_Alignment.components[2].score;  // carry previous
        }
        int curRegime = g_RegimeState.currentRegime;
        string regDetail = StringFormat("regime %d   |   live adaptive self-cal: %s   |   best WR %.0f%%",
            curRegime, g_LiveAdaptive.selfCalibrated?"yes":"building",
            g_LiveAdaptive.totalLiveTrades>10 ? 65.0 : 0.0);
        total += CalcAlignmentComponent(2, "Regime stability", 0.14,
            regimeScore, 0.0, 1.0, regDetail);
    }

    // ## [3] VOLUME / INSTITUTIONAL FLOW COHERENCE (weight 0.12) ##########
    // Institutional flow should be coherent with signal direction.
    // High volume + conviction close in signal direction = aligned.
    // High spread (thin liquidity) = misaligned.
    {
        // Enhanced: uses volumeDelta (acceleration) + closePosition (conviction direction)
        // from CalculateMarketFeatures -- gives a real microstructure flow proxy
        // Enhanced: uses volumeDelta + closePosition as institutional flow proxy.
        double flowScore = 0.5;
        if(intelligence.isValid) {
            MarketStateFeatures _ff = CalculateMarketFeatures(0);
            double _vDelta   = _ff.volumeDelta;      // 5-bar tick vol acceleration
            double _closPos  = _ff.closePosition;    // 0=closed at low, 1=at high
            double _bodyR    = _ff.bodyRatio;         // body/range conviction
            double _liqIdx   = intelligence.liquidityIndex;  // spread tightness

            // Directional flow: volume spike closing at extreme = institutional intent
            // Close near high + volume surge = buying pressure confirmed
            // Close near low + volume surge = selling pressure confirmed
            double _dirFlow  = MathAbs(_closPos - 0.5) * 2.0;  // 0=neutral, 1=extreme
            double _flowConv = _vDelta * _dirFlow * (0.5 + _bodyR * 0.5);  // max ~2.0

            // Normalise to 0-1: neutral (1.0 vol, 0.5 close) = 0.5 score
            flowScore = MathMin(1.0,
                _flowConv * 0.40 +           // directional volume conviction
                _liqIdx   * 0.35 +           // spread tightness (liquidity)
                (_vDelta > 0.8 ? MathMin(1.0, _vDelta/2.0) : 0.3) * 0.25  // volume level
            );
            flowScore = MathMax(0.0, flowScore);
        }
        MarketStateFeatures _ffl = CalculateMarketFeatures(0);
        string flowDetail = StringFormat("vol delta %.1fx   |   close pos %.0f%%   |   liquidity %.2f",
            _ffl.volumeDelta, _ffl.closePosition * 100.0, intelligence.liquidityIndex);
        total += CalcAlignmentComponent(3, "Volume coherence", 0.12,
            flowScore, 0.0, 1.0, flowDetail);
    }

    // ## [4] CANDLE ANATOMY ACCURACY (weight 0.10) ########################
    // The calibrated anatomy weights should be predicting correctly.
    // Compare live anatomy WR vs calibrated weights -- divergence = misalignment.
    {
        double anatScore = 0.5;
        if(g_CandleWeightsCalibrated && g_LiveAdaptive.totalLiveTrades >= 30) {
            // Use regime-specific baseline WR as reference instead of flat 0.65
            // This makes anatomy accuracy meaningful across all regime types
            int _curR = g_RegimeState.currentRegime;
            double _baselineWR = (_curR >= 0 && _curR < 9 && g_RegimeLiveWR[MathMin(8,MathMax(0,_curR))] > 0.0)
                ? g_RegimeLiveWR[MathMin(8,MathMax(0,_curR))] : 0.65;

            double totalDiv = 0.0, totalConf = 0.0; int anatCount = 0;
            for(int ai = 0; ai < 14; ai++) {
                if(g_LiveAdaptive.anatomyLiveTrades[ai] < 8) continue;
                double calibW   = g_CalibratedCandleWeights[ai];
                double liveWR   = g_LiveAdaptive.anatomyLiveWR[ai];
                // Implied weight: how the calibrated weight should sit given live WR
                double implied  = (liveWR / MathMax(0.40, _baselineWR));
                double diverge  = MathAbs(calibW - implied);
                // Weight confidence by observation count -- 50+ trades = full confidence
                double conf = MathMin(1.0, g_LiveAdaptive.anatomyLiveTrades[ai] / 50.0);
                totalDiv  += diverge * conf;
                totalConf += conf;
                anatCount++;
            }
            if(anatCount > 0 && totalConf > 0) {
                double weightedAvgDiv = totalDiv / totalConf;
                anatScore = MathMax(0.0, MathMin(1.0, 1.0 - weightedAvgDiv * 0.75));
            }
        }
        string anatDetail = g_CandleWeightsCalibrated
            ? StringFormat("calibrated weights active   |   %d anatomy patterns tracked",
                g_LiveAdaptive.totalLiveTrades)
            : "uncalibrated (neutral 1.0 weights)";
        total += CalcAlignmentComponent(4, "Anatomy accuracy", 0.10,
            anatScore, 0.0, 1.0, anatDetail);
    }

    // ## [5] SESSION PERFORMANCE (weight 0.08) ############################
    // Are the expected best-performing sessions (London, NY) actually
    // delivering? A session producing <50% WR is a red flag.
    {
        double sessScore = 0.60;  // start slightly positive
        if(g_LiveAdaptive.totalLiveTrades >= 20) {
            double bestSessWR = 0.0, worstSessWR = 1.0;
            int sessSampled = 0;
            for(int si = 0; si < 4; si++) {
                if(g_LiveAdaptive.sessionTrades[si] < 8) continue;
                sessSampled++;
                double sWR = g_LiveAdaptive.sessionLiveWR[si];
                if(sWR > bestSessWR) bestSessWR = sWR;
                if(sWR < worstSessWR) worstSessWR = sWR;
            }
            if(sessSampled >= 2) {
                sessScore = bestSessWR * 0.70 + (1.0 - MathMax(0, 0.50 - worstSessWR)) * 0.30;
                sessScore = MathMax(0.0, MathMin(1.0, sessScore));
            }
        }
        int curHour = TimeHour(TimeCurrent());
        string sesName = (curHour >= 7 && curHour < 13) ? "London" :
                         (curHour >= 13 && curHour < 17) ? "NY" :
                         (curHour >= 0 && curHour < 7)   ? "Asian" : "Late";
        string sessDetail = StringFormat("current: %s   |   best session WR %.0f%%",
            sesName, g_LiveAdaptive.totalLiveTrades>=20 ?
            g_LiveAdaptive.sessionLiveWR[(curHour>=7&&curHour<13)?1:(curHour>=13&&curHour<17)?2:0]*100 : 65.0);
        total += CalcAlignmentComponent(5, "Session alignment", 0.08,
            sessScore, 0.0, 1.0, sessDetail);
    }

    // ## [6] DRAWDOWN FORENSICS HEALTH (weight 0.08) ######################
    // The absence of a drawdown is good. An active drawdown with a known
    // cause that is being addressed is okay. An unexplained deterioration is bad.
    {
        double ddScore = 1.0;
        if(g_DrawdownForensics.inDrawdown) {
            ddScore = 0.40;
            if(StringLen(g_DrawdownForensics.dominantIssue) > 0) ddScore = 0.55;  // known cause
            if(g_Slingshot.isActive) ddScore = 0.65;  // actively recovering
        }
        double currDD = g_State.currentDrawdown;
        if(currDD > FLOOR_SLINGSHOT_THRESHOLD) ddScore = MathMin(ddScore, 0.30);
        else if(currDD > FLOOR_SLINGSHOT_THRESHOLD * 0.5) ddScore = MathMin(ddScore, 0.60);
        string ddDetail = StringFormat("DD %.1f%%   |   %s   |   slingshot: %s",
            currDD, g_DrawdownForensics.inDrawdown ? g_DrawdownForensics.dominantIssue : "healthy",
            g_Slingshot.isActive ? "active" : "off");
        total += CalcAlignmentComponent(6, "Drawdown health", 0.08,
            ddScore, 0.0, 1.0, ddDetail);
    }

    // ## [7] PROTECTION SYSTEM FREQUENCY (weight 0.08) ###################
    // Ghost and slingshot activations are defences -- healthy systems rarely
    // need them. Frequent activation = the model is struggling.
    // Low activation = system is aligned and trading cleanly.
    {
        double protScore = 1.0;
        // Ghost mode active = score penalty
        if(g_SmartCB.inGhostMode) protScore = 0.50;
        // Slingshot active
        if(g_Slingshot.isActive) {
            if(g_Slingshot.triggerMode == SLING_CRISIS) protScore = MathMin(protScore, 0.25);
            else if(g_Slingshot.triggerMode == SLING_EQUITY) protScore = MathMin(protScore, 0.45);
            else protScore = MathMin(protScore, 0.65);  // EARLY -- just cautionary
        }
        // Consecutive losses
        if(g_SmartCB.consecutiveLosses >= 3) protScore = MathMin(protScore, 0.60);
        if(g_SmartCB.consecutiveLosses >= 6) protScore = MathMin(protScore, 0.35);
        // Recent ghost activations this session
        if(g_Slingshot.activationCount >= 3) protScore = MathMin(protScore, 0.40);
        string protDetail = StringFormat("ghost: %s   |   sling: %s   |   consec losses: %d   |   activations: %d",
            g_SmartCB.inGhostMode?"active":"off",
            g_Slingshot.isActive?"ACTIVE":"off",
            g_SmartCB.consecutiveLosses, g_Slingshot.activationCount);
        total += CalcAlignmentComponent(7, "Protection frequency", 0.08,
            protScore, 0.0, 1.0, protDetail);
    }

    // ## DYNAMIC COMPONENT WEIGHTING ######################################
    double redistributed = 0.0;
    int totalLT = g_LiveAdaptive.totalLiveTrades + g_State.totalTrades;

    // Score discrimination (idx 1): needs 50+ trades to be reliable
    if(totalLT < 50) {
        redistributed += g_Alignment.components[1].score * g_Alignment.components[1].weight;
        total -= g_Alignment.components[1].score * g_Alignment.components[1].weight;
        total += 0.65 * g_Alignment.components[1].weight; // replace with neutral
    }
    // Regime stability (idx 2): needs 30+ trades across regimes
    if(g_LiveAdaptive.selfCalibrated == false && totalLT < 30) {
        redistributed += g_Alignment.components[2].score * g_Alignment.components[2].weight;
        total -= g_Alignment.components[2].score * g_Alignment.components[2].weight;
        total += 0.65 * g_Alignment.components[2].weight;
    }
    // Anatomy accuracy (idx 4): needs calibrated weights
    if(!g_CandleWeightsCalibrated) {
        redistributed += g_Alignment.components[4].score * g_Alignment.components[4].weight;
        total -= g_Alignment.components[4].score * g_Alignment.components[4].weight;
        total += 0.65 * g_Alignment.components[4].weight;
    }
    // Session alignment (idx 5): needs 8+ trades per session
    bool sessionDataThin = true;
    for(int _si=0;_si<4;_si++) if(g_LiveAdaptive.sessionTrades[_si]>=8){sessionDataThin=false;break;}
    if(sessionDataThin) {
        redistributed += g_Alignment.components[5].score * g_Alignment.components[5].weight;
        total -= g_Alignment.components[5].score * g_Alignment.components[5].weight;
        total += 0.65 * g_Alignment.components[5].weight;
    }

    // ## AGGREGATE ##########################################################
    double raw = MathMax(0.0, MathMin(1.0, total));
    g_Alignment.overallScorePrev    = g_Alignment.overallScore;
    g_Alignment.overallScore        = raw;
    // EMA smoothing (alpha=0.15 -- responsive but not jittery)
    g_Alignment.overallScoreSmoothed =
        g_Alignment.overallScoreSmoothed * 0.85 + raw * 0.15;

    // Trend: 30-period direction of smoothed score
    if(g_Alignment.scoreHistoryLen >= 6) {
        double oldest = g_Alignment.scoreHistory[(g_Alignment.scoreHistoryIdx + 48 - 6) % 48];
        g_Alignment.trend = g_Alignment.overallScoreSmoothed - oldest;
        g_Alignment.trendStrength = MathMin(1.0, MathAbs(g_Alignment.trend) * 10.0);
    }

    // Store in history
    g_Alignment.scoreHistory[g_Alignment.scoreHistoryIdx % 48] = raw;
    g_Alignment.scoreHistoryIdx++;
    if(g_Alignment.scoreHistoryLen < 48) g_Alignment.scoreHistoryLen++;

    // ## ACTION DERIVATIONS ################################################
    g_Alignment.shouldReduceRisk     = (g_Alignment.overallScoreSmoothed < 0.40);
    g_Alignment.shouldSuspendTrading = (g_Alignment.overallScoreSmoothed < 0.20);
    g_Alignment.shouldIncreaseTier   = (g_Alignment.overallScoreSmoothed > 0.80 &&
                                        g_Alignment.trend > 0.02);
    // Trigger review if score dropped > 0.20 in last hour (12 readings)
    if(g_Alignment.scoreHistoryLen >= 12) {
        double prev1h = g_Alignment.scoreHistory[(g_Alignment.scoreHistoryIdx + 48 - 12) % 48];
        g_Alignment.shouldTriggerReview = (prev1h - raw > 0.20);
    }

    // ## SELF-CORRECTION FEEDBACK #############################################
    // The CEO adjusts the live adaptive threshold proportionally only.
    // designed consecutive-loss gate. That would be the CEO overriding the system.
    int _scTrades = g_LiveAdaptive.totalLiveTrades + g_State.totalTrades;
    double _rawSC = GetMarketAlignmentRaw();

    if(_rawSC > 0.80 && g_Alignment.trend > 0.01
       && _scTrades >= 100 && !g_Slingshot.isActive && !g_SmartCB.inGhostMode) {
        // Earned: ease threshold slightly
        g_LiveAdaptive.liveOptimalThreshold = MathMax(55.0,
            g_LiveAdaptive.liveOptimalThreshold - 1.0);
    } else if(_rawSC < 0.20 && g_LiveAdaptive.selfCalibrated && _scTrades >= 50) {
        // Critical AND confirmed: threshold +3pt (not ghost -- let ghost fire naturally)
        g_LiveAdaptive.liveOptimalThreshold = MathMin(80.0,
            g_LiveAdaptive.liveOptimalThreshold + 3.0);
        if(!g_CalibSilent)
            PrintFormat("  alignment %.2f   |   critical   |   threshold %.0f   |   ghost will fire if losses continue",
                _rawSC, g_LiveAdaptive.liveOptimalThreshold);
    } else if(_rawSC < 0.35 && g_LiveAdaptive.selfCalibrated && _scTrades >= 50) {
        // Confirmed weak: threshold +2pt
        g_LiveAdaptive.liveOptimalThreshold = MathMin(78.0,
            g_LiveAdaptive.liveOptimalThreshold + 2.0);
    }

    // ## PERSISTENT CSV LOG ###################################################
    // Write alignment data to disk every 5 minutes during full updates.
    // This creates a permanent record across MT4 restarts -- critical for
    // analysing the demo run. File: MQL4/Files/TUNGSTEN_alignment.csv
    if(fullUpdate) {
        int _af = FileOpen("TUNGSTEN_alignment.csv", FILE_WRITE|FILE_CSV|FILE_ANSI|FILE_SHARE_READ, ',');
        if(_af != INVALID_HANDLE) {
            // Header on first write (empty file)
            if(FileTell(_af) == 0)
                FileWrite(_af, "timestamp","datetime","score_raw","score_gated","trend",
                          "wr_align","score_disc","regime_stab","vol_coh","anatomy",
                          "session","drawdown","protection","total_trades","self_calibrated");
            FileSeek(_af, 0, SEEK_END);
            string _ts = TimeToString(now, TIME_DATE|TIME_MINUTES);
            int _tt = g_LiveAdaptive.totalLiveTrades + g_State.totalTrades;
            FileWrite(_af, IntegerToString((int)now), _ts,
                DoubleToStr(GetMarketAlignmentRaw(),4), DoubleToStr(GetMarketAlignment(),4),
                DoubleToStr(g_Alignment.trend,4),
                DoubleToStr(g_Alignment.components[0].score,4),
                DoubleToStr(g_Alignment.components[1].score,4),
                DoubleToStr(g_Alignment.components[2].score,4),
                DoubleToStr(g_Alignment.components[3].score,4),
                DoubleToStr(g_Alignment.components[4].score,4),
                DoubleToStr(g_Alignment.components[5].score,4),
                DoubleToStr(g_Alignment.components[6].score,4),
                DoubleToStr(g_Alignment.components[7].score,4),
                IntegerToString(_tt),
                g_LiveAdaptive.selfCalibrated ? "true" : "false");
            FileClose(_af);
        }
    }

    // Log every 30 minutes or on significant change
    static datetime lastAlignLog = 0;
    double delta = g_Alignment.overallScore - g_Alignment.overallScorePrev;
    bool significantChange = MathAbs(delta) > 0.08;
    if(fullUpdate || significantChange || (now - lastAlignLog > 1800)) {
        lastAlignLog = now;
        string trend = g_Alignment.trend > 0.01 ? "improving" : g_Alignment.trend < -0.01 ? "degrading" : "stable";
        int _totalT2 = g_LiveAdaptive.totalLiveTrades + g_State.totalTrades;
        double _rawNow = GetMarketAlignmentRaw();
        // Delta vs 6 readings ago (~3 hours)
        double _rawOld = g_Alignment.scoreHistoryLen >= 6
            ? g_Alignment.scoreHistory[(g_Alignment.scoreHistoryIdx + 48 - 6) % 48] : _rawNow;
        double _delta = _rawNow - _rawOld;
        string _deltaStr = StringFormat("%s%.2f", _delta >= 0 ? "+" : "", _delta);
        PrintFormat("  LIVE  |   alignment   %.2f   |   %s 3h   |   %s   |   %s   |   %d trades",
            _rawNow, _deltaStr,
            _rawNow >= 0.75 ? "strong" : _rawNow >= 0.50 ? "ok" :
            _rawNow >= 0.30 ? "weak" : "critical",
            trend, _totalT2);
        if(fullUpdate) {
            for(int ci = 0; ci < 8; ci++) {
                if(g_Alignment.components[ci].score < 0.50) {  // only log weak components
                    PrintFormat("    %-22s  %.2f  [%s]  %s",
                        g_Alignment.components[ci].name,
                        g_Alignment.components[ci].score,
                        g_Alignment.components[ci].status,
                        g_Alignment.components[ci].detail);
                }
            }
        }
    }
}

// ## CEO ALIGNMENT ACCESSOR ###################################################
// Before that point returns 0.65 -- the calibrated floor WR normalised to neutral.
// This means the CEO is an observer-only until it has earned the right to act.
double GetMarketAlignment() {
    // Always neutral before the system has traded meaningfully
    int totalTrades = g_LiveAdaptive.totalLiveTrades + g_State.totalTrades;
    if(totalTrades < 20 || g_Alignment.updateCount < 4)
        return 0.65;  // neutral -- no suppression, no amplification

    double raw = g_Alignment.overallScoreSmoothed;

    // Blend toward neutral based on data maturity
    double maturity;
    if(totalTrades < 50)       maturity = 0.30;  // 30% blend toward neutral
    else if(totalTrades < 100) maturity = 0.15;  // 15% blend toward neutral
    else                       maturity = 0.0;   // full score trusted

    double aligned = raw * (1.0 - maturity) + 0.65 * maturity;

    // Entropy penalty: high-entropy regimes produce unreliable alignment signals.
    // If current regime averages >0.65 entropy (near-random), blend alignment toward 0.65 neutral.
    if(g_CorrelationsLearned) {
        int _gmaReg = g_RegimeState.currentRegime;
        if(_gmaReg >= 0 && _gmaReg < 9 && g_RegimeCorrelations[_gmaReg].barCount >= 50) {
            double _entr = g_RegimeCorrelations[_gmaReg].avgEntropy;
            if(_entr > 0.65) {
                double _entrBlend = MathMin(0.50, (_entr - 0.65) * 2.0);  // 0-50% blend toward neutral
                aligned = aligned * (1.0 - _entrBlend) + 0.65 * _entrBlend;
            }
        }
    }
    return aligned;
}

// Raw score -- for logging and reporting only, never for trading decisions
double GetMarketAlignmentRaw() { return g_Alignment.overallScoreSmoothed; }

//| PERFORMANCE TIER SELF-REASONING                                  |
// ========================================================================
// L7  LIVE ADAPTATION  (OWA · Gradient · MCM · PLDS · Market Awareness)
// ========================================================================
void UpdateLiveAdaptive(bool won, double score, int regime, int sessionHour,
                        double profit, MarketStateFeatures &anatomy) {
    g_LiveAdaptive.totalLiveTrades++;
    g_LiveAdaptive.lastUpdate = TimeCurrent();

    // ## Regime tracking #####################################################
    if(regime >= 0 && regime < 9) {
        g_LiveAdaptive.regimeTrades[regime]++;
        if(won) g_LiveAdaptive.regimeWins[regime]++;
        if(g_LiveAdaptive.regimeTrades[regime] >= 8) {
            double rWR = (double)g_LiveAdaptive.regimeWins[regime] / g_LiveAdaptive.regimeTrades[regime];
            g_LiveAdaptive.regimeLiveWR[regime] = rWR;
            // Self-adjust threshold: if WR > 72% in this regime -> lower threshold (more signals)
            //                        if WR < 58% -> raise threshold (fewer, higher conviction only)
            double baselineWR = 0.65;
            double deviation = rWR - baselineWR;
            // Adaptive learning rate: if we've seen 20+ trades in this regime,
            // scale the adjustment by regime confidence -- well-observed regimes
            // adjust faster (up to 1.5x), thin regimes adjust slower (0.7x).
            int _rt = g_LiveAdaptive.regimeTrades[regime];
        // SVJ-I: Smooth live regime confidence — grows proportionally with evidence
        // 0 trades=0.70x - 5=0.90x - 15=1.10x - 30+=1.50x (sqrt progression)
        double _lrMult = (_rt <= 0) ? 0.70 : MathMax(0.70, MathMin(1.50, 0.70 + MathSqrt((double)_rt/30.0)*0.80));

            // Base adjustment: negative deviation -> lower threshold (more trades)
            double _wfAbsorb = 1.0;
            if(g_CorrelationsLearned && regime >= 0 && regime < 9
               && g_RegimeCorrelations[regime].signalTotal >= 10) {
                double _p2WRr = g_RegimeCorrelations[regime].signalWR;
                // signalWR 0.55 - 0% absorption; 0.70+ - 40% absorption
                _wfAbsorb = MathMax(0.60, MathMin(1.0, 1.0 - (_p2WRr - 0.55) * 2.67));
            }
            g_LiveAdaptive.regimeThreshAdj[regime] = -deviation * 25.0 * _lrMult * _wfAbsorb;
            g_LiveAdaptive.regimeThreshAdj[regime] = MathMax(-6.0, MathMin(6.0, g_LiveAdaptive.regimeThreshAdj[regime]));
        }
    }

    // ## Session tracking ####################################################
    int sess = (sessionHour >= 0 && sessionHour < 8) ? 0 :
               (sessionHour < 13) ? 1 :
               (sessionHour < 17) ? 2 : 3;
    g_LiveAdaptive.sessionTrades[sess]++;
    if(won) g_LiveAdaptive.sessionWins[sess]++;
    if(g_LiveAdaptive.sessionTrades[sess] >= 5)
        g_LiveAdaptive.sessionLiveWR[sess] = (double)g_LiveAdaptive.sessionWins[sess] / g_LiveAdaptive.sessionTrades[sess];

    // ## Score bucket discrimination ##########################################
    // Does a high score actually predict wins better than a low score?
    // This is the core question for self-calibrating the threshold.
    double scoreDist = MathAbs(score - 50.0);  // Distance from neutral
    int bucket = MathMax(0, MathMin(4, (int)(scoreDist / 10.0)));
    g_LiveAdaptive.scoreBucketTrades[bucket]++;
    if(won) g_LiveAdaptive.scoreBucketWins[bucket]++;
    int _bN = g_LiveAdaptive.scoreBucketTrades[bucket];
    if(_bN >= 5) {
        // Bayesian-shrunk WR: prior 0.65 fades as observations grow.
        // Prior weight = 20/(n+20) -> 50% at n=20, 17% at n=100, 9% at n=200.
        double _rawBWR = (double)g_LiveAdaptive.scoreBucketWins[bucket] / _bN;
        double _priorW = 20.0 / (_bN + 20.0);
        // Prior differs by bucket: higher-score buckets should beat 0.65 baseline
        double _bucketPrior = 0.65 + (bucket - 2) * 0.03;  // 0.59, 0.62, 0.65, 0.68, 0.71
        g_LiveAdaptive.scoreBucketWR[bucket] =
            _rawBWR * (1.0 - _priorW) + _bucketPrior * _priorW;
    }

    // ## Candle anatomy live accuracy #########################################
    bool anat[16];
    anat[0]=anatomy.isBullishRejection; anat[1]=anatomy.isBearishRejection;
    anat[2]=anatomy.isBullishEngulf;    anat[3]=anatomy.isBearishEngulf;
    anat[4]=anatomy.isBullishKicker;    anat[5]=anatomy.isBearishKicker;
    anat[6]=anatomy.isMorningStar;      anat[7]=anatomy.isEveningStar;
    anat[8]=anatomy.isThreeWhiteSoldiers; anat[9]=anatomy.isThreeBlackCrows;
    anat[10]=anatomy.isConvictionCandle;  anat[11]=anatomy.isIndecisionCandle;
    anat[12]=anatomy.isInsideBar;         anat[13]=anatomy.isOutsideBar;
    // Slots 14/15: conviction close -- body + extreme close position (highest quality bars)
    anat[14]=(anatomy.closePosition > 0.80 && anatomy.bodyRatio > 0.50 && anatomy.isBullishCandle);
    anat[15]=(anatomy.closePosition < 0.20 && anatomy.bodyRatio > 0.50 && !anatomy.isBullishCandle);
    for(int ai = 0; ai < 16; ai++) {
        if(!anat[ai]) continue;
        g_LiveAdaptive.anatomyLiveTrades[ai]++;
        if(won) g_LiveAdaptive.anatomyLiveWins[ai]++;
        if(g_LiveAdaptive.anatomyLiveTrades[ai] >= 8) {
            double liveAnatWR = (double)g_LiveAdaptive.anatomyLiveWins[ai] / g_LiveAdaptive.anatomyLiveTrades[ai];
            g_LiveAdaptive.anatomyLiveWR[ai] = liveAnatWR;
            // If live anatomy WR diverges significantly from calibrated weight, blend toward live
            if(g_CandleWeightsCalibrated && ai < 14) {  // slots 14/15 are live-only (no calibrated source)
                double calibW = g_CalibratedCandleWeights[ai];
                double liveImpliedW = MathMax(0.3, MathMin(2.0, liveAnatWR / 0.65));
                // 30% live, 70% calibrated -- live takes over gradually as sample grows
                double blendFactor = MathMin(0.30, g_LiveAdaptive.anatomyLiveTrades[ai] / 100.0);
                g_CalibratedCandleWeights[ai] = calibW * (1.0 - blendFactor) + liveImpliedW * blendFactor;
            }
        }
    }

    // ## CALIBRATED PRIOR FOR UNSEEN REGIMES #################################
    // If a regime hasn't been seen in live trading yet, seed its WR from the
    // Phase 2 calibrated regime WR -- the best prior we have before live data.
    // This means regime blocking works from trade 1 in that regime, not trade 15.
    if(g_WeightsOptimized && regime >= 0 && regime < 9) {
        if(g_LiveAdaptive.regimeTrades[regime] < 5 && g_RegimeLiveWR[MathMin(8,MathMax(0,regime))] > 0.0) {
            g_LiveAdaptive.regimeLiveWR[regime] = g_RegimeLiveWR[MathMin(8,MathMax(0,regime))];
        }
    }

    // ## LIVE EDGE SCORE #######################################################
    // Rolling composite of WR alignment, score discrimination, and session quality.
    // Read by CalculateStatisticalEdge (post-calibration path) for 20% blend.
    if(g_LiveAdaptive.totalLiveTrades >= 20) {
        double _calWR2 = (g_WeightsOptimized && g_E99_Validation.expectedWinRate > 0.1)
            ? g_E99_Validation.expectedWinRate / 100.0 : 0.65;
        double _rolWR2 = g_Risk.recentWinRate / 100.0;
        double _wrComp = MathMax(0.0, MathMin(1.0, 0.5 + (_rolWR2 - _calWR2) * 3.0));
        double _discComp = 0.5;
        if(g_LiveAdaptive.scoreBucketTrades[4] >= 5 && g_LiveAdaptive.scoreBucketTrades[0] >= 5)
            _discComp = MathMax(0.0, MathMin(1.0, 0.5 +
                (g_LiveAdaptive.scoreBucketWR[4] - g_LiveAdaptive.scoreBucketWR[0]) * 2.5));
        double _sessComp = 0.5, _bestSWR2 = 0;
        for(int _si2=0; _si2<4; _si2++)
            if(g_LiveAdaptive.sessionTrades[_si2] >= 8 && g_LiveAdaptive.sessionLiveWR[_si2] > _bestSWR2)
                _bestSWR2 = g_LiveAdaptive.sessionLiveWR[_si2];
        if(_bestSWR2 > 0) _sessComp = MathMax(0.0, MathMin(1.0, _bestSWR2));
        g_LiveAdaptive.liveEdgeScore = _wrComp * 0.50 + _discComp * 0.30 + _sessComp * 0.20;
    }


    // ## Self-calibrated threshold (Bayesian bucket discrimination) ###########
    if(g_LiveAdaptive.totalLiveTrades >= 50) {
        // Find the bucket where WR first exceeds the calibrated baseline + 3pp
        double _calBase = (g_WeightsOptimized && g_E99_Validation.expectedWinRate > 0.1)
            ? g_E99_Validation.expectedWinRate / 100.0 : 0.65;
        double _edgeBucket = -1;  // bucket index where edge reliably starts
        for(int _ck = 4; _ck >= 0; _ck--) {
            if(g_LiveAdaptive.scoreBucketTrades[_ck] >= 8 &&
               g_LiveAdaptive.scoreBucketWR[_ck] >= _calBase + 0.03) {
                _edgeBucket = _ck;
                break;
            }
        }
        // Map edge bucket to threshold: bucket 4 (highest score) = threshold 65
        // bucket 3 = 60, bucket 2 = 55. Floor at 50, cap at 70.
        if(_edgeBucket >= 0) {
            double _impliedThr = 50.0 + _edgeBucket * 5.0;
            // Confidence: how many trades in the edge bucket?
            double _edgeBucketConf = MathMin(1.0, g_LiveAdaptive.scoreBucketTrades[(int)_edgeBucket] / 30.0);
            // Blend: existing threshold x (1-conf) + implied x conf
            double _blended = g_LiveAdaptive.liveOptimalThreshold * (1.0 - _edgeBucketConf * 0.3)
                            + _impliedThr * (_edgeBucketConf * 0.3);
            double _prevThr = g_LiveAdaptive.liveOptimalThreshold;
    g_LiveAdaptive.liveOptimalThreshold    = MathMax(48.0, MathMin(75.0, _blended));
    if(MathAbs(g_LiveAdaptive.liveOptimalThreshold - _prevThr) >= 2.0 && EnableFriendlyLogs && !g_CalibSilent)
        PrintFormat("  threshold drift   |   %.0f→%.0f   |   score discrimination %.2f",
            _prevThr, g_LiveAdaptive.liveOptimalThreshold,
            g_LiveAdaptive.scoreBucketWR[4] - g_LiveAdaptive.scoreBucketWR[0]);
            g_LiveAdaptive.liveThresholdConfidence = _edgeBucketConf;
        }
        // Compare top bucket (40-50pt above neutral) vs bottom (0-10pt)
        double topWR    = g_LiveAdaptive.scoreBucketWR[4];
        double bottomWR = g_LiveAdaptive.scoreBucketWR[0];
        double topObs   = g_LiveAdaptive.scoreBucketTrades[4];
        double botObs   = g_LiveAdaptive.scoreBucketTrades[0];

        if(topObs >= 5 && botObs >= 5) {
            double discrimination = topWR - bottomWR;  // Positive = score is working
            // High discrimination -> system knows what it's doing -> can lower threshold
            // Low/negative discrimination -> score is random -> raise threshold
            if(discrimination > 0.15) {
                g_LiveAdaptive.liveOptimalThreshold = MathMax(52.0, 68.0 - discrimination * 20.0);
                g_LiveAdaptive.liveThresholdConfidence = MathMin(0.70, topObs / 30.0);
            } else if(discrimination < 0.05) {
                g_LiveAdaptive.liveOptimalThreshold = MathMin(82.0, 68.0 + (0.05 - discrimination) * 40.0);
                g_LiveAdaptive.liveThresholdConfidence = 0.40;
            } else {
                g_LiveAdaptive.liveOptimalThreshold = 68.0;
                g_LiveAdaptive.liveThresholdConfidence = 0.25;
            }
        }
    }

    // ## Rolling 30-trade WR and edge score ##################################
    // Count wins in last 30 trades via the ring buffer
    int last30W = g_SmartCB.ghostWins + g_SmartCB.ghostLosses > 0
        ? g_SmartCB.ghostWins : 0;  // approximate from available counters
    g_LiveAdaptive.liveWR30 = g_Risk.recentWinRate / 100.0;

    // Edge score: combination of WR above baseline and score discrimination
    // FIX26 DEAD: double wrEdge = MathMax(0.0, g_LiveAdaptive.liveWR30 - 0.65) * 3.0;  // 0 at 65%, 1 at 98%
    // FIX26 DEAD: int regimesWithEdge = 0;
    int regimesSampled = 0;
    for(int ri2 = 0; ri2 < 9; ri2++) if(g_LiveAdaptive.regimeTrades[ri2] >= 15) regimesSampled++;
    g_LiveAdaptive.selfCalibrated = (regimesSampled >= 2 && g_LiveAdaptive.totalLiveTrades >= 30);
}

void EvaluatePerformanceTier() {
    // Initialise on first call
    if(g_Tier.currentTier == 0 && g_Tier.tierUnlockedAt == 0) {
        g_Tier.currentTier = TIER_FLOOR;
        g_Tier.consecutiveMediumDays = 0;
        g_Tier.consecutiveFallbackDays = 0;
    }

    if(g_State.totalTrades < 30) return;  // Need data before reasoning

    double rollingWR = g_Risk.recentWinRate;  // 20-trade rolling WR
    int today = TimeDay(TimeCurrent());
    static int lastTierDay = 0;
    if(today == lastTierDay) return;  // Evaluate once per day
    lastTierDay = today;

    // ## MEDIUM TIER UNLOCK ###################################################
    bool regimeQualityOk = true;
    if(g_CorrelationsLearned) {
        int _tReg = g_RegimeState.currentRegime;
        if(_tReg >= 0 && _tReg < 9 && g_RegimeCorrelations[_tReg].signalTotal >= 5) {
            if(g_RegimeCorrelations[_tReg].signalWR > 0.05 && g_RegimeCorrelations[_tReg].signalWR < 0.60)
                regimeQualityOk = false;  // calibrated-poor regime — don't inflate tier
        }
    }
    bool canUnlockMedium = (g_State.totalTrades >= 30 && rollingWR >= MED_LEARNED_WR && regimeQualityOk);
    double sustainThreshold = MED_LEARNED_WR - 3.0;  // 69% -- 3pt tolerance

    // Alignment as ACCELERATOR not GATE for MEDIUM tier:
    // CEO alignment at 0.70+ earns an early unlock (20 trades instead of 30).
    // CEO alignment at 0.80+ earns a bonus: risk cap slightly higher for first week.
    double _tierAlign = GetMarketAlignment();
    int tr = g_State.totalTrades;
    bool earlyUnlock = (_tierAlign >= 0.70 && rollingWR >= MED_LEARNED_WR && tr >= 20);
    bool bonusUnlock  = (_tierAlign >= 0.80 && rollingWR >= MED_LEARNED_WR && tr >= 30);

    if(g_Tier.currentTier == TIER_FLOOR && (canUnlockMedium || earlyUnlock)) {
        g_Tier.currentTier = TIER_MEDIUM;
        if(earlyUnlock && tr < 30)
            PrintFormat("  tier upgrade   |   MEDIUM   |   early unlock   |   alignment %.2f earned it", _tierAlign);
        g_Tier.tierUnlockedAt = TimeCurrent();
        g_Tier.consecutiveMediumDays = 1;
        g_Tier.consecutiveFallbackDays = 0;
        g_Tier.mediumEverUnlocked = true;
        g_Tier.peakTierWR = rollingWR;

        // Upgrade ghost trigger to MED tier (5 consecutive losses at medium tier)
        // -- system is performing well, allow slightly more tolerance
        lastSignificantLog = TimeCurrent();
        PrintFormat("  LIVE  |   tier   floor -> medium   |   WR %.0f%% (+%.0fpp)   |   %d trades   |   20 tpd now",
                    rollingWR, rollingWR - FLOOR_START_WR, g_State.totalTrades);

        // Apply medium tier parameters
        RecoveryDrawdownTrigger = MED_SLINGSHOT_THRESHOLD;
        return;
    }

    // ## MEDIUM TIER SUSTAIN ##################################################
    if(g_Tier.currentTier == TIER_MEDIUM) {
        if(rollingWR >= sustainThreshold) {
            g_Tier.consecutiveMediumDays++;
            g_Tier.consecutiveFallbackDays = 0;
            if(rollingWR > g_Tier.peakTierWR) g_Tier.peakTierWR = rollingWR;
        } else {
            g_Tier.consecutiveFallbackDays++;
            PrintFormat("  tier warning   |   WR %.1f%% below sustain %.0f%%   |   day %d/2 before fallback",
                        rollingWR, sustainThreshold, g_Tier.consecutiveFallbackDays);

            if(g_Tier.consecutiveFallbackDays >= 2) {
                // Fall back to FLOOR tier
                g_Tier.currentTier = TIER_FLOOR;
                g_Tier.consecutiveFallbackDays = 0;
                RecoveryDrawdownTrigger = FLOOR_SLINGSHOT_THRESHOLD;  // 15%

                PrintFormat("  TIER FALLBACK   |   MEDIUM -> FLOOR   |   WR %.1f%%   |   2 days below %.0f%%",
                            rollingWR, sustainThreshold);
                Print("  floor spec restored   |   system will re-earn medium tier when WR recovers");
            }
        }
    }

    // ## FLOOR TIER RE-QUALIFY ################################################
    if(g_Tier.currentTier == TIER_FLOOR && g_Tier.mediumEverUnlocked) {
        if(rollingWR >= MED_LEARNED_WR) {
            g_Tier.consecutiveFallbackDays = 0;
            // Will unlock on next evaluation when canUnlockMedium passes
        }
    }
}

//| NOT "winning = accelerate" but "winning + strong trend + high    |
//| confidence + stable regime = strategic acceleration"             |
void EvaluateSmartAcceleration() {
    g_Aggressive.shouldAccelerate = false;
    g_Aggressive.accelerationReason = "";
    
    
    // 1. Performance check
    bool performingWell = (g_Risk.recentWinRate > 70 && g_Risk.recentProfitFactor > 1.8);
    
    // 2. Trend strength
    double adx = iADX(_Symbol, PERIOD_CURRENT, 14, PRICE_CLOSE, MODE_MAIN, 0);
    g_Aggressive.trendStrength = adx;
    bool strongTrend = (adx > 30);
    
    // 3. Market structure clarity (check MA alignment)
    double ma20 = iMA(_Symbol, PERIOD_CURRENT, 20, 0, MODE_SMA, PRICE_CLOSE, 0);
    double ma50 = iMA(_Symbol, PERIOD_CURRENT, 50, 0, MODE_SMA, PRICE_CLOSE, 0);
    double ma200 = iMA(_Symbol, PERIOD_CURRENT, 200, 0, MODE_SMA, PRICE_CLOSE, 0);
    bool clearStructure = ((ma20 > ma50 && ma50 > ma200) || (ma20 < ma50 && ma50 < ma200));
    
    // 4. Regime stability - REAL tracking of regime changes
    static int lastTrackedRegime = -1;
    static int barsSinceRegimeChange = 0;
    static int regimeChangesLast100Bars = 0;
    static int barCounter = 0;
    
    int currentRegime = DetectCurrentRegime();
    barCounter++;
    
    if(currentRegime != lastTrackedRegime && lastTrackedRegime != -1) {
        regimeChangesLast100Bars++;
        barsSinceRegimeChange = 0;
        lastTrackedRegime = currentRegime;
    } else if(currentRegime == lastTrackedRegime) {
        barsSinceRegimeChange++;
    } else if(lastTrackedRegime == -1) {
        lastTrackedRegime = currentRegime;
        barsSinceRegimeChange = 0;
    }
    
    // Reset counter every 100 bars
    if(barCounter >= 100) {
        regimeChangesLast100Bars = 0;
        barCounter = 0;
    }
    
    // Regime is stable if: Same regime for 20+ bars AND < 3 changes in last 100 bars
    bool stableRegime = (barsSinceRegimeChange >= 20 && regimeChangesLast100Bars < 3);
    
    // 5. Milestone position (accelerate ONLY if on-track or ahead, NOT behind)
    bool milestonePositionOK = (g_Goal.trajectoryScore >= -10);  // Not more than 10% behind
    
    // 6. Pattern confluence - REAL confidence from recent performance
    // Calculate from recent win rate and regime-specific win rate
    double recentWR = 50.0;  // Default
    if(g_TradeHistoryCount >= 20) {
        int recentWins = 0;
        int recentCount = MathMin(20, g_TradeHistoryCount);
        for(int i = 0; i < recentCount; i++) {
            if(g_TradeHistory[g_TradeHistoryCount - 1 - i].won) {
                recentWins++;
            }
        }
        recentWR = (recentCount > 0) ? (double)recentWins / recentCount * 100.0 : 0.0;  // FIX
    }
    
    // Get regime-specific win rate if available
    double regimeWR = 50.0;  // Default
    if(currentRegime >= 0 && currentRegime < 9) {
        if(g_RegimeLearning.regimes[currentRegime].totalTrades > 0) {
            regimeWR = (double)g_RegimeLearning.regimes[currentRegime].wonTrades / 
                       g_RegimeLearning.regimes[currentRegime].totalTrades * 100.0;
        }
    }
    
    // Confidence is blend of recent performance and regime-specific performance
    g_Aggressive.confidenceLevel = (recentWR * 0.6) + (regimeWR * 0.4);
    bool highConfidence = (g_Aggressive.confidenceLevel > 70);
    
    // DECISION: Accelerate ONLY if ALL conditions met
    g_Aggressive.marketConditionsFavorable = (strongTrend && clearStructure && stableRegime);
    
    if(performingWell && g_Aggressive.marketConditionsFavorable && milestonePositionOK && highConfidence) {
        g_Aggressive.shouldAccelerate = true;
        g_Aggressive.accelerationReason = "Strong trend + High WR + Clear structure + On trajectory";
    }
}

// --─ L7 LIVE ADAPTATION — Intelligence memory and system state structs --
//     (IntelligenceMemory, AlgorithmicIntuition, MarketMemory, StrategyGenerator)
struct IntelligenceMemory {
    IntelligentAssessment assessments[5000];
    int count;
    int decisionsCorrect;
    int decisionsWrong;
    double averageConfidenceWhenRight;
    double averageConfidenceWhenWrong;
};

IntelligenceMemory g_IntelligenceMemory;

// E6 SUPERIOR INDICATORS

// --─ Market Character Analysis: Hurst exponent ------------------------─
double E99_HurstExponent(int startBar, int periods) {
    // CEO-E (9.18A): Multi-scale R/S Hurst exponent via log-log regression
    // Uses 4 scales {25,50,75,100% of periods} for proper Hurst estimation.
    // Single-scale R/S is noisy; log-log regression over multiple scales is standard.
    if(startBar + periods + 2 >= Bars || periods < 20) return 0.5;
    int _scales[4]; _scales[0]=periods/4; _scales[1]=periods/2;
    _scales[2]=(int)(periods*0.75); _scales[3]=periods;
    if(_scales[0] < 8) _scales[0] = 8;
    double _logN[4]; ArrayInitialize(_logN,0.0);
    double _logRS[4]; ArrayInitialize(_logRS,0.0);
    int _nScales = 0;
    for(int _si = 0; _si < 4; _si++) {
        int _sc = _scales[_si];
        if(startBar + _sc + 1 >= Bars) continue;
        double _mean = 0;
        for(int i = 0; i < _sc; i++) {
            double p1 = Close[startBar + i], p2 = Close[startBar + i + 1];
            _mean += (p2 > 0) ? MathLog(p1 / p2) : 0;
        }
        _mean /= _sc;
        double _cumDev = 0, _maxD = 0, _minD = 0, _var = 0;
        for(int i = 0; i < _sc; i++) {
            double p1 = Close[startBar+i], p2 = Close[startBar+i+1];
            double _ret = (p2 > 0) ? MathLog(p1/p2) : 0;
            _var += (_ret - _mean) * (_ret - _mean);
            _cumDev += (_ret - _mean);
            if(_cumDev > _maxD) _maxD = _cumDev;
            if(_cumDev < _minD) _minD = _cumDev;
        }
        double _range = _maxD - _minD;
        double _std = SafeSqrt(_var / _sc);
        if(_std < 0.000001 || _range < 0.000001) continue;
        _logN[_nScales] = MathLog((double)_sc);
        _logRS[_nScales] = SafeLog(_range / NonZero(_std));
        _nScales++;
    }
    if(_nScales < 2) return 0.5;
    // OLS log-log regression: H = slope of log(R/S) vs log(n)
    double _sumX=0,_sumY=0,_sumXX=0,_sumXY=0;
    for(int i=0;i<_nScales;i++){_sumX+=_logN[i];_sumY+=_logRS[i];_sumXX+=_logN[i]*_logN[i];_sumXY+=_logN[i]*_logRS[i];}
    double _denom = _nScales*_sumXX - _sumX*_sumX;
    if(MathAbs(_denom) < 0.000001) return 0.5;
    double H = (_nScales*_sumXY - _sumX*_sumY) / _denom;
    return MathMax(0.0, MathMin(1.0, H));
}

// --─ Market Character Analysis: Fractal dimension ----------------------
double E99_FractalDimension(int startBar, int periods) {
    if(startBar + periods >= Bars) return 1.5;
    
    double priceMax = Close[startBar], priceMin = Close[startBar];
    for(int i = 0; i < periods; i++) {
        double price = Close[startBar + i];
        if(price > priceMax) priceMax = price;
        if(price < priceMin) priceMin = price;
    }
    
    double priceRange = priceMax - priceMin;
    if(priceRange == 0) return 1.5;
    
    double pathLength = 0;
    for(int i = 0; i < periods - 1; i++) {
        pathLength += MathAbs(Close[startBar + i] - Close[startBar + i + 1]);
    }
    
    if(pathLength == 0) return 1.5;
    
    double FD = 1.0 + SafeLog(pathLength / NonZero(priceRange)) / SafeLog(periods);
    return MathMax(1.0, MathMin(2.0, FD));
}

// --─ Market Character Analysis: Entropy --------------------------------─
double E99_MarketEntropy(int startBar, int periods, int bins) {
    if(startBar + periods >= Bars) return 0.5;
    
    double changes[];
    if(ArrayResize(changes, periods) < periods) return 0.0;
    double maxChange = 0.0001;
    
    for(int i = 0; i < periods; i++) {
        changes[i] = Close[startBar + i] - Close[startBar + i + 1];
        double absChange = MathAbs(changes[i]);
        if(absChange > maxChange) maxChange = absChange;
    }
    
    int histogram[];
    if(ArrayResize(histogram, bins) < bins) return 0.0;
    ArrayInitialize(histogram, 0);
    
    for(int i = 0; i < periods; i++) {
        int binIndex = (int)((changes[i] / maxChange + 1.0) / 2.0 * (bins - 1));
        binIndex = MathMax(0, MathMin(bins - 1, binIndex));
        histogram[binIndex]++;
    }
    
    double entropy = 0;
    for(int i = 0; i < bins; i++) {
        if(histogram[i] > 0) {
            double p = (double)histogram[i] / periods;
            entropy -= p * MathLog(p) / MathLog(2.0);
        }
    }
    
    // OP-A (9.18A): Normalise by achievable max (85% of theoretical for market returns)
    // Market returns cluster near zero — uniform distribution is never achieved.
    // Normalising by theoretical log(bins) compresses the signal toward the middle.
    double maxEntropy = MathLog(bins) / MathLog(2.0) * 0.85;  // OP-A: realistic ceiling
    if(maxEntropy > 0) entropy /= maxEntropy;
    
    return MathMax(0.0, MathMin(1.0, entropy));
}

// --─ Regime metrics: Hurst + Fractal + Entropy composite --------------─

void E99_GetRegimeMetrics(int bar, double &trendConf, double &meanRevConf, double &noiseConf) {
    double H = E99_HurstExponent(bar, 100);
    double FD = E99_FractalDimension(bar, 50);
    double entropy = E99_MarketEntropy(bar, 100);
    
    trendConf = 0;
    if(H > 0.55) trendConf += (H - 0.55) / 0.35 * 40;
    if(FD < 1.5) trendConf += (1.5 - FD) / 0.5 * 30;
    if(entropy < 0.5) trendConf += (0.5 - entropy) / 0.5 * 30;
    
    meanRevConf = 0;
    if(H < 0.45) meanRevConf = (0.45 - H) / 0.35 * 100;
    
    noiseConf = 0;
    if(FD > 1.6) noiseConf += (FD - 1.6) / 0.4 * 50;
    if(entropy > 0.6) noiseConf += (entropy - 0.6) / 0.4 * 50;
}

// E9.9 SCORE CALCULATION ENGINE

// ===== SLS12 T1: SHARED SCORE CORE =====
// The single source of truth for scoring at an arbitrary historical bar. Calibration, config
// testing, and conviction self-calibration ALL route through this so they evaluate the EXACT
// bidirectional (-100..+100) score the live system trades on — eliminating the old toy-vs-real
// divergence. It installs the candidate component weights into the regime slot that the live
// Enhanced engine reads, scores the bar through that real engine, then restores the originals.
// `weights[]` order matches ComponentWeights: [mtf, momentum, volume, volatility, session, pattern, ...].
double CalculateUnifiedScoreCoreAtBar(int bar, double &weights[]) {
    if(bar < 1 || bar >= Bars) return 0.0;
    // Determine this bar's regime so we install the candidate weights into the slot Enhanced uses.
    MarketStateFeatures _f = CalculateMarketFeatures(bar);
    int _reg = ClassifyBarToRegime(_f, bar);
    if(_reg < 0 || _reg > 8) _reg = 0;
    // Save originals, install candidate, score through the REAL engine, restore.
    ComponentWeights _saved = g_RegimeOptimalWeights[_reg];
    if(ArraySize(weights) >= 6) {
        g_RegimeOptimalWeights[_reg].mtf        = weights[0];
        g_RegimeOptimalWeights[_reg].momentum   = weights[1];
        g_RegimeOptimalWeights[_reg].volume     = weights[2];
        g_RegimeOptimalWeights[_reg].volatility = weights[3];
        g_RegimeOptimalWeights[_reg].session    = weights[4];
        g_RegimeOptimalWeights[_reg].pattern    = weights[5];
    }
    double _score = CalculateEnhancedUnifiedScore(bar);
    g_RegimeOptimalWeights[_reg] = _saved;   // restore — never leave candidate installed
    return _score;
}

// [SLS13 C3] retired dead function CalculateUnifiedScoreAtBar (139 lines, zero refs)

//| PHASE 2.1: SMART GRID SEARCH (5-7 minutes)                       |

//| PHASE 2.2: FOCUSED REFINEMENT (8-10 minutes)                     |

//| PHASE 2.3: WALK-FORWARD VALIDATION (3-4 minutes)                 |

//| PHASE 2.4: ELITE CONFIGURATION (1-2 minutes)                     |

//| MAIN PHASE 2 COORDINATOR                                         |
//| Calls appropriate sub-phase based on current stage               |

//| Detect Current Regime (calibrated + hysteresis)                  |
int DetectCurrentRegime() {
    if(Bars < 50) return 4;  // Default: clean range (safe default)
    MarketStateFeatures f = CalculateMarketFeatures(0);

    // Hysteresis-protected rule-based classifier (stable, low-latency)
    int ruleRegime = ClassifyBarToRegime_WithHysteresis(f, 0);

    int _finalReg = ruleRegime;
    // Correlation-based prediction (Phase 2 learned signatures)
    if(g_CorrelationsLearned) {
        int corrRegime = PredictRegimeFromCorrelations(f);
        if(corrRegime >= 0 && corrRegime < 9 &&
           g_RegimeCorrelations[corrRegime].overallAccuracy >= 0.65) {
            _finalReg = corrRegime;  // Correlation model confident -- use it

            // 9.40 (thesis item 5): resolved the "does this sync back?" ambiguity flagged
            // in 9.38/9.39. Determined this was unfinished wiring, not an intentional
            // confirmation-only signal: nothing in this branch (unlike the FIX55 DNA check
            // just below) documented a deliberate "does not change classification" intent,
            // and several OTHER call sites read g_RegimeState.currentRegime directly
            // (position sizing, TP/SL RR selection, tier-exit logic) rather than calling
            // this function -- so those decisions silently disagreed with whatever this
            // function returned to ITS caller for the same bar. Finishing the wiring here,
            // but gated on the same real-time structural-evidence check the raw hysteresis
            // path requires (RegimeHasStructuralConfirmation), so a historically-confident
            // correlation (>=65% accuracy, accumulated over many past bars) still can't
            // overwrite live regime state without current-bar corroboration -- preserves
            // the anti-whipsaw intent of the hysteresis system instead of bypassing it.
            if(corrRegime != g_RegimeState.currentRegime &&
               RegimeHasStructuralConfirmation(corrRegime, f)) {
                if(g_RegimePrevCapture >= 0 && g_RegimePrevCapture < 9)
                    g_RegimeTransitions[g_RegimePrevCapture][corrRegime]++;
                g_RegimePrevCapture                 = corrRegime;
                g_RegimeState.currentRegime         = corrRegime;
                g_RegimeState.confirmedBars         = 1;
                g_RegimeState.transitionRegime      = -1;
                g_RegimeState.transitionConfirmBars = 0;
                g_RegimeState.inTransition           = false;
                g_LastRegimeChangeBar               = (Bars > 0) ? Bars : 0;
                g_RegimeState.lastChange            = TimeCurrent();
                if(!g_Calibration.isCalibrating)
                    PrintFormat("  REGIME |   %s   |   correlation-confirmed (structural)   |   thr -> %.0f",
                                GetRegimeName(corrRegime), g_CurrentThreshold);
            }
        }
    }

    // FIX55 REGIME DNA: characterise the live market and measure how well it matches the
    // resolved regime's established behavioural signature. This AUGMENTS confidence and
    // provides an online transition signal — it does NOT change the classification or any
    // trade gate. Filtered (bar 1 back), so no look-ahead. Cheap: once per bar via caller.
    ComputeRegimeDNA(1, 40, g_LiveDNA);
    g_RegimeDNA_Match = RegimeDNAMatch(_finalReg, g_LiveDNA);
    g_RegimeDNA_Drift = 1.0 - g_RegimeDNA_Match;

    // SLS18 RANK4: regime age — track once per bar via Time[0] guard
    {
        static datetime _raLastBar = 0;
        static int      _raLastReg = -1;
        if(Time[0] != _raLastBar) {
            if(_raLastReg >= 0 && _finalReg != _raLastReg) {
                if(!g_Calibration.isCalibrating)
                    TLog(StringFormat("  LIVE  ·  regime transition  ·  %s → %s  ·  conviction dampened 12 bars",
                        GetRegimeName(_raLastReg), GetRegimeName(_finalReg)));
                g_RegimeAge = 0;
            } else if(g_RegimeAge < 999) {
                g_RegimeAge++;
            }
            _raLastReg = _finalReg;
            _raLastBar = Time[0];
        }
    }

    return _finalReg;
}

//| Catastrophic Recalibration — Level 3 Contingency                 |

// -- Catastrophic Recalibration — Level 3 Contingency ------------------------
// Called when Building tier confirms that previous calibration assumptions
// were NOT just drifted but fundamentally WRONG.
// Key difference from normal recalibration:
//   Normal:  re-runs same phases with same logic — finds new optimal params
//   Catastrophic: knows old answers were wrong - corrects for that bias
//                 purges stale correlations, forces fresh regime detection,
//                 uses recency-weighted data, wider search, no inheritance
void TriggerCatastrophicRecalibration(int reasonCode) {
    if(g_CatastrophicRecalib) return;  // already in progress

    // Log the diagnosis
    string _reasons[] = {"calibration age", "WR collapse", "PF collapse",
                         "regime shift", "multiple drift factors"};
    string _why = (reasonCode >= 0 && reasonCode < 5) ? _reasons[reasonCode] : "unknown";
    PrintFormat("  CATREC|   recalibrating   drift source: %s   |   anti-bias active", _why);
    PrintFormat("    live WR %.0f%%  prev calib WR %.0f%%  threshold %.0f  regime %s",
                g_Risk.recentWinRate,
                g_Calibration.baselineWR * 100.0,
                g_CurrentThreshold,
                GetRegimeName(g_RegimeState.currentRegime));

    // Snapshot pre-recalib state for comparison after
    g_Calibration.preCalibLiveWR   = g_Risk.recentWinRate;
    g_Calibration.preCalibThreshold = g_CurrentThreshold;
    g_Calibration.catastrophicMode  = true;
    g_Calibration.catastrophicReason = reasonCode;
    g_Calibration.catastrophicStartTime = TimeCurrent();
    // SLS(20): catastrophic mode declares the previous calibration fundamentally wrong --
    // the 9.42 subsystems must not keep trusting its outputs. Reset the geometry flag so
    // the IC pass falls back to per-regime mirror multipliers (not the discredited 3C
    // values), and the duration flag so continuationProb uses its legacy estimate until
    // this recalibration re-measures regime durations. Both re-arm inside this same run
    // (3C sets the geometry flag; the transition scan sets the duration flag).
    g_TPSLMultCalibrated       = false;
    g_RegimeDurationCalibrated = false;
    ArrayInitialize(g_RegimeBracketFallback, false);  // WARRANT#80: stale fallback flags don't survive a catastrophic geometry reset

    // -- Purge stale correlations ----------------------------------------─
    // If these regime correlations led to bad trades, they need fresh data
    // Only purge regimes where live performance was demonstrably poor
    for(int _r = 0; _r < 9; _r++) {
        if(g_RegimeStats[_r].trades >= 10) {
            double _liveWR = (g_RegimeStats[_r].trades > 0)
                ? (double)g_RegimeStats[_r].wins / g_RegimeStats[_r].trades : 0.5;
            if(_liveWR < 0.50) {
                // This regime specifically failed — zero its calibration confidence
                // Don't delete (we need structure) but reset weight to 0.5 (neutral)
                g_RegimeCorrelations[_r].signalWR    = 0.50;  // neutral prior
                g_RegimeCorrelations[_r].signalTotal = 0;     // force fresh learning
                g_RegimeCorrelations[_r].lowVolWR    = 0.0;
                g_RegimeCorrelations[_r].medVolWR    = 0.0;
                g_RegimeCorrelations[_r].highVolWR   = 0.0;
                PrintFormat("    purged regime %d (%s) — live WR was %.0f%%",
                            _r, GetRegimeName(_r), _liveWR * 100);
            }
        }
    }

    // -- Reset ProbDB for this pair ------------------------------------─
    // The probability buckets were trained on a market that no longer applies
    // Clear them so they rebuild from the next trades, not the failed history
    // Clear ProbDB thin buckets — they were built on failed assumptions
    // ProbDB reset: full clear via struct reset
    ArrayInitialize(g_ProbDB.regimePatternCounts, 0);
    ArrayInitialize(g_ProbDB.scoreZonePatternCounts, 0);
    g_ProbDB.totalSamples = 0; g_ProbDB.patternCount = 0;

    // -- Reset GLOT live adaptation ------------------------------------─
    // The live threshold drift was trained on wrong assumptions
    // Reset it to calibration baseline so catastrophic recalib starts clean
    g_LiveAdaptive.liveOptimalThreshold = 0;  // will be recomputed from fresh calib

    // -- Set catastrophic recalibration flag for all phases ------------
    g_CatastrophicRecalib = true;
    g_CatastrophicReasonCode = reasonCode;

    // -- Trigger recalibration ----------------------------------------─
    g_Calibration.isComplete  = false;
    g_Calibration.isCalibrating = false;  // will re-trigger on next tick
    g_CEO_NeedsRecalibration  = false;
    g_Calibration.calibrationAttempts = 0;  // fresh attempt counter
}

void RunMarketCalibration() {
    // Connection guard — pause on disconnect, resume automatically
    if(!IsConnected()) {
        static datetime _dcLog=0;
        if(TimeCurrent()-_dcLog>300){
            Print("  CAL   |   broker disconnected   |   pausing   |   will resume");
            _dcLog=TimeCurrent();
        }
        return;
    }
    // Minimum Bars guard — wait until price history is available
    if(Bars < 500) return;  // minimum bars for calibration (Phase 1 needs bar 500+)
    // DIAGNOSTIC: Log first call only
    static int callCount = 0;
    callCount++;
    
    if(callCount == 1) {
        DetectServerTimeOffset();  // GMT offset detection before calibration
    }
    
    // CRITICAL: Call the actual calibration logic
    bool calibrationResult = RunCalibrationMode();
    
    // Log only when complete - suppress intermediate call noise
    if(calibrationResult && callCount <= 10) {
        // completion logged by LogStartup() online banner
    }
    
    // If calibration completes successfully, mark it done
    if(calibrationResult) {
        g_Calibration.isComplete = true;
    if(!g_CalibSilent && !g_Calibration.executionSuspended) {
            // HONEST COMPOUNDING PROJECTION: derived from measured edge, not aspiration.
            // 9.40 (thesis item 2): now routed through CalculateDefensibleDailyGrowthRateCore,
            // the same half-Kelly geometric formula E99_CalculatePathToMillion() uses live --
            // previously this block computed a second, additive-edge answer to the same
            // question with different math, so the system reported two different growth
            // numbers for the same concept depending on which code path asked.
            double _gpWR  = (g_Ghost_Total>10)?(double)g_Ghost_Wins/MathMax(1,g_Ghost_Total):0.0;
            double _gpTPD = MathMax(1.0, g_BaselineTradesPerDay);
            double _gpStartProj = 0, _gpMedianReturn = 0;
            double _gpDayFrac = CalculateDefensibleDailyGrowthRateCore(_gpWR, g_P6_AvgRR, _gpTPD,
                                                                        _gpStartProj, _gpMedianReturn);
            double _gpDay  = _gpDayFrac * 100.0;  // as %/day, matching prior log format
            int    _gpDays = (_gpDay > 0.01) ? (int)MathCeil(MathLog(10.0)/MathLog(1.0+_gpDay/100.0)) : 0;
            if(_gpDays > 0)
                PrintFormat("  GAME PLAN |   half-Kelly WR %.1f%%  RR %.2f  x  %.1f trades/day   |   ~%.2f%%/day   |   10x in ~%d trading days",
                            _gpWR*100.0, g_P6_AvgRR, _gpTPD, _gpDay, _gpDays);
            else
                Print("  GAME PLAN |   edge too thin to project compounding   |   live validation will tell the truth");
            PrintFormat("  TUNGSTEN  |   %d out-of-sample trades stand behind this   |   we go careful, then we go", g_Ghost_Total);
        }
        // After catastrophic recalib: mandatory ghost before live
        if(g_Calibration.catastrophicMode && !g_SmartCB.inGhostMode) {
            ActivateGhostMode();
            Print("  CATREC  |   recalibration complete — ghost validation required before live");
            PrintFormat("    new threshold %.0f (was %.0f)   new WR gate 68%%",
                        g_CurrentThreshold, g_Calibration.preCalibThreshold);
            g_Calibration.catastrophicMode = false;  // recalib done; ghost validates it
            g_CatastrophicRecalib = false;
        }
        if(g_Calibration.fragileFlag)
            Print("  ⚠ armed   |   walk-forward instability detected   |   monitor performance closely");

        // E9.9: Validate calibration quality
        if(E99_Enable && g_E99_Initialized) {
            E99_ValidateCalibration();
        }

        // ## Wire calibration outputs to live execution ##################
        // Gate thresholds from Phase 5.1 scenario banks + Phase 2 correlations
        BuildCustomGatesFromCalibration();

        // ## Seed live-accumulation stats from calibration results ########
        if(g_WeightsOptimized) {
            // Regime stats: convert CEUS magnitude to normalized threshold
            for(int _sr = 0; _sr < 9; _sr++) {
                double _thr = MathMax(58.0, MathMin(85.0,
                              50.0 + g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_sr))] / 2.0));
                g_RegimeStats[_sr].optimalThreshold = _thr;
                // Mark as seeded but not data-confirmed (hasData stays false
                // until real trades flow -- avoids polluting the WR fields)
            }
            // Session stats: map GMT hours to session index, use best available threshold
            // Sessions: 0=London(7-16), 1=NY(16-21), 2=Asia(21-7), 3=Sydney(21-6)
            // SLS(20) SYNC FIX: this map previously used its own hour windows (London 7-16,
            // NY 16-21, Asia 21-7) while Phase 3B.5 trains under DIFFERENT windows
            // (London 7-16, NY 12-21, Asia 0-9, Sydney 21-6) -- so for hours like 22 this
            // block consulted Asia's validity for weights 3B.5 had trained under Sydney,
            // and session 3 was unreachable entirely. The map is now derived from the SAME
            // window definitions 3B.5 uses; overlap hours resolve to whichever member
            // session carries the most validated regimes (evidence-weighted, not arbitrary).
            int sesMap[24];
            {
                int _smStart[4]; _smStart[0]=7;  _smStart[1]=12; _smStart[2]=0; _smStart[3]=21;
                int _smEnd[4];   _smEnd[0]=16;   _smEnd[1]=21;   _smEnd[2]=9;  _smEnd[3]=6;
                for(int _h2 = 0; _h2 < 24; _h2++) {
                    int _best = 2, _bestValid = -1;   // default Asia if no window claims the hour
                    for(int _s2 = 0; _s2 < 4; _s2++) {
                        bool _member = (_smStart[_s2] <= _smEnd[_s2])
                                     ? (_h2 >= _smStart[_s2] && _h2 < _smEnd[_s2])
                                     : (_h2 >= _smStart[_s2] || _h2 < _smEnd[_s2]);  // wraparound (Sydney 21-6)
                        if(!_member) continue;
                        int _v = 0;
                        for(int _r2 = 0; _r2 < 9; _r2++) if(g_SessionWeightsValid[_s2][_r2]) _v++;
                        if(_v > _bestValid) { _bestValid = _v; _best = _s2; }
                    }
                    sesMap[_h2] = _best;
                }
            }
            // For each hour, pick the regime that dominates that session
            // and seed from its calibrated threshold
            for(int _h = 0; _h < 24; _h++) {
                int _ses = sesMap[_h];
                // 9.42 FIX: the accumulator started at 68.0 and then averaged that seed in
                // with the calibrated thresholds (68 + thr) / count -- one valid regime at
                // threshold 70 produced (68+70)/1 = 138, clamped to 85. Every session hour
                // with ANY valid weights was silently forced to the maximum-conservatism
                // threshold, erasing the per-session calibration this block exists to seed.
                // The 68 seed is now what it was meant to be: the no-data fallback only.
                double _thrSum = 0.0;
                int _bestCount = 0;
                for(int _r = 0; _r < 9; _r++) {
                    if(g_SessionWeightsValid[_ses][_r]) {
                        _thrSum += MathMax(52.0, MathMin(85.0,
                                   50.0 + g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_r))] / 2.0));
                        _bestCount++;
                    }
                }
                double _bestThr = (_bestCount > 0) ? (_thrSum / _bestCount) : 68.0;
                g_SessionStats[_h].optimalThreshold = MathMax(58.0, MathMin(85.0, _bestThr));
            }
        }

        g_Calibration.isCalibrating = false;
        // online banner emitted by LogStartup() on next tick
    }
}


//| Optimize Regime Sensitivities                                    |


//| Extended Ghost Mode - Virtual Trading Validation                 |

//| COMPREHENSIVE ANALYTICS & LIVE ADAPTATION SYSTEM                 |

//| Record Individual Ghost Trade                                    |
void RecordGhostTrade(int bar, bool isLong, double entry, double sl, double tp, 
                      double score, double atr, bool hitTP, bool hitSL, int barsToOutcome,
                      double momentum, double trend, double reversal, double vol) {
    
    int index = g_GhostTradeCount % 100;
    GhostTradeRecord trade;
    
    trade.tradeNumber = g_GhostTradeCount + 1;
    trade.timestamp = iTime(Symbol(), 0, bar);
    trade.barIndex = bar;
    trade.isLong = isLong;
    trade.entryPrice = entry;
    trade.stopLoss = sl;
    trade.takeProfit = tp;
    trade.entryScore = score;
    trade.atrAtEntry = atr;
    trade.hitTP = hitTP;
    trade.hitSL = hitSL;
    trade.timeout = (!hitTP && !hitSL);
    trade.barsToOutcome = barsToOutcome;
    
    double pipValue = MathMax(Point, 0.00001) * 10;  // FIX: guard pipValue
    // 9.40 (thesis item 1): RecordGhostTrade previously scored every TP hit as a flat
    // 2.5R, every SL hit as a flat -1.5R, and every timeout as a score-gated flat
    // 1.5R/-0.8R guess -- regardless of the trade's ACTUAL TP/SL distance, which
    // DetermineOptimalTPSL sets dynamically per regime/session/volatility. Phase 6 (the
    // go-live gate) scores profit factor off these numbers, so a flat-R shortcut here
    // meant the gate was validating a simplified fiction of the system's own behavior,
    // same root cause as the fabricated live R-multiples fixed in 9.39. Now derived from
    // the real risk distance and real exit price, same as the live-trade fix.
    double riskDist = MathAbs(entry - sl);
    if(riskDist < Point) riskDist = MathMax(Point, atr * 0.1);  // guard: degenerate zero-risk case

    if(hitTP) {
        double rewardDist = MathAbs(tp - entry);
        trade.rMultiple = (riskDist > 0) ? rewardDist / riskDist : 0.0;
        trade.pipProfit = MathAbs(tp - entry) / pipValue;
        trade.percentGain = (entry > 0) ? ((tp - entry) / entry) * 100.0 : 0.0;  // FIX
    } else if(hitSL) {
        trade.rMultiple = -1.0;  // a stop-loss hit is, by definition, -1R of the risk taken
        trade.pipProfit = -MathAbs(entry - sl) / pipValue;
        trade.percentGain = (entry > 0) ? -((MathAbs(entry - sl) / entry) * 100.0) : 0.0;  // FIX
    } else {
        // Timeout (neither TP nor SL hit within barsToOutcome): use the ACTUAL close price
        // at the timeout bar rather than a fabricated flat guess.
        int timeoutBar = MathMax(0, bar - barsToOutcome);
        double exitPrice = iClose(Symbol(), 0, timeoutBar);
        double actualMove = isLong ? (exitPrice - entry) : (entry - exitPrice);
        trade.rMultiple = (riskDist > 0) ? actualMove / riskDist : 0.0;
        trade.pipProfit = actualMove / pipValue;
        trade.percentGain = (entry > 0) ? (actualMove / entry) * 100.0 : 0.0;
    }
    
    double maxProfit = 0;
    double maxDrawdown = 0;
    int mfeBar = 0;
    int maeBar = 0;
    
    for(int j = 1; j <= barsToOutcome && (bar - j) >= 0; j++) {
        double high = iHigh(Symbol(), 0, bar - j);
        double low = iLow(Symbol(), 0, bar - j);
        
        double profit, drawdown;
        if(isLong) {
            profit = (high - entry) / pipValue;
            drawdown = (entry - low) / pipValue;
        } else {
            profit = (entry - low) / pipValue;
            drawdown = (high - entry) / pipValue;
        }
        
        if(profit > maxProfit) {
            maxProfit = profit;
            mfeBar = j;
        }
        if(drawdown > maxDrawdown) {
            maxDrawdown = drawdown;
            maeBar = j;
        }
    }
    
    trade.maxFavorableExcursion = maxProfit;
    trade.maxAdverseExcursion = maxDrawdown;
    trade.barOfMFE = mfeBar;
    trade.barOfMAE = maeBar;
    trade.volatilityLevel = (entry > 0) ? (atr / entry) * 100.0 : 0.0;  // FIX
    trade.sessionHour = TimeHour(iTime(Symbol(), 0, bar));
    trade.momentumScore = momentum;
    trade.trendScore = trend;
    trade.reversalScore = reversal;
    trade.volatilityScore = vol;

    // ## CANDLE ANATOMY AT GHOST ENTRY #####################################
    MarketStateFeatures _gca = CalculateMarketFeatures(bar > 0 ? bar : 0);
    trade.candleBodyPct       = _gca.candleBodyPct;
    trade.upperWickPct        = _gca.upperWickPct;
    trade.lowerWickPct        = _gca.lowerWickPct;
    trade.closingStrength     = _gca.closingStrength;
    trade.wickPressureScore   = _gca.wickPressureScore;
    trade.barDrama            = _gca.barDrama;
    trade.momentumBias5       = _gca.momentumBias5;
    trade.isBullishRejection  = _gca.isBullishRejection;
    trade.isBearishRejection  = _gca.isBearishRejection;
    trade.isBullishEngulf     = _gca.isBullishEngulf;
    trade.isBearishEngulf     = _gca.isBearishEngulf;
    trade.isConvictionCandle  = _gca.isConvictionCandle;
    trade.isIndecisionCandle  = _gca.isIndecisionCandle;

    g_GhostTrades[index] = trade;
    g_GhostTradeCount++;
}

//| Calculate Ghost Analytics                                        |

//| Run Ghost Mode - Main Orchestration                              |
bool RunGhostMode(int barsToTest, double threshold) {
    // Ghost mode runs silently -- progress via ticker only
    
    // Reset counters
    g_GhostTradeCount = 0;
    // Cap barsToTest to Bars-30 so indicator calls (shift=bar) never exceed Bars
    if(barsToTest > Bars - 30) barsToTest = Bars - 30;
    if(barsToTest < 30) return false;  // not enough bars to run ghost
    int tradesCreated = 0;
    // Sequential non-overlapping: after entering a trade, skip until it exits
    int _gmNextValid = barsToTest;  // start from oldest bar, work forward
    // Streaming stats for batch logging
    int _gmBatchBase=0, _gmBatchWins=0, _gmTotal=0, _gmWins=0;
    double _gmBatchPnL=0.0;
    for(int bar = barsToTest; bar >= 20; bar--) {
        if(bar > _gmNextValid) continue;  // trade in progress — skip
        double close = iClose(Symbol(), 0, bar);
        double atr   = iATR(Symbol(), 0, 14, bar);
        
        if(close == 0 || atr == 0) continue;
        double entry0 = (bar>=1)? iOpen(Symbol(),0,bar-1) : close;  // next bar open: no look-ahead
        
        // BUG J FIX: Use the calibrated unified score, not the simplified toy formula.
        // The toy formula (momentum+trend+reversal+vol)/4 produced scores incomparable to
        // the trained threshold, making Phase 2.4 ghost results meaningless.
        double score = CalculateEnhancedUnifiedScore(bar);
        
        // BUG M FIX: Bidirectional logic using signed score (-100 to +100).
        bool isLong  = (score >= threshold);
        bool isShort = (score <= -threshold);
        
        if(!isLong && !isShort) continue;  // No signal - skip bar
        
        bool isLongTrade = isLong;  // If both triggered (impossible now), long takes priority
        double entry = entry0;  // next bar open, consistent with live execution

        // -- REGIME-SPECIFIC TP/SL: use Phase 3C calibrated multipliers ----------
        // Each ghost must use the same parameters that live trading uses
        int _gmReg = ClassifyBarToRegime(CalculateMarketFeatures(bar), bar);
        double _gmSLM = (_gmReg>=0&&_gmReg<9) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,_gmReg))] : 1.5;
        double _gmTPM = (_gmReg>=0&&_gmReg<9) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,_gmReg))] : 2.5;
        if(_gmSLM < 0.8) _gmSLM = 1.5;  // safety: never use unset multipliers
        if(_gmTPM < 1.0) _gmTPM = 2.5;
        // forge-cleanup-3 WARRANT#58 (seam audit "whole suite -> live engine", 2026-07-17):
        // Ghost Mode is the fixed-reference check -- it already uses the real live scorer
        // (CalculateEnhancedUnifiedScore) and Phase 3C's real per-regime SL/TP multipliers
        // above, but still walked forward a hardcoded 20 bars below instead of the same
        // validated per-regime exit horizon (WARRANT#51/52) everything upstream now uses.
        // A ghost "pass" measured under the wrong horizon is not evidence the config that
        // actually goes live will do what Ghost said it would.
        int _gmExitH = (_gmReg>=0&&_gmReg<9&&g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_gmReg))]>=5)
                       ? g_RegimeOptimalExitBars[MathMin(8,MathMax(0,_gmReg))] : 20;

        // -- PROBDB FILTER: apply Phase 4 probability filter --------------------─
        if(g_ProbabilityDatabaseBuilt && _gmReg >= 0 && _gmReg < 9) {
            double _rThrGM = g_RegimeOptimalThresholds[MathMin(8,MathMax(0,_gmReg))];
            int _srGM = MathMax(0,MathMin(9,(int)((MathAbs(score)-_rThrGM)/5.0)));
            if(score < 0) _srGM += 10;
            int _sesGM = DetermineSession(TimeHour(Time[bar]));
            int _volGM = DetermineVolatility(atr);
            MicroPattern _patGM = DetectMicroPatternAt(bar);
            ConditionalProbability _pGM = QueryProbabilityMatrix(_gmReg, _srGM, _patGM.type, _sesGM, _volGM);
            if(_pGM.observations >= 5 && (_pGM.winRate < 0.65 || _pGM.expectedValue < 0.3)) continue;
        }

        double sl = isLongTrade ? (entry - atr * _gmSLM) : (entry + atr * _gmSLM);
        double tp = isLongTrade ? (entry + atr * _gmTPM) : (entry - atr * _gmTPM);
        
        // Check future bars for TP/SL hit
        bool hitTP = false;
        bool hitSL = false;
        int barsToOutcome = 0;
        
        for(int futureBar = bar - 1; futureBar >= MathMax(0, bar - _gmExitH); futureBar--) {
            double high = iHigh(Symbol(), 0, futureBar);
            double low  = iLow(Symbol(), 0, futureBar);
            barsToOutcome = bar - futureBar;
            
            if(isLongTrade) {
                if(high >= tp) { hitTP = true; break; }
                if(low  <= sl) { hitSL = true; break; }
            } else {
                if(low  <= tp) { hitTP = true; break; }
                if(high >= sl) { hitSL = true; break; }
            }
        }
        
        // Decompose score into components for RecordGhostTrade
        double rsi  = iRSI(Symbol(), 0, 14, PRICE_CLOSE, bar);
        double macd = iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_MAIN, bar);
        double adx  = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, bar);
        double momentum  = MathAbs(score) > 50 ? 75.0 : 50.0;
        double trend     = adx;
        double reversal  = (rsi < 30 || rsi > 70) ? 70.0 : 50.0;
        double vol       = MathMin((atr / close * 100) * 10, 100);
        
        RecordGhostTrade(bar, isLongTrade, entry, sl, tp, MathAbs(score), atr,
                        hitTP, hitSL, barsToOutcome,
                        momentum, trend, reversal, vol);
        tradesCreated++;
        // Sequential: advance cursor past this trade exit
        int _gmExitBar = bar - barsToOutcome;
        _gmNextValid = MathMax(20, _gmExitBar - 1);
        // Streaming stats for batch reporting
        bool _gmWon = hitTP || (!hitSL && ((isLongTrade && iClose(Symbol(),0,MathMax(0,_gmExitBar)) > entry) ||
                                          (!isLongTrade && iClose(Symbol(),0,MathMax(0,_gmExitBar)) < entry)));
        _gmTotal++;
        if(_gmWon) { _gmWins++; _gmBatchWins++; _gmBatchPnL+=1.0; } else _gmBatchPnL-=1.0;
        if(!g_CalibSilent && _gmTotal > 0 && _gmTotal % 50 == 0) {
            double _bSz = _gmTotal - _gmBatchBase;
            PrintFormat("  ghost batch %d  |  trades %d-%d  |  WR %.0f%%  |  running %.0f%%  |  P&L %+.1f",
                _gmTotal/50, _gmBatchBase+1, _gmTotal,
                (_bSz>0)?(double)_gmBatchWins/_bSz*100:0,
                (_gmTotal>0)?(double)_gmWins/_gmTotal*100:0, _gmBatchPnL);
            _gmBatchBase=_gmTotal; _gmBatchWins=0; _gmBatchPnL=0;
        }
        
        // progress tracked silently
    }
    
    // Calculate analytics
    if(g_GhostTradeCount >= 10) {
        CalculateGhostAnalytics();
        
        double winRate = 0;
        if(g_GhostTradeCount > 0) {
            int winners = 0;
            int sampleN = MathMin(g_GhostTradeCount, 100);
            for(int i = 0; i < sampleN; i++) {
                if(g_GhostTrades[i].rMultiple > 0) winners++;
            }
            // WR from stored sample; stream total used for frequency reporting
            winRate = (sampleN > 0) ? (double)winners / sampleN * 100.0 : 0.0;
            if(!g_CalibSilent && g_GhostTradeCount > sampleN)
                PrintFormat("  GHOST  |   %d trades scored   |   %d total   |   WR %.0f%%",
                    sampleN, g_GhostTradeCount, winRate);
        }
        
        PrintFormat("  ghost sim   |   %d trades   |   WR %.0f%%",
            g_GhostTradeCount, winRate);
        
        return (winRate >= 60.0 && g_GhostTradeCount >= 30);
    }
    
    return false;
}
void CalculateGhostAnalytics() {
    
    int totalTrades = MathMin(g_GhostTradeCount, 100);
    if(totalTrades < 10) return;
    
    double totalRWon = 0;
    double totalRLost = 0;
    double sumR = 0;
    double sumRSquared = 0;
    int winners = 0;
    int losers = 0;
    double sumBarsTP = 0;
    double sumBarsSL = 0;
    double sumMFE_Winners = 0;
    double sumMAE_Winners = 0;
    double sumMFE_Losers = 0;
    double sumMAE_Losers = 0;
    double sumScoreWinners = 0;
    double sumScoreLosers = 0;
    int asianTrades = 0, asianWins = 0;
    int londonTrades = 0, londonWins = 0;
    int nyTrades = 0, nyWins = 0;
    int lowVolTrades = 0, lowVolWins = 0;
    int medVolTrades = 0, medVolWins = 0;
    int highVolTrades = 0, highVolWins = 0;
    int currentStreak = 0;
    int maxWinStreak = 0;
    int maxLoseStreak = 0;
    double bestR = -999;
    double worstR = 999;
    
    for(int i = 0; i < totalTrades; i++) {
        GhostTradeRecord t = g_GhostTrades[i];
        double r = t.rMultiple;
        sumR += r;
        sumRSquared += (r * r);
        
        if(r > bestR) bestR = r;
        if(r < worstR) worstR = r;
        
        if(r > 0) {
            totalRWon += r;
            winners++;
            sumBarsTP += t.barsToOutcome;
            sumMFE_Winners += t.maxFavorableExcursion;
            sumMAE_Winners += t.maxAdverseExcursion;
            sumScoreWinners += t.entryScore;
            currentStreak = (currentStreak > 0) ? currentStreak + 1 : 1;
            if(currentStreak > maxWinStreak) maxWinStreak = currentStreak;
        } else {
            totalRLost += MathAbs(r);
            losers++;
            sumBarsSL += t.barsToOutcome;
            sumMFE_Losers += t.maxFavorableExcursion;
            sumMAE_Losers += t.maxAdverseExcursion;
            sumScoreLosers += t.entryScore;
            currentStreak = (currentStreak < 0) ? currentStreak - 1 : -1;
            if(MathAbs(currentStreak) > maxLoseStreak) maxLoseStreak = MathAbs(currentStreak);
        }
        
        if(t.sessionHour >= 0 && t.sessionHour < 8) {
            asianTrades++;
            if(r > 0) asianWins++;
        } else if(t.sessionHour >= 8 && t.sessionHour < 16) {
            londonTrades++;
            if(r > 0) londonWins++;
        } else if(t.sessionHour >= 13 && t.sessionHour < 21) {
            nyTrades++;
            if(r > 0) nyWins++;
        }
        
        if(t.volatilityLevel < 0.5) {
            lowVolTrades++;
            if(r > 0) lowVolWins++;
        } else if(t.volatilityLevel < 1.0) {
            medVolTrades++;
            if(r > 0) medVolWins++;
        } else {
            highVolTrades++;
            if(r > 0) highVolWins++;
        }
    }
    
    g_Analytics.avgRMultiple = (totalTrades > 0) ? sumR / totalTrades : 0.0;  // FIX
    g_Analytics.bestRMultiple = bestR;
    g_Analytics.worstRMultiple = worstR;
    g_Analytics.realProfitFactor = (totalRLost > 0) ? (totalRWon / totalRLost) : 999;
    g_Analytics.avgBarsToTP = (winners > 0) ? (sumBarsTP / winners) : 0;
    g_Analytics.avgBarsToSL = (losers > 0) ? (sumBarsSL / losers) : 0;
    g_Analytics.winEfficiency = (g_Analytics.avgBarsToSL > 0) ? (g_Analytics.avgBarsToTP / g_Analytics.avgBarsToSL) : 1.0;
    g_Analytics.avgMFE_Winners = (winners > 0) ? (sumMFE_Winners / winners) : 0;
    g_Analytics.avgMAE_Winners = (winners > 0) ? (sumMAE_Winners / winners) : 0;
    g_Analytics.avgMFE_Losers = (losers > 0) ? (sumMFE_Losers / losers) : 0;
    g_Analytics.avgMAE_Losers = (losers > 0) ? (sumMAE_Losers / losers) : 0;
    g_Analytics.tpWastedPotential = g_Analytics.avgMFE_Winners - 25.0;
    g_Analytics.slPrematureStops = (g_Analytics.avgMFE_Losers > 10.0) ? g_Analytics.avgMFE_Losers : 0;
    g_Analytics.tpTooConservative = (g_Analytics.tpWastedPotential > 10.0);
    g_Analytics.slTooTight = (g_Analytics.slPrematureStops > 10.0);
    g_Analytics.avgScoreWinners = (winners > 0) ? (sumScoreWinners / winners) : 0;
    g_Analytics.avgScoreLosers = (losers > 0) ? (sumScoreLosers / losers) : 0;
    g_Analytics.scoreDiscrimination = MathAbs(g_Analytics.avgScoreWinners - g_Analytics.avgScoreLosers);
    
    if(g_Analytics.avgScoreWinners > 50) {
        g_Analytics.optimalThreshold = g_Analytics.avgScoreWinners - (g_Analytics.scoreDiscrimination / 4.0);
    } else {
        g_Analytics.optimalThreshold = 100 - g_Analytics.avgScoreLosers + (g_Analytics.scoreDiscrimination / 4.0);
    }
    
    g_Analytics.asianWR = (asianTrades > 0) ? ((double)asianWins / asianTrades * 100.0) : 0;
    g_Analytics.londonWR = (londonTrades > 0) ? ((double)londonWins / londonTrades * 100.0) : 0;
    g_Analytics.nyWR = (nyTrades > 0) ? ((double)nyWins / nyTrades * 100.0) : 0;
    
    if(g_Analytics.asianWR >= g_Analytics.londonWR && g_Analytics.asianWR >= g_Analytics.nyWR) {
        g_Analytics.bestSession = "Asian (0-8 GMT)";
    } else if(g_Analytics.londonWR >= g_Analytics.nyWR) {
        g_Analytics.bestSession = "London (8-16 GMT)";
    } else {
        g_Analytics.bestSession = "NY (13-21 GMT)";
    }
    
    g_Analytics.lowVolWR = (lowVolTrades > 0) ? ((double)lowVolWins / lowVolTrades * 100.0) : 0;
    g_Analytics.medVolWR = (medVolTrades > 0) ? ((double)medVolWins / medVolTrades * 100.0) : 0;
    g_Analytics.highVolWR = (highVolTrades > 0) ? ((double)highVolWins / highVolTrades * 100.0) : 0;
    
    if(g_Analytics.lowVolWR >= g_Analytics.medVolWR && g_Analytics.lowVolWR >= g_Analytics.highVolWR) {
        g_Analytics.bestVolatility = "Low (<0.5%)";
    } else if(g_Analytics.medVolWR >= g_Analytics.highVolWR) {
        g_Analytics.bestVolatility = "Medium (0.5-1.0%)";
    } else {
        g_Analytics.bestVolatility = "High (>1.0%)";
    }
    
    g_Analytics.longestWinStreak = maxWinStreak;
    g_Analytics.longestLoseStreak = maxLoseStreak;
    
    double variance = (totalTrades > 0) ? (sumRSquared / totalTrades) - (g_Analytics.avgRMultiple * g_Analytics.avgRMultiple) : 0.0001;
    double stdDev = MathSqrt(MathMax(variance, 0.0001));
    g_Analytics.sharpeRatio = g_Analytics.avgRMultiple / stdDev;
    
    g_Analytics.qualityPassesTest = (
        g_Analytics.avgRMultiple > 0.3 &&
        g_Analytics.realProfitFactor > 1.5 &&
        g_Analytics.scoreDiscrimination > 5.0
    );
    
    g_Analytics.needsTighterThreshold = (g_Analytics.scoreDiscrimination < 5.0);
    g_Analytics.needsWiderStops = (g_Analytics.slPrematureStops > 15.0);
    g_Analytics.needsBiggerTargets = (g_Analytics.tpWastedPotential > 15.0);
    g_Analytics.preferCertainSessions = (
        MathAbs(g_Analytics.asianWR - g_Analytics.londonWR) > 10.0 ||
        MathAbs(g_Analytics.londonWR - g_Analytics.nyWR) > 10.0
    );
    g_Analytics.preferCertainVolatility = (
        MathAbs(g_Analytics.lowVolWR - g_Analytics.highVolWR) > 10.0
    );
}

//| Display Analytics with Intelligent Consolidation                 |

//| Initialize Live Performance Tracker from Calibration             |
void InitializeLivePerformance() {
    
    g_LivePerf.tradesThisSession = 0;
    g_LivePerf.winsThisSession = 0;
    g_LivePerf.lossesThisSession = 0;
    g_LivePerf.avgRThisSession = 0;
    
    // Copy calibration baseline
    g_LivePerf.expectedWR = g_Calibration.ghostWinRate;
    g_LivePerf.actualWR = g_Calibration.ghostWinRate;  // Start aligned
    g_LivePerf.wrDeviation = 0;
    g_LivePerf.significantDeviation = false;
    
    // Threshold management
    g_LivePerf.baseThreshold = g_Calibration.bestThreshold;
    g_LivePerf.currentThreshold = g_Calibration.bestThreshold;
    g_LivePerf.thresholdAdjustment = 0;
    g_LivePerf.lastAdjustment = TimeCurrent();
    
    // Session learning
    g_LivePerf.morningWR = 0;
    g_LivePerf.afternoonWR = 0;
    g_LivePerf.preferMorning = false;
    g_LivePerf.preferAfternoon = false;
    
    // Volatility from calibration
    g_LivePerf.avgVolatility = 0;
    if(StringFind(g_Analytics.bestVolatility, "Low") >= 0) {
        g_LivePerf.optimalVolatility = 0.4;
    } else if(StringFind(g_Analytics.bestVolatility, "Medium") >= 0) {
        g_LivePerf.optimalVolatility = 0.75;
    } else {
        g_LivePerf.optimalVolatility = 1.2;
    }
    g_LivePerf.inOptimalVolatility = true;
    
    g_LivePerf.currentWinStreak = 0;
    g_LivePerf.currentLoseStreak = 0;
    g_LivePerf.onHotStreak = false;
    g_LivePerf.onColdStreak = false;
    
    g_LivePerf.needsThresholdIncrease = false;
    g_LivePerf.needsThresholdDecrease = false;
    g_LivePerf.needsVolatilityFilter = g_Analytics.preferCertainVolatility;
    g_LivePerf.needsSessionFilter = g_Analytics.preferCertainSessions;
    
    if(g_LivePerf.expectedWR > 0.0 || g_LivePerf.baseThreshold > 0.0)
        PrintFormat("  expected WR   |   %.1f%%   |   base threshold %.0f", 
               g_LivePerf.expectedWR, g_LivePerf.baseThreshold);
    PrintFormat("  Session filter: %s  |  Volatility filter: %s",
               g_LivePerf.needsSessionFilter ? "ACTIVE" : "OFF",
               g_LivePerf.needsVolatilityFilter ? "ACTIVE" : "OFF");
}

//| Update Live Performance After Each Trade                         |
void UpdateLivePerformance(bool wasWin, double rResult) {
    
    g_LivePerf.tradesThisSession++;
    
    if(wasWin) {
        g_LivePerf.winsThisSession++;
        g_LivePerf.currentWinStreak++;
        g_LivePerf.currentLoseStreak = 0;
    } else {
        g_LivePerf.lossesThisSession++;
        g_LivePerf.currentLoseStreak++;
        g_LivePerf.currentWinStreak = 0;
    }
    
    // Update average R
    g_LivePerf.avgRThisSession = ((g_LivePerf.avgRThisSession * (g_LivePerf.tradesThisSession - 1)) + rResult) / g_LivePerf.tradesThisSession;
    
    // Calculate actual WR
    if(g_LivePerf.tradesThisSession >= 5) {  // Need minimum sample
        g_LivePerf.actualWR = ((double)g_LivePerf.winsThisSession / g_LivePerf.tradesThisSession) * 100.0;
        g_LivePerf.wrDeviation = g_LivePerf.actualWR - g_LivePerf.expectedWR;
        g_LivePerf.significantDeviation = (MathAbs(g_LivePerf.wrDeviation) > 10.0);
    }
    
    // Check streaks
    g_LivePerf.onHotStreak = (g_LivePerf.currentWinStreak >= 5);
    g_LivePerf.onColdStreak = (g_LivePerf.currentLoseStreak >= 3);
    
    // Session learning
    int hour = TimeHour(TimeCurrent());
    if(hour >= 0 && hour < 12) {
        // Morning trade
        static int morningTrades = 0;
        static int morningWins = 0;
        morningTrades++;
        if(wasWin) morningWins++;
        g_LivePerf.morningWR = ((double)morningWins / morningTrades) * 100.0;
    } else {
        // Afternoon trade
        static int afternoonTrades = 0;
        static int afternoonWins = 0;
        afternoonTrades++;
        if(wasWin) afternoonWins++;
        g_LivePerf.afternoonWR = ((double)afternoonWins / afternoonTrades) * 100.0;
    }
    
    // Auto-correction logic
    if(g_LivePerf.tradesThisSession >= 10) {
        if(g_LivePerf.actualWR < g_LivePerf.expectedWR - 10.0) {
            // Underperforming - tighten threshold
            g_LivePerf.needsThresholdIncrease = true;
            g_LivePerf.needsThresholdDecrease = false;
        } else if(g_LivePerf.actualWR > g_LivePerf.expectedWR + 10.0 && g_LivePerf.avgRThisSession > 0.5) {
            // Overperforming - can loosen threshold for more trades
            g_LivePerf.needsThresholdDecrease = true;
            g_LivePerf.needsThresholdIncrease = false;
        }
    }
}

//| Auto-Adjust Threshold Based on Live Performance                  |
// [SLS13 C3] retired dead function GetAdaptiveThreshold (55 lines, zero refs)

//| Intelligent Session Status Display (Consolidated, No Spam)       |

// [SLS13 C3] retired dead function RunExtendedGhostMode (286 lines, zero refs)

//| Validate Calibration Results                                     |

