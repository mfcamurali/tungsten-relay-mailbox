void PredictPatternFormation() {
    if(!patternAnalysis.isValid || patternAnalysis.validCandles < 3) return;
    
    // Predict pattern completion
    int currentPattern = patternAnalysis.dominantPattern;
    if(currentPattern == 0) currentPattern = patternAnalysis.secondaryPattern;
    
    if(currentPattern != 0) {
        double maturityScore = patternAnalysis.maturityScore;
        double volumeSupport = intelligence.volumeRatio;
        double trendAlignment = MathAbs(intelligence.mtfConsensus);
        
        // Calculate pattern formation probability
        predictiveSystem.patternFormationProbability = maturityScore * 0.4 + 
            (volumeSupport > 1.2 ? 0.3 : 0.1) + trendAlignment * 0.3;
        
        predictiveSystem.predictedPatternType = currentPattern;
        predictiveSystem.predictedPatternStrength = (int)(patternAnalysis.patternStrength[0] * 100);
        predictiveSystem.patternPredictionConfidence = predictiveSystem.patternFormationProbability;
    }
    
    // Predict breakout scenarios
    if(marketStructure.isValid) {
        double distanceToResistance = MathAbs(iClose(Symbol(), 0, 0) - marketStructure.primaryResistance) /NonZero(intelligence.atr);
        double distanceToSupport = MathAbs(iClose(Symbol(), 0, 0) - marketStructure.primarySupport) /NonZero(intelligence.atr);
        
        predictiveSystem.breakoutImminent = (distanceToResistance < 1.0 || distanceToSupport < 1.0) && 
                                           intelligence.volumeRatio > 1.3;
        
        predictiveSystem.resistanceBreakProbability = 1.0 - MathMin(1.0, distanceToResistance / 2.0);
        predictiveSystem.supportBreakProbability = 1.0 - MathMin(1.0, distanceToSupport / 2.0);
    }
    
    // Predict reversal scenarios
    bool exhaustionSignals = intelligence.rsi > 75 || intelligence.rsi < 25;
    // CRITICAL FIX: Reduced from 0.001 to 0.0001 for real forex M5 ranges
    // This catches normal-to-active MACD moves for reversal prediction
    bool divergenceSignals = MathAbs(intelligence.macdHistogram) > 0.0001;
    
    predictiveSystem.reversalImminent = exhaustionSignals && divergenceSignals;
    predictiveSystem.trendReversalProbability = (exhaustionSignals ? 0.4 : 0.1) + 
                                               (divergenceSignals ? 0.3 : 0.1) + 
                                               (intelligence.atrVolatility > 1.5 ? 0.2 : 0.0);
}

void ForecastRegimeChanges() {
    if(!enhancedBias.isValid) return;
    
    // Analyze regime stability
    double consensusStrength = enhancedBias.consensusStrength;
    double biasConsistency = enhancedBias.biasConsistency;
    double timeframeAlignment = MathAbs(enhancedBias.bullishTimeframes - enhancedBias.bearishTimeframes);
    
    predictiveSystem.regimeStabilityScore = (consensusStrength * 0.4) + 
                                           (biasConsistency / 10.0 * 0.3) + 
                                           ((7 - timeframeAlignment) / 7.0 * 0.3);
    
    // Predict regime changes
    predictiveSystem.regimeChangeImminent = predictiveSystem.regimeStabilityScore < 0.3 && 
                                           intelligence.atrVolatility > 1.3;
    
    if(predictiveSystem.regimeChangeImminent) {
        // Predict new regime based on momentum and volume
        if(intelligence.priceVelocity > 0 && intelligence.volumeRatio > 1.2) {
            predictiveSystem.predictedRegime = (int)REGIME_BULLISH;
        } else if(intelligence.priceVelocity < 0 && intelligence.volumeRatio > 1.2) {
            predictiveSystem.predictedRegime = (int)REGIME_BEARISH;
        } else {
            predictiveSystem.predictedRegime = (int)REGIME_CONSOLIDATION;
        }
        
        predictiveSystem.regimeTransitionProbability = (int)((1.0 - predictiveSystem.regimeStabilityScore) * 100);
        predictiveSystem.regimePredictionConfidence = 0.7 + (intelligence.atrVolatility - 1.0) * 0.2;
    }
    
    // Predict consolidation vs trending
    double trendingFactors = MathAbs(intelligence.mtfConsensus) + (intelligence.adx > 25 ? 0.3 : 0.0);
    predictiveSystem.consolidationProbability = 1.0 - MathMin(1.0, trendingFactors);
    
    // Predict volatility spikes
    double volatilityFactors = intelligence.atrVolatility + 
                              (intelligence.volumeRatio > 1.5 ? 0.3 : 0.0) + 
                              (MathAbs(intelligence.priceAcceleration) > 0.5 ? 0.2 : 0.0);
    
    predictiveSystem.volatilitySpikeProbability = MathMin(0.9, volatilityFactors - 1.0);
}

void UpdateNeuralNetworkSimulation() {
    // Prepare normalised indicator snapshot for diagnostic reference
    // NOTE: Random weights removed — untrained neural forward pass was corrupting
    // probabilities already correctly computed by ForecastRegimeChanges and
    // PredictPatternFormation. This function now serves as an input normaliser.
    predictiveSystem.neuralInputs[0] = intelligence.rsi / 100.0;
    predictiveSystem.neuralInputs[1] = MathMax(-1.0, MathMin(1.0, intelligence.macd * 100.0));
    predictiveSystem.neuralInputs[2] = intelligence.adx / 100.0;
    predictiveSystem.neuralInputs[3] = intelligence.stochMain / 100.0;
    predictiveSystem.neuralInputs[4] = intelligence.mfi / 100.0;
    predictiveSystem.neuralInputs[5] = MathMin(1.0, intelligence.atrVolatility / 2.0);
    predictiveSystem.neuralInputs[6] = MathMax(0.0, MathMin(1.0, (intelligence.volumeRatio - 0.5) / 1.5));
    predictiveSystem.neuralInputs[7] = (intelligence.mtfConsensus + 1.0) / 2.0;
    predictiveSystem.neuralInputs[8] = engine.unifiedScore / 100.0;
    // momentumContinuationProbability/trendReversalProbability/volatilitySpikeProbability
    // are set by ForecastRegimeChanges+PredictPatternFormation. Random neural overwrite REMOVED.
    // are set by ForecastRegimeChanges() and PredictPatternFormation() — do NOT overwrite here.
}

// [SLS13 C3] retired dead function ValidatePredictions (48 lines, zero refs)

double CalculatePredictiveScore(bool isBuy) {
    if(!predictiveSystem.predictionsValid) return 50.0;  // Neutral if no predictions
    
    double score = 50.0;  // Start at neutral
    double indicators[8] = {0, 0, 0, 0, 0, 0, 0, 0};  // 6 conditional writes possible — headroom
    int indicatorCount = 0;
    double currentPrice = iClose(Symbol(), 0, 0);
    
    // Short-term prediction (Weight: 30%)
    if(predictiveSystem.shortTermPrediction > 0 && currentPrice > 0) {
        double predictedChange = (predictiveSystem.shortTermPrediction - currentPrice) / NonZero(currentPrice);
        double predScore = 50.0;
        
        if(isBuy && predictedChange > 0) {
            predScore = 50.0 + (predictedChange * 1000.0 * predictiveSystem.predictionConfidence[0]);
        } else if(!isBuy && predictedChange < 0) {
            predScore = 50.0 + (MathAbs(predictedChange) * 1000.0 * predictiveSystem.predictionConfidence[0]);
        }
        
        predScore = MathMax(0, MathMin(100, predScore));
        indicators[indicatorCount++] = predScore;
        score += (predScore - 50.0) * 0.30;
    }
    
    // Pattern prediction (Weight: 25%)
    if(predictiveSystem.predictedPatternType != 0) {
        double patScore = 50.0;
        bool patternAligned = (isBuy && predictiveSystem.predictedPatternType > 0) ||
                             (!isBuy && predictiveSystem.predictedPatternType < 0);
        if(patternAligned) {
            patScore = 50.0 + (predictiveSystem.patternFormationProbability * 50.0);
        }
        
        indicators[indicatorCount++] = patScore;
        score += (patScore - 50.0) * 0.25;
    }
    
    // Breakout prediction (Weight: 20%)
    if(predictiveSystem.breakoutImminent) {
        double breakScore = 50.0;
        if(isBuy && predictiveSystem.resistanceBreakProbability > 0.6) {
            breakScore = 70.0;
        } else if(!isBuy && predictiveSystem.supportBreakProbability > 0.6) {
            breakScore = 30.0;
        }
        
        indicators[indicatorCount++] = breakScore;
        score += (breakScore - 50.0) * 0.20;
    }
    
    // Regime prediction (Weight: 15%)
    if(predictiveSystem.regimeChangeImminent) {
        double regimeScore = 50.0;
        bool regimeAligned = (isBuy && predictiveSystem.predictedRegime == (int)REGIME_BULLISH) ||
                            (!isBuy && predictiveSystem.predictedRegime == (int)REGIME_BEARISH);
        if(regimeAligned) {
            regimeScore = 50.0 + (predictiveSystem.regimePredictionConfidence * 50.0);
        }
        
        indicators[indicatorCount++] = regimeScore;
        score += (regimeScore - 50.0) * 0.15;
    }
    
    // Momentum continuation (Weight: 10%)
    if(isBuy && predictiveSystem.momentumContinuationProbability > 0.6 && intelligence.priceVelocity > 0) {
        indicators[indicatorCount++] = 70.0;
        score += 20.0 * 0.10;
    } else if(!isBuy && predictiveSystem.momentumContinuationProbability > 0.6 && intelligence.priceVelocity < 0) {
        indicators[indicatorCount++] = 30.0;
        score -= 20.0 * 0.10;
    }
    
    // Weight by prediction reliability
    score = 50.0 + (score - 50.0) * predictiveSystem.predictionReliability;
    score = MathMax(0, MathMin(100, score));
    
    // Apply consensus amplification
    if(indicatorCount > 0) {
        int bullishCount = 0;
        int bearishCount = 0;
        for(int i = 0; i < indicatorCount; i++) {
            if(indicators[i] > 60) bullishCount++;
            else if(indicators[i] < 40) bearishCount++;
        }
        
        double consensus = (indicatorCount > 0) ? (double)MathMax(bullishCount, bearishCount) / indicatorCount : 0.5;  // FIX: guard
        score = ApplyConsensusAmplification(score, consensus);
    }
    
    return score;
}

// NEW MARKET MEMORY SYSTEM IMPLEMENTATION
void InitializeMarketMemorySystem() {
    // Initialize historical contexts
    for(int i = 0; i < REGIME_MEMORY_DEPTH; i++) {
        marketMemory.historicalContexts[i].timestamp = 0;
        marketMemory.historicalContexts[i].regime = 0;
        marketMemory.historicalContexts[i].score = 50.0;
        marketMemory.historicalContexts[i].volatility = 1.0;
        marketMemory.historicalContexts[i].volume = 1.0;
        marketMemory.historicalContexts[i].winRate = 50.0;
        marketMemory.historicalContexts[i].profitFactor = 1.0;
        
        for(int j = 0; j < 4; j++) {
            marketMemory.historicalContexts[i].thresholds[j] = 50.0;
        }
        
        marketMemory.historicalContexts[i].wasSuccessful = false;
        marketMemory.historicalContexts[i].effectiveness = 0.5;
    }
    
    marketMemory.contextIndex = 0;
    marketMemory.validContexts = 0;
    
    // Initialize strategy memories
    for(int i = 0; i < 20; i++) {
        marketMemory.strategyMemories[i].strategyType = i;
        
        for(int j = 0; j < 10; j++) {
            marketMemory.strategyMemories[i].parameters[j] = 1.0;
        }
        
        marketMemory.strategyMemories[i].effectiveness = 0.5;
        marketMemory.strategyMemories[i].reliability = 0.5;
        marketMemory.strategyMemories[i].usageCount = 0;
        marketMemory.strategyMemories[i].successCount = 0;
        marketMemory.strategyMemories[i].lastUsed = 0;
        marketMemory.strategyMemories[i].lastSuccess = 0;
        marketMemory.strategyMemories[i].adaptationRate = 0.1;
    }
    
    marketMemory.activeStrategies = 5;
    
    // Initialize pattern memories
    for(int i = 0; i < 30; i++) {
        marketMemory.patternMemories[i].patternType = i - 15; // NonZero(Range.from) -15 to +14
        
        for(int j = 0; j < 8; j++) {
            marketMemory.patternMemories[i].contextFactors[j] = 0.5;
        }
        
        marketMemory.patternMemories[i].successRate = 50.0;
        marketMemory.patternMemories[i].profitability = 0.5;
        marketMemory.patternMemories[i].occurrences = 0;
        marketMemory.patternMemories[i].successes = 0;
        marketMemory.patternMemories[i].reliability = 0.5;
        marketMemory.patternMemories[i].confidence = 0.5;
    }
    
    // Initialize parameter memories
    for(int i = 0; i < 50; i++) {
        marketMemory.parameterMemories[i].parameterValue = 1.0;
        marketMemory.parameterMemories[i].parameterType = i % 10;
        marketMemory.parameterMemories[i].effectiveness = 0.5;
        marketMemory.parameterMemories[i].consistency = 0.5;
        marketMemory.parameterMemories[i].lastUsed = 0;
        marketMemory.parameterMemories[i].usageFrequency = 0;
    }
    
    marketMemory.memoryReliability = 0.5;
    marketMemory.memoryDepth = 0.0;
    marketMemory.contextualAccuracy = 0.5;
    marketMemory.strategicConsistency = 0.5;
    marketMemory.memorySystemActive = true;
    marketMemory.learningEnabled = true;
    
    marketMemory.lastMemoryUpdate = 0;
    marketMemory.isValid = true;
    marketMemory.needsUpdate = true;
    
    LogCriticalEvent("Market Memory System Initialized", "MEMORY");
}

void UpdateMarketMemorySystem() {
    static datetime lastMemoryUpdate = 0;
    if((TimeCurrent() - lastMemoryUpdate) < 300) return; // NonZero(Update.every) 5 minutes
    lastMemoryUpdate = TimeCurrent();
    
    StoreMarketContext();
    UpdateStrategyEffectiveness();
    LearnFromPatternOutcomes();
    AdaptParametersFromMemory();
    
    marketMemory.lastMemoryUpdate = TimeCurrent();
    marketMemory.needsUpdate = false;
}

void StoreMarketContext() {
    datetime currentTime = TimeCurrent();
    
    // Store current market state
    marketMemory.historicalContexts[marketMemory.contextIndex].timestamp = currentTime;
    marketMemory.historicalContexts[marketMemory.contextIndex].regime = (int)engine.regime;
    marketMemory.historicalContexts[marketMemory.contextIndex].score = engine.unifiedScore;
    marketMemory.historicalContexts[marketMemory.contextIndex].volatility = intelligence.atrVolatility;
    marketMemory.historicalContexts[marketMemory.contextIndex].volume = intelligence.volumeRatio;
    marketMemory.historicalContexts[marketMemory.contextIndex].winRate = CalculateRecentWinRate();
    marketMemory.historicalContexts[marketMemory.contextIndex].profitFactor = CalculateProfitFactor();
    
    // Store current thresholds
    marketMemory.historicalContexts[marketMemory.contextIndex].thresholds[0] = engine.buyThreshold;
    marketMemory.historicalContexts[marketMemory.contextIndex].thresholds[1] = engine.sellThreshold;
    marketMemory.historicalContexts[marketMemory.contextIndex].thresholds[2] = riskMgr.currentRisk;
    marketMemory.historicalContexts[marketMemory.contextIndex].thresholds[3] = riskMgr.currentRR;
    
    // Determine if context was successful
    double recentWinRate = CalculateRecentWinRate();
    marketMemory.historicalContexts[marketMemory.contextIndex].wasSuccessful = recentWinRate > 60.0;
    marketMemory.historicalContexts[marketMemory.contextIndex].effectiveness = recentWinRate / 100.0;
    
    marketMemory.contextIndex = (marketMemory.contextIndex + 1) % REGIME_MEMORY_DEPTH;
    if(marketMemory.validContexts < REGIME_MEMORY_DEPTH) {
        marketMemory.validContexts++;
    }
    
    // Update memory depth metric
    marketMemory.memoryDepth = (double)marketMemory.validContexts / NonZero(REGIME_MEMORY_DEPTH);
}

void RecallSimilarContexts(double similarityThreshold) {
    if(marketMemory.validContexts == 0) return;
    
    int currentRegime = (int)engine.regime;
    double currentScore = engine.unifiedScore;
    double currentVolatility = intelligence.atrVolatility;
    double currentVolume = intelligence.volumeRatio;
    
    double totalEffectiveness = 0.0;
    int similarContexts = 0;
    
    for(int i = 0; i < marketMemory.validContexts; i++) {
        // Calculate similarity score
        double regimeSimilarity = (marketMemory.historicalContexts[i].regime == currentRegime) ? 1.0 : 0.0;
        double scoreSimilarity = 1.0 - MathAbs(marketMemory.historicalContexts[i].score - currentScore) / 100.0;
        double volatilitySimilarity = 1.0 - MathAbs(marketMemory.historicalContexts[i].volatility - currentVolatility);
        double volumeSimilarity = 1.0 - MathAbs(marketMemory.historicalContexts[i].volume - currentVolume);
        
        double overallSimilarity = (regimeSimilarity * 0.4 + scoreSimilarity * 0.3 + 
                                   volatilitySimilarity * 0.2 + volumeSimilarity * 0.1);
        
        if(overallSimilarity >= similarityThreshold) {
            totalEffectiveness += marketMemory.historicalContexts[i].effectiveness;
            similarContexts++;
        }
    }
    
    // Update contextual accuracy
    if(similarContexts > 0) {
        marketMemory.contextualAccuracy = totalEffectiveness / NonZero(similarContexts);
    }
}

void UpdateStrategyEffectiveness() {
    double currentWinRate = CalculateRecentWinRate();
    double currentProfitFactor = CalculateProfitFactor();
    
    // Update active strategy effectiveness
    for(int i = 0; i < marketMemory.activeStrategies; i++) {
        marketMemory.strategyMemories[i].usageCount++;
        
        if ((double)currentWinRate > 60.0) {
            marketMemory.strategyMemories[i].successCount++;
            marketMemory.strategyMemories[i].lastSuccess = TimeCurrent();
        }
        
        marketMemory.strategyMemories[i].lastUsed = TimeCurrent();
        
        // Calculate effectiveness
        if(marketMemory.strategyMemories[i].usageCount > 0) {
            double successRate = (double)marketMemory.strategyMemories[i].successCount / 
                                marketMemory.strategyMemories[i].usageCount;
            marketMemory.strategyMemories[i].effectiveness = successRate;
            marketMemory.strategyMemories[i].reliability = MathMin(1.0, 
                marketMemory.strategyMemories[i].usageCount / 20.0) * successRate;
        }
    }
    
    // Calculate strategic consistency
    double totalEffectiveness = 0.0;
    for(int i = 0; i < marketMemory.activeStrategies; i++) {
        totalEffectiveness += marketMemory.strategyMemories[i].effectiveness;
    }
    
    if(marketMemory.activeStrategies > 0) {
        marketMemory.strategicConsistency = totalEffectiveness / NonZero(marketMemory.activeStrategies);
    }
}

void LearnFromPatternOutcomes() {
    if(!patternAnalysis.isValid) return;
    
    int currentPattern = patternAnalysis.dominantPattern;
    if(currentPattern == 0) return;
    
    // Find pattern memory (int)index
    int memoryIndex = -1;
    for(int i = 0; i < 30; i++) {
        if(marketMemory.patternMemories[i].patternType == currentPattern) {
            memoryIndex = i;
            break;
        }
    }
    
    if(memoryIndex >= 0) {
        marketMemory.patternMemories[memoryIndex].occurrences++;
        
        // Store context factors
        marketMemory.patternMemories[memoryIndex].contextFactors[0] = intelligence.rsi / 100.0;
        marketMemory.patternMemories[memoryIndex].contextFactors[1] = intelligence.atrVolatility;
        marketMemory.patternMemories[memoryIndex].contextFactors[2] = intelligence.volumeRatio;
        marketMemory.patternMemories[memoryIndex].contextFactors[3] = intelligence.mtfConsensus;
        marketMemory.patternMemories[memoryIndex].contextFactors[4] = engine.unifiedScore / 100.0;
        marketMemory.patternMemories[memoryIndex].contextFactors[5] = patternAnalysis.patternStrength[0];
        marketMemory.patternMemories[memoryIndex].contextFactors[6] = patternAnalysis.confirmationScore;
        marketMemory.patternMemories[memoryIndex].contextFactors[7] = intelligence.liquidityIndex;
        
        // Update success metrics
        double recentWinRate = CalculateRecentWinRate();
        if ((double)recentWinRate > 60.0) {
            marketMemory.patternMemories[memoryIndex].successes++;
        }
        
        // Calculate pattern metrics
        if(marketMemory.patternMemories[memoryIndex].occurrences > 0) {
            marketMemory.patternMemories[memoryIndex].successRate = 
                (double)marketMemory.patternMemories[memoryIndex].successes / 
                marketMemory.patternMemories[memoryIndex].occurrences * 100.0;
            
            marketMemory.patternMemories[memoryIndex].reliability = 
                MathMin(1.0, marketMemory.patternMemories[memoryIndex].occurrences / 10.0);
            
            marketMemory.patternMemories[memoryIndex].confidence = 
                marketMemory.patternMemories[memoryIndex].successRate / 100.0 * 
                marketMemory.patternMemories[memoryIndex].reliability;
        }
    }
}

void AdaptParametersFromMemory() {
    RecallSimilarContexts(0.7); // NonZero(Recall.contexts) with 70% similarity
    
    if(marketMemory.contextualAccuracy > 0.7) {
        // Adapt thresholds based on similar historical contexts
        double thresholdAdjustment = (marketMemory.contextualAccuracy - 0.5) * 0.2;
        
        // Find the most effective historical context
        double bestEffectiveness = 0.0;
        int bestContextIndex = -1;
        
        for(int i = 0; i < marketMemory.validContexts; i++) {
            if(marketMemory.historicalContexts[i].effectiveness > bestEffectiveness) {
                bestEffectiveness = marketMemory.historicalContexts[i].effectiveness;
                bestContextIndex = i;
            }
        }
        
        if(bestContextIndex >= 0 && bestEffectiveness > 0.6) {
            // Memory conviction: similar historical setups feed CEUS directly
            // Positive historical outcome = add conviction. Negative = reduce.
            double _memOutcome = (marketMemory.historicalContexts[bestContextIndex].winRate > 0.50) ? 1.0 : -1.0;
            double _memScore = (bestEffectiveness - 0.6) * 25.0;  // 0 to +10 pts range
            double _memConviction = (_memOutcome > 0) ? _memScore : -(_memScore * 0.5);
            g_MarketMemoryConviction = _memConviction;  // stored for CEUS to read
            // Gradually adapt towards the most effective parameters
            double adaptationRate = 0.1;
            
            double targetBuyThreshold = marketMemory.historicalContexts[bestContextIndex].thresholds[0];
            double targetSellThreshold = marketMemory.historicalContexts[bestContextIndex].thresholds[1];
            
            // GLOT AUTHORITY: post-calibration, GetLearnedOptimalThreshold is the single
            // threshold writer (WRG/shadow/CEO/FREQ adjustors live inside it).
            if(!g_Calibration.isComplete) {
                engine.buyThreshold = engine.buyThreshold * (1.0 - adaptationRate) +
                                     targetBuyThreshold * adaptationRate;
                engine.sellThreshold = engine.sellThreshold * (1.0 - adaptationRate) +
                                      targetSellThreshold * adaptationRate;
                engine.buyThreshold = MathMax(60.0, MathMin(85.0, engine.buyThreshold));
                engine.sellThreshold = MathMax(15.0, MathMin(40.0, engine.sellThreshold));
            }
        }
    }
    
    // Update memory reliability
    double averageAccuracy = 0.0;
    int accuracyCount = 0;
    
    for(int i = 0; i < marketMemory.validContexts; i++) {
        if(marketMemory.historicalContexts[i].effectiveness > 0) {
            averageAccuracy += marketMemory.historicalContexts[i].effectiveness;
            accuracyCount++;
        }
    }
    
    if(accuracyCount > 0) {
        marketMemory.memoryReliability = averageAccuracy / NonZero(accuracyCount);
    }
}

double GetContextualEffectiveness(int regime, double score) {
    double totalEffectiveness = 0.0;
    int matchingContexts = 0;
    
    for(int i = 0; i < marketMemory.validContexts; i++) {
        if(marketMemory.historicalContexts[i].regime == regime && 
           MathAbs(marketMemory.historicalContexts[i].score - score) < 20.0) {
            totalEffectiveness += marketMemory.historicalContexts[i].effectiveness;
            matchingContexts++;
        }
    }
    
    return (matchingContexts > 0) ? (totalEffectiveness / NonZero(matchingContexts)) : 0.5;
}

// NEW DYNAMIC STRATEGY GENERATOR IMPLEMENTATION (FIXED)
void InitializeDynamicStrategyGenerator() {
    // FIXED: Initialize strategy genes with completely separate random generation to avoid operator issues
    for(int i = 0; i < STRATEGY_GENE_POOL_SIZE; i++) {
        // FIXED: Use completely separate statements to avoid any operator overloading issues
        int randomValue1 = MathRand();
        int randomValue2 = MathRand();
        int randomValue3 = MathRand();
        int randomValue4 = MathRand();
        int randomValue5 = MathRand();
        int randomValue6 = MathRand();
        int randomValue7 = MathRand();
        int randomValue8 = MathRand();
        
        int mod1 = randomValue1 % 1000;
        int mod2 = randomValue2 % 1000;
        int mod3 = randomValue3 % 1000;
        int mod4 = randomValue4 % 1000;
        int mod5 = randomValue5 % 1000;
        int mod6 = randomValue6 % 1000;
        int mod7 = randomValue7 % 1000;
        int mod8 = randomValue8 % 1000;
        
        double val1 = 0.8 + (double)mod1 / 2500.0; // 0.8-1.2
        double val2 = 0.7 + (double)mod2 / 1666.0; // 0.7-1.3
        double val3 = 0.5 + (double)mod3 / 2000.0; // 0.5-1.0
        double val4 = 0.3 + (double)mod4 / 1428.0; // 0.3-1.0
        double val5 = 0.2 + (double)mod5 / 1250.0; // 0.2-1.0
        double val6 = 0.4 + (double)mod6 / 1666.0; // 0.4-1.0
        double val7 = 0.05 + (double)mod7 / 6666.0; // 0.05-0.2
        double val8 = 0.3 + (double)mod8 / 1428.0; // 0.3-1.0
        
        strategyGenerator.strategyGenes[i].thresholdMultiplier = val1;
        strategyGenerator.strategyGenes[i].riskMultiplier = val2;
        strategyGenerator.strategyGenes[i].timeframeWeight = val3;
        strategyGenerator.strategyGenes[i].patternWeight = val4;
        strategyGenerator.strategyGenes[i].volumeWeight = val5;
        strategyGenerator.strategyGenes[i].momentumWeight = val6;
        strategyGenerator.strategyGenes[i].adaptationSpeed = val7;
        strategyGenerator.strategyGenes[i].conservatismLevel = val8;
        
        strategyGenerator.strategyGenes[i].effectiveness = 0.5;
        strategyGenerator.strategyGenes[i].fitness = 0.5;
        strategyGenerator.strategyGenes[i].generation = 0;
        strategyGenerator.strategyGenes[i].mutations = 0;
        strategyGenerator.strategyGenes[i].isActive = (i < 5); // NonZero(Start.with) 5 active genes
        strategyGenerator.strategyGenes[i].isElite = false;
    }
    
    strategyGenerator.activeGenes = 5;
    strategyGenerator.eliteGenes = 0;
    strategyGenerator.generation = 0;
    
    // FIXED: Initialize creative multipliers with proper random generation
    for(int i = 0; i < 15; i++) {
        int randVal = MathRand() % 1000;
        strategyGenerator.creativeMultipliers[i] = 0.8 + (double)randVal / 2500.0;
    }
    
    strategyGenerator.innovationFactor = 0.1;
    strategyGenerator.explorationRate = 0.2;
    strategyGenerator.creativeModeActive = false;
    strategyGenerator.explorationPhase = false;
    
    // FIXED: Initialize dynamic rules with proper random generation
    for(int i = 0; i < 25; i++) {
        int rand1 = MathRand() % 10;
        int rand2 = MathRand() % 10;
        int rand3 = MathRand() % 3;
        int rand4 = MathRand() % 1000;
        int rand5 = MathRand() % 1000;
        int rand6 = MathRand() % 1000;
        
        strategyGenerator.dynamicRules[i].condition1 = rand1;
        strategyGenerator.dynamicRules[i].condition2 = rand2;
        strategyGenerator.dynamicRules[i].operatorType = rand3; // NonZero(FIXED): Using operatorType instead of operator
        strategyGenerator.dynamicRules[i].threshold1 = 30.0 + (double)rand4 / 25.0;
        strategyGenerator.dynamicRules[i].threshold2 = 30.0 + (double)rand5 / 25.0;
        strategyGenerator.dynamicRules[i].weight = 0.1 + (double)rand6 / 1250.0;
        strategyGenerator.dynamicRules[i].isActive = (i < 10);
        strategyGenerator.dynamicRules[i].isEffective = false;
        strategyGenerator.dynamicRules[i].successRate = 50.0;
        strategyGenerator.dynamicRules[i].confidence = 0.5;
    }
    
    strategyGenerator.activeRules = 10;
    strategyGenerator.effectiveRules = 0;
    
    // Initialize combination weights
    for(int i = 0; i < 10; i++) {
        strategyGenerator.combinationWeights[i] = 1.0 / 10.0; // NonZero(Equal.weighting) initially
    }
    
    strategyGenerator.dominantStrategy = 0;
    strategyGenerator.backupStrategy = 1;
    strategyGenerator.strategyConfidence = 0.5;
    strategyGenerator.combinationEffectiveness = 0.5;
    
    strategyGenerator.innovationScore = 0.0;
    strategyGenerator.creativityIndex = 0.1;
    strategyGenerator.newStrategiesGenerated = 0;
    strategyGenerator.successfulInnovations = 0;
    strategyGenerator.lastInnovation = 0;
    strategyGenerator.lastStrategyUpdate = 0;
    
    strategyGenerator.generatorActive = true;
    strategyGenerator.needsUpdate = true;
    
    LogCriticalEvent("Dynamic Strategy Generator Initialized - Fixed", "STRATEGY");
}

void UpdateDynamicStrategyGenerator() {
    static datetime lastStrategyUpdate = 0;
    if((TimeCurrent() - lastStrategyUpdate) < 600) return; // NonZero(Update.every) 10 minutes
    lastStrategyUpdate = TimeCurrent();
    
    EvolveStrategyGenes();
    GenerateCreativeParameters();
    CombineEffectiveStrategies();
    
    strategyGenerator.lastStrategyUpdate = TimeCurrent();
    strategyGenerator.needsUpdate = false;
}

void EvolveStrategyGenes() {
    // Evaluate fitness of active genes
    for(int i = 0; i < strategyGenerator.activeGenes; i++) {
        if(strategyGenerator.strategyGenes[i].isActive) {
            strategyGenerator.strategyGenes[i].fitness = EvaluateStrategyFitness(i);
        }
    }
    
    // Select elite strategies
    SelectEliteStrategies();
    
    // Mutate non-elite strategies
    for(int i = 0; i < STRATEGY_GENE_POOL_SIZE; i++) {
        if(strategyGenerator.strategyGenes[i].isActive && !strategyGenerator.strategyGenes[i].isElite) {
            if((MathRand() % 100) < 30) { // 30% mutation chance
                MutateStrategyGenes();
            }
        }
    }
    
    strategyGenerator.generation++;
}

double EvaluateStrategyFitness(int geneIndex) {
    if(geneIndex >= STRATEGY_GENE_POOL_SIZE) return 0.0;
    
    double fitness = 0.5;
    
    // Performance-based fitness
    double recentWinRate = CalculateRecentWinRate();
    double profitFactor = CalculateProfitFactor();
    
    fitness += (recentWinRate - 50.0) / 100.0; // -0.5 to +0.5
    fitness += (profitFactor - 1.0) * 0.2; // NonZero(Profit.factor) contribution
    
    // Risk-adjusted fitness
    if(riskMgr.maxDrawdown > 0) {
        fitness -= riskMgr.maxDrawdown / 100.0; // NonZero(Penalize.drawdown)
    }
    
    // Consistency bonus
    if(tradeManager.consecutiveWins > 3) {
        fitness += 0.1;
    }
    
    // Innovation bonus
    if(strategyGenerator.strategyGenes[geneIndex].mutations > 0) {
        fitness += strategyGenerator.strategyGenes[geneIndex].mutations * 0.02; // NonZero(Small.bonus) for mutation
    }
    
    // Market condition adaptability
    double memoryEffectiveness = marketMemory.contextualAccuracy;
    fitness += (memoryEffectiveness - 0.5) * 0.3;
    
    return MathMax(0.1, MathMin(1.0, fitness));
}

void SelectEliteStrategies() {
    // Reset elite flags
    for(int i = 0; i < STRATEGY_GENE_POOL_SIZE; i++) {
        strategyGenerator.strategyGenes[i].isElite = false;
    }
    
    strategyGenerator.eliteGenes = 0;
    
    // Find top 20% performers
    double eliteCount = (int)(strategyGenerator.activeGenes * 0.2);
    if(eliteCount < 1) eliteCount = 1;
    
    for(int elite = 0; elite < eliteCount; elite++) {
        double bestFitness = 0.0;
        int bestIndex = -1;
        
        for(int i = 0; i < STRATEGY_GENE_POOL_SIZE; i++) {
            if(strategyGenerator.strategyGenes[i].isActive && 
               !strategyGenerator.strategyGenes[i].isElite &&
               strategyGenerator.strategyGenes[i].fitness > bestFitness) {
                bestFitness = strategyGenerator.strategyGenes[i].fitness;
                bestIndex = i;
            }
        }
        
        if(bestIndex >= 0) {
            strategyGenerator.strategyGenes[bestIndex].isElite = true;
            strategyGenerator.eliteGenes++;
        }
    }
}

void MutateStrategyGenes() {
    // Select a random non-elite gene to mutate
    int geneIndex = -1;
    for(int attempts = 0; attempts < 10; attempts++) {
        int candidate = MathRand() % STRATEGY_GENE_POOL_SIZE;
        if(strategyGenerator.strategyGenes[candidate].isActive && 
           !strategyGenerator.strategyGenes[candidate].isElite) {
            geneIndex = candidate;
            break;
        }
    }
    
    if(geneIndex < 0) return;
    
    // FIXED: Apply mutations with proper random generation avoiding operator issues
    int randStrength = MathRand() % 100;
    double mutationStrength = 0.1 + (double)randStrength / 1000.0; // 0.1-0.2
    
    int randCheck1 = MathRand() % 100;
    if(randCheck1 < 50) {
        int randChange1 = MathRand() % 1000;
        double randomChange = (double)randChange1 / 1000.0 - 0.5;
        double newValue = strategyGenerator.strategyGenes[geneIndex].thresholdMultiplier + (randomChange * mutationStrength);
        strategyGenerator.strategyGenes[geneIndex].thresholdMultiplier = MathMax(0.5, MathMin(1.5, newValue));
    }
    
    int randCheck2 = MathRand() % 100;
    if(randCheck2 < 50) {
        int randChange2 = MathRand() % 1000;
        double randomChange = (double)randChange2 / 1000.0 - 0.5;
        double newValue = strategyGenerator.strategyGenes[geneIndex].riskMultiplier + (randomChange * mutationStrength);
        strategyGenerator.strategyGenes[geneIndex].riskMultiplier = MathMax(0.5, MathMin(2.0, newValue));
    }
    
    int randCheck3 = MathRand() % 100;
    if(randCheck3 < 30) {
        int randChange3 = MathRand() % 1000;
        double randomChange = (double)randChange3 / 1000.0 - 0.5;
        double newValue = strategyGenerator.strategyGenes[geneIndex].adaptationSpeed + (randomChange * mutationStrength * 0.5);
        strategyGenerator.strategyGenes[geneIndex].adaptationSpeed = MathMax(0.01, MathMin(0.5, newValue));
    }
    
    strategyGenerator.strategyGenes[geneIndex].mutations++;
    strategyGenerator.strategyGenes[geneIndex].generation = strategyGenerator.generation;
}

void GenerateCreativeParameters() {
    // Activate creative mode under certain conditions
    double volatility = intelligence.atrVolatility;
    double winRate = CalculateRecentWinRate();
    
    strategyGenerator.creativeModeActive = (volatility > 1.5 || winRate < 45.0);
    
    if(strategyGenerator.creativeModeActive) {
        // Increase exploration rate
        double newRate = strategyGenerator.explorationRate * 1.2;
        strategyGenerator.explorationRate = MathMin(0.5, newRate);
        
        // Generate creative parameter combinations
        for(int i = 0; i < 15; i++) {
            int randPercent = MathRand() % 100;
            double explorationThreshold = (int)(strategyGenerator.explorationRate * 100);
            if(randPercent < explorationThreshold) {
                int randValue = MathRand() % 1000;
                strategyGenerator.creativeMultipliers[i] = 0.5 + (double)randValue / 1000.0; // NonZero(More.variation) in creative mode
            }
        }
        
        // Innovation tracking
        double newScore = strategyGenerator.innovationScore + 0.1;
        strategyGenerator.innovationScore = newScore;
        
        datetime currentTime = TimeCurrent();
        if((currentTime - strategyGenerator.lastInnovation) > 3600) { // NonZero(New.innovation) per hour
            strategyGenerator.newStrategiesGenerated++;
            strategyGenerator.lastInnovation = currentTime;
        }
    } else {
        // Reduce exploration rate in stable conditions
        double newRate = strategyGenerator.explorationRate * 0.95;
        strategyGenerator.explorationRate = MathMax(0.05, newRate);
    }
    
    // Update creativity (int)index
    double combinedScore = strategyGenerator.innovationScore + 
                          strategyGenerator.explorationRate + 
                          (strategyGenerator.newStrategiesGenerated * 0.1);
    strategyGenerator.creativityIndex = combinedScore / 3.0;
}


