// All logging functions consolidated here. Four previously scattered
// logging sections (L762, L808, L8160, L17009) feed into these functions.

//  ASCII SYMBOL DEFINITIONS (MT4-Compatible)

#define SYM_PAUSE     "[-]"
#define SYM_STOP      "[X]"
#define SYM_QUIET     "[zzz]"
#define SYM_FAST      "[>>]"
#define SYM_SCALE     "[SCALE+]"
#define SYM_MONEY     "[$$$]"
#define SYM_RECOVER   "[+]"
#define SYM_TARGET    "[o]"
#define SYM_LONDON    "[LONDON]"
#define SYM_NY        "[NY]"
#define SYM_ASIAN     "[ASIAN]"

//  HELPER FUNCTIONS

//| Get current session name                                         |
string GetSessionName() {
    int hour = Hour();
    if(hour >= 12 && hour < 16) return "Overlap";
    if(hour >= 7 && hour < 16) return "London";
    if(hour >= 12 && hour < 21) return "NY";
    return "Asian";
}

//| Create padding string                                            |

//| Format number with commas                                        |
string FormatNumber(double num) {
    string str = DoubleToStr(num, 0);
    int len = StringLen(str);
    string result = "";
    int count = 0;
    
    for(int i = len - 1; i >= 0; i--) {
        if(count == 3) {
            result = "," + result;
            count = 0;
        }
        result = StringSubstr(str, i, 1) + result;
        count++;
    }
    return result;
}

//| Check daily reset                                                |
void CheckDailyReset() {
    datetime currentDay = iTime(Symbol(), PERIOD_D1, 0);
    
    if(g_LastDayReset != currentDay) {
        // Log yesterday's summary if we had activity
        if(g_DailyWins + g_DailyLosses > 0) {
            LogDailySummary();
        }
        
        // Reset daily stats
        g_DailyStartBalance = AccountBalance();
        g_DailyWins = 0;
        g_DailyLosses = 0;
        g_DailyProfit = 0;
        g_MaxWinStreakToday = 0;
        g_BestTradeToday = 0;
        g_LastDayReset = currentDay;
    }
}

//| Check hourly reset                                               |
void CheckHourlyReset() {
    datetime currentHour = iTime(Symbol(), PERIOD_H1, 0);
    
    if(g_LastHourReset != currentHour) {
        // Log hourly update if enabled and we had activity
        if(ShowHourlyUpdates && g_HourlyTrades > 0 && EnableFriendlyLogs) {
            LogHourlyUpdate();
        }
        
        // Reset hourly stats
        g_HourlyTrades = 0;
        g_HourlyProfit = 0;
        g_LastHourReset = currentHour;
    }
}

//| Startup logging                                                  |

//| Print clean separator line                                       |


void PrintEmptyLine()   { }  // suppressed -- log stays dense


void LogStartup() {
    if(!EnableFriendlyLogs) return;
    PrintFormat("  TUNGSTEN " + EA_VERSION + " A7.5 QUANT " + EA_BUILD_ID + " |   %s   |   $%.2f   |   online", Symbol(), AccountBalance());
}

//| State transition logging                                         |

//| Trade entry logging                                              |

//| Trade exit logging                                               |

//| Signal rejection logging                                         |

//| Hourly update                                                    |
void LogHourlyUpdate() {
    if(g_HourlyTrades == 0) {
        // Only log quiet hours during Asian
        if(GetSessionName() == "Asian") {
            // Asian session quiet: silent
            // balance noted silently
            PrintEmptyLine();
        }
        return;
    }
    
    if(g_HourlyProfit > 0) {
        double totalWR = (g_DailyWins + g_DailyLosses > 0) ?
                         (double)g_DailyWins / (g_DailyWins + g_DailyLosses) * 100.0 : 0;
        PrintFormat("  LIVE  |   hour   +$%.0f   |   %d trades   |   %.0f%% WR   |   %s%.0f today",
                   g_HourlyProfit, g_HourlyTrades, totalWR, g_DailyProfit >= 0?"+$":"-$", MathAbs(g_DailyProfit));
        PrintEmptyLine();
    }
}

//| Daily summary                                                    |
void LogDailySummary() {
    if(!EnableFriendlyLogs) {
        PrintFormat("  LIVE  |   day   %d trades   |   %d wins   |   $%.2f", g_DailyWins+g_DailyLosses, g_DailyWins, g_DailyProfit);
        return;
    }
    
    int totalTrades = g_DailyWins + g_DailyLosses;
    if(totalTrades == 0) return;
    
    double winRate = ((double)g_DailyWins / totalTrades) * 100.0;
    double dailyPercent = ((AccountBalance() - g_DailyStartBalance) / NonZero(g_DailyStartBalance)) * 100.0;
    double percentToTarget = (AccountBalance() / 75000.0) * 100.0;
    
    // ## FLOOR GROWTH RATE CHECK ##################################################
    // FLOOR_DAILY_GROWTH_RATE = 28% avg. Not expected every day -- checked over rolling window.
    // A single day below floor is normal; logged for awareness only.
    bool aboveDailyFloor = (dailyPercent >= FLOOR_DAILY_GROWTH_RATE * 100.0);

    if(dailyPercent > 5.0 || winRate > 75.0) {
        PrintEmptyLine();
        // Delta vs yesterday's WR
        double _wrDelta = winRate - g_Risk.recentWinRate;  // rough prior approximation
        string _wrDeltaStr = StringFormat("%s%.0fpp", _wrDelta >= 0 ? "+" : "", _wrDelta);
        PrintFormat("  LIVE  |   day   %d trades   |   %.0f%% WR (%s)   |   +$%.0f   |   +%.1f%%   |   $%s   |   %s",
                   totalTrades, winRate, _wrDeltaStr, g_DailyProfit, dailyPercent,
                   FormatNumber(AccountBalance()),
                   aboveDailyFloor ? "floor met" : "below floor");
        if(g_BestTradeToday > 0)
            PrintFormat("  best trade +%.1fR   |   streak %d", g_BestTradeToday, g_MaxWinStreakToday);
        return;
    }
    
    if(dailyPercent < -2.0 || winRate < 60.0) {
        PrintEmptyLine();
        PrintFormat("  day complete   |   %d trades   |   %.0f%% WR   |   $%.0f   |   %.1f%%   |   $%s",
                   totalTrades, winRate, g_DailyProfit, dailyPercent, FormatNumber(AccountBalance()));
        return;
    }
    
    PrintFormat("  day complete   |   %d trades   |   %.0f%% WR   |   $%.0f   |   %.1f%%   |   $%s",
               totalTrades, winRate, g_DailyProfit, dailyPercent, FormatNumber(AccountBalance()));
}

//| Check milestones                                                 |
void CheckMilestones() {
    if(!CelebrateMilestones) return;
    
    double balance = AccountBalance();
    
    // Balance milestones
    if(balance >= 500 && !g_Milestone_500) {
        g_Milestone_500 = true;
        PrintEmptyLine();
        PrintFormat("  MILE  |   $500   |   %.1fx growth", AccountBalance() / MathMax(1.0, (double)StartingBalance));
        // milestone noted
        PrintEmptyLine();
    }
    
    if(balance >= 1000 && !g_Milestone_1000) {
        g_Milestone_1000 = true;
        PrintEmptyLine();
        PrintFormat("  MILE  |   $1,000   |   %.1fx growth", AccountBalance() / MathMax(1.0, (double)StartingBalance));
        // milestone noted
        PrintEmptyLine();
    }
    
    if(balance >= 2500 && !g_Milestone_2500) {
        g_Milestone_2500 = true;
        PrintEmptyLine();
        PrintFormat("  MILE  |   $2,500   |   %.1fx growth", AccountBalance() / MathMax(1.0, (double)StartingBalance));
        // milestone noted
        PrintEmptyLine();
    }
    
    if(balance >= 5000 && !g_Milestone_5000) {
        g_Milestone_5000 = true;
        PrintEmptyLine();
        PrintFormat("  MILE  |   $5,000   |   %.1fx growth", AccountBalance() / MathMax(1.0, (double)StartingBalance));
        // milestone noted
        PrintEmptyLine();
    }
    
    if(balance >= 10000 && !g_Milestone_10000) {
        g_Milestone_10000 = true;
        PrintEmptyLine();
        PrintFormat("  MILE  |   $10,000   |   %.1fx growth", AccountBalance() / MathMax(1.0, (double)StartingBalance));
        // milestone noted
        PrintEmptyLine();
    }
    
    if(balance >= 25000 && !g_Milestone_25000) {
        g_Milestone_25000 = true;
        PrintEmptyLine();
        PrintFormat("  MILE  |   $25,000   |   %.1fx growth", AccountBalance() / MathMax(1.0, (double)StartingBalance));
        // milestone noted
        PrintEmptyLine();
    }
    
    if(balance >= 50000 && !g_Milestone_50000) {
        g_Milestone_50000 = true;
        PrintEmptyLine();
        Print("  MILE  |   $50,000   |   500x growth   |   67% to target");
        PrintEmptyLine();
    }
    
    if(balance >= 75000 && !g_Milestone_75000) {
        g_Milestone_75000 = true;
        PrintEmptyLine();
        PrintFormat("  target reached   |   $75,000   |   %.0fx growth   |   $%s balance",
                   balance / 100.0, FormatNumber(balance));
        PrintEmptyLine();
    }
    
    // Win streak milestones
    if(g_CurrentWinStreak >= 10) {
        static datetime lastStreakLog = 0;
        if(TimeCurrent() - lastStreakLog > 3600) {  // Once per hour max
            PrintEmptyLine();
            PrintFormat("  10 in a row   |   WR %.0f%% today   |   $%.0f", (g_DailyWins > 0 ? (double)g_DailyWins/(g_DailyWins+g_DailyLosses)*100:0), g_DailyProfit);
            PrintEmptyLine();
            lastStreakLog = TimeCurrent();
        }
    }
}

