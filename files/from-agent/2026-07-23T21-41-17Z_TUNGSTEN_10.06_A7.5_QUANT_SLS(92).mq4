// Ghost streaming stats — published after RunComprehensiveGhostValidation
int      g_Ghost_StreamTotal    = 0;       // total trades simulated (uncapped)
// Phase 6 gate results — published by RunComprehensiveGhostValidation
// Retry 2 and failure diagnostics read these from the outer scope
bool     g_P6_WR            = false;  // Phase 6 gate: WR
bool     g_P6_PF            = false;  // Phase 6 gate: PF
bool     g_P6_EV            = false;  // Phase 6 gate: EV
bool     g_P6_CL            = false;  // Phase 6 gate: consecutive losses
bool     g_P6_SIG           = false;  // Phase 6 gate: statistical sig
bool     g_P6_HIST          = false;  // Phase 6 gate: walk-forward stable
int      g_P6_Total         = 0;      // total ghost trades at publication
int      g_P6_ResultCount   = 0;      // stored detail trades (≤299)
int      g_P6_RegimeObs[9];   // per-regime OOS obs for Retry 2 worst-regime logic
int      g_P6_RegimeWins[9];  // per-regime OOS wins for Retry 2
double   g_P6_ReqWR  = FLOOR_START_WR;  // expectancy-coherent WR requirement [45..65], set by validation
double   g_P6_AvgRR  = 2.5;             // realized reward:risk of OOS ghost trades, set by validation
// ── SPEC VOCABULARY: every live-side "performing to spec?" judgment keys to
// the system's OWN published requirement, not a fixed scalper yardstick.
// Offsets from the original design are preserved (learning curve = +7pp).
double SpecWR()          { return (g_Calibration.requiredWinRate > 1.0) ? g_Calibration.requiredWinRate : FLOOR_START_WR; }
double SpecLearnedWR()   { return MathMin(85.0, SpecWR() + (FLOOR_LEARNED_WR - FLOOR_START_WR)); }
double SpecBreakevenWR() { return 100.0 / (1.0 + MathMax(0.5, g_P6_AvgRR)); }
int      g_Ghost_StreamWins     = 0;       // wins in all simulated trades
double   g_Ghost_StreamPnL      = 0.0;     // cumulative profitPct across all trades
