    regimeStrategies[11].optimalTP = 1.5;
    regimeStrategies[11].riskTolerance = 0.6;
    regimeStrategies[11].allowAggressive = false;
}

// STEP 4: REPLACE E99_ProcessExecutionDecisions COMPLETELY

void E99_ProcessExecutionDecisions()
{
    // BEEHIVE GATE -- the Beehive's command-level trading permission.
    if(g_E99_Initialized && !g_E99_TradingAllowed) {
        static datetime lastBeehiveBlock = 0;
        if(TimeCurrent() - lastBeehiveBlock > 180) {  // every 3 min, not 5 — stay legible
            // Name which subsystems are still pending so a held state is never a mystery.
            string _pending = "";
            if(!g_E99_Beehive.calibration.operational)   _pending += "calib ";
            if(!g_E99_Beehive.probabilityDB.operational) _pending += "probDB ";
            if(!g_E99_Beehive.regimeBanks.operational)   _pending += "regimes ";
            if(!g_E99_Beehive.patternMicro.operational)  _pending += "patMicro ";
            if(!g_E99_Beehive.patternMacro.operational)  _pending += "patMacro ";
            if(!g_E99_Beehive.scenarios.operational)     _pending += "scenarios ";
            if(!g_E99_Beehive.dynamicRisk.operational)   _pending += "risk ";
            if(!g_E99_Beehive.threshold.operational)     _pending += "threshold ";
            if(!g_E99_Beehive.recovery.operational)      _pending += "recovery ";
            if(_pending == "") _pending = "maturing on live data (optimal subsystems pending)";
            PrintFormat("  BEE   |   %.0f%% ready   |   %d/9 operational, %d/9 optimal   |   held: waiting on %s",
                        g_E99_Beehive.overallReadiness * 100.0,
                        g_E99_Beehive.subsystemsOperational,
                        g_E99_Beehive.subsystemsOptimal,
                        _pending);
            lastBeehiveBlock = TimeCurrent();
        }
        return;
    }

    // NOTE: Ensure you call EvaluateEdgeAndMaybeExecute(edgeScore) before rejecting/trading decisions.

    // Auto-guard: ensure ms defaults and update candle history early
    EnsureMSEngineDefaults();
    UpdateCandleHistory();

    // Ensure currentTickMs is set
    currentTickMs = GetCurrentMilliseconds();

    // CRITICAL FIX: Decision interval for M5 timeframe
    // M5 = new candle every 300,000ms, checking every 10ms is wasteful
    // 200ms = 5 checks per second is more than sufficient
    if(engine.decisionIntervalMs <= 0) engine.decisionIntervalMs = 200;

    if(engine.forceFirstMSRun) {
        engine.forceFirstMSRun = false;
        engine.lastDecisionMs = 0;
    }

    if(engine.lastDecisionMs == 0) {
        engine.lastDecisionMs = currentTickMs - engine.decisionIntervalMs - 1;
    }

    double deltaMs = (double)(currentTickMs - engine.lastDecisionMs);
    if(deltaMs < engine.decisionIntervalMs) return;

    engine.lastDecisionMs = currentTickMs;
    engine.executionDelayMs = 0;

    static double last_unifiedScore_log = -9999.0;
    static int    last_regime_log = -1;
    static datetime lastSignalLog = 0;
    double score_now = engine.unifiedScore;
    int regime_now = (int)engine.regime;

    // CRITICAL FIX #30: Handle first log initialization properly
    bool isFirstLog = (last_unifiedScore_log == -9999.0);
    if(isFirstLog) {
        last_unifiedScore_log = score_now;  // Initialize to current score
        last_regime_log = regime_now;
        lastSignalLog = TimeCurrent();
        // Don't log on first tick, just initialize
        engine.regime = ClassifyEnhancedRegime();
        LogRegimeChange();
        return;
    }

    // CRITICAL FIX #27: Only log on significant changes or time interval
    // Removed regimeChanged condition to respect 30-second regime hysteresis
    // Increased threshold from 5.0 to 10.0 to reduce noise
    bool significantChange = MathAbs(score_now - last_unifiedScore_log) > 10.0;
    bool timeForLog = (TimeCurrent() - lastSignalLog) >= 300;
    
    // OLD TUNGSTEN SIGNAL LOG DELETED - Using new empathetic format only
    // All signal logging now handled by LogComponentDiagnostics()
    
    engine.regime = ClassifyEnhancedRegime();
    LogRegimeChange();  // NEW: Log regime changes with context
    ApplyRegimeStrategy((int)engine.regime);

    E99_UpdateConservativeMode();

    E99_UpdateComponentTracking();
    
    // PATTERN STATE: Update micro/macro formations on every bar close
    // This keeps g_PatternState.currentMicro/Macro in sync with the
    // live market, feeding the sequence learning database.
    UpdatePatternState();
    
    // Sync PatternState shortcuts after update
    g_PatternState.currentMicroPattern = g_PatternState.currentMicro.type;
    g_PatternState.currentMacroPattern = g_PatternState.currentMacro.type;
    g_PatternState.microConfidence     = g_PatternState.currentMicro.confidence;
    g_PatternState.macroConfidence     = g_PatternState.currentMacro.confidence;
    
    // INTELLIGENCE ENHANCEMENT LAYERS UPDATE
    UpdatePatternEvolution();        // Creative adaptation
    UpdateMultiAssetCorrelation();   // Systemic awareness
    UpdateAlgorithmicIntuition();    // Anomaly detection
    
    // ## CEO ALIGNMENT PRE-FILTER ########################################
    {
        double _preAlign = GetMarketAlignment();
        if(_preAlign < 0.20 && g_LiveAdaptive.selfCalibrated) {
            static datetime _lastAlignBlock = 0;
            if(TimeCurrent() - _lastAlignBlock > 300) {
                PrintFormat("  CEO   |   alignment %.2f critical   |   skipping signal   |   ghost will fire on losses",
                    _preAlign);
                _lastAlignBlock = TimeCurrent();
            }
            return;
        }
    }

    // Calculate base edge then enhance with intelligence layers
    double baseEdge = CalculateStatisticalEdge();
    double edgeScore = CalculateIntelligenceEnhancedEdge(baseEdge);

    bool edgeOk = ValidateEdge(edgeScore);
    if(!edgeOk) {
        // ValidateEdge now logs the specific rejection reason
        // (edge insufficient, consistency too low, or clarity too low)
        return;
    }

    double riskScore = CalculateRiskScore();
    bool riskOk = ValidateRisk(riskScore);
    if(!riskOk) {
        // CRITICAL FIX #33: Removed MS_DECISION REJECT log spam
        return;
    }

    CalculateOptimalPositionSizing();
    DetermineOptimalTPSL();
    bool execOk = ValidateExecution();
    if(!execOk) {
        // CRITICAL FIX #33: Removed MS_DECISION REJECT log spam
        return;
    }

    // Call existing signal generation / order execution section
    GenerateAndExecuteSignals();

}

// STAGE 1: IDENTIFY STATISTICAL EDGE

void E99_UpdateComponentTracking() {
    // LIVE PERFORMANCE FEEDBACK -- update signal readings first
    UpdateMomentumIntelligence();
    UpdateReversalIntelligence();
    UpdateVolatilityIntelligence();
    UpdateBiasIntelligence();
    UpdatePatternIntelligence();
    UpdatePredictiveIntelligence();

    // CLOSE THE FEEDBACK LOOP (runs once per bar, not every tick)
    static datetime lastPerfUpdate = 0;
    bool newBar = (iTime(Symbol(), PERIOD_CURRENT, 0) != lastPerfUpdate);

    if(newBar) {
        lastPerfUpdate = iTime(Symbol(), PERIOD_CURRENT, 0);
        int currentRegime = (int)engine.regime;
        if(currentRegime < 0 || currentRegime >= 12) currentRegime = 0;

        E99_UpdateComponentPerformance(momentumIntel,   currentRegime);
        E99_UpdateComponentPerformance(reversalIntel,   currentRegime);
        E99_UpdateComponentPerformance(volatilityIntel, currentRegime);
        E99_UpdateComponentPerformance(biasIntel,       currentRegime);
        E99_UpdateComponentPerformance(patternIntel,    currentRegime);
        E99_UpdateComponentPerformance(predictiveIntel, currentRegime);

        E99_AdjustComponentWeight(momentumIntel);
        E99_AdjustComponentWeight(reversalIntel);
        E99_AdjustComponentWeight(volatilityIntel);
        E99_AdjustComponentWeight(biasIntel);
        E99_AdjustComponentWeight(patternIntel);
        E99_AdjustComponentWeight(predictiveIntel);
    }

    // Calculate effective weights (base * performance * risk-adjusted)
    // Now reflects actual live trade results instead of static 1.0 multipliers
    momentumIntel.effectiveWeight = momentumIntel.baseWeight * momentumIntel.performanceWeight * momentumIntel.riskAdjustedWeight;
    reversalIntel.effectiveWeight = reversalIntel.baseWeight * reversalIntel.performanceWeight * reversalIntel.riskAdjustedWeight;
    volatilityIntel.effectiveWeight = volatilityIntel.baseWeight * volatilityIntel.performanceWeight * volatilityIntel.riskAdjustedWeight;
    biasIntel.effectiveWeight = biasIntel.baseWeight * biasIntel.performanceWeight * biasIntel.riskAdjustedWeight;
    patternIntel.effectiveWeight = patternIntel.baseWeight * patternIntel.performanceWeight * patternIntel.riskAdjustedWeight;
    predictiveIntel.effectiveWeight = predictiveIntel.baseWeight * predictiveIntel.performanceWeight * predictiveIntel.riskAdjustedWeight;
    
    // Calculate votes (signal * quality * edge * confidence * weight)
    momentumIntel.vote = momentumIntel.signalStrength * momentumIntel.signalQuality * 
                         momentumIntel.edgeContribution * momentumIntel.confidenceLevel * 
                         momentumIntel.effectiveWeight;
    
    reversalIntel.vote = reversalIntel.signalStrength * reversalIntel.signalQuality * 
                         reversalIntel.edgeContribution * reversalIntel.confidenceLevel * 
                         reversalIntel.effectiveWeight;
    
    volatilityIntel.vote = volatilityIntel.signalStrength * volatilityIntel.signalQuality * 
                           volatilityIntel.edgeContribution * volatilityIntel.confidenceLevel * 
                           volatilityIntel.effectiveWeight;
    
    biasIntel.vote = biasIntel.signalStrength * biasIntel.signalQuality * 
                     biasIntel.edgeContribution * biasIntel.confidenceLevel * 
                     biasIntel.effectiveWeight;
    
    patternIntel.vote = patternIntel.signalStrength * patternIntel.signalQuality * 
                        patternIntel.edgeContribution * patternIntel.confidenceLevel * 
                        patternIntel.effectiveWeight;
    
    predictiveIntel.vote = predictiveIntel.signalStrength * predictiveIntel.signalQuality * 
                           predictiveIntel.edgeContribution * predictiveIntel.confidenceLevel * 
                           predictiveIntel.effectiveWeight;
}

void UpdateMomentumIntelligence() {
    double momentumSignal = 0.0;
    double signalQuality = 0.5;
    
    // RSI momentum
    double rsiMomentum = (intelligence.rsi - 50.0) / 50.0;
    momentumSignal += rsiMomentum * 0.3;
    
    // Quality: Strong RSI readings are more reliable
    if(MathAbs(rsiMomentum) > 0.4) signalQuality += 0.15;
    
    // MACD momentum
    double macdSignal = intelligence.macdHistogram * 10000.0;
    macdSignal = MathMax(-1.0, MathMin(1.0, macdSignal));
    momentumSignal += macdSignal * 0.3;
    
    // Quality: MACD + acceleration alignment
    if(intelligence.macdAccel * macdSignal > 0) signalQuality += 0.15;
    
    // Price velocity
    double velocitySignal = intelligence.priceVelocity / 10.0;
    velocitySignal = MathMax(-1.0, MathMin(1.0, velocitySignal));
    momentumSignal += velocitySignal * 0.2;
    
    // Stochastic
    double stochMomentum = (intelligence.stochMain - 50.0) / 50.0;
    momentumSignal += stochMomentum * 0.2;
    
    // Edge: All indicators aligned = strong edge
    double alignment = 0.0;
    if(rsiMomentum * macdSignal > 0) alignment += 0.25;
    if(rsiMomentum * velocitySignal > 0) alignment += 0.25;
    if(macdSignal * stochMomentum > 0) alignment += 0.25;
    if(velocitySignal * stochMomentum > 0) alignment += 0.25;
    
    momentumIntel.signalStrength = MathMax(-1.0, MathMin(1.0, momentumSignal));
    momentumIntel.signalQuality = MathMin(1.0, signalQuality);
    momentumIntel.edgeContribution = alignment;
    momentumIntel.confidenceLevel = (signalQuality + alignment) / 2.0;
    momentumIntel.signalConsistency = alignment;
    
    // Risk: Momentum can reverse
    momentumIntel.riskContribution = 0.5 + (MathAbs(momentumIntel.signalStrength) * 0.3);
    
    momentumIntel.lastUpdate = TimeCurrent();
}

void UpdateReversalIntelligence() {
    double reversalSignal = 0.0;
    double signalQuality = 0.5;
    double edgeStrength = 0.0;
    
    // RSI exhaustion
    if(intelligence.rsi < 20) {
        reversalSignal += 0.9;
        signalQuality += 0.25;
        edgeStrength += 0.4;
    } else if(intelligence.rsi < 30) {
        reversalSignal += 0.6;
        signalQuality += 0.15;
        edgeStrength += 0.25;
    } else if(intelligence.rsi > 80) {
        reversalSignal -= 0.9;
        signalQuality += 0.25;
        edgeStrength += 0.4;
    } else if(intelligence.rsi > 70) {
        reversalSignal -= 0.6;
        signalQuality += 0.15;
        edgeStrength += 0.25;
    }
    
    // Stochastic exhaustion
    if(intelligence.stochMain < 20 || intelligence.stochMain > 80) {
        signalQuality += 0.1;
        edgeStrength += 0.15;
    }
    
    // Reversal probability
    if(intelligence.reversalProbability > 0.7) {
        reversalSignal += intelligence.priceVelocity > 0 ? -0.5 : 0.5;
        edgeStrength += 0.2;
    }
    
    // Volume confirmation
    if(intelligence.volumeRatio > 1.3) {
        signalQuality += 0.15;
        edgeStrength += 0.25;
    }
    
    reversalIntel.signalStrength = MathMax(-1.0, MathMin(1.0, reversalSignal));
    reversalIntel.signalQuality = MathMin(1.0, signalQuality);
    reversalIntel.edgeContribution = MathMin(1.0, edgeStrength);
    reversalIntel.confidenceLevel = (signalQuality + edgeStrength) / 2.0;
    reversalIntel.riskContribution = 0.6; // Reversals have timing risk
    
    reversalIntel.lastUpdate = TimeCurrent();
}

void UpdateVolatilityIntelligence() {
    double volatilitySignal = 0.0;
    double signalQuality = 0.5;
    double edgeStrength = 0.5;
    
    // Volatility-based signals
    if(intelligence.atrVolatility > 1.5) {
        // High volatility - fade extremes carefully
        signalQuality += 0.2;
        if(intelligence.rsi > 70) {
            volatilitySignal = -0.5;
            edgeStrength += 0.2;
        } else if(intelligence.rsi < 30) {
            volatilitySignal = 0.5;
            edgeStrength += 0.2;
        }
    } else if(intelligence.atrVolatility < 0.7) {
        // Low volatility - breakout potential
        signalQuality += 0.15;
        volatilitySignal = (intelligence.rsi - 50.0) / 100.0;
        edgeStrength += 0.15;
    }
    
    volatilityIntel.signalStrength = MathMax(-1.0, MathMin(1.0, volatilitySignal));
    volatilityIntel.signalQuality = MathMin(1.0, signalQuality);
    volatilityIntel.edgeContribution = MathMin(1.0, edgeStrength);
    volatilityIntel.confidenceLevel = signalQuality * 0.7; // Lower confidence for vol signals
    volatilityIntel.riskContribution = intelligence.atrVolatility; // Direct risk measure
    
    volatilityIntel.lastUpdate = TimeCurrent();
}

void UpdateBiasIntelligence() {
    double biasSignal = 0.0;
    double signalQuality = 0.5;
    double edgeStrength = 0.5;
    
    if(enhancedBias.directionalBiasValid) {
        double netBias = (double)(enhancedBias.bullishTimeframes - enhancedBias.bearishTimeframes) / 
                        NonZero(enhancedBias.bullishTimeframes + enhancedBias.bearishTimeframes + enhancedBias.neutralTimeframes);
        
        biasSignal = netBias * enhancedBias.consensusStrength;
        
        // Quality from consensus strength
        signalQuality += enhancedBias.consensusStrength * 0.3;
        
        // Edge from strong bias
        if(enhancedBias.biasStrong) {
            edgeStrength += 0.3;
            signalQuality += 0.2;
        }
        
        // Consistency adds edge
        if(enhancedBias.biasConsistency > 3) {
            edgeStrength += 0.2;
        }
    }
    
    biasIntel.signalStrength = MathMax(-1.0, MathMin(1.0, biasSignal));
    biasIntel.signalQuality = MathMin(1.0, signalQuality);
    biasIntel.edgeContribution = MathMin(1.0, edgeStrength);
    biasIntel.confidenceLevel = enhancedBias.biasConfidence;
    biasIntel.riskContribution = 0.4; // Lower risk when bias is clear
    
    biasIntel.lastUpdate = TimeCurrent();
}

void UpdatePatternIntelligence() {
    // Pattern intelligence now reads from g_PatternState which is
    // populated by the full swing-point-based DetectMicroPattern/
    // DetectMacroPattern pipeline - not the 3-candle fallback.
    double patternSignal = 0.0;
    double signalQuality = 0.5;
    double edgeStrength  = 0.5;

    PatternType micro = g_PatternState.currentMicroPattern;
    PatternType macro = g_PatternState.currentMacroPattern;
    double microConf  = g_PatternState.microConfidence;
    double macroConf  = g_PatternState.macroConfidence;

    // ---- Derive directional signal from named pattern type ----
    // Bullish formations
    bool isBullishPattern =
        (micro == PATTERN_BULL_FLAG         || micro == PATTERN_ASCENDING_TRIANGLE  ||
         micro == PATTERN_CUP_AND_HANDLE    || micro == PATTERN_MOMENTUM_CONTINUATION ||
         micro == PATTERN_BULLISH_PENNANT   || micro == PATTERN_DOUBLE_BOTTOM       ||
         micro == PATTERN_INV_HEAD_SHOULDERS|| micro == PATTERN_MORNING_STAR         ||
         micro == PATTERN_HAMMER_AT_SUPPORT || micro == PATTERN_BULLISH_CHOCH        ||
         micro == PATTERN_BULLISH_ENGULFING || micro == PATTERN_SR_BOUNCE           ||
         micro == PATTERN_RANGE_FAKEOUT     || micro == PATTERN_HH);

    // Bearish formations
    bool isBearishPattern =
        (micro == PATTERN_BEAR_FLAG          || micro == PATTERN_DESCENDING_TRIANGLE  ||
         micro == PATTERN_INVERTED_CUP_HANDLE|| micro == PATTERN_BEARISH_CONTINUATION ||
         micro == PATTERN_BEARISH_PENNANT    || micro == PATTERN_DOUBLE_TOP           ||
         micro == PATTERN_HEAD_SHOULDERS     || micro == PATTERN_EVENING_STAR         ||
         micro == PATTERN_SHOOTING_STAR_AT_RES || micro == PATTERN_BEARISH_CHOCH      ||
         micro == PATTERN_BEARISH_ENGULFING  || micro == PATTERN_CLIMAX_REVERSAL      ||
         micro == PATTERN_PARABOLIC_STALL    || micro == PATTERN_DIVERGENCE           ||
         micro == PATTERN_LL);

    // Neutral / noise
    bool isNeutralPattern =
        (micro == PATTERN_CONSOLIDATION || micro == PATTERN_WIDE_SR_RESPECT ||
         micro == PATTERN_RANGE_COMPRESSION || micro == PATTERN_WHIPSAW     ||
         micro == PATTERN_DOJI || micro == PATTERN_SPINNING_TOP_EXTREME     ||
         micro == PATTERN_UNKNOWN || micro == PATTERN_NONE);

    // Base signal from micro
    if(isBullishPattern)      patternSignal =  microConf;
    else if(isBearishPattern) patternSignal = -microConf;
    else                      patternSignal =  0.0;

    // Macro confirmation: same direction strengthens, opposite weakens
    if(macro == PATTERN_HH || macro == PATTERN_BULL_FLAG ||
       macro == PATTERN_ASCENDING_TRIANGLE || macro == PATTERN_DOUBLE_BOTTOM ||
       macro == PATTERN_INV_HEAD_SHOULDERS || macro == PATTERN_BULLISH_PENNANT) {
        if(patternSignal > 0) { patternSignal *= (1.0 + macroConf * 0.3); edgeStrength += 0.20; }
        else                  { patternSignal *= (1.0 - macroConf * 0.3); }
    }
    if(macro == PATTERN_LL || macro == PATTERN_BEAR_FLAG ||
       macro == PATTERN_DESCENDING_TRIANGLE || macro == PATTERN_DOUBLE_TOP ||
       macro == PATTERN_HEAD_SHOULDERS || macro == PATTERN_BEARISH_PENNANT) {
        if(patternSignal < 0) { patternSignal *= (1.0 + macroConf * 0.3); edgeStrength += 0.20; }
        else                  { patternSignal *= (1.0 - macroConf * 0.3); }
    }
    if(macro == PATTERN_WIDE_SR_RESPECT || macro == PATTERN_CONSOLIDATION) {
        // Range macro: reversal patterns at boundaries get quality boost
        if(micro == PATTERN_SR_BOUNCE || micro == PATTERN_FAILED_BREAKOUT ||
           micro == PATTERN_RANGE_FAKEOUT) {
            signalQuality += 0.20;
            edgeStrength  += 0.15;
        }
    }

    // Pattern-specific quality boosts
    // Multi-swing formations (Double Bottom/Top, H&S) carry highest reliability
    if(micro == PATTERN_DOUBLE_BOTTOM  || micro == PATTERN_DOUBLE_TOP ||
       micro == PATTERN_HEAD_SHOULDERS || micro == PATTERN_INV_HEAD_SHOULDERS) {
        signalQuality += 0.25;
        edgeStrength  += 0.25;
    }
    // Bull/Bear flags and pennants: reliable continuations
    if(micro == PATTERN_BULL_FLAG      || micro == PATTERN_BEAR_FLAG ||
       micro == PATTERN_BULLISH_PENNANT || micro == PATTERN_BEARISH_PENNANT) {
        signalQuality += 0.20;
        edgeStrength  += 0.18;
    }
    // CHoCH: structural reversal, high edge when confirmed
    if(micro == PATTERN_BULLISH_CHOCH || micro == PATTERN_BEARISH_CHOCH) {
        signalQuality += 0.15;
        edgeStrength  += 0.22;
    }
    // Exhaustion patterns: trade against the prior trend
    if(micro == PATTERN_PARABOLIC_STALL || micro == PATTERN_CLIMAX_REVERSAL ||
       micro == PATTERN_SPINNING_TOP_EXTREME) {
        signalQuality += 0.10;
        edgeStrength  += 0.15;
    }

    // Confidence derived from micro confidence ? pattern reliability
    double patternReliability = microConf;
    patternIntel.signalStrength    = MathMax(-1.0, MathMin(1.0, patternSignal));
    patternIntel.signalQuality     = MathMin(1.0, signalQuality);
    patternIntel.edgeContribution  = MathMin(1.0, edgeStrength);
    patternIntel.confidenceLevel   = MathMin(1.0, microConf * 0.6 + macroConf * 0.4);
    patternIntel.riskContribution  = isNeutralPattern ? 0.6 : 0.5;
    patternIntel.lastUpdate        = TimeCurrent();
}

void UpdatePredictiveIntelligence() {
    double predictiveSignal = 0.0;
    double signalQuality = 0.5;
    double edgeStrength = 0.5;
    
    if(predictiveSystem.predictionsValid) {
        predictiveSignal = predictiveSystem.predictedTrend * 100.0;
        predictiveSignal += (predictiveSystem.momentumContinuationProbability - 0.5) * 2.0;
        predictiveSignal -= (predictiveSystem.trendReversalProbability - 0.5) * 1.5;
        predictiveSignal /= 3.0;
        
        // Quality from prediction reliability
        signalQuality += predictiveSystem.predictionReliability * 0.3;
        
        // Edge from cumulative accuracy
        if(predictiveSystem.cumulativeAccuracy > 0.65) {
            edgeStrength += 0.3;
        }
    }
    
    // ## MARKET DNA CONTEXT ################################################
    double volumeContext  = MathMax(0.4, MathMin(1.6, intelligence.volumeRatio));
    double dramaContext   = 0.5;
    if(Bars >= 2) {
        MarketStateFeatures _pi = CalculateMarketFeatures(1);
        dramaContext = 0.3 + _pi.barDrama * 0.7;  // 0.3 (flat) to 1.0 (dramatic)
        // If market is drifting (low drama + low volume), reduce signal quality
        if(_pi.barDrama < 0.20 && intelligence.volumeRatio < 0.85) {
            signalQuality *= 0.75;  // Quiet drifting market -- predictions less reliable
        }
        // If market has clear directional conviction, boost reliability
        if(_pi.isConvictionCandle && _pi.barDrama > 0.6)
            signalQuality = MathMin(1.0, signalQuality + 0.10);
    }
    double marketVoice = volumeContext * dramaContext;  // 0.12 to 1.6

    // Risk contribution: higher when market is actively moving (cleaner execution)
    // Lower when thin (wide spread, drift) -- unpredictable slippage territory
    double spreadRisk = MathMin(0.4, intelligence.spreadNormalized * 0.5);
    predictiveIntel.riskContribution = MathMax(0.30, MathMin(0.80, 0.55 * marketVoice - spreadRisk));

    predictiveIntel.signalStrength  = MathMax(-1.0, MathMin(1.0, predictiveSignal));
    predictiveIntel.signalQuality   = MathMin(1.0, signalQuality);
    predictiveIntel.edgeContribution = MathMin(1.0, edgeStrength);
    predictiveIntel.confidenceLevel = predictiveSystem.predictionReliability * marketVoice;
    predictiveIntel.lastUpdate      = TimeCurrent();
}

void ApplyRegimeStrategy(int regime) {
    if(regime < 0 || regime >= 12) regime = 11;
    
    momentumIntel.baseWeight = regimeStrategies[regime].momentumWeight;
    reversalIntel.baseWeight = regimeStrategies[regime].reversalWeight;
    volatilityIntel.baseWeight = regimeStrategies[regime].volatilityWeight;
    biasIntel.baseWeight = regimeStrategies[regime].biasWeight;
    patternIntel.baseWeight = regimeStrategies[regime].patternWeight;
    predictiveIntel.baseWeight = regimeStrategies[regime].predictiveWeight;
}

// ========================================================================
// L5  EXECUTION GATE  (GIS 8-gates · Taylor edge · ProbDB · PLDS)
// ========================================================================
double CalculateStatisticalEdge() {
    // POST-CALIBRATION PATH: when CEUS weights are optimised, derive the statistical
    // edge from the CEUS score directly -- it already encodes regime-specific IC-weighted
    // component contributions. Using the legacy voting system alongside CEUS causes
    // silent directional conflicts. Let CEUS dominate; legacy supplements when uncalibrated.
    if(g_Calibration.isComplete && g_WeightsOptimized) {
        // CEUS score is 0-100 (50=neutral). Map to edge space: 50->0.50, 100->1.0, 0->0.0
        double ceusScore = engine.unifiedScore;  // set by CalculateEnhancedUnifiedScore
        double ceusEdge  = ceusScore / 100.0;    // 0.0-1.0

        // Blend with alignment score to produce a model-coherence-weighted edge
        double alignMod = (GetMarketAlignment() - 0.35) / 0.65;  // 0=critical, 1=strong
        alignMod = MathMax(0.0, MathMin(1.0, alignMod));

        // Weighted: 70% CEUS signal edge, 30% alignment coherence
        double blendedEdge = ceusEdge * 0.70 + (0.35 + alignMod * 0.30) * 0.30;
        blendedEdge = MathMax(0.0, MathMin(1.0, blendedEdge));

        // Apply live adaptive edge score if self-calibrated
        if(g_LiveAdaptive.selfCalibrated && g_LiveAdaptive.liveEdgeScore > 0.0) {
            blendedEdge = blendedEdge * 0.80 + g_LiveAdaptive.liveEdgeScore * 0.20;
        }

        taylorDecision.opportunity.edgeClarity     = blendedEdge;
        taylorDecision.opportunity.edgeConsistency = MathMin(1.0, blendedEdge + 0.15);
        return blendedEdge;
    }

    // PRE-CALIBRATION: legacy component voting system (fallback only)
    
    // PART 1: BASIC COMPONENT ALIGNMENT (30% weight)
    double totalVote = momentumIntel.vote + reversalIntel.vote + volatilityIntel.vote +
                      biasIntel.vote + patternIntel.vote + predictiveIntel.vote;
    double totalWeight = momentumIntel.effectiveWeight + reversalIntel.effectiveWeight +
                        volatilityIntel.effectiveWeight + biasIntel.effectiveWeight +
                        patternIntel.effectiveWeight + predictiveIntel.effectiveWeight;
    double normalizedVote = (totalVote / NonZero(totalWeight));
    double score = 50.0 + (normalizedVote * 50.0);
    
    // Component alignment consistency
    int alignedComponents = 0;
    bool isBullish = normalizedVote > 0;
    if((momentumIntel.signalStrength > 0) == isBullish) alignedComponents++;
    if((reversalIntel.signalStrength > 0) == isBullish) alignedComponents++;
    if((volatilityIntel.signalStrength > 0) == isBullish) alignedComponents++;
    if((biasIntel.signalStrength > 0) == isBullish) alignedComponents++;
    if((patternIntel.signalStrength > 0) == isBullish) alignedComponents++;
    if((predictiveIntel.signalStrength > 0) == isBullish) alignedComponents++;
    double alignmentScore = alignedComponents / 6.0;  // 0-1
    
    // PART 2: PRICE POSITION INTELLIGENCE (25% weight)
    double currentPrice = (Bid + Ask) / 2.0;
    
    // CRITICAL SAFETY: Check if enough bars exist for THIS specific timeframe
    int currentTFBars = iBars(_Symbol, PERIOD_CURRENT);
    double high_20 = 0, low_20 = 0;
    
    if(currentTFBars >= 20) {
        // Safe to use 20-period calculation
        int highestBar = SafeHL(iHighest(_Symbol, PERIOD_CURRENT, MODE_HIGH, 20, 0));
        int lowestBar = SafeHL(iLowest(_Symbol, PERIOD_CURRENT, MODE_LOW, 20, 0));
        
        // Double-check returned indices are valid
        if(highestBar >= 0 && highestBar < currentTFBars && 
           lowestBar >= 0 && lowestBar < currentTFBars) {
            high_20 = iHigh(_Symbol, PERIOD_CURRENT, highestBar);
            low_20 = iLow(_Symbol, PERIOD_CURRENT, lowestBar);
        } else {
            // Fallback: use current high/low
            high_20 = iHigh(_Symbol, PERIOD_CURRENT, 0);
            low_20 = iLow(_Symbol, PERIOD_CURRENT, 0);
        }
    } else {
        // Not enough bars, use current bar only
        high_20 = iHigh(_Symbol, PERIOD_CURRENT, 0);
        low_20 = iLow(_Symbol, PERIOD_CURRENT, 0);
    }
    
    double priceRange = high_20 - low_20;
    double pricePosition = (currentPrice - low_20) / NonZero(priceRange);  // 0=low, 1=high
    
    // Calculate price position edge
    double positionEdge = 0.0;
    
    // CRITICAL FIX: If range is too small (consolidation), use alternative calculation
    double minRange = iATR(_Symbol, PERIOD_CURRENT, 14, 0) * 0.5;  // Half of ATR
    if(priceRange < minRange) {
        // Range too small, use momentum-based clarity instead
        double rsi = iRSI(_Symbol, PERIOD_CURRENT, 14, PRICE_CLOSE, 0);
        if(isBullish) {
            positionEdge = (100.0 - rsi) / 100.0;  // Lower RSI = better BUY clarity
        } else {
            positionEdge = rsi / 100.0;  // Higher RSI = better SELL clarity
        }
    } else {
        // Normal calculation
        if(isBullish) {
            // Bullish signal better near lows (want to buy cheap)
            positionEdge = 1.0 - pricePosition;  // Higher edge when price near low
            if(pricePosition < 0.3) positionEdge *= 1.3;  // Bonus at bottom 30%
        } else {
            // Bearish signal better near highs (want to sell expensive)
            positionEdge = pricePosition;  // Higher edge when price near high
            if(pricePosition > 0.7) positionEdge *= 1.3;  // Bonus at top 30%
        }
    }
    
    // CRITICAL FIX: Prevent zero/negative clarity - EMERGENCY MINIMUM
    // User's logs show clarity = 0.000 constantly
    // This blocks 100% of trades even with 65% edges
    // Set emergency minimum of 0.05 if calculation returns too low
    positionEdge = MathMax(0.05, MathMin(1.0, positionEdge));  // Force minimum 0.05, max 1.0
    
    // PART 3: MOMENTUM INTELLIGENCE (20% weight)
    double momentum_now = g_ComponentScores.momentum - 50.0;  // -50 to +50
    double momentum_5ago = 0.0;
    static double g_LastMomentum[10];
    static int g_MomentumIndex = 0;
    
    // SAFETY: Only access history if we have enough data
    if(g_MomentumIndex >= 5) {
        int historyIndex = (g_MomentumIndex - 5) % 10;
        momentum_5ago = g_LastMomentum[historyIndex];
    }
    
    // Store current momentum (circular buffer)
    g_LastMomentum[g_MomentumIndex % 10] = momentum_now;
    g_MomentumIndex++;
    
    // Check if momentum is accelerating in signal direction
    double momentumChange = momentum_now - momentum_5ago;
    double momentumEdge = 0.0;
    if(isBullish && momentumChange > 0) {
        // Bullish signal + accelerating bullish momentum = HIGH EDGE
        momentumEdge = MathMin(1.0, MathAbs(momentumChange) / 20.0);
    } else if(!isBullish && momentumChange < 0) {
        // Bearish signal + accelerating bearish momentum = HIGH EDGE
        momentumEdge = MathMin(1.0, MathAbs(momentumChange) / 20.0);
    } else if((isBullish && momentumChange < -10) || (!isBullish && momentumChange > 10)) {
        // Momentum fighting signal = LOW EDGE
        momentumEdge = 0.2;
    } else {
        momentumEdge = 0.5;  // Neutral
    }
    
    // PART 4: VOLATILITY CONTEXT (15% weight)
    // Better edge when volatility favors the move
    double atrNow = intelligence.atrVolatility;
    double atrAvg = 0.0;
    for(int i = 1; i <= 20; i++) {
        atrAvg += iATR(_Symbol, PERIOD_CURRENT, 14, i);
    }
    atrAvg /= 20.0;
    double volExpansion = atrNow / NonZero(atrAvg);  // >1 = expanding, <1 = contracting
    
    double volatilityEdge = 0.5;  // Default neutral
    if(volExpansion > 1.2) {
        // Expanding volatility = good for breakout/trend moves
        if(intelligence.adx > 25) volatilityEdge = 0.85;  // High ADX + expansion = very good
        else volatilityEdge = 0.70;
    } else if(volExpansion < 0.8) {
        // Contracting volatility = lower edge (range-bound)
        volatilityEdge = 0.35;
    }
    
    // PART 5: CONFIRMATION INTELLIGENCE (10% weight)
    // Recent price action confirms the signal?
    double confirmationEdge = 0.5;  // Default
    double close_now = iClose(_Symbol, PERIOD_CURRENT, 0);
    double close_3 = iClose(_Symbol, PERIOD_CURRENT, 3);
    double priceMove = (close_now - close_3) / NonZero(close_3) * 10000;  // Pips moved
    
    if(isBullish && priceMove > 5) {
        // Bullish signal + price already moving up = confirmation
        confirmationEdge = 0.80;
    } else if(!isBullish && priceMove < -5) {
        // Bearish signal + price already moving down = confirmation
        confirmationEdge = 0.80;
    } else if((isBullish && priceMove < -10) || (!isBullish && priceMove > 10)) {
        // Price moving against signal = low edge
        confirmationEdge = 0.25;
    }
    
    // ## PART 6: LIVE ADAPTIVE + ALIGNMENT INTELLIGENCE ######################
    // The live edge factor now incorporates the CEO alignment score.
    double liveEdgeFactor = 0.50;
    double _seAlign = GetMarketAlignment();  // CEO: 0-1
    if(g_LiveAdaptive.selfCalibrated) {
        double liveEdge = 0.30 + g_LiveAdaptive.liveEdgeScore * 0.50;
        // Blend with alignment: if alignment is 0.8, trust the live edge fully
        // if alignment is 0.4, dampen it significantly
        liveEdgeFactor = liveEdge * (0.40 + _seAlign * 0.75);
        liveEdgeFactor = MathMax(0.15, MathMin(0.90, liveEdgeFactor));
        // Per-regime live WR alignment
        int regime6 = g_RegimeState.currentRegime;
        if(regime6 >= 0 && regime6 < 9 && g_LiveAdaptive.regimeTrades[regime6] >= 10) {
            double rLiveWR = g_LiveAdaptive.regimeLiveWR[regime6];
            // If live WR in this regime > 70%, this is a strong context
            if(rLiveWR >= 0.70) liveEdgeFactor = MathMin(0.85, liveEdgeFactor + 0.15);
            else if(rLiveWR < 0.55) liveEdgeFactor = MathMax(0.20, liveEdgeFactor - 0.20);
        }
    }

    // ## CANDLE ANATOMY EDGE LAYER ##########################################
    // Current bar anatomy directly says how convinced the market is right now.
    MarketStateFeatures _ea = CalculateMarketFeatures(0);
    double anatomyEdge = 0.50 + (_ea.wickPressureScore * 0.25);  // wick direction
    if(_ea.isConvictionCandle && _ea.isBullishCandle && isBullish)  anatomyEdge += 0.15;
    if(_ea.isConvictionCandle && _ea.isBearishCandle && !isBullish) anatomyEdge += 0.15;
    if(_ea.isIndecisionCandle)   anatomyEdge -= 0.10;
    if(_ea.isBullishRejection  && isBullish)  anatomyEdge += 0.12;
    if(_ea.isBearishRejection  && !isBullish) anatomyEdge += 0.12;
    anatomyEdge += (_ea.momentumBias5 * (isBullish?1:-1)) * 0.08;
    anatomyEdge = MathMax(0.15, MathMin(0.95, anatomyEdge));

    // ## REGIME-AWARE POSITION EDGE ########################################
    // In trending regimes, a breakout ABOVE the 20-bar high is CORRECT for buys.
    // The old code penalised this (buying near highs = bad). Fix with regime context.
    int curRegimeEdge = g_RegimeState.currentRegime;
    bool isTrendRegime = (curRegimeEdge == 0 || curRegimeEdge == 1);  // 0=bull,1=bear trend
    if(isTrendRegime) {
        // In trend: position edge reverses -- buy the breakout, sell the breakdown
        if(isBullish && pricePosition > 0.70) positionEdge = MathMin(0.95, positionEdge * 1.4);
        else if(!isBullish && pricePosition < 0.30) positionEdge = MathMin(0.95, positionEdge * 1.4);
    }

    // COMBINE ALL INTELLIGENCE LAYERS (regime-weighted blend)
    double intelligentEdge = (alignmentScore  * 0.22) +  // Component alignment
                             (positionEdge    * 0.16) +  // Price position (regime-adjusted)
                             (momentumEdge    * 0.16) +  // Momentum acceleration
                             (volatilityEdge  * 0.12) +  // Volatility context
                             (confirmationEdge* 0.08) +  // Price confirmation
                             (liveEdgeFactor  * 0.14) +  // Live adaptive intelligence
                             (anatomyEdge     * 0.12);   // Current bar anatomy

    // edgeClarity is used by ValidateEdge -- set to TRUE signal discriminability,
    // not price position (which was causing 0.000 clarity readings in logs).
    // Clarity = how consistent are the component signals?
    // High clarity = everything pointing same way. Low = mixed signals.
    double signalConsensus = (double)alignedComponents / 6.0;
    double edgeClarity = signalConsensus * 0.60 + (_ea.candleBodyPct) * 0.40;
    edgeClarity = MathMax(0.05, MathMin(1.0, edgeClarity));

    taylorDecision.opportunity.edgeStrength   = intelligentEdge;
    taylorDecision.opportunity.edgeClarity    = edgeClarity;  // Fixed: was always 0
    taylorDecision.opportunity.edgeConsistency = alignmentScore;
    
    // CRITICAL FIX: Enhanced score smoothing to prevent wild oscillations
    // User's NEW logs STILL showed: 86.6 (+31.52) -> 55.1 (-17.67) -> 72.8 (+17.7)
    // 3-period MA wasn't enough - increasing to 5-period for better stability
    static double g_ScoreHistory[5] = {50.0, 50.0, 50.0, 50.0, 50.0};
    static int g_ScoreIndex = 0;
    
    // Store current score in circular buffer
    g_ScoreHistory[g_ScoreIndex % 5] = score;
    g_ScoreIndex++;
    
    // Calculate smoothed score (average of last 5)
    double smoothedScore = (g_ScoreHistory[0] + g_ScoreHistory[1] + g_ScoreHistory[2] + 
                           g_ScoreHistory[3] + g_ScoreHistory[4]) / 5.0;
    
    // [FIX-A] engine.unifiedScore NOT overwritten here -- this smoothedScore is an
    // internal vote-MA unrelated to the CEUS pipeline. Clobbering it would discard
    // calibrated regime/session/vol weights. Score flows intact from ProcessExecutionDecisions.
    
    return intelligentEdge;
}

// 9.39: shared bounds-checked accessor -- ValidateEdge, ValidateRisk,
// CalculateOptimalPositionSizing, and DetermineOptimalTPSL each indexed
// regimeStrategies[currentRegime] directly with no bounds check. Falls back to
// regime 9 (VOLATILITY SPIKE -- the most defensive config: smallest positions,
// lowest risk tolerance, no aggressive mode) rather than an arbitrary index,
// since an out-of-range regime represents genuine uncertainty.
RegimeStrategy GetRegimeStrategy(int regime) {
    if(regime < 0 || regime >= 12) regime = 9;
    return regimeStrategies[regime];
}

bool ValidateEdge(double edgeScore) {
    int currentRegime = (int)engine.regime;
    double requiredEdge = GetRegimeStrategy(currentRegime).requiredEdgeStrength;

    if(conservativeModeActive) requiredEdge += 0.10;

    // ## MARKET STRUCTURE GATES ############################################
    // These gates adjust required edge based on current market microstructure.
    // They are cumulative -- multiple adverse conditions compound the requirement.

    // Gate 1: Spread relative to ATR (thin liquidity)
    if(intelligence.spreadNormalized > 0.30) {
        requiredEdge += 0.08;
    }
    if(intelligence.spreadNormalized > 0.50) {
        // Spread > 50% of ATR: genuinely thin -- only exceptional setups
        requiredEdge += 0.12;
    }

    // ## CANDLE ANATOMY GATE: indecision ###################################
    // An indecision bar means the market hasn't resolved direction yet.
    // It's valid to trade after confirmed resolution, not during uncertainty.
    // Only applies when weights show indecision is unreliable in this context.
    if(g_CandleWeightsCalibrated) {
        MarketStateFeatures _ve = CalculateMarketFeatures(0);
        if(_ve.isIndecisionCandle && g_CalibratedCandleWeights[11] > 0.7) {
            requiredEdge += 0.05;  // Raise bar -- wait for conviction
        }
        // If bar drama is very low (market is barely moving), raise bar too
        if(_ve.barDrama < 0.15 && intelligence.volumeRatio < 0.8) {
            requiredEdge += 0.04;  // Flat bar on low volume = no institutional interest
        }
    }

    // ## PRECISION MICROSTRUCTURE GATES (new fields) ######################
    {
        MarketStateFeatures _pmg = CalculateMarketFeatures(0);
        // Gate: ATR spike -- extreme volatility degrades execution quality
        if(_pmg.atrPercentile > 0.85)
            requiredEdge += 0.06;  // Top 15% ATR: spike risk -- raise bar
        // Gate: Volume confirmation in trend regimes
        if(currentRegime <= 3 && _pmg.volumeDelta < 0.70)
            requiredEdge += 0.05;  // Trend signal on declining volume = suspect breakout
        // Gate: Close position counter to signal direction
        bool _isBuyVE = (edgeScore > 0.5);
        if(_isBuyVE  && _pmg.closePosition < 0.25) requiredEdge += 0.04;  // Buy but closed near low
        if(!_isBuyVE && _pmg.closePosition > 0.75) requiredEdge += 0.04;  // Sell but closed near high
        // Bonus: conviction close in signal direction earns slight relaxation
        if(_isBuyVE  && _pmg.closePosition > 0.80 && _pmg.bodyRatio > 0.55) requiredEdge -= 0.03;
        if(!_isBuyVE && _pmg.closePosition < 0.20 && _pmg.bodyRatio > 0.55) requiredEdge -= 0.03;
    }

    double tolerance      = requiredEdge * 0.02;
    double effectiveEdgeReq = requiredEdge - tolerance;

    bool edgePass        = (edgeScore >= effectiveEdgeReq);
    // edgeConsistency = alignmentScore (0-1): how many components agree on direction
    // 0.15 = 1/6 agree -- too easy. Raise to 0.33 = at least 2/6 aligned.
    bool consistencyPass = (taylorDecision.opportunity.edgeConsistency >= 0.33);
    // edgeClarity is now signal discriminability (bodyPct + consensus), not price position.
    // Old value 0.027 was designed around price-position which ranged 0.05-1.0.
    // New range is also 0.05-1.0 but more meaningful. Keep threshold at 0.20.
    bool clarityPass     = (taylorDecision.opportunity.edgeClarity >= 0.20);

    if(!edgePass)        return false;
    if(!consistencyPass) return false;
    if(!clarityPass)     return false;

    taylorDecision.opportunity.hasStatisticalEdge = true;
    taylorDecision.opportunity.edgeStrength = edgeScore;
    return true;
}

// STAGE 2: ASSESS AND VALIDATE RISK

double CalculateRiskScore() {
    double totalRisk = 0.0;
    
    // Market risk (volatility, spread, liquidity)
    double marketRisk = 0.0;
    
    // Volatility risk -- enhanced with atrPercentile (distributional context)
    // Raw ATR ratio tells you size relative to recent average.
    // atrPercentile tells you where you are in the full distribution -- 
    // top 10% of volatility means the market is in genuinely unusual conditions.
    MarketStateFeatures _rsf = CalculateMarketFeatures(0);  // cached
    if(_rsf.atrPercentile > 0.90)       marketRisk += 0.45;  // extreme spike -- high execution risk
    else if(_rsf.atrPercentile > 0.80)  marketRisk += 0.30;  // spike environment
    else if(intelligence.atrVolatility > 1.5) marketRisk += 0.20;
    else if(intelligence.atrVolatility < 0.7) marketRisk += 0.12;
    // Counter-structure adds model risk: price far from EMA200 in wrong direction
    if(MathAbs(_rsf.ema200Distance) > 3.0) marketRisk += 0.10;
    
    // Spread risk
    if(intelligence.spreadNormalized > 2.0) marketRisk += 0.3;
    else if(intelligence.spreadNormalized > 1.5) marketRisk += 0.15;
    
    // Liquidity risk
    if(intelligence.liquidityIndex < 0.5) marketRisk += 0.3;
    else if(intelligence.liquidityIndex < 0.7) marketRisk += 0.15;
    
    taylorDecision.opportunity.marketRisk = MathMin(1.0, marketRisk);
    
    // Execution risk (timing, slippage)
    double executionRisk = 0.0;
    
    // Recent slippage or execution delays
    if(engine.executionDelayMs > RAPID_EXECUTION_TIMEOUT) executionRisk += 0.2;
    
    // Market hours risk
    int hour = TimeHour(TimeCurrent());
    if(hour < 2 || hour > 22) executionRisk += 0.15; // Outside main hours
    
    taylorDecision.opportunity.executionRisk = MathMin(1.0, executionRisk);
    
    // Portfolio/correlation risk
    double correlationRisk = 0.0;
    
    // Portfolio heat
    if(tradeManager.portfolioHeat > PORTFOLIO_HEAT_LIMIT * 0.8) correlationRisk += 0.3;
    else if(tradeManager.portfolioHeat > PORTFOLIO_HEAT_LIMIT * 0.6) correlationRisk += 0.15;
    
    // Number of active trades
    if(engine.activeTrades >= riskMgr.maxConcurrentTrades * 0.8) correlationRisk += 0.2;
    
    // Daily risk used
    if ((double)maxDailyRiskUsed > 3.0) correlationRisk += 0.25;
    else if ((double)maxDailyRiskUsed > 2.0) correlationRisk += 0.15;
    
    taylorDecision.opportunity.correlationRisk = MathMin(1.0, correlationRisk);
    
    // Total risk score
    totalRisk = (marketRisk * 0.4) + (executionRisk * 0.2) + (correlationRisk * 0.4);
    
    taylorDecision.opportunity.riskScore = totalRisk;
    
    return totalRisk;
}

bool ValidateRisk(double riskScore) {
    int currentRegime = (int)engine.regime;
    double riskTolerance = GetRegimeStrategy(currentRegime).riskTolerance;
    
    // In conservative mode, reduce tolerance
    if(conservativeModeActive) {
        riskTolerance *= 0.7;
    }
    
    // After consecutive stop-outs, be more cautious
    if(consecutiveStopOuts >= 3) {
        riskTolerance *= 0.8;
    }
    
    // Check if risk is acceptable
    double maxAcceptableRisk = 0.5 * riskTolerance;
    
    if(riskScore > maxAcceptableRisk) return false;

    // Additional safety checks

    // Portfolio heat check
    if(tradeManager.portfolioHeat > PORTFOLIO_HEAT_LIMIT) return false;

    // Daily risk check
    if((double)maxDailyRiskUsed > 4.0) return false;

    // Emergency mode check
    if(riskMgr.emergencyActive) return false;

    // Max concurrent trades check
    if(engine.activeTrades >= riskMgr.maxConcurrentTrades) return false;
    
    taylorDecision.opportunity.maxAcceptableRisk = maxAcceptableRisk;
    taylorDecision.opportunity.passesRiskCheck = true;
    
    return true;
}

// STAGE 3: OPTIMIZE POSITION SIZING AND TP/SL

void CalculateOptimalPositionSizing() {
    int currentRegime = (int)engine.regime;
    double accountEquity = AccountEquity();
    
    // Base position size from Kelly Criterion
    double edgeStrength = taylorDecision.opportunity.edgeStrength;
    double winRate = CalculateRecentWinRate() / 100.0;
    double avgRR = tpslSystem.recentRR;
    
    // Kelly = (winRate * (avgRR + 1) - 1) / avgRR
    double kellyFraction = 0.0;
    if(avgRR > 0 && winRate > 0) {
        kellyFraction = (winRate * (avgRR + 1.0) - 1.0) / NonZero(avgRR);
        kellyFraction = MathMax(0.0, MathMin(0.25, kellyFraction)); // Cap at 25%
    }
    
    // Start with conservative fraction of Kelly
    taylorDecision.kellyCriterion = kellyFraction;
    // 9.43 UNITS FIX: kellyFraction is a FRACTION OF EQUITY TO RISK (dimensionless), but
    // this function's output flows into lot-denominated fields (lot-step normalization,
    // broker min/max lot bounds, and the "broker limit approaching" warning). The old
    // code passed the raw fraction straight through -- half-Kelly 0.05 became 0.05 LOTS
    // on every account from $1k to $1M identically, and accountEquity was fetched then
    // never used. Convert properly: lots = riskMoney / (SL distance in ticks x tick
    // value), with SL distance estimated the same way the live path estimates it
    // (ATR x the current regime's calibrated SL multiplier).
    double baseSize = kellyFraction * 0.5; // 50% of Kelly (safety margin) -- still a fraction here
    {
        double _psATR = iATR(Symbol(), 0, 14, 1);
        int    _psReg = MathMin(8, MathMax(0, currentRegime));
        double _psSLM = (g_RegimeOptimalSLMult[_psReg] >= 0.3) ? g_RegimeOptimalSLMult[_psReg] : 1.5;
        double _psTickVal  = MarketInfo(Symbol(), MODE_TICKVALUE);
        double _psTickSize = MarketInfo(Symbol(), MODE_TICKSIZE);
        if(_psATR > 0 && _psTickVal > 0 && _psTickSize > 0 && accountEquity > 0) {
            double _slDist     = _psATR * _psSLM;                          // price distance
            double _riskMoney  = accountEquity * baseSize;                  // $ at risk
            double _lossPerLot = (_slDist / _psTickSize) * _psTickVal;      // $ lost per lot at SL
            baseSize = (_lossPerLot > 0) ? _riskMoney / _lossPerLot : 0.01; // now genuinely LOTS
        }
    }
    if(baseSize <= 0) baseSize = 0.01; // Minimum base
    
    // Adjust for edge strength
    double edgeMultiplier = 0.7 + (edgeStrength * 0.6); // 0.7 to 1.3
    
    // Adjust for risk
    double riskMultiplier = 1.0 - (taylorDecision.opportunity.riskScore * 0.5); // 0.5 to 1.0
    
    // Adjust for regime
    double regimeMultiplier = GetRegimeStrategy(currentRegime).maxPositionSize;
    
    // Adjust for recent performance
    double performanceMultiplier = 1.0;
    if(tpslSystem.consecutiveWins >= 3) {
        performanceMultiplier = 1.15; // Increase when winning
    } else if(tpslSystem.consecutiveLosses >= 3) {
        performanceMultiplier = 0.7; // Decrease when losing
    }
    
    // Adjust for confidence
    double avgConfidence = (momentumIntel.confidenceLevel + reversalIntel.confidenceLevel + 
                           biasIntel.confidenceLevel + patternIntel.confidenceLevel) / 4.0;
    double confidenceMultiplier = 0.8 + (avgConfidence * 0.4); // 0.8 to 1.2
    
    // Calculate final size
    taylorDecision.calculatedSize = baseSize * edgeMultiplier * confidenceMultiplier * performanceMultiplier;
    taylorDecision.riskAdjustedSize = taylorDecision.calculatedSize * riskMultiplier * regimeMultiplier;
    
    // Apply conservative mode
    if(conservativeModeActive) {
        taylorDecision.riskAdjustedSize *= 0.6;
    }
    
    // E9.93 UPGRADE: Broker-aware lot cap -- replaces hard 0.5-1.5 ceiling
    double brokerMaxLot  = MarketInfo(Symbol(), MODE_MAXLOT);
    double brokerMinLot  = MarketInfo(Symbol(), MODE_MINLOT);
    double brokerLotStep = MarketInfo(Symbol(), MODE_LOTSTEP);
    if(brokerMaxLot  <= 0) brokerMaxLot  = 500.0;
    if(brokerMinLot  <= 0) brokerMinLot  = 0.01;
    if(brokerLotStep <= 0) brokerLotStep = 0.01;

    // Normalize to lot step
    double normalizedSize = taylorDecision.riskAdjustedSize;
    if(brokerLotStep > 0)
        normalizedSize = MathFloor(normalizedSize / brokerLotStep) * brokerLotStep;

    // Apply broker bounds (minimum 0.01 lots, maximum broker-reported)
    taylorDecision.finalSize = MathMax(brokerMinLot, MathMin(brokerMaxLot, normalizedSize));

    // Warn when approaching broker lot ceiling (>80% of max)
    static datetime lastBrokerCapWarn = 0;
    if(taylorDecision.finalSize >= brokerMaxLot * 0.80 && TimeCurrent() - lastBrokerCapWarn > 3600) {
        PrintFormat("  broker limit approaching   |   lot %.2f   |   consider additional account", taylorDecision.finalSize);
        lastBrokerCapWarn = TimeCurrent();
    }
    
    // Store in opportunity
    taylorDecision.opportunity.basePositionSize = baseSize;
    taylorDecision.opportunity.confidenceMultiplier = confidenceMultiplier;
    taylorDecision.opportunity.riskAdjustment = riskMultiplier * regimeMultiplier;
    taylorDecision.opportunity.finalPositionSize = taylorDecision.finalSize;
}

void DetermineOptimalTPSL() {
    int currentRegime = (int)engine.regime;
    if(currentRegime < 0 || currentRegime >= 9) currentRegime = 0;  // R8 valid

    double edgeStrength = taylorDecision.opportunity.edgeStrength;
    double riskScore    = taylorDecision.opportunity.riskScore;

    // ## Base TP/SL multipliers: calibrated Phase 3C values take priority #####
    // Conservative / optimal / aggressive are derived from the calibrated base
    // with +/-15% / +/-30% spread so the blending logic below still has range.
    double baseTP, baseSL;
    if(g_WeightsOptimized) {
        baseSL = (g_RegimeOptimalSLMult[MathMin(8,MathMax(0,currentRegime))] > 0) ? g_RegimeOptimalSLMult[MathMin(8,MathMax(0,currentRegime))] : 1.5;
        baseTP = (g_RegimeOptimalTPMult[MathMin(8,MathMax(0,currentRegime))] > 0) ? g_RegimeOptimalTPMult[MathMin(8,MathMax(0,currentRegime))] : 2.5;
        // Session-specific override
        int _gmtH3 = (TimeHour(TimeCurrent()) - g_ServerTimeOffsetHours + 24) % 24;
        int ses3 = (_gmtH3>=7&&_gmtH3<16)?0:(_gmtH3>=16&&_gmtH3<21)?1:(_gmtH3>=21||_gmtH3<6)?3:2;
        if(g_SessionSLMult[ses3][currentRegime] > 0.1) {
            baseSL = g_SessionSLMult[ses3][currentRegime];
            baseTP = g_SessionTPMult[ses3][currentRegime];
        }
    } else {
        baseSL = 1.5;
        baseTP = regimeStrategies[currentRegime].optimalTP;
        if(baseTP <= 0) baseTP = 2.5;
    }

    // Derive three tiers from base (conservative/optimal/aggressive)
    taylorDecision.conservativeTP = baseTP * 0.85;
    taylorDecision.optimalTP      = baseTP;
    taylorDecision.aggressiveTP   = baseTP * 1.20;

    // Choose tier based on setup quality
    if(edgeStrength > 0.75 && taylorDecision.opportunity.edgeConsistency > 0.75 &&
       riskScore < 0.3 && regimeStrategies[currentRegime].allowAggressive) {
        taylorDecision.selectedTP = taylorDecision.aggressiveTP;
        taylorDecision.opportunity.isHighConfidenceSetup = true;
    } else if(edgeStrength > 0.65 && taylorDecision.opportunity.edgeConsistency > 0.65) {
        taylorDecision.selectedTP = taylorDecision.optimalTP;
        taylorDecision.opportunity.isModerateSetup = true;
    } else {
        taylorDecision.selectedTP = taylorDecision.conservativeTP;
        taylorDecision.opportunity.isLowConfidenceSetup = true;
    }

    // Volatility adjustment (legacy: ATR ratio)
    if(intelligence.atrVolatility > 1.5)      taylorDecision.selectedTP *= 1.2;
    else if(intelligence.atrVolatility < 0.8)  taylorDecision.selectedTP *= 0.9;

    // Precision volatility adjustment using atrPercentile (distribution-aware)
    // Spike environment: tighten TP (spike reverts). SL side of this moved below --
    // 9.39: selectedSL isn't assigned until the tier-selection block further down,
    // so the widen/tighten-SL adjustment used to run against a stale prior-tick value
    // and then get silently overwritten a few lines later. It never actually took effect.
    double _atrPctSLAdj = 1.0;  // applied to selectedSL after it's actually assigned below
    {
        MarketStateFeatures _tpf = CalculateMarketFeatures(0);  // cached
        if(_tpf.atrPercentile > 0.80) {
            _atrPctSLAdj = 1.15;                 // widen SL -- spike bars hit tight stops
            taylorDecision.selectedTP *= 0.90;   // reduce TP -- spike reverses quickly
        } else if(_tpf.atrPercentile < 0.20) {
            _atrPctSLAdj = 0.90;                 // tighten SL -- compressed vol = less noise
        }
        // Volume expansion confirmation: if vol expanding AND TP is aggressive,
        // maintain it -- the move has fuel
        if(_tpf.volExpansion > 1.3 && taylorDecision.opportunity.isHighConfidenceSetup)
            taylorDecision.selectedTP *= 1.05;  // slight TP extension on confirmed expansion
    }

    // Recent performance adjustment
    if(tpslSystem.consecutiveWins >= 3 && tpslSystem.recentWinRate > 0.7)
        taylorDecision.selectedTP *= 1.1;

    taylorDecision.selectedTP = MathMax(DYNAMIC_TP_BASE * 0.8,
                                        MathMin(DYNAMIC_TP_MAX, taylorDecision.selectedTP));

    // SL: derive tiers from calibrated base
    taylorDecision.tightSL  = baseSL * 0.85;
    taylorDecision.normalSL = baseSL;
    taylorDecision.wideSL   = baseSL * 1.20;

    if(riskScore > 0.4 || intelligence.atrVolatility > 1.8) {
        taylorDecision.selectedSL = taylorDecision.tightSL;
    } else if(edgeStrength > 0.7 && intelligence.atrVolatility < 1.2) {
        taylorDecision.selectedSL = taylorDecision.normalSL;
    } else {
        taylorDecision.selectedSL = taylorDecision.normalSL * 0.95;
    }

    // 9.39: this is the atrPercentile-based widen/tighten from above, now actually applied.
    taylorDecision.selectedSL *= _atrPctSLAdj;

    if(tpslSystem.consecutiveLosses >= FLOOR_GHOST_CONSEC_LOSSES)
        taylorDecision.selectedSL *= 0.85;

    tpslSystem.currentTPMultiplier = taylorDecision.selectedTP;
    tpslSystem.currentSLMultiplier = taylorDecision.selectedSL;
}

bool ValidateExecution() {
    // Check spread
    if(intelligence.spreadNormalized > 2.0) {
        taylorDecision.rejectionReason = "Spread is wide - waiting for optimal execution";
        return false;
    }
    
    // Check liquidity
    if(intelligence.liquidityIndex < 0.5) {
        taylorDecision.rejectionReason = "Insufficient liquidity";
        return false;
    }
    
    // Check Kelly fraction: if edge is zero or negative, don't trade.
    if(taylorDecision.kellyCriterion <= 0) {
        taylorDecision.rejectionReason = "Kelly criterion zero -- no statistical edge";
        return false;
    }

    // Check RR ratio
    double impliedRR = taylorDecision.selectedTP / NonZero(taylorDecision.selectedSL);
    if(impliedRR < MIN_RISK_REWARD_RATIO) {
        taylorDecision.rejectionReason = "Risk-reward ratio below minimum";
        return false;
    }
    
    // Calculate expected value
    double winRate = CalculateRecentWinRate() / 100.0;
    taylorDecision.expectedProfit = winRate * impliedRR;
    taylorDecision.expectedLoss = (1.0 - winRate) * 1.0;
    taylorDecision.expectedValue = taylorDecision.expectedProfit - taylorDecision.expectedLoss;
    
    // Expected value must be positive
    if(taylorDecision.expectedValue <= 0) {
        taylorDecision.rejectionReason = "Negative expected value";
        return false;
    }
    
    // Store in opportunity
    taylorDecision.opportunity.riskRewardRatio = impliedRR;
    taylorDecision.opportunity.expectedValue = taylorDecision.expectedValue;
    taylorDecision.opportunity.passesExecutionCheck = true;
    
    // Calculate confidence score (0-100)
    taylorDecision.confidenceScore = (int)((taylorDecision.opportunity.edgeStrength * 30) + 
                                           (taylorDecision.opportunity.edgeConsistency * 30) + 
                                           ((1.0 - taylorDecision.opportunity.riskScore) * 20) + 
                                           (taylorDecision.expectedValue * 20));
    
    return true;
}


// REPLACE CalculateEnhancedProbability

// CONSERVATIVE MODE AND RISK CONTROL

void E99_UpdateConservativeMode() {
    // SMART CIRCUIT BREAKER - Ghost Mode Instead of Pause
    
    // Track consecutive losses for smart circuit breaker
    g_SmartCB.consecutiveLosses = g_State.consecutiveLosses;  // FIX15: immediate, not 60s lag
    
    // Activate GHOST MODE after FLOOR_GHOST_CONSEC_LOSSES consecutive losses (floor: 4)
    // System may trigger earlier if adaptive learning detects edge deterioration.
    // Never triggers later than FLOOR_GHOST_CONSEC_LOSSES regardless of settings.
    // Calibrated ghost trigger threshold — dynamic by regime/session quality.
    int _cbFloor = FLOOR_GHOST_CONSEC_LOSSES;
    if(g_CorrelationsLearned) {
        int _cbReg  = g_RegimeState.currentRegime;
        int _cbGmtH = (TimeHour(TimeCurrent()) - g_ServerTimeOffsetHours + 24) % 24;
        int _cbSess = (_cbGmtH < 8) ? 0 : (_cbGmtH < 13) ? 1 : (_cbGmtH < 17) ? 2 : 3;
        if(_cbReg >= 0 && _cbReg < 9 && g_RegimeCorrelations[_cbReg].signalTotal >= 5) {
            double _cbWR = (g_RegimeCorrelations[_cbReg].sessionTotal[_cbSess] >= 5)
                ? g_RegimeCorrelations[_cbReg].sessionWR[_cbSess]
                : g_RegimeCorrelations[_cbReg].signalWR;
            if(_cbWR < 0.50)       _cbFloor = 2;
            else if(_cbWR < 0.55)  _cbFloor = 3;
            else if(_cbWR >= 0.70) _cbFloor = MathMin(6, FLOOR_GHOST_CONSEC_LOSSES + 2);
        }
    }

    int _ceoGhostFloor = g_CEO_GhostTriggerLosses;  // CCS: elite needs more losses to trigger
    if(tpslSystem.consecutiveLosses >= _ceoGhostFloor && !g_SmartCB.inGhostMode && UseGhostDuringPauses) {
        ActivateGhostMode();
        return;
    }

    // Traditional conservative mode (fallback if ghost disabled)
    int _rlt10=FLOOR_GHOST_CONSEC_LOSSES;
    { int _rc10=MathMin(8,MathMax(0,g_RegimeState.currentRegime));
      if(_rc10==0||_rc10==1) _rlt10=6; else if(_rc10==6||_rc10==7) _rlt10=4; }
    if(tpslSystem.consecutiveLosses >= _rlt10 && !conservativeModeActive && !UseGhostDuringPauses) {
        conservativeModeActive = true;
        consecutiveStopOuts = tpslSystem.consecutiveLosses;
        LogCriticalEvent("CONSERVATIVE MODE ACTIVATED - Raising quality bar", "RISK");
    }
    
    // Deactivate after 3 consecutive wins OR after ghost mode completes successfully
    if((tpslSystem.consecutiveWins >= 3 || g_SmartCB.canResumeTrading) && conservativeModeActive) {
        conservativeModeActive = false;
        consecutiveStopOuts = 0;

        if(g_SmartCB.canResumeTrading) {
            LogCriticalEvent(StringFormat("Ghost mode complete - Resuming: %s",
                           g_SmartCB.resumeReason), "GHOST");
        } else {
            LogCriticalEvent("Conservative mode deactivated - Normal operation", "RISK");
        }
    }

    // ## POST-GHOST SLINGSHOT INTELLIGENCE ####################################
    static bool postGhostSlingshotChecked = false;
    if(g_SmartCB.inGhostMode) postGhostSlingshotChecked = false;  // Reset when ghost starts
    if(!g_SmartCB.inGhostMode && !postGhostSlingshotChecked) {
        postGhostSlingshotChecked = true;
        // Ghost just ended -- check whether it succeeded
        int ghostTotal = g_SmartCB.ghostWins + g_SmartCB.ghostLosses;
        double ghostWR = ghostTotal > 0 ? (double)g_SmartCB.ghostWins / ghostTotal * 100.0 : 0;
        bool ghostFailed = (ghostTotal >= FLOOR_GHOST_MIN_TRADES && ghostWR < FLOOR_GHOST_VALIDATION_WR);
        bool equityStillDown = (g_State.currentDrawdown >= FLOOR_SLINGSHOT_THRESHOLD * 0.5);

        if(ghostFailed && equityStillDown && !g_Slingshot.isActive) {
            PrintFormat("  GHOST  |   mode insufficient   |   WR %.0f%%   |   equity -%.1f%%   |   activating slingshot",
                       ghostWR, g_State.currentDrawdown);
            ActivateSlingshotWithMode(SLING_EQUITY);
        }
    }
    
    // Reset daily risk at start of new day
    static int lastDay = 0;
    int currentDay = TimeDay(TimeCurrent());
    if(currentDay != lastDay) {
        maxDailyRiskUsed = 0.0;
        lastDay = currentDay;
    }
}

// REPLACE UpdateOutcomeValidationFramework

// Duplicate definition of function 'UpdateOutcomeValidationFramework' removed by auto-fix. Kept the most complete implementation.

void E99_UpdateComponentPerformance(IntelligentComponent &comp, int regime) {
    // Scan recent trades
    int recentTrades = 0;
    int profitable = 0;
    double totalProfit = 0.0;
    double totalLoss = 0.0;

    // SLS23 FIX: this function re-scans the same up-to-20 most-recent closed trades every call
    // (once per bar) but used to ++ these counters instead of resetting them first -- they grew
    // roughly at bar-rate forever, so within days the accumulated mass made the win-rate ratio
    // E99_AdjustComponentWeight reads numerically frozen and unresponsive to real new trades.
    if(regime >= 0 && regime < 9) {
        comp.recentSignals[regime] = 0;
        comp.correctSignals[regime] = 0;
    }

    for(int i = OrdersHistoryTotal() - 1; i >= 0 && recentTrades < 20; i--) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                recentTrades++;
                comp.recentSignals[regime]++;
                
                if(profit > 0) {
                    profitable++;
                    comp.correctSignals[regime]++;
                    totalProfit += profit;
                } else {
                    totalLoss += MathAbs(profit);
                }
            }
        }
    }
    
    if(recentTrades > 0) {
        comp.averageProfit[regime] = totalProfit / NonZero(recentTrades);
        comp.averageLoss[regime] = totalLoss / NonZero(recentTrades);
        
        // Calculate Sharpe ratio
        if(comp.averageLoss[regime] > 0) {
            comp.sharpeRatio[regime] = (comp.averageProfit[regime] - comp.averageLoss[regime]) / 
                                       NonZero(comp.averageLoss[regime]);
        }
    }
}

void E99_AdjustComponentWeight(IntelligentComponent &comp) {
    int currentRegime = (int)engine.regime;
    
    // Calculate win rate
    double winRate = 0.5;
    if(currentRegime >= 0 && currentRegime < 9 && comp.recentSignals[currentRegime] > 5) {
        winRate = (double)comp.correctSignals[currentRegime] / NonZero(comp.recentSignals[currentRegime]);
    }
    
    // Calculate profit factor
    double profitFactor = 1.0;
    if(comp.averageLoss[currentRegime] > 0) {
        profitFactor = comp.averageProfit[currentRegime] / NonZero(comp.averageLoss[currentRegime]);
    }
    
    // Adjust performance weight based on profitability
    if(profitFactor > 1.5 && winRate > 0.60) {
        // Excellent performance
        comp.performanceWeight *= 1.05;
        comp.performanceWeight = MathMin(1.5, comp.performanceWeight);
    } else if(profitFactor < 0.8 || winRate < 0.45) {
        // Poor performance
        comp.performanceWeight *= 0.95;
        comp.performanceWeight = MathMax(0.6, comp.performanceWeight);
    }
    
    // Adjust risk-adjusted weight based on Sharpe ratio
    if(comp.sharpeRatio[currentRegime] > 1.0) {
        comp.riskAdjustedWeight = 1.0 + (comp.sharpeRatio[currentRegime] - 1.0) * 0.2;
    } else if(comp.sharpeRatio[currentRegime] < 0.5) {
        comp.riskAdjustedWeight = 0.8 + comp.sharpeRatio[currentRegime] * 0.4;
    } else {
        comp.riskAdjustedWeight = 1.0;
    }
    
    comp.riskAdjustedWeight = MathMax(0.6, MathMin(1.4, comp.riskAdjustedWeight));
    
    // Gradual return to baseline
    if(comp.performanceWeight > 1.2) {
        comp.performanceWeight *= 0.995;
    } else if(comp.performanceWeight < 0.9) {
        comp.performanceWeight *= 1.005;
    }
}

