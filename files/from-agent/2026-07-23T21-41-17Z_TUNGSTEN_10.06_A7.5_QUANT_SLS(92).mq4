    regimeStrategies[8].aggressiveTP = 3.5;
    regimeStrategies[8].optimalTP = 2.5;
    regimeStrategies[8].riskTolerance = 1.2;
    regimeStrategies[8].allowAggressive = true;
    
    // SLS(20) FORMAL STATUS -- regimeStrategies[9..11]: RESERVED, UNREACHABLE BY CONSTRUCTION.
    // Invariants that keep this safe: (1) the classifier's entire output domain is 0-8
    // (regimeBelief[9], ClassifyBarToRegime_WithHysteresis); (2) the sole accessor
    // GetRegimeStrategy() clamps its index to [0,8], so no code path can read 9-11 even
    // with a corrupted regime value; (3) no persistence block writes or reads these
    // entries. They are dormant configuration for the unfinished Layer 1 adaptive/hybrid
    // regime concept (useAdaptiveRegime). Wiring them is an architectural expansion
    // (every [9]-dimensioned structure in the system would need widening), not a patch --
    // do not wire, do not delete, without a deliberate architecture decision.
    // VOLATILITY SPIKE (9) - DEFENSIVE: Reduce size, tight stops
    regimeStrategies[9].maxPositionSize = 0.8;        // SMALLER positions
    regimeStrategies[9].maxRiskPercent = 1.0;
    // CRITICAL FIX: During volatility, edges COMPRESS (uncertainty increases)
    // Logic: LOWER requirements + SMALLER size = appropriate volatility management
    // NOT: HIGHER requirements (that blocks ALL trades during volatility)
    regimeStrategies[9].requiredEdgeStrength = 0.30;  // FIX: Realistic for volatility (was 0.50, now 0.30)
    regimeStrategies[9].momentumWeight = 0.8;
    regimeStrategies[9].reversalWeight = 1.3;
    regimeStrategies[9].volatilityWeight = 2.0;
