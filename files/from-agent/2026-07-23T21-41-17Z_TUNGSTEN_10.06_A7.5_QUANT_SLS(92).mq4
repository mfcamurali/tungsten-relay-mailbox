// PATTERN TEMPLATE - Defines what to look for in ratio terms
struct PatternTemplate {
    PatternType type;
    string name;
    int regime;
    bool isBullish;
    // Ratio thresholds (all relative, instrument-agnostic)
    double minBodyRatio;        // Minimum body/range ratio for key candles
    double maxBodyRatio;        // Maximum body/range ratio for key candles
    double minWickRatio;        // Minimum wick/range ratio
    double minBarsSpan;         // Minimum candles pattern spans
    double maxBarsSpan;         // Maximum candles pattern spans
    // Contextual requirements
    bool requiresSupport;       // Must be near support
    bool requiresResistance;    // Must be near resistance
    double minADXContext;       // ADX context requirement
    double maxADXContext;       // ADX max for ranging patterns
};

// BUILT-IN PATTERN LIBRARY - Loaded at startup
// 33 researched patterns across 8 regimes
PatternTemplate g_PatternLibrary[35];
int g_PatternLibraryCount = 0;

void InitializePatternLibrary() {
    if(g_PatternLibraryCount > 0) return; // Already initialized
    int i = 0;

    // --- REGIME 0: STRONG BULLISH TREND ---

    // Bull Flag
    g_PatternLibrary[i].type = PATTERN_BULL_FLAG;
    g_PatternLibrary[i].name = "Bull Flag";
    g_PatternLibrary[i].regime = 0;
    g_PatternLibrary[i].isBullish = true;
    g_PatternLibrary[i].minBodyRatio = 0.55;  // Impulse candles are strong
    g_PatternLibrary[i].maxBodyRatio = 1.0;
    g_PatternLibrary[i].minWickRatio = 0.0;
    g_PatternLibrary[i].minBarsSpan = 6;
    g_PatternLibrary[i].maxBarsSpan = 20;
    g_PatternLibrary[i].requiresSupport = false;
    g_PatternLibrary[i].requiresResistance = false;
    g_PatternLibrary[i].minADXContext = 20;
    g_PatternLibrary[i].maxADXContext = 100;
    i++;

    // Ascending Triangle
    g_PatternLibrary[i].type = PATTERN_ASCENDING_TRIANGLE;
    g_PatternLibrary[i].name = "Ascending Triangle";
    g_PatternLibrary[i].regime = 0;
    g_PatternLibrary[i].isBullish = true;
    g_PatternLibrary[i].minBodyRatio = 0.3;
    g_PatternLibrary[i].maxBodyRatio = 0.7;
    g_PatternLibrary[i].minWickRatio = 0.25;   // Rejection wicks at resistance
    g_PatternLibrary[i].minBarsSpan = 8;
    g_PatternLibrary[i].maxBarsSpan = 35;
    g_PatternLibrary[i].requiresSupport = false;
    g_PatternLibrary[i].requiresResistance = true;
    g_PatternLibrary[i].minADXContext = 15;
    g_PatternLibrary[i].maxADXContext = 100;
    i++;

    // Momentum Continuation
    g_PatternLibrary[i].type = PATTERN_MOMENTUM_CONTINUATION;
    g_PatternLibrary[i].name = "Momentum Continuation";
    g_PatternLibrary[i].regime = 0;
    g_PatternLibrary[i].isBullish = true;
    g_PatternLibrary[i].minBodyRatio = 0.60;
    g_PatternLibrary[i].maxBodyRatio = 1.0;
    g_PatternLibrary[i].minWickRatio = 0.0;
    g_PatternLibrary[i].minBarsSpan = 2;
    g_PatternLibrary[i].maxBarsSpan = 5;
    g_PatternLibrary[i].requiresSupport = false;
    g_PatternLibrary[i].requiresResistance = false;
    g_PatternLibrary[i].minADXContext = 22;
    g_PatternLibrary[i].maxADXContext = 100;
    i++;

    // Bullish Pennant
    g_PatternLibrary[i].type = PATTERN_BULLISH_PENNANT;
    g_PatternLibrary[i].name = "Bullish Pennant";
    g_PatternLibrary[i].regime = 0;
    g_PatternLibrary[i].isBullish = true;
    g_PatternLibrary[i].minBodyRatio = 0.2;
    g_PatternLibrary[i].maxBodyRatio = 0.6;
    g_PatternLibrary[i].minWickRatio = 0.15;
    g_PatternLibrary[i].minBarsSpan = 4;
    g_PatternLibrary[i].maxBarsSpan = 12;
    g_PatternLibrary[i].requiresSupport = false;
    g_PatternLibrary[i].requiresResistance = false;
    g_PatternLibrary[i].minADXContext = 18;
    g_PatternLibrary[i].maxADXContext = 100;
    i++;

    // --- REGIME 1: STRONG BEARISH TREND ---

    // Bear Flag
    g_PatternLibrary[i].type = PATTERN_BEAR_FLAG;
    g_PatternLibrary[i].name = "Bear Flag";
    g_PatternLibrary[i].regime = 1;
    g_PatternLibrary[i].isBullish = false;
    g_PatternLibrary[i].minBodyRatio = 0.55;
    g_PatternLibrary[i].maxBodyRatio = 1.0;
    g_PatternLibrary[i].minWickRatio = 0.0;
    g_PatternLibrary[i].minBarsSpan = 6;
    g_PatternLibrary[i].maxBarsSpan = 20;
    g_PatternLibrary[i].requiresSupport = false;
    g_PatternLibrary[i].requiresResistance = false;
    g_PatternLibrary[i].minADXContext = 20;
    g_PatternLibrary[i].maxADXContext = 100;
    i++;

    // Descending Triangle
    g_PatternLibrary[i].type = PATTERN_DESCENDING_TRIANGLE;
