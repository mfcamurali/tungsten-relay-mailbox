    // Calculate frequency metrics
    CalculateFrequencyMetrics();
    
    // Calculate regime-specific performance
    CalculateRegimeSpecificPerformance();
    
    // Calculate latency metrics
    CalculateLatencyMetrics();
    
    // Perform statistical analysis
    PerformStatisticalAnalysis();
}

// PERFORMANCE ANALYTICS HELPER FUNCTIONS

void CalculateBasicPerformanceMetrics() {
    // Count wins, losses, and calculate basic statistics from closed trades
    int totalClosedTrades = 0;
    int wins = 0;
    int losses = 0;
    double totalProfit = 0.0;
    double totalLoss = 0.0;
    double sumWins = 0.0;
    double sumLosses = 0.0;
    
    // Scan through order history
    for(int i = OrdersHistoryTotal() - 1; i >= 0 && totalClosedTrades < 100; i--) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                totalClosedTrades++;
                
                if(profit > 0) {
                    wins++;
                    sumWins += profit;
                    totalProfit += profit;
                } else if(profit < 0) {
                    losses++;
                    sumLosses += MathAbs(profit);
                    totalLoss += MathAbs(profit);
                }
                
                if(totalClosedTrades <= 100) {
                    performanceAnalytics.tradeReturns[totalClosedTrades - 1] = profit;
                    int duration = (int)(OrderCloseTime() - OrderOpenTime());
                    performanceAnalytics.tradeDurations[totalClosedTrades - 1] = duration;
                }
            }
        }
    }
    
    // Update basic metrics
    performanceAnalytics.totalTrades = totalClosedTrades;
    performanceAnalytics.winningTrades = wins;
    performanceAnalytics.losingTrades = losses;
    
    if(totalClosedTrades > 0) {
        performanceAnalytics.winRate = (double)wins / NonZero(totalClosedTrades) * 100.0;
    }
    
    if(wins > 0) {
        performanceAnalytics.averageWin = sumWins / NonZero(wins);
    }
    
    if(losses > 0) {
        performanceAnalytics.averageLoss = sumLosses / NonZero(losses);
    }
    
    if(totalLoss > 0) {
        performanceAnalytics.profitFactor = totalProfit / NonZero(totalLoss);
    } else if(totalProfit > 0) {
        performanceAnalytics.profitFactor = totalProfit; // NonZero(No.losses) yet
    }
    
    if(totalClosedTrades > 0) {
        performanceAnalytics.expectancy = (totalProfit - totalLoss) / NonZero(totalClosedTrades);
    }
}

void CalculateAdvancedPerformanceMetrics() {
    // Calculate Sharpe Ratio
    if(performanceAnalytics.totalTrades < 2) return;
    
    // Calculate average return and standard deviation
    double sumReturns = 0.0;
    double sumSquaredReturns = 0.0;
    int validReturns = 0;
    
    for(int i = 0; i < performanceAnalytics.totalTrades && i < 100; i++) {
        if(performanceAnalytics.tradeReturns[i] != 0.0) {
            sumReturns += performanceAnalytics.tradeReturns[i];
            sumSquaredReturns += performanceAnalytics.tradeReturns[i] * performanceAnalytics.tradeReturns[i];
            validReturns++;
        }
    }
    
    if(validReturns > 1) {
        double avgReturn = sumReturns / NonZero(validReturns);
        double variance = (sumSquaredReturns / NonZero(validReturns)) - (avgReturn * avgReturn);
        double stdDev = MathSqrt(MathMax(0.0, variance));
        
        if(stdDev > 0) {
            performanceAnalytics.sharpeRatio = (avgReturn / NonZero(stdDev)) * MathSqrt(validReturns);
        }
        
        // Calculate Sortino Ratio (using downside deviation)
        double sumDownsideSquared = 0.0;
        int downsideCount = 0;
        
        for(int i = 0; i < validReturns && i < 100; i++) {
            if(performanceAnalytics.tradeReturns[i] < 0) {
                sumDownsideSquared += performanceAnalytics.tradeReturns[i] * performanceAnalytics.tradeReturns[i];
                downsideCount++;
            }
        }
        
        if(downsideCount > 0) {
            double downsideDeviation = MathSqrt(sumDownsideSquared / NonZero(downsideCount));
            if(downsideDeviation > 0) {
                performanceAnalytics.sortinoRatio = (avgReturn / NonZero(downsideDeviation)) * MathSqrt(validReturns);
            }
        }
        
        // Calculate Calmar Ratio
        if(performanceAnalytics.maxDrawdown > 0) {
            performanceAnalytics.calmarRatio = MathAbs(avgReturn * validReturns) / NonZero(performanceAnalytics.maxDrawdown);
        }
        
        // Calculate risk-adjusted return
        if(stdDev > 0) {
            performanceAnalytics.riskAdjustedReturn = avgReturn / NonZero(stdDev);
        }
    }
}

void CalculateDrawdownMetrics() {
    double peakBalance = AccountBalance();
    double maxDrawdown = 0.0;
    double currentDrawdown = 0.0;
    
    // Calculate from closed trades
    double runningBalance = AccountBalance();
    double runningPeak = runningBalance;
    
    for(int i = 0; i < OrdersHistoryTotal(); i++) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                runningBalance += profit;
                
                if(runningBalance > runningPeak) {
                    runningPeak = runningBalance;
                }
                
                double drawdown = runningPeak - runningBalance;
                if(drawdown > maxDrawdown) {
                    maxDrawdown = drawdown;
                }
            }
        }
    }
    
    // Calculate current drawdown from peak equity
    if(tradeManager.peakEquity > 0) {
        currentDrawdown = tradeManager.peakEquity - AccountEquity();
        if(currentDrawdown < 0) currentDrawdown = 0;
        
        double currentDrawdownPercent = (currentDrawdown / NonZero(tradeManager.peakEquity)) * 100.0;
        performanceAnalytics.currentDrawdown = currentDrawdownPercent;
    }
    
    // Update max drawdown
    if(maxDrawdown > performanceAnalytics.maxDrawdown) {
        performanceAnalytics.maxDrawdown = maxDrawdown;
    }
    
    // Calculate recovery factor
    double calculatedNetProfit = AccountBalance() - AccountBalance(); // NonZero(Would.need) initial balance
    if(performanceAnalytics.maxDrawdown > 0 && calculatedNetProfit > 0) {
        performanceAnalytics.recoveryFactor = calculatedNetProfit / NonZero(performanceAnalytics.maxDrawdown);
    }
}

void CalculateFrequencyMetrics() {
    if(performanceAnalytics.totalTrades == 0) return;
    
    // Calculate average hold time
    double totalHoldTime = 0.0;
    int validDurations = 0;
    
    for(int i = 0; i < performanceAnalytics.totalTrades && i < 100; i++) {
        if(performanceAnalytics.tradeDurations[i] > 0) {
            totalHoldTime += performanceAnalytics.tradeDurations[i];
            validDurations++;
        }
    }
    
    if(validDurations > 0) {
        performanceAnalytics.averageHoldTime = totalHoldTime / NonZero(validDurations);
    }
    
    // Calculate trades per day/hour based on history
    datetime firstTradeTime = 0;
    datetime lastTradeTime = 0;
    
    if(OrdersHistoryTotal() > 0) {
        if(OrderSelect(0, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                firstTradeTime = OrderOpenTime();
            }
        }
        
        if(OrderSelect(OrdersHistoryTotal() - 1, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                lastTradeTime = OrderCloseTime();
            }
        }
    }
    
    if(firstTradeTime > 0 && lastTradeTime > firstTradeTime) {
        int totalSeconds = (int)(lastTradeTime - firstTradeTime);
        double totalDays = totalSeconds / 86400.0;
        double totalHours = totalSeconds / 3600.0;
        
        if(totalDays > 0) {
            performanceAnalytics.tradesPerDay = performanceAnalytics.totalTrades / NonZero(totalDays);
        }
        
        if(totalHours > 0) {
            performanceAnalytics.tradesPerHour = performanceAnalytics.totalTrades / NonZero(totalHours);
        }
        
        performanceAnalytics.averageFrequency = performanceAnalytics.tradesPerDay;
    }
}

void CalculateRegimeSpecificPerformance() {
    // Initialize regime arrays
    for(int i = 0; i < 12; i++) {
        performanceAnalytics.regimeTrades[i] = 0;
        performanceAnalytics.regimeWins[i] = 0;
        performanceAnalytics.regimePerformance[i] = 0.0;
    }
    
    // Analyze closed trades by regime (if regime info is stored in comments or can be determined)
    for(int i = 0; i < OrdersHistoryTotal(); i++) {
        if(OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
            if(OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
                double profit = OrderProfit() + OrderSwap() + OrderCommission();

                // Try to extract regime from order comment or use current regime as approximation
                int regime = EstimateTradeRegime(OrderComment());
                
                if(regime >= 0 && regime < 12) {
                    performanceAnalytics.regimeTrades[regime]++;
                    performanceAnalytics.regimePerformance[regime] += profit;
                    
                    if(profit > 0) {
                        performanceAnalytics.regimeWins[regime]++;
                    }
                }
            }
        }
    }
    
    // Calculate win rates by regime
    for(int i = 0; i < 12; i++) {
        if(performanceAnalytics.regimeTrades[i] > 0) {
            performanceAnalytics.winRateByRegime[i] = (double)performanceAnalytics.regimeWins[i] / 
                                                       performanceAnalytics.regimeTrades[i] * 100.0;
        }
    }
}

void CalculateLatencyMetrics() {
    // Calculate average execution latency from recent trades
    double totalLatency = 0.0;
    int latencyCount = 0;
    
    // Use decision engine metrics
    if(engine.executionDelayMs > 0 && engine.executionDelayMs < 1000) {
        performanceAnalytics.executionSpeed = engine.executionDelayMs;
    }
    
    if(engine.decisionIntervalMs > 0) {
        performanceAnalytics.decisionLatency = engine.decisionIntervalMs;
    }
    
    performanceAnalytics.totalLatency = performanceAnalytics.executionSpeed + performanceAnalytics.decisionLatency;
    
    // Calculate average latency from trade manager
    if(tradeManager.executionDelayMs > 0) {
        performanceAnalytics.averageLatency = tradeManager.executionDelayMs;
    }
}

void PerformStatisticalAnalysis() {
    // Perform statistical significance tests
    if(performanceAnalytics.totalTrades < 30) {
        performanceAnalytics.isStatisticallySignificant = false;
        return;
    }
    
    // Check if results are statistically significant
    // Using a simple z-test approximation for win rate
    double expectedWinRate = 0.5; // NonZero(Null.hypothesis): 50% win rate (random)
    double actualWinRate = performanceAnalytics.winRate / 100.0;
    double n = performanceAnalytics.totalTrades;
    
    if(n > 0) {
        // Standard error of proportion
        double standardError = MathSqrt((expectedWinRate * (1 - expectedWinRate)) / NonZero(n));
        
        if(standardError > 0) {
            // Z-score
            double zScore = (actualWinRate - expectedWinRate) / NonZero(standardError);
            
            // If absolute z-score > 1.96, result is significant at 95% confidence level
            if(MathAbs(zScore) > 1.96) {
                performanceAnalytics.isStatisticallySignificant = true;
            }
        }
    }
    
    // Calculate volatility of returns
    if(performanceAnalytics.totalTrades > 1) {
        double sumReturns = 0.0;
        double sumSquaredReturns = 0.0;
        int validCount = 0;
        
        for(int i = 0; i < performanceAnalytics.totalTrades && i < 100; i++) {
            if(performanceAnalytics.tradeReturns[i] != 0.0) {
                sumReturns += performanceAnalytics.tradeReturns[i];
                sumSquaredReturns += performanceAnalytics.tradeReturns[i] * performanceAnalytics.tradeReturns[i];
                validCount++;
            }
        }
        
        if(validCount > 1) {
            double mean = sumReturns / NonZero(validCount);
            double variance = (sumSquaredReturns / NonZero(validCount)) - (mean * mean);
            performanceAnalytics.volatility = MathSqrt(MathMax(0.0, variance));
        }
    }
    
    // Calculate performance trend
    if(performanceAnalytics.totalTrades >= 10) {
        double recentProfit = 0.0;
        double olderProfit = 0.0;
        int recentCount = 0;
        int olderCount = 0;
        
        for(int i = 0; i < performanceAnalytics.totalTrades && i < 100; i++) {
            if(i < performanceAnalytics.totalTrades / 2) {
                recentProfit += performanceAnalytics.tradeReturns[i];
                recentCount++;
            } else {
                olderProfit += performanceAnalytics.tradeReturns[i];
                olderCount++;
            }
        }
        
        double recentAvg = (recentCount > 0) ? recentProfit / NonZero(recentCount) : 0;
        double olderAvg = (olderCount > 0) ? olderProfit / NonZero(olderCount) : 0;
        
        if(olderAvg != 0) {
            performanceAnalytics.performanceTrend = ((recentAvg - olderAvg) / NonZero(MathAbs(olderAvg))) * 100.0;
        }
    }
}

int EstimateTradeRegime(string comment) {
    // Attempt to extract regime information from order comment
    // If the comment contains regime indicators, parse them
    // Otherwise, return current regime as best estimate
    
    // Check if comment contains regime number (format: "Regime:N" or "R:N")
    if(StringFind(comment, "Regime:") >= 0) {
        int startPos = StringFind(comment, "Regime:") + 7;
        if(startPos < StringLen(comment)) {
            string regimeStr = (startPos < StringLen(comment)) ? StringSubstr(comment, startPos, 2) : "";
            int regimeValue = (int)StringToInteger(regimeStr);
            if(regimeValue >= 0 && regimeValue < 12) {
                return regimeValue;
            }
        }
    }
    
    if(StringFind(comment, "R:") >= 0) {
        int startPos = StringFind(comment, "R:") + 2;
        if(startPos < StringLen(comment)) {
            string regimeStr = (startPos < StringLen(comment)) ? StringSubstr(comment, startPos, 2) : "";
            int regimeValue = (int)StringToInteger(regimeStr);
            if(regimeValue >= 0 && regimeValue < 12) {
                return regimeValue;
            }
        }
    }
    
    // Check for regime keywords in comment
    if(StringFind(comment, "ULTRA_BULLISH") >= 0 || StringFind(comment, "UltraBullish") >= 0) return 0;
    if(StringFind(comment, "STRONG_BULLISH") >= 0 || StringFind(comment, "StrongBullish") >= 0) return 1;
    if(StringFind(comment, "BULLISH") >= 0 || StringFind(comment, "Bullish") >= 0) return 2;
    if(StringFind(comment, "NEUTRAL_BULLISH") >= 0 || StringFind(comment, "NeutralBullish") >= 0) return 3;
    if(StringFind(comment, "CONSOLIDATION") >= 0 || StringFind(comment, "Consolidation") >= 0) return 4;
    if(StringFind(comment, "NEUTRAL_BEARISH") >= 0 || StringFind(comment, "NeutralBearish") >= 0) return 5;
    if(StringFind(comment, "BEARISH") >= 0 || StringFind(comment, "Bearish") >= 0) return 6;
    if(StringFind(comment, "STRONG_BEARISH") >= 0 || StringFind(comment, "StrongBearish") >= 0) return 7;
    if(StringFind(comment, "ULTRA_BEARISH") >= 0 || StringFind(comment, "UltraBearish") >= 0) return 8;
    if(StringFind(comment, "VOLATILITY") >= 0 || StringFind(comment, "Volatility") >= 0) return 9;
    if(StringFind(comment, "BREAKOUT") >= 0 || StringFind(comment, "Breakout") >= 0) return 10;
    
    // If no regime information found in comment, return current regime as estimate
    return (int)engine.regime;
}

// Strategy Combination Function
void CombineEffectiveStrategies() {
    // Combine top performing strategy genes
    double totalFitness = 0.0;
    
    for(int i = 0; i < strategyGenerator.activeGenes; i++) {
        if(strategyGenerator.strategyGenes[i].isActive) {
            totalFitness += strategyGenerator.strategyGenes[i].fitness;
        }
    }
    
    if(totalFitness <= 0) return;
    
    // Calculate combination weights
    for(int i = 0; i < strategyGenerator.activeGenes && i < 10; i++) {
        if(strategyGenerator.strategyGenes[i].isActive) {
            strategyGenerator.combinationWeights[i] = strategyGenerator.strategyGenes[i].fitness / NonZero(totalFitness);
        }
    }
    
    // Find dominant and backup strategies
    double bestFitness = 0.0;
    double secondBestFitness = 0.0;
    
    for(int i = 0; i < strategyGenerator.activeGenes; i++) {
        if(strategyGenerator.strategyGenes[i].isActive) {
            if(strategyGenerator.strategyGenes[i].fitness > bestFitness) {
                secondBestFitness = bestFitness;
                strategyGenerator.backupStrategy = strategyGenerator.dominantStrategy;
                bestFitness = strategyGenerator.strategyGenes[i].fitness;
                strategyGenerator.dominantStrategy = i;
            } else if(strategyGenerator.strategyGenes[i].fitness > secondBestFitness) {
                secondBestFitness = strategyGenerator.strategyGenes[i].fitness;
                strategyGenerator.backupStrategy = i;
            }
        }
    }
    
    strategyGenerator.strategyConfidence = bestFitness;
    strategyGenerator.combinationEffectiveness = totalFitness / NonZero(strategyGenerator.activeGenes);
}

// Logging Functions


void LogSystemStatus()
{
    static datetime lastStatusLog = 0;
    int statusInterval = 300;  // 5 minutes instead of 5 seconds
    if((TimeCurrent() - lastStatusLog) < statusInterval) return;
    lastStatusLog = TimeCurrent();

    int active = tradeManager.activeTradeCount;
    double winRate = CalculateRecentWinRate();
    double pf = CalculateProfitFactor();
    double score = engine.unifiedScore;
    int regime = (int)engine.regime;
    double risk = (riskMgr.currentRisk > 0) ? riskMgr.currentRisk : BASE_RISK_PERCENT;

    string modeName = "Balanced";
    switch(engine.mode) {
        case MODE_ULTRA_CONSERVATIVE: modeName = "Conservative"; break;
        case MODE_AGGRESSIVE:         modeName = "Aggressive";   break;
        case MODE_HIGH_FREQUENCY:     modeName = "HFT";          break;
        case MODE_MICRO_SCALPING:     modeName = "Scalping";     break;
        case MODE_OPTIMIZATION:       modeName = "Optimising";   break;
    }

    string regimeName = (regime >= 0 && regime < 9) ? GetRegimeName(regime) : DetermineMarketRegime();
    string _awSt = g_Awareness.isValid ? ("  [" + g_Awareness.awarenessNote + "]") : "";
    PrintFormat("  LIVE  |   status   %d active   |   score %.1f   |   WR %.0f%%   |   PF %.2f   |   risk %.1f%%   |   %s %s%s",
                active, score, winRate, pf, risk, regimeName, modeName, _awSt);
}


void LogCriticalEvent(string message, string category) {
    // Calm, informative — no alarm language in the journal
    if(category == "CRITICAL")
        Print("  alert   |   " + message);
    else
        PrintFormat("  %s   |   %s", category, message);
}

void LogTradeExecution(string message) {
    Print("  trade   |   " + message);
}

